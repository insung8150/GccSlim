#!/bin/bash
# gccfork-slim-now [<sid|prefix>] [--mode strong|medium|weak] [--dry-run]
#                  [--keep-recent N] [--no-backup] [--json]
#
# Slim the current active Claude Code session (or explicit sid) in place.
#
# Prefer the Rust binary (~/.local/bin/gccfork-slim); fall back to Python.
# If Rust is incompatible or fails, silently fall back without user-facing noise.

set -e

PROJECTS_DIR="${HOME}/.claude/projects"
GCCFORK_BIN="${GCCFORK_BIN:-${HOME}/.local/bin/gccfork}"
RUST_SLIM_BIN="${GCCFORK_SLIM_BIN:-${HOME}/.local/bin/gccfork-slim}"

if [[ ! -x "$GCCFORK_BIN" ]]; then
    echo "error: $GCCFORK_BIN is not executable" >&2
    exit 1
fi

# ─── Argument parsing ──────────────────────────────────────────────────
PASSTHRU=()
SID=""
JSON_OUT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --mode|--keep-recent)
            PASSTHRU+=("$1" "$2"); shift 2 ;;
        --dry-run|--no-backup)
            PASSTHRU+=("$1"); shift ;;
        --json)
            PASSTHRU+=("$1"); JSON_OUT="1"; shift ;;
        --help|-h)
            sed -n '2,8p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        --*)
            echo "unknown option: $1" >&2; exit 1 ;;
        *)
            SID="$1"; shift ;;
    esac
done

# ─── Auto-detect sid from ~/.claude/sessions/<PID>.json (Claude source) ─
detect_sid_from_sessions_json() {
    local pid=$$
    while [[ "$pid" != "1" && -n "$pid" ]]; do
        local name
        name=$(ps -p "$pid" -o comm= 2>/dev/null || true)
        if [[ "$name" == "claude" ]]; then
            local mapping="$HOME/.claude/sessions/$pid.json"
            if [[ -f "$mapping" ]]; then
                python3 -c "import json,sys; print(json.load(open('$mapping'))['sessionId'])" 2>/dev/null
                return $?
            fi
            return 1
        fi
        pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
    done
    return 1
}

if [[ -z "$SID" ]]; then
    if SID=$(detect_sid_from_sessions_json) && [[ -n "$SID" ]]; then
        [[ -z "$JSON_OUT" ]] && echo "(sessions/<pid>.json) sid=$SID"
    else
        echo "error: failed to extract sid from ~/.claude/sessions/<PID>.json" >&2
        echo "       pass sid explicitly: gccfork-slim-now <sid>" >&2
        exit 1
    fi
fi

# ─── Rust delegation when available ────────────────────────────────────
# The Rust binary uses the same interface for self-sid slim via `--sid <SID>`.
# On failure, fall back silently to Python.
if [[ -x "$RUST_SLIM_BIN" ]] && [[ "${GCCFORK_DISABLE_RUST:-0}" != "1" ]]; then
    if "$RUST_SLIM_BIN" --sid "$SID" "${PASSTHRU[@]}" 2>/dev/null; then
        exit 0
    fi
    # Rust failed; use Python fallback without user-facing noise.
fi

exec "$GCCFORK_BIN" slim-inplace "$SID" "${PASSTHRU[@]}"
