#!/bin/bash
# gccfork-slim-now [<sid|prefix>] [--mode strong|medium|weak] [--dry-run]
#                  [--keep-recent N] [--no-backup] [--json]
#
# 현재 활성 Claude Code 세션 (또는 명시한 sid) 의 jsonl 을 in-place 슬림.
#
# Rust 바이너리 우선 (~/.local/bin/gccfork-slim) — 없으면 Python fallback.
# Rust 가 호환되지 않거나 실패해도 silent fallback (사용자 안내 X).

set -e

PROJECTS_DIR="${HOME}/.claude/projects"
GCCFORK_BIN="${GCCFORK_BIN:-${HOME}/.local/bin/gccfork}"
RUST_SLIM_BIN="${GCCFORK_SLIM_BIN:-${HOME}/.local/bin/gccfork-slim}"

if [[ ! -x "$GCCFORK_BIN" ]]; then
    echo "에러: $GCCFORK_BIN 실행 불가" >&2
    exit 1
fi

# ─── 인자 파싱 ─────────────────────────────────────────────────────────
PASSTHRU=()
SID=""
JSON_OUT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --mode|--keep-recent)
            PASSTHRU+=("$1" "$2"); shift 2 ;;
        --dry-run|--no-backup)
            PASSTHRU+=("$1"); shift ;;
        --json)
            PASSTHRU+=("$1"); JSON_OUT="1"; shift ;;
        --help|-h)
            sed -n '2,8p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        --*)
            echo "알 수 없는 옵션: $1" >&2; exit 1 ;;
        *)
            SID="$1"; shift ;;
    esac
done

# ─── sid 자동 감지: ~/.claude/sessions/<PID>.json (Claude Code 공식 source) ──
detect_sid_from_sessions_json() {
    local pid=$$
    while [[ "$pid" != "1" && -n "$pid" ]]; do
        local name
        name=$(ps -p "$pid" -o comm= 2>/dev/null || true)
        if [[ "$name" == "claude" ]]; then
            local mapping="$HOME/.claude/sessions/$pid.json"
            if [[ -f "$mapping" ]]; then
                python3 -c "import json,sys; print(json.load(open('$mapping'))['sessionId'])" 2>/dev/null
                return $?
            fi
            return 1
        fi
        pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
    done
    return 1
}

if [[ -z "$SID" ]]; then
    if SID=$(detect_sid_from_sessions_json) && [[ -n "$SID" ]]; then
        [[ -z "$JSON_OUT" ]] && echo "(sessions/<pid>.json) sid=$SID"
    else
        echo "에러: ~/.claude/sessions/<PID>.json 에서 sid 추출 실패" >&2
        echo "       sid 를 직접 인자로 넘기세요: gccfork-slim-now <sid>" >&2
        exit 1
    fi
fi

# ─── Rust 위임 (있으면) ───────────────────────────────────────────────
# Rust 바이너리는 같은 인터페이스로 자기 sid 슬림 — `--sid <SID>` 로 호출.
# 실패 시 silent 하게 Python fallback 으로 떨어짐.
if [[ -x "$RUST_SLIM_BIN" ]] && [[ "${GCCFORK_DISABLE_RUST:-0}" != "1" ]]; then
    if "$RUST_SLIM_BIN" --sid "$SID" "${PASSTHRU[@]}" 2>/dev/null; then
        exit 0
    fi
    # Rust 실패 → Python fallback (사용자 안내 X)
fi

exec "$GCCFORK_BIN" slim-inplace "$SID" "${PASSTHRU[@]}"
