    def action_archive_selected_via_key(self) -> None:
        """Ctrl+Shift+M key handler dispatching to model B (true merge).

        If opt 5 (archive_trigger_mode) is button-only, ignore the key.
        Model A (simple archive_session) is no longer called directly from
        keys/buttons; its backend function is reused only inside merge for
        child archives.
        """
        trigger_mode = str(get_archive_pref("archive_trigger_mode"))
        if trigger_mode not in {"keybinding", "both"}:
            return
        self.action_merge_selected()

    sessions: reactive[list[Session]] = reactive([], recompose=False)

    def __init__(self, current_cwd: Optional[str], current_session_id: Optional[str], scope_all: bool) -> None:
        super().__init__()
        self.current_cwd = normalize_cwd(current_cwd)
        self.current_session_id = current_session_id
        self.scope_all = scope_all
        self.filter_text = ""
        self.view_mode = "tree"
        self.list_sessions: list[Session] = []
        self.selected_session_id = current_session_id
        self._active_copy_widget_id: Optional[str] = None
        self._programmatic_update = False
        self._pending_context_widget_id: Optional[str] = None
        self._pending_context_text = ""
        self._menu_text = ""
        self._list_pointer_interacting = False
        self._current_list_lines: list[str] = []
        self._current_list_items: list[tuple[Session, str]] = []
        # Restore last divider position (clamped 0.2~0.8). Default 0.46.
        try:
            saved_ratio = float(pref_get("left_pane_ratio", 0.46))
        except Exception:
            saved_ratio = 0.46
        self.left_pane_ratio = max(0.05, min(0.95, saved_ratio))
        self._pane_dragging = False
        # Pending soft forks: parent_id -> {parent_id, name, created_at}.
        # When claude creates a new JSONL, _reconcile_pending_soft_forks records parent/name.
        self._pending_soft_forks: dict[str, dict] = {}
        # Pending new root sessions: list of {name, cwd, created_at}.
        # When claude spawns without --resume and creates a new JSONL,
        # cwd + timing matching registers the name.
        self._pending_new_roots: list[dict] = []
        # Session ID set from the previous scan, used to detect new sessions on auto reload.
        self._last_known_session_ids: set[str] = set()
        # Multi-select (Ctrl/Shift + left click). A plain click only updates
        # selected_session_id; an empty set means single-select mode, otherwise multi-select.
        self._multi_selected_ids: set[str] = set()
        # Range anchor for Shift+click: row index of the last plain/Ctrl clicked session.
        self._multi_anchor_row: Optional[int] = None
        # One-shot flag preventing mouse_up from clearing multi_selected right after
        # a checkbox/modifier click.
        self._suppress_pointer_clear: bool = False
        # Shown while AI summary generation runs in the background.
        self._summarize_in_progress: bool = False
        # Deep search state initialized by the mixin helper.
        self._init_deep_search_state()

        # Auto slim (auto-reload trigger) was archived on 2026-05-06; init removed.

        # Dynamic live-session marker tracking:
        #   _spawned_sids: sessions directly spawned by this gccfork via new/fork/clone/resume.
        #     They get the owned marker color.
        #   _spawned_confirmed_sids: spawned SIDs observed live at least once.
        #     Live registration can lag several seconds after spawn, so this gate prevents
        #     newly spawned SIDs from disappearing before the bridge reports them live.
        #     Spawn cleanup runs only when a confirmed SID is now dead.
        #   _live_sids: snapshot of all active SIDs from read_live_sessions().
        #     Other live sessions get the live marker color; spawned ownership wins on overlap.
        # Synced on every _auto_reload_tick. The PPID-based startup-only logic no longer
        # affects marker colors.
        self._spawned_sids: set[str] = set()
        self._spawned_confirmed_sids: set[str] = set()
        # First registration timestamp per spawned SID; discard if not live after 60 seconds.
        self._spawned_at: dict[str, float] = {}
        self._live_sids: set[str] = set()

