    def compose(self) -> ComposeResult:
        yield CopyMenuItem("⎘ 복사", id="copy-menu-copy", classes="copy-menu-item")
        yield CopyMenuItem("✕ 취소", id="copy-menu-cancel", classes="copy-menu-item")


class CopyMenuItem(Static):
    def set_state(self, label: str, enabled: bool = True) -> None:
        self.update(label)
        if enabled:
            self.remove_class("-disabled")
        else:
            self.add_class("-disabled")

    def is_enabled(self) -> bool:
        return not self.has_class("-disabled")

    async def _on_mouse_down(self, event: events.MouseDown) -> None:
        event.prevent_default()
        event.stop()

    async def _on_mouse_up(self, event: events.MouseUp) -> None:
        if event.button != 1:
            event.stop()
            return
        event.prevent_default()
        event.stop()
        if not self.is_enabled():
            return
        if hasattr(self.app, "handle_copy_menu_action"):
            if self.id == "copy-menu-copy":
                self.app.handle_copy_menu_action("copy")
            elif self.id == "copy-menu-cancel":
                self.app.handle_copy_menu_action("cancel")


class PaneDivider(Static):
    async def _on_mouse_down(self, event: events.MouseDown) -> None:
        if event.button != 1:
            return
        event.prevent_default()
        event.stop()
        self.capture_mouse()
        self.add_class("-dragging")
        if hasattr(self.app, "begin_pane_drag"):
            self.app.begin_pane_drag(event.screen_x)

    async def _on_mouse_move(self, event: events.MouseMove) -> None:
        if not self.has_class("-dragging"):
            return
        event.prevent_default()
        event.stop()
        if hasattr(self.app, "update_pane_drag"):
            self.app.update_pane_drag(event.screen_x)

    async def _on_mouse_up(self, event: events.MouseUp) -> None:
        if not self.has_class("-dragging"):
            return
        event.prevent_default()
        event.stop()
        self.release_mouse()
        self.remove_class("-dragging")
        if hasattr(self.app, "finish_pane_drag"):
            self.app.finish_pane_drag(event.screen_x)


class FilterDot(Static):
    def __init__(self, color_style: str, **kwargs) -> None:
        super().__init__("", **kwargs)
        self.color_style = color_style

    def render(self) -> Text:
        dot = Text()
        dot.append("●", style=f"{self.color_style} bold")
        return dot


class FilterTool(Static, can_focus=True):
    class Activated(Message):
        def __init__(self, tool: "FilterTool") -> None:
            super().__init__()
            self.tool = tool

    def __init__(self, label: str, color_style: str, **kwargs) -> None:
        super().__init__("", **kwargs)
        self.tool_label = label
        self.color_style = color_style

    def set_label(self, label: str) -> None:
        self.tool_label = label
        self.refresh()

    def render(self) -> Text:
        # Labels include their own emoji, so no separate dot is needed.
        return Text(self.tool_label, style="bold")

    async def _on_mouse_down(self, event: events.MouseDown) -> None:
        if event.button != 1:
            return
        event.prevent_default()
        event.stop()
        self.focus()

    async def _on_mouse_up(self, event: events.MouseUp) -> None:
        if event.button != 1:
            return
        event.prevent_default()
        event.stop()
        self.focus()
        self.post_message(self.Activated(self))

    async def _on_key(self, event: events.Key) -> None:
        if event.key not in {"enter", "space"}:
            return
        event.prevent_default()
        event.stop()
        self.post_message(self.Activated(self))


def _single_line(text: Optional[str], default: str = "") -> str:
    if not text:
        return default
    collapsed = " ".join(part for part in text.splitlines() if part.strip())
    return collapsed.strip() or default


def _format_preview_messages(title: str, messages: list[Msg]) -> list[str]:
    lines = [title]
    if not messages:
        lines.append("(none)")
        return lines

    for msg in messages:
        icon = "👤" if msg.role == "user" else "🤖"
        lines.append(f"{icon} [{msg.role}]")
        body_lines = msg.text.splitlines() or [""]
        for line in body_lines:
            lines.append(f"  {line}")
        lines.append("")
    if lines[-1] == "":
        lines.pop()
    return lines


def render_preview_text(session: Session, current_id: Optional[str], width: int = 80) -> str:
    lines: list[str] = []

    # AI summary header: if registry has ai_summary, prepend it as a highlighted box.
    # Multi-line summaries are supported; each line gets a ❯ prefix.
    if session.ai_summary:
        title_label = " AI summary "
        rule_char = "─"
        left = max(3, width - len(title_label) - 2 - 2)
        top_rule = rule_char * left + title_label + rule_char * 2
        bottom_rule = rule_char * max(10, width - 2)
        lines.append(top_rule)
        for ai_line in session.ai_summary.splitlines():
            ai_line = ai_line.strip()
            if ai_line:
                lines.append(f"❯ {ai_line}")
        lines.append(bottom_rule)

    title = session.custom_name or session.auto_summary or "(untitled)"

    lines.append(f"Title: {title}")
    if current_id and session.id == current_id:
        lines.append("Status: current session")
    lines.append(f"Session ID: {session.id}")
    lines.append(f"File: {session.jsonl_path}")
    lines.append(f"Time: {session.mtime:%Y-%m-%d %H:%M}")
    lines.append(f"Turns/size: {session.turn_count} turns / {fmt_size(session.size_bytes)}")
    lines.append(f"Work folder: {session.cwd or '(no cwd)'}")
    lines.append(f"originator/source: {session.originator or '?'} / {session.source or '?'}")

    if session.parent_id:
        if session.fork_type == "hard":
            fork_note = "🪓 hard fork (direct jsonl copy + sessionId replacement, fully preserved)"
        elif session.fork_type == "soft":
            fork_note = "🔱 soft fork (claude --fork-session; large sessions may auto-compact)"
        elif session.fork_type == "auto":
            fork_note = "🔱 soft fork inferred from parentUuid chain; not recorded in registry"
        elif session.fork_type == "convert":
            fork_note = "🔁 converted derived session (original JSONL preserved, target CLI format regenerated)"
        else:
            fork_note = "unknown fork type"
        lines.append(f"Parent session: {session.parent_id}")
        lines.append(f"Fork type: {fork_note}")

    if session.compact_count > 0:
        lines.append(f"Compact history: 🔩 {session.compact_count} detected isCompactSummary markers")

    lines.append("")
    lines.extend(_format_preview_messages("FIRST", session.first_msgs))
    lines.append("")
    lines.append("... middle omitted ...")
    lines.append("")
    lines.extend(_format_preview_messages("LAST", session.last_msgs))
    return "\n".join(lines)


def _codex_session_id_from_path(path: Path) -> Optional[str]:
    match = UUID_ANY_RE.search(path.stem)
    return match.group(1) if match else None


def _codex_content_text(content: object) -> str:
    """Extract only human-readable text from Codex response_item content."""
    if isinstance(content, str):
        return content
    if isinstance(content, dict):
        text = content.get("text")
        return text if isinstance(text, str) else ""
    if isinstance(content, list):
        parts: list[str] = []
        for item in content:
            if isinstance(item, str):
                parts.append(item)
                continue
            if not isinstance(item, dict):
                continue
            if item.get("type") in {"input_text", "output_text", "text"}:
                text = item.get("text")
                if isinstance(text, str) and text:
                    parts.append(text)
        return "\n".join(parts)
    return ""


def _codex_auto_summary(dev_text: str, messages: list[Msg], sid: str) -> str:
    m = re.search("\uc6d0\ubcf8 Claude SID:\\s*([0-9a-f-]{36})", dev_text, re.IGNORECASE)
    if m:
        return f"Codex import <= {m.group(1)[:8]}"
    for msg in messages:
        if msg.role == "user" and msg.text.strip():
            return "Codex: " + _single_line(msg.text, default="")[:80]
    return f"Codex session {sid[:8]}"


def parse_codex_session(path: Path) -> Optional[Session]:
    """Parse ~/.codex/sessions JSONL into the shared GccSlim Session model."""
    sid: Optional[str] = None
    cwd: Optional[str] = None
    originator: Optional[str] = None
    source: Optional[str] = None
    dev_text = ""
    event_messages: list[Msg] = []
    response_messages: list[Msg] = []
    event_user_count = 0
    response_user_count = 0

    try:
        stat = path.stat()
    except OSError:
        return None

    try:
        with path.open("r", encoding="utf-8", errors="ignore") as fh:
            for raw in fh:
                raw = raw.strip()
                if not raw:
                    continue
                try:
                    obj = json.loads(raw)
                except json.JSONDecodeError:
                    continue
                typ = obj.get("type")
                payload = obj.get("payload") if isinstance(obj.get("payload"), dict) else {}

                if typ == "session_meta":
                    sid = payload.get("id") or sid
                    cwd = payload.get("cwd") or cwd
                    originator = payload.get("originator") or originator
                    src = payload.get("source")
                    if src:
                        source = f"codex:{src}"
                    continue

                if typ == "turn_context":
                    cwd = payload.get("cwd") or cwd
                    continue

                if typ == "event_msg":
                    ev_type = payload.get("type")
                    msg_text = payload.get("message")
                    if isinstance(msg_text, str) and msg_text.strip():
                        if ev_type == "user_message":
                            event_user_count += 1
                        if ev_type in {"user_message", "agent_message"}:
                            role = "user" if ev_type == "user_message" else "assistant"
                            event_messages.append(Msg(role, msg_text))
                    continue

                if typ != "response_item" or payload.get("type") != "message":
                    continue
                role = payload.get("role")
                text = _codex_content_text(payload.get("content"))
                if role == "developer" and text and not dev_text:
                    dev_text = text
                    continue
                if role not in {"user", "assistant"} or not text.strip():
                    continue
                if role == "user":
                    response_user_count += 1
                response_messages.append(Msg(role, text))
    except OSError:
        return None

    sid = sid or _codex_session_id_from_path(path)
    if not sid:
        return None

    messages = response_messages if response_messages else event_messages
    turn_count = response_user_count if response_user_count else event_user_count
    auto_summary = _codex_auto_summary(dev_text, messages, sid)
    reg = registry_get(sid)
    fork_type = reg.get("fork_type")
    if reg.get("parent_id") and not fork_type:
        fork_type = "convert"

    return Session(
        id=sid,
        jsonl_path=path,
        mtime=datetime.fromtimestamp(stat.st_mtime),
        turn_count=turn_count,
        size_bytes=stat.st_size,
        first_msgs=messages[:3],
        last_msgs=messages[-6:],
        auto_summary=auto_summary,
        cwd=normalize_cwd(cwd),
        source="codex",
        originator=originator or source or "codex",
        custom_name=reg.get("name"),
        parent_id=reg.get("parent_id"),
        fork_type=fork_type,
        ai_summary=reg.get("ai_summary"),
        important=bool(reg.get("important", False)),
        compact_count=0,
        live_turn_count=turn_count,
    )


def scan_codex_sessions(current_cwd: Optional[str], scope_all: bool) -> list[Session]:
    if not CODEX_SESSIONS_DIR.exists():
        return []
    normalized_current = normalize_cwd(current_cwd)
    out: list[Session] = []
    for path in CODEX_SESSIONS_DIR.glob("*/*/*/*.jsonl"):
        if ".bak." in path.name:
            continue
        sess = parse_codex_session(path)
        if not sess:
            continue
        if not scope_all and normalized_current and sess.cwd != normalized_current:
            continue
        out.append(sess)
    return out


def _read_codex_wrapper_states() -> list[dict]:
    """Read Codex active-session state files written by the GccSlim wrapper.

    Codex has no official live file like Claude's ~/.claude/sessions/<PID>.json,
    so Codex launched by GccSlim uses /tmp/gccfork-codex-*.state-* as truth source.
    """
    states: list[dict] = []
    for state_path in sorted(glob.glob(CODEX_WRAPPER_STATE_GLOB), key=lambda p: os.path.getmtime(p), reverse=True):
        try:
            with open(state_path, "r", encoding="utf-8") as fh:
                data = json.load(fh)
        except Exception:
            continue
        sid = data.get("session_id")
        pid = data.get("codex_pid")
        session_file = data.get("session_file")
        if not isinstance(sid, str) or not sid:
            continue
        if not isinstance(pid, int) or not Path(f"/proc/{pid}").exists():
            continue
        if session_file and not Path(str(session_file)).exists():
            continue
        data["_state_path"] = state_path
        states.append(data)
    return states


def _codex_active_sid_pid_map() -> dict[str, list[int]]:
    out: dict[str, list[int]] = {}
    for data in _read_codex_wrapper_states():
        sid = data.get("session_id")
        pid = data.get("codex_pid")
        if isinstance(sid, str) and isinstance(pid, int):
            out.setdefault(sid, []).append(pid)
    return out


def _find_codex_session_by_id(session_id: str) -> Optional[Session]:
    if not session_id or not CODEX_SESSIONS_DIR.exists():
        return None
    best: Optional[Session] = None
    for path in CODEX_SESSIONS_DIR.glob("*/*/*/*.jsonl"):
        if ".bak." in path.name:
            continue
        if _codex_session_id_from_path(path) != session_id:
            continue
        sess = parse_codex_session(path)
        if not sess:
            continue
        if best is None or sess.mtime > best.mtime:
            best = sess
    return best


def _codex_wrapper_state_for_sid(session_id: str) -> Optional[dict]:
    best: Optional[dict] = None
    for data in _read_codex_wrapper_states():
        if data.get("session_id") != session_id:
            continue
        if best is None or float(data.get("updated_at") or 0) > float(best.get("updated_at") or 0):
            best = data
    return best


def _display_session_id(session: Session) -> str:
    if session.source == "codex":
        return _codex_sid_label(session.id)
    return session.id[:4]


def _codex_sid_label(session_id: str) -> str:
    """Human-facing Codex id label.

    Codex ids share time-ordered prefixes, so GccSlim/GccSlim uses the last
    three hex chars with a tilde everywhere it displays a short Codex id.
    """
    sid = str(session_id or "")
    return f"~{sid[-3:]}" if len(sid) >= 3 else f"~{sid}"


def _clean_parent_title(title: str) -> str:
    title = re.sub(r"^\[Clone of [a-f0-9]{8}\]\s*", "", title, flags=re.IGNORECASE)
    # Legacy prefix format: "XXXXXXXX[<= XXXXXXXX] name" / "XXXXXXXX name".
    title = re.sub(r"^[a-f0-9]{8}(?:\[<= [a-f0-9]{8}\])?\s*", "", title, flags=re.IGNORECASE)
    # New suffix format: "name XXXX[<= XXXX]".
    title = re.sub(r"\s*[a-f0-9]{4}\[<=\s*[a-f0-9]{4}\]\s*$", "", title, flags=re.IGNORECASE)
    # Codex suffix format: "name ~xxx[<= ~yyy]"; also remove legacy ~xxxx.
    title = re.sub(r"\s*~[a-f0-9]{3,4}\[<=\s*~[a-f0-9]{3,4}\]\s*$", "", title, flags=re.IGNORECASE)
    return title.strip()


def make_new_session_path(parent_path: Path, new_session_id: str, parent_cwd: Optional[str] = None) -> Path:
    """Choose the jsonl path for a new session.

    Principle: claude --resume looks for jsonl in the cwd slug folder, so the
    new jsonl must be placed in the slug folder for `parent_cwd`. This protects
    cases where the parent jsonl was moved and its folder slug no longer matches cwd.

    If parent_cwd is None or the slug is unchanged, keep the parent jsonl folder.
    """
    if parent_cwd:
        try:
            cwd_slug = cwd_to_slug(parent_cwd)
            cwd_dir = PROJECTS_DIR / cwd_slug
            if cwd_dir != parent_path.parent:
                cwd_dir.mkdir(parents=True, exist_ok=True)
                return cwd_dir / f"{new_session_id}.jsonl"
        except Exception:
            pass
    return parent_path.parent / f"{new_session_id}.jsonl"


def _verify_hard_fork_copy(src_path: Path, dst_path: Path, src_stat_before: os.stat_result) -> None:
    """Verify hard-fork jsonl copy integrity and fail fast on race outcomes.

    Checks:
      1. whether parent src changed during copy; size/mtime changes mean another PID wrote concurrently
      2. whether copied dst size is close to parent size (>=95%); smaller means read race truncation

    On failure, immediately remove dst and raise ValueError to prevent a partially
    copied zombie jsonl from entering registry. Caller can clean up contention and retry.

    Background: when multiple old PIDs occupy the same sid, hard-fork copying can
    race with another PID writing the parent jsonl. This produced empty/short child
    jsonl files in the 2026-05-02 9ada incident.
    """
    src_stat_after = src_path.stat()
    dst_size = dst_path.stat().st_size
    src_size_before = src_stat_before.st_size

    if src_stat_after.st_size != src_size_before or src_stat_after.st_mtime_ns != src_stat_before.st_mtime_ns:
        try:
            dst_path.unlink()
        except OSError:
            pass
        raise ValueError(
            f"Parent jsonl changed during hard fork "
            f"({src_size_before:,}B → {src_stat_after.st_size:,}B). "
            f"Another PID occupying the parent sid is writing concurrently. "
            f"Stop the occupying PID and retry."
        )

    if src_size_before > 1024 and dst_size < src_size_before * 0.95:
        try:
            dst_path.unlink()
        except OSError:
            pass
        raise ValueError(
            f"Hard fork copy size is abnormal "
            f"(src={src_size_before:,}B, dst={dst_size:,}B, ratio={dst_size/src_size_before:.1%}). "
            f"Suspected copy read race; check parent sid occupying PIDs and retry."
        )


def hard_fork_session_with(session: Session, new_session_id: str, custom_name: str) -> Session:
    """Hard fork with preselected new_uuid and name for ForkNameScreen integration.

    Body logic matches `hard_fork_session`, but uses externally chosen values.
    """
    # Put the new jsonl in the parent.cwd slug folder because resume looks there.
    new_path = make_new_session_path(session.jsonl_path, new_session_id, session.cwd)
    if new_path.exists():
        raise ValueError(f"A file with the same ID already exists: {new_path.name}")

    old_marker = f'"sessionId":"{session.id}"'
    new_marker = f'"sessionId":"{new_session_id}"'
    new_path.parent.mkdir(parents=True, exist_ok=True)
    src_stat_before = session.jsonl_path.stat()
    with NamedTemporaryFile("w", delete=False, dir=new_path.parent, encoding="utf-8") as handle:
        tmp_path = Path(handle.name)
        with session.jsonl_path.open("r", encoding="utf-8") as fin:
            for line in fin:
                handle.write(line.replace(old_marker, new_marker))
    try:
        os.replace(tmp_path, new_path)
    except Exception:
        if tmp_path.exists():
            tmp_path.unlink()
        raise

    _verify_hard_fork_copy(session.jsonl_path, new_path, src_stat_before)

    clone_name = (custom_name or f"{new_session_id[:4]}[<= {session.id[:4]}]").strip()[:120]
    # Safety guard section 7: mark sources that are merge results for UnmergeConfirmScreen guidance.
    src_entry = registry_get(session.id) or {}
    src_is_merged = bool(src_entry.get("is_merged"))
    extra: dict = {}
    if src_is_merged:
        extra["forked_from_merged"] = session.id
    registry_set(
        new_session_id,
        parent_id=session.id,
        fork_type="hard",
        name=clone_name,
        **extra,
    )

    cloned = parse_session(new_path)
    if not cloned:
        raise ValueError("Could not read the cloned session.")
    cloned.custom_name = clone_name
    cloned.parent_id = session.id
    cloned.fork_type = "hard"
    return cloned


def _make_codex_clone_path(source_path: Path, source_sid: str, new_sid: str) -> Path:
    if source_sid in source_path.name:
        return source_path.with_name(source_path.name.replace(source_sid, new_sid, 1))
    return source_path.with_name(f"{source_path.stem}-{new_sid}.jsonl")


def _rewrite_codex_session_meta_line(raw: str, source_sid: str, new_sid: str) -> str:
    try:
        obj = json.loads(raw)
    except Exception:
        return raw
    if obj.get("type") != "session_meta":
        return raw
    payload = obj.get("payload")
    if not isinstance(payload, dict) or payload.get("id") != source_sid:
        return raw
    obj = dict(obj)
    payload = dict(payload)
    payload["id"] = new_sid
    payload["cloned_from_session_id"] = source_sid
    payload["cloned_by"] = "gccfork-hard-fork"
    obj["payload"] = payload
    return json.dumps(obj, ensure_ascii=False, separators=(",", ":")) + "\n"


def hard_fork_codex_session_with(session: Session, new_session_id: str, custom_name: str) -> Session:
    """Hard-copy a Codex JSONL session.

    Codex identifies a session by the first `session_meta.payload.id`, not by
    repeated Claude-style `"sessionId"` markers, so only the file name and
    session_meta id are changed.
    """
    new_path = _make_codex_clone_path(session.jsonl_path, session.id, new_session_id)
    if new_path.exists():
        raise ValueError(f"A file with the same ID already exists: {new_path.name}")

    new_path.parent.mkdir(parents=True, exist_ok=True)
    src_stat_before = session.jsonl_path.stat()
    with NamedTemporaryFile("w", delete=False, dir=new_path.parent, encoding="utf-8") as handle:
        tmp_path = Path(handle.name)
        with session.jsonl_path.open("r", encoding="utf-8", errors="ignore") as fin:
            for line in fin:
                handle.write(_rewrite_codex_session_meta_line(line, session.id, new_session_id))
    try:
        os.replace(tmp_path, new_path)
    except Exception:
        if tmp_path.exists():
            tmp_path.unlink()
        raise

    _verify_hard_fork_copy(session.jsonl_path, new_path, src_stat_before)

    clone_name = (
        custom_name or f"{_codex_sid_label(new_session_id)}[<= {_codex_sid_label(session.id)}]"
    ).strip()[:120]
    registry_set(
        new_session_id,
        parent_id=session.id,
        fork_type="hard",
        name=clone_name,
        source_cli="codex",
        source_session_id=session.id,
        source_jsonl=str(session.jsonl_path),
    )

    cloned = parse_codex_session(new_path)
    if not cloned:
        raise ValueError("Could not read the cloned Codex session.")
    cloned.custom_name = clone_name
    cloned.parent_id = session.id
    cloned.fork_type = "hard"
    cloned.source = "codex"
    return cloned


def _gccfork_repo_dir() -> Path:
    candidates: list[Path] = []
    env_repo = os.environ.get("GCCFORK_REPO_DIR")
    if env_repo:
        candidates.append(Path(env_repo).expanduser())
    here = Path(__file__).resolve()
    candidates.extend([
        here.parent.parent,
        Path.home() / "JOB_FOLD" / "\uc720\uc6a9\ud55c\uae30\ub2a5\ucd94\uac00\ubd84" / "GccSlim",
        Path.home() / "Projects" / "GccSlim",
    ])
    for cand in candidates:
        if (cand / "src" / "gccfork" / "codex_slim_reload.py").is_file():
            return cand
    return here.parent.parent


def _load_codex_slim_reload_module():
    import importlib.util

    sidecar_path = Path(__file__).resolve().parent / "gccfork_codex_slim_reload.py"
    module_path = _gccfork_repo_dir() / "src" / "gccfork" / "codex_slim_reload.py"
    if not module_path.is_file() and sidecar_path.is_file():
        module_path = sidecar_path
    if not module_path.is_file():
        raise FileNotFoundError(f"Codex slim module not found: {module_path}")
    spec = importlib.util.spec_from_file_location("_gccfork_codex_slim_reload", module_path)
    if spec is None or spec.loader is None:
        raise ImportError(f"Codex slim module load failed: {module_path}")
    module = importlib.util.module_from_spec(spec)
    sys.modules["_gccfork_codex_slim_reload"] = module
    spec.loader.exec_module(module)
    return module


def _write_codex_slim_restart_marker(
    *,
    session_id: str,
    session_file: Path,
    cwd: Optional[str],
    mode: str,
    keep_recent: int,
    source_pid: int,
    wrapper_id: Optional[str],
) -> None:
    payload = {
        "request_id": f"gccfork-tui-codex-slim-{uuid_lib.uuid4().hex[:10]}",
        "session_id": session_id,
        "session_file": str(session_file),
        "cwd": cwd,
        "mode": mode,
        "keep_recent": keep_recent,
        "created_at": time.time(),
        "source_pid": source_pid,
        "wrapper_id": wrapper_id,
    }
    tmp = CODEX_SLIM_MARKER_PATH.with_name(CODEX_SLIM_MARKER_PATH.name + f".tmp-{os.getpid()}")
    tmp.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    os.replace(tmp, CODEX_SLIM_MARKER_PATH)


def slim_codex_session_with(
    session: Session,
    *,
    mode: str,
    keep_recent: Optional[int],
    clone: bool,
    include_compact_summaries: bool = True,
    trim_recent_tools: bool = True,
    custom_name: Optional[str] = None,
) -> dict:
    module = _load_codex_slim_reload_module()
    plan = module.build_slim_plan(
        session.jsonl_path,
        mode=mode,
        keep_recent=keep_recent,
        codex_root=Path.home() / ".codex",
        include_compact_summaries=include_compact_summaries,
        trim_recent_tools=trim_recent_tools,
    )
    if clone:
        clone_result = module.apply_slim_plan_to_new_session(plan)
        new_sid = str(clone_result.cloned_session_id)
        clone_name = (
            custom_name.replace("????", new_sid[-3:]) if custom_name
            else f"{_clean_parent_title(session.title)} 🔻{_codex_sid_label(new_sid)}[<= {_codex_sid_label(session.id)}]"
        ).strip()[:120]
        registry_set(
            new_sid,
            parent_id=session.id,
            fork_type="slim",
            name=clone_name,
            source_cli="codex",
            source_session_id=session.id,
            source_jsonl=str(session.jsonl_path),
        )
        cloned = parse_codex_session(Path(clone_result.cloned_file))
        if cloned:
            cloned.custom_name = clone_name
            cloned.parent_id = session.id
            cloned.fork_type = "slim"
        return {
            "sid": new_sid,
            "path": str(clone_result.cloned_file),
            "session": cloned,
            "backup": None,
            "old_size": plan.original_bytes,
            "new_size": clone_result.cloned_bytes,
            "old_lines": plan.original_lines,
            "new_lines": clone_result.cloned_lines,
            "saved_bytes": plan.original_bytes - clone_result.cloned_bytes,
            "saved_percent": (plan.original_bytes - clone_result.cloned_bytes) * 100.0 / max(plan.original_bytes, 1),
            "mode": plan.mode,
            "keep_recent": plan.keep_recent,
            "compact_summary_count": getattr(plan, "compact_summary_count", 0),
            "clone": True,
        }

    module.apply_slim_plan(plan)
    slimmed = parse_codex_session(session.jsonl_path)
    return {
        "sid": plan.session_id,
        "path": str(plan.session_file),
        "session": slimmed,
        "backup": str(plan.backup_path),
        "old_size": plan.original_bytes,
        "new_size": plan.slim_bytes,
        "old_lines": plan.original_lines,
        "new_lines": plan.slim_lines,
        "saved_bytes": plan.saved_bytes,
        "saved_percent": plan.saved_percent,
        "mode": plan.mode,
        "keep_recent": plan.keep_recent,
        "compact_summary_count": getattr(plan, "compact_summary_count", 0),
        "clone": False,
    }


def detect_compact_marker_index(jsonl_path: Path) -> Optional[int]:
    """Return the line index of the last isCompactSummary marker in jsonl.

    A session may have been compacted multiple times, but Claude resume only
    reads the last marker.
    """
    last_idx = None
    try:
        with jsonl_path.open("r", encoding="utf-8", errors="ignore") as fh:
            for i, raw in enumerate(fh):
                try:
                    obj = json.loads(raw)
                except json.JSONDecodeError:
                    continue
                if obj.get("isCompactSummary") is True:
                    last_idx = i
    except OSError:
        pass
    return last_idx


def _call_rust_slim_general(
    *,
    jsonl_path: Path,
    sid: str,
    mode: str,
    keep_recent_turns: int = 0,
    keep_recent_lines: int = 0,
    backup: bool = True,
) -> dict:
    """General slim, verdict-based, delegated to Rust subprocess.

    Since Phase E-7 on 2026-05-06, the Python verdict body is archived and Rust is mandatory.
    """
    import subprocess
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim binary not found: {rust_bin}\n"
            "General slim requires Rust since Phase E-7."
        )
    cmd = [
        str(rust_bin),
        "--jsonl", str(jsonl_path),
        "--mode", mode,
        "--skip-security", "--no-preflight", "--json",
    ]
    if keep_recent_turns:
        cmd.extend(["--keep-recent", str(keep_recent_turns)])
    elif keep_recent_lines:
        cmd.extend(["--keep-recent", str(keep_recent_lines)])
    if not backup:
        cmd.append("--no-backup")
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode != 0:
        raise RuntimeError(f"Rust slim failed (exit {res.returncode}):\n{res.stderr}")
    rust_result = json.loads(res.stdout)
    return {
        "sid": rust_result.get("sid", sid),
        "path": str(jsonl_path),
        "marker_idx": rust_result.get("marker_idx"),
        "pre_kept": rust_result.get("pre_kept", 0),
        "kept": rust_result.get("kept", 0),
        "stubbed": rust_result.get("stubbed", 0),
        "dropped": rust_result.get("dropped", 0),
        "rebinded": rust_result.get("rebinded", 0),
        "old_size": int(rust_result.get("old_kb", 0) * 1024),
        "new_size": int(rust_result.get("new_kb", 0) * 1024),
        "ratio_pct": 100.0 - rust_result.get("saved_pct", 0),
        "mode": mode,
        "in_place": True,
        "backup": rust_result.get("backup"),
        "committed": True,
    }


def _call_rust_unfold_inplace(
    *,
    session: "Session",
    keep_recent_turns_last: int = 5,
    mode: str = "strong",
) -> dict:
    """In-place unfold via Rust subprocess (gccfork-slim --unfold-inplace).

    Since Phase E on 2026-05-06, Python unfold_session is archived and Rust
    handles segment-aware slim plus atomic write.
    """
    import subprocess
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim binary not found: {rust_bin}\n"
            "Unfold requires Rust since Phase E."
        )
    cmd = [
        str(rust_bin),
        "--jsonl", str(session.jsonl_path),
        "--mode", mode,
        "--unfold-inplace",
        "--keep-recent-turns", str(keep_recent_turns_last),
        "--skip-security", "--no-preflight", "--json",
    ]
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode == 2:
        # EXIT_INPUT — NoCompactionFound
        raise ValueError(f"🪚 {session.id[:8]} — no auto-compact markers; nothing to unfold.")
    if res.returncode != 0:
        raise RuntimeError(f"Rust unfold-inplace failed (exit {res.returncode}):\n{res.stderr}")
    rust_result = json.loads(res.stdout)
    return {
        "sid": rust_result.get("sid", session.id),
        "bytes_before": int(rust_result.get("old_kb", 0) * 1024),
        "bytes_after": int(rust_result.get("new_kb", 0) * 1024),
        "n_segments": rust_result.get("n_segments", 0),
        "n_markers": rust_result.get("n_markers", 0),
        "kept": rust_result.get("kept", 0),
        "dropped": rust_result.get("dropped", 0),
        "elapsed_sec": rust_result.get("elapsed_ms", 0) / 1000.0,
        "backup_path": Path(rust_result["backup"]) if rust_result.get("backup") else None,
    }


def _call_rust_unfold_bundle(
    *,
    session: "Session",
    keep_recent_turns: int = 5,
    mode: str = "strong",
) -> dict:
    """Bundle unfold via Rust subprocess (gccfork-slim --anti-frag --unfold-bundle).

    Since Phase E on 2026-05-06, Python bundle_unfold_session is archived.
    Rust handles fork creation, new jsonl processing, and registry registration.
    """
    import subprocess, uuid, shutil
    from gccfork_sessions import registry_set
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim binary not found: {rust_bin}\n"
            "Bundle unfold requires Rust since Phase E. Re-run install.sh or restore "
            "bin/_archive_2026-05-06_phase_e_python/."
        )

    # 1. Generate new sid and copy jsonl as fork.
    new_sid = str(uuid.uuid4())
    new_path = session.jsonl_path.parent / f"{new_sid}.jsonl"
    shutil.copy2(str(session.jsonl_path), str(new_path))

    # 2. Rust subprocess with preserve_markers=false, ignoring markers to bundle all.
    cmd = [
        str(rust_bin),
        "--jsonl", str(new_path),
        "--mode", mode,
        "--anti-frag", "--unfold-bundle",
        "--keep-recent-turns", str(keep_recent_turns),
        "--no-backup",
        "--skip-security", "--no-preflight", "--json",
    ]
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode != 0:
        try: new_path.unlink()
        except Exception: pass
        raise RuntimeError(f"Rust unfold-bundle failed (exit {res.returncode}):\n{res.stderr}")
    rust_result = json.loads(res.stdout)

    # 3. Replace sessionId fields in the new jsonl with the new sid.
    #    Rust detected the original sid, so update after fork.
    import re
    sid_re = re.compile(r'"sessionId":\s*"[^"]+"')
    new_marker = f'"sessionId":"{new_sid}"'
    content = new_path.read_text(encoding="utf-8")
    content = sid_re.sub(new_marker, content)
    new_path.write_text(content, encoding="utf-8")

    # 4. Register in registry with parent = original.
    parent_name = (session.custom_name or session.id[:4])
    registry_set(
        new_sid,
        parent_id=session.id,
        fork_type="hard",
        name=f"{parent_name} 🪚 bundle[<= {session.id[:4]}]",
    )

    return {
        "new_sid": new_sid,
        "new_jsonl_path": new_path,
        "bytes_before": int(rust_result.get("old_kb", 0) * 1024),
        "bytes_after": int(rust_result.get("new_kb", 0) * 1024),
        "n_bundles": rust_result.get("n_bundles", 0),
        "n_recent": rust_result.get("n_recent", 0),
        "elapsed_sec": rust_result.get("elapsed_ms", 0) / 1000.0,
    }


def _call_rust_anti_frag(
    *,
    jsonl_path: Path,
    sid: str,
    mode: str,
    keep_recent_turns: int,
    backup: bool,
    dynamic_cap: bool,
    visible_cap: int = 0,
) -> dict:
    """Wrapper for Rust gccfork-slim --anti-frag.

    In Phase D, anti-frag + dynamic_cap moved fully to Rust.
    The Python body is archived in bin/_archive_2026-05-06_phase_d_python/.

    Returns dict with the same shape as Python `slim_anti_frag_session`:
      bytes_before, bytes_after, kept, dropped, n_bundles, n_recent,
      effective_trim, dynamic_cap, backup_path, sid, jsonl_path, in_place.
    """
    import subprocess
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim binary not found: {rust_bin}\n"
            f"(anti-frag is handled by Rust since Phase D. Re-run install.sh or restore "
            f"GCCFORK_DISABLE_RUST=1 + bin/_archive_2026-05-06_phase_d_python/)"
        )
    cmd = [
        str(rust_bin),
        "--jsonl", str(jsonl_path),
        "--mode", mode,
        "--anti-frag",
        "--keep-recent-turns", str(keep_recent_turns),
        "--skip-security",
        "--no-preflight",
        "--json",
    ]
    if not backup:
        cmd.append("--no-backup")
    if not dynamic_cap:
        cmd.append("--no-dynamic-cap")
    if visible_cap > 0:
        cmd.extend(["--visible-cap", str(visible_cap)])
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode != 0:
        raise RuntimeError(
            f"Rust anti-frag failed (exit {res.returncode}):\n{res.stderr}"
        )
    rust_result = json.loads(res.stdout)
    # Convert Rust output into the Python-compatible dict shape.
    return {
        "in_place": True,
        "sid": rust_result.get("sid", sid),
        "jsonl_path": jsonl_path,
        "bytes_before": int(rust_result.get("old_kb", 0) * 1024),
        "bytes_after": int(rust_result.get("new_kb", 0) * 1024),
        "kept": rust_result.get("kept", 0),
        "dropped": rust_result.get("dropped", 0),
        "n_bundles": rust_result.get("n_bundles", 0),
        "n_recent": rust_result.get("n_recent", 0),
        "elapsed_sec": rust_result.get("elapsed_ms", 0) / 1000.0,
        "backup_path": Path(rust_result["backup"]) if rust_result.get("backup") else None,
        "dynamic_cap": rust_result.get("dynamic_cap", dynamic_cap),
        "effective_trim": rust_result.get("effective_trim", 0),
    }


def slim_fork_session_with(
    session: Session,
    new_session_id: str,
    custom_name: str,
    mode: str,
    *,
    in_place: bool = False,
    backup: bool = True,
    keep_recent_lines: int = 0,
    keep_recent_turns: int = 0,
    visible_cap: int = 0,
    dry_run: bool = False,
    defer_commit: bool = False,
    anti_fragmentation: bool = False,
) -> "Session | dict":
    """Marker-aware two-pass slim, fork or in-place.

    Measured policy, user-verified:
      Claude Code sends only messages after the latest isCompactSummary marker
      as resume context. Lines before the marker are preserved as archive but
      are not tokenized. Therefore:
        - pre-marker lines = KEEP_AS_IS, with only sessionId replacement
        - marker line itself = always KEEP
        - post-marker lines = verdict-based KEEP/STUB/DROP for context savings

    Uncompacted sessions have marker_idx=None, so the entire file is treated as post-marker.

    mode: "strong" | "medium" | "weak"

    in_place=True:
        Keep the same sid. Atomically overwrite original jsonl with os.replace.
        Do not touch registry or parse_session, because no new session is created.
        backup=True creates .bak.<ts>.jsonl automatically. Returns stats dict.

    keep_recent_lines (>0):
        Always KEEP_AS_IS for the last N file lines as an in-place safety guard
        protecting current active work. Ignored when 0.

    keep_recent_turns (>0):
        KEEP_AS_IS from the Nth user message from file end through the end.
        Takes precedence over `keep_recent_lines`. One turn can vary from about
        5 to 15 lines, so this preserves the intended "latest N turns" meaning.
        Ignored when 0 and falls back to keep_recent_lines.

    dry_run=True:
        Write slim result to a temporary file, compute stats, then clean up.
        Does not change original or registry. Available for fork and in-place.
    """
    from gccfork_settings import SLIM_MODE_ALIASES

    # Migrate old keys (strict/balanced/loose) to new keys (strong/medium/weak).
    mode = SLIM_MODE_ALIASES.get(mode, mode)
    if mode not in {"strong", "medium", "weak"}:
        raise ValueError(f"Unknown slim mode: {mode}")

    # Bundle processing mode moved to Rust in Phase D on 2026-05-06.
    # Python body is archived in bin/_archive_2026-05-06_phase_d_python/.
    # Calls ~/.local/bin/gccfork-slim --anti-frag --json as subprocess.
    if anti_fragmentation and not dry_run:
        try:
            dynamic_cap = bool(pref_get("slim_default_dynamic_cap", True))
        except Exception:
            dynamic_cap = True
        # in_place=False fork mode is unsupported by Rust and currently unused.
        if not in_place:
            raise NotImplementedError(
                "anti-frag fork mode is unsupported by Rust. Use in_place=True only."
            )
        result = _call_rust_anti_frag(
            jsonl_path=session.jsonl_path,
            sid=session.id,
            mode=mode,
            keep_recent_turns=keep_recent_turns or 5,
            backup=backup,
            dynamic_cap=dynamic_cap,
            visible_cap=visible_cap,
        )
        if in_place:
            return result
        # Fork mode: register new session and return Session object.
        registry_set(
            new_session_id,
            parent_id=session.id,
            fork_type="slim",
            name=custom_name or f"🔻[<= {session.id[:4]}]",
        )
        cloned = parse_session(result["jsonl_path"])
        if not cloned:
            raise ValueError("Could not read bundle-processing slim result.")
        cloned.custom_name = custom_name
        cloned.parent_id = session.id
        cloned.fork_type = "slim"
        return cloned
    # Phase E-7 on 2026-05-06: verdict-based general slim Python body is archived.
    # Rust gccfork-slim is the single processor. Fork mode is unsupported and deprecated.
    if not in_place:
        raise NotImplementedError(
            "fork mode (in_place=False) is deprecated because Rust has not supported it since Phase E-7. "
            "Use in_place=True. All TUI slim calls are already in-place."
        )

    if dry_run:
        # Rust should handle dry-run too through gccfork-slim --dry-run.
        # Until that flag is implemented, return simple file-size stats.
        old_size = session.jsonl_path.stat().st_size
        return {
            "sid": session.id, "path": str(session.jsonl_path),
            "marker_idx": detect_compact_marker_index(session.jsonl_path),
            "kept": 0, "stubbed": 0, "dropped": 0, "rebinded": 0,
            "old_size": old_size, "new_size": old_size,
            "ratio_pct": 100.0, "mode": mode, "in_place": True, "dry_run": True,
        }

    # General in-place slim delegated to Rust subprocess.
    return _call_rust_slim_general(
        jsonl_path=session.jsonl_path,
        sid=session.id,
        mode=mode,
        keep_recent_turns=keep_recent_turns or 0,
        keep_recent_lines=keep_recent_lines or 0,
        backup=backup,
    )



def hard_fork_session(session: Session) -> Session:
    """Hard-fork a Claude Code session.

    Method:
      1. read original jsonl line by line
      2. replace repeated `"sessionId":"<old>"` markers with `"sessionId":"<new>"`
      3. save as `<new_uuid>.jsonl` in the same slug folder
      4. record parent_id, fork_type="hard", and clone name in registry

    UUID strings that happen to appear in message bodies are unaffected because
    replacement matches the `"sessionId":"` prefix form only. This completely
    bypasses auto-compact triggered by `--fork-session`, so even large sessions
    can resume with their JSONL fully preserved.
    """
    new_session_id = str(uuid_lib.uuid4())
    new_path = make_new_session_path(session.jsonl_path, new_session_id, session.cwd)
    if new_path.exists():
        raise ValueError(f"A file with the same ID already exists: {new_path.name}")

    old_marker = f'"sessionId":"{session.id}"'
    new_marker = f'"sessionId":"{new_session_id}"'

    new_path.parent.mkdir(parents=True, exist_ok=True)
    src_stat_before = session.jsonl_path.stat()
    with NamedTemporaryFile("w", delete=False, dir=new_path.parent, encoding="utf-8") as handle:
        tmp_path = Path(handle.name)
        with session.jsonl_path.open("r", encoding="utf-8") as fin:
            for line in fin:
                handle.write(line.replace(old_marker, new_marker))

    try:
        os.replace(tmp_path, new_path)
    except Exception:
        if tmp_path.exists():
            tmp_path.unlink()
        raise

    _verify_hard_fork_copy(session.jsonl_path, new_path, src_stat_before)

    parent_title = _clean_parent_title(session.title)
    suffix = f"{new_session_id[:4]}[<= {session.id[:4]}]"
    clone_name = (f"{parent_title} {suffix}" if parent_title else suffix).strip()[:120]
    registry_set(new_session_id, parent_id=session.id, fork_type="hard", name=clone_name)

    cloned = parse_session(new_path)
    if not cloned:
        raise ValueError("Could not read the cloned session.")
    cloned.custom_name = clone_name
    cloned.parent_id = session.id
    cloned.fork_type = "hard"
    return cloned


def snapshot_session_ids() -> set[str]:
    ids: set[str] = set()
    if not PROJECTS_DIR.exists():
        return ids
    for jsonl in PROJECTS_DIR.glob("*/*.jsonl"):
        sid = extract_session_id_from_path(jsonl)
        if sid:
            ids.add(sid)
    return ids


def find_newest_new_session(before_ids: set[str]) -> Optional[Session]:
    candidates: list[Session] = []
    for session in scan_sessions(current_cwd=None, scope_all=True):
        if session.id not in before_ids:
            candidates.append(session)
    if not candidates:
        return None
    return max(candidates, key=lambda item: item.mtime)


def find_claude_pids_for_session_id(session_id: str) -> list[int]:
    """Map sid to active claude PIDs, using sessions/<PID>.json as truth source.

    Core principle from fork notes: cmdline, mtime, fd, and env based guesses are
    inaccurate. When Claude Code changes sessionId after resume, cmdline matching
    can pick the wrong PID because active sid differs from the start-command sid.

    This is a thin compatibility wrapper around `gccfork_sessions.find_live_pids_by_sid`.
    New code should call the helper directly.
    """
    return find_live_pids_by_sid(session_id) if session_id else []


def _is_claude_cmdline(cmdline: str) -> bool:
    """Identify a `claude` CLI process.

    Claude Code often runs as `node /usr/lib/node_modules/@anthropic-ai/claude-code/cli.js`,
    so match either `claude-code/cli.js` in cmdline or argv[0] ending in `claude`.
    """
    if not cmdline:
        return False
    if "claude-code/cli.js" in cmdline:
        return True
    if "@anthropic-ai/claude-code" in cmdline:
        return True
    first_arg = cmdline.split(" ", 1)[0]
    name = Path(first_arg).name
    return name == "claude" or first_arg.endswith("/claude")


def find_claude_processes_for_session(
    session_id: str,
    cwd: Optional[str] = None,
    jsonl_path: Optional[Path] = None,
) -> list[dict]:
    results = []
    proc_root = Path("/proc")
    if not proc_root.exists():
        return results

    session_start_ts = None
    jsonl_mtime = None
    if jsonl_path and jsonl_path.exists():
        try:
            jsonl_mtime = jsonl_path.stat().st_mtime
        except OSError:
            jsonl_mtime = None
        try:
            with jsonl_path.open("r", encoding="utf-8") as handle:
                for index, raw in enumerate(handle):
                    if index > 30:
                        break
                    try:
                        obj = json.loads(raw)
                    except json.JSONDecodeError:
                        continue
                    ts = obj.get("timestamp")
                    if isinstance(ts, str):
                        session_start_ts = datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
                        break
        except OSError:
            pass

    now = time.time()
    mtime_age = (now - jsonl_mtime) if jsonl_mtime else None
    target_cwd = normalize_cwd(cwd)

    for pid_dir in proc_root.iterdir():
        if not pid_dir.name.isdigit():
            continue
        try:
            cmdline_raw = (pid_dir / "cmdline").read_bytes().decode("utf-8", errors="ignore")
            cmdline = cmdline_raw.replace("\x00", " ").strip()
            if not _is_claude_cmdline(cmdline):
                continue

            try:
                proc_cwd = normalize_cwd((pid_dir / "cwd").resolve().as_posix())
            except Exception:
                proc_cwd = None
            try:
                tty = (pid_dir / "fd" / "0").resolve().as_posix()
                if not tty.startswith("/dev/pts") and not tty.startswith("/dev/tty"):
                    tty = ""
            except Exception:
                tty = ""
            try:
                proc_start = (pid_dir / "status").stat().st_mtime
            except OSError:
                proc_start = 0.0

            confidence = None
            birth_delta = None
            if session_id in cmdline:
                confidence = "exact"
            elif target_cwd and proc_cwd == target_cwd:
                if session_start_ts and proc_start:
                    birth_delta = abs(proc_start - session_start_ts)
                    if birth_delta <= 15.0:
                        confidence = "birth"
                if not confidence and jsonl_mtime and mtime_age is not None and mtime_age < 60:
                    if proc_start and proc_start < jsonl_mtime:
                        confidence = "recent"
                if not confidence:
                    confidence = "cwd"
            elif target_cwd and proc_cwd and proc_cwd.startswith(target_cwd + "/"):
                confidence = "cwd-sub"
            else:
                continue

            results.append({
                "pid": int(pid_dir.name),
                "tty": tty,
                "cwd": proc_cwd,
                "cmdline": cmdline[:120],
                "confidence": confidence,
                "proc_start": proc_start,
                "age_sec": int(now - proc_start) if proc_start else -1,
                "birth_delta": birth_delta,
            })
        except (OSError, PermissionError):
            continue

    order = {"exact": 0, "birth": 1, "recent": 2, "cwd": 3, "cwd-sub": 4}
    results.sort(key=lambda item: (order.get(item["confidence"], 9), item.get("birth_delta") or 9999))
    return results


def _session_from_proc_fds(pid: int) -> Optional[Session]:
    fd_dir = Path("/proc") / str(pid) / "fd"
    if not fd_dir.exists():
        return None
    for fd in fd_dir.iterdir():
        try:
            target = fd.resolve()
        except Exception:
            continue
        try:
            target_str = target.as_posix()
        except Exception:
            continue
        if not target_str.startswith(PROJECTS_DIR.as_posix() + "/") or target.suffix != ".jsonl":
            continue
        session = parse_session(target)
        if session:
            return session
    return None


def _session_from_cmdline(cmdline: str) -> Optional[Session]:
    for match in UUID_ANY_RE.finditer(cmdline):
        session = find_session_by_id(match.group(1))
        if session:
            return session
    return None


def _infer_process_session(
    proc: dict,
    target_session: Session,
    same_cwd_sessions: list[Session],
) -> Optional[Session]:
    session = _session_from_proc_fds(proc["pid"])
    if session:
        return session

    session = _session_from_cmdline(proc.get("cmdline", ""))
    if session:
        return session

    if proc.get("confidence") in {"exact", "birth", "recent"}:
        return target_session

    candidates = [item for item in same_cwd_sessions if item.id != target_session.id]
    proc_start = proc.get("proc_start")
    if proc_start and candidates:
        nearest = min(candidates, key=lambda item: abs(item.mtime.timestamp() - proc_start))
        if abs(nearest.mtime.timestamp() - proc_start) <= 86400:
            return nearest

    if proc.get("cwd") == target_session.cwd:
        return target_session
    return None


def _apply_confirm_text_theme(
    screen: ModalScreen,
    display_text: str,
    bullet_sessions: dict[int, str],
) -> None:
    try:
        text_area = screen.query_one("#confirm-text", TextArea)
    except Exception:
        return

    app_theme = screen.app.current_theme
    accent = Color.parse(app_theme.accent or app_theme.primary)
    surface = Color.parse(app_theme.surface or app_theme.background or "#202020")
    foreground = Color.parse(app_theme.foreground or "#f3f3f3")
    summary_bg = surface.blend(accent, 0.22)
    syntax_styles = {
        "confirm-summary-row": Style(
            bgcolor=summary_bg.rich_color,
            color=foreground.rich_color,
        )
    }
    syntax_styles.update(
        {
            f"session-color-{index}": Style(color=color, bold=True)
            for index, color in enumerate(_COLOR_STYLES)
        }
    )

    theme = TextAreaTheme(
        name="gccfork-confirm-text",
        cursor_line_style=Style(
            bgcolor=summary_bg.rich_color,
            color=foreground.rich_color,
        ),
        syntax_styles=syntax_styles,
    )
    text_area.register_theme(theme)
    text_area.theme = "gccfork-confirm-text"

    lines = display_text.splitlines()
    highlights: defaultdict[int, list[tuple[int, int, str]]] = defaultdict(list)
    for row in range(min(2, len(lines))):
        line_end = len(lines[row].encode("utf-8"))
        if line_end:
            highlights[row].append((0, line_end, "confirm-summary-row"))

    for row, session_id in bullet_sessions.items():
        if row >= len(lines):
            continue
        bullet_index = lines[row].find("●")
        if bullet_index < 0:
            continue
        start = len(lines[row][:bullet_index].encode("utf-8"))
        end = len(lines[row][: bullet_index + 1].encode("utf-8"))
        highlights[row].append((start, end, f"session-color-{_color_index_for_session(session_id)}"))

    text_area._highlights = highlights
    text_area._line_cache.clear()
    text_area.refresh()


def _configure_confirm_screen(
    screen: ModalScreen,
    message: str,
    bullet_sessions: dict[int, str],
) -> None:
    try:
        confirm_box = screen.query_one("#confirm-box", Vertical)
        text_area = screen.query_one("#confirm-text", TextArea)
    except Exception:
        return

    raw_lines = message.splitlines() or [""]
    screen_width = screen.size.width or 100
    max_line_width = max(cell_len(line) for line in raw_lines)
    desired_box_width = min(max(56, max_line_width + 6), max(40, screen_width - 4))
    confirm_box.styles.width = desired_box_width

    def finalize() -> None:
        content_width = max(20, (text_area.size.width or desired_box_width) - 2)
        display_lines = list(raw_lines)
        for row in range(min(2, len(display_lines))):
            pad = max(0, content_width - cell_len(display_lines[row]))
            if pad:
                display_lines[row] = display_lines[row] + (" " * pad)
        display_text = "\n".join(display_lines)
        text_area.load_text(display_text)
        wrapped_height = sum(max(1, math.ceil(cell_len(line) / content_width)) for line in display_lines)
        text_area.styles.height = max(3, wrapped_height)
        _apply_confirm_text_theme(screen, display_text, bullet_sessions)

    screen.call_after_refresh(finalize)


def _apply_bullet_highlights(text_area: TextArea, display_text: str, bullet_sessions: dict[int, str]) -> None:
    app_theme = text_area.app.current_theme
    syntax_styles = {
        f"session-color-{index}": Style(color=color, bold=True)
        for index, color in enumerate(_COLOR_STYLES)
    }
    theme = TextAreaTheme(
        name="gccfork-bullet-text",
        cursor_line_style=Style(
            bgcolor=Color.parse(app_theme.accent or app_theme.primary).blend(
                Color.parse(app_theme.surface or app_theme.background or "#202020"), 0.15
            ).rich_color,
            color=Color.parse(app_theme.foreground or "#f3f3f3").rich_color,
        ),
        syntax_styles=syntax_styles,
    )
    text_area.register_theme(theme)
    text_area.theme = "gccfork-bullet-text"

    lines = display_text.splitlines()
    highlights: defaultdict[int, list[tuple[int, int, str]]] = defaultdict(list)
    for row, session_id in bullet_sessions.items():
        if row >= len(lines):
            continue
        bullet_index = lines[row].find("●")
        if bullet_index < 0:
            continue
        start = len(lines[row][:bullet_index].encode("utf-8"))
        end = len(lines[row][: bullet_index + 1].encode("utf-8"))
        highlights[row].append((start, end, f"session-color-{_color_index_for_session(session_id)}"))
    text_area._highlights = highlights
    text_area._line_cache.clear()
    text_area.refresh()


class RenameScreen(ModalScreen[Optional[str]]):
    def __init__(self, current_name: str = "") -> None:
        super().__init__()
        self.current_name = current_name

    def compose(self) -> ComposeResult:
        with Vertical(id="rename-box"):
            yield Label("세션 이름 지정 (빈 값 → 이름 삭제):")
            yield Input(value=self.current_name, id="rename-input")
            with Horizontal(id="rename-btn-row"):
                yield Button("취소", id="btn-rename-cancel")
                yield Button("저장", id="btn-rename-save", variant="primary")
            yield Label("Enter = 저장, Esc = 취소", classes="hint")

    def on_mount(self) -> None:
        inp = self.query_one("#rename-input", Input)
        inp.focus()
        # If a default value is present, put cursor at the end for immediate editing.
        try:
            inp.cursor_position = len(inp.value)
        except Exception:
            pass

    def on_input_submitted(self, event: Input.Submitted) -> None:
        self.dismiss(event.value)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-rename-save":
            self.dismiss(self.query_one("#rename-input", Input).value)
        elif event.button.id == "btn-rename-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)


class ForkNameScreen(ModalScreen[Optional[dict]]):
    """Name/options confirmation modal shown right before forking.

    Result:
      - None for cancel
      - {"name": str, "skip_future": bool} for confirmed name
    """

    def __init__(
        self,
        default_name: str,
        title: str = "Set Fork Name",
        other_env: Optional[str] = None,
        current_terminal: Optional[str] = None,
        allow_codex_open: bool = False,
        open_target_options: Optional[list[tuple[str, str, bool]]] = None,
        sid_prefix: Optional[str] = None,
    ) -> None:
        super().__init__()
        self.default_name = default_name
        self.title_text = title
        self.allow_codex_open = allow_codex_open
        self.open_target_options = open_target_options
        if self.open_target_options is None and allow_codex_open:
            self.open_target_options = [
                ("claude", "Claude로 재개", True),
                ("codex", "Codex로 열기", False),
            ]
        # other_env: "vscode" / "gnome-terminal" / None
        # Show toggle only when an environment opposite to current terminal is available.
        self.other_env = other_env
        # current_terminal: terminal currently running gccfork. In VSCode, tab/window
        # distinction is meaningless because both are new panel entries, so hide the checkbox.
        self.current_terminal = current_terminal
        # sid_prefix: cases where sid is known before spawn, such as new/hard fork.
        # Show a readonly 4-char prefix left of input. _result() prepends it to
        # the result name automatically, so users edit only the suffix.
        self.sid_prefix = sid_prefix

    def _sid_prefix_applies(self) -> bool:
        """Return whether the readonly sid prefix is truthful for target CLI.

        Claude new-root can be started with a preselected --session-id, so the
        prefix is exact. Codex new-root cannot currently accept an externally
        chosen sid; it creates the real sid on first startup. Showing the Claude
        preallocated prefix for Codex is misleading, so hide and do not prepend
        it when the selected target is Codex.
        """
        if not self.sid_prefix:
            return False
        return self._current_open_target() != "codex"

    def _effective_target(self) -> Optional[str]:
        """Return final target terminal based on current checkbox state."""
        if self.other_env:
            try:
                if self.query_one("#forkname-other-env", Checkbox).value:
                    return self.other_env
            except Exception:
                pass
        return self.current_terminal

    def _update_newtab_visibility(self) -> None:
        """Hide the new-tab checkbox when target is VSCode, where the option is invalid."""
        try:
            newtab = self.query_one("#forkname-newtab", Checkbox)
        except Exception:
            return
        show = self._effective_target() != "vscode"
        newtab.display = show
        if not show:
            newtab.value = False  # Clear stale checked state.

    def _update_sid_prefix_visibility(self) -> None:
        try:
            prefix = self.query_one("#forkname-sid-prefix", Static)
        except Exception:
            return
        prefix.display = self._sid_prefix_applies()

    def compose(self) -> ComposeResult:
        with Vertical(id="forkname-box"):
            # Header with the same tone as slim modal: brand, title, meta.
            with Horizontal(id="forkname-header"):
                yield Static("[b]GccForK[/]", id="forkname-brand", markup=True)
                yield Static(
                    f"[b]{self.title_text}[/]",
                    id="forkname-title", markup=True,
                )
                yield Static(
                    f"[dim]v{GCCFORK_VERSION}[/]",
                    id="forkname-meta", markup=True,
                )

            # Body with section cards.
            with Vertical(id="forkname-scroll"):
                # Name input.
                with Vertical(classes="fkn-section", id="forkname-name-section"):
                    yield Static(
                        "[b][이름][/] 세션 이름",
                        classes="fkn-section-title", markup=True,
                    )
                    if self.sid_prefix:
                        # Known 4-char sid case: readonly [XXXX] on left plus editable input.
                        # Convention is brackets plus uppercase hex, for example [9C64].
                        with Horizontal(id="forkname-input-row"):
                            yield Static(
                                f"[{self.sid_prefix.upper()}]  ",
                                id="forkname-sid-prefix", markup=False,
                            )
                            yield Input(value=self.default_name, id="forkname-input")
                    else:
                        yield Input(value=self.default_name, id="forkname-input")

                # Options. Order matters: send-to-other-environment before new-tab.
                # New-tab appears/disappears based on the environment toggle, so placing
                # it below keeps layout changes natural.
                with Vertical(classes="fkn-section", id="forkname-option-section"):
                    yield Static(
                        "[b][옵션][/] 옵션",
                        classes="fkn-section-title", markup=True,
                    )
                    if self.open_target_options:
                        yield Static("열기 방식", classes="fkn-option-label")
                        with RadioSet(id="forkname-open-target"):
                            for value, label, checked in self.open_target_options:
                                yield RadioButton(label, value=checked, id=f"forkname-open-{value}")
                    if self.other_env:
                        if self.other_env == "vscode":
                            other_label = "VSCode 브리지로 보내기"
                        elif self.other_env == "gnome-terminal":
                            other_label = "gnome-terminal로 보내기"
                        else:
                            other_label = f"Send to {self.other_env}"
                        yield Checkbox(
                            other_label,
                            value=False,
                            id="forkname-other-env",
                        )
                    # Spawn mode: unchecked = new window, checked = new tab.
                    # Hidden in on_mount/on_checkbox_changed when target is VSCode.
                    yield Checkbox(
                        "새 탭으로 열기 (해제 = 새 창)",
                        value=False,
                        id="forkname-newtab",
                    )

            # Footer: cancel, spacer, confirm.
            with Horizontal(id="forkname-btn-row"):
                yield Button("Esc 취소", id="btn-forkname-cancel")
                yield Static("", id="forkname-btn-spacer")
                yield Button("Enter 확인", id="btn-forkname-save", variant="primary")

    def on_mount(self) -> None:
        inp = self.query_one("#forkname-input", Input)
        inp.focus()
        inp.cursor_position = len(inp.value)
        self._update_newtab_visibility()
        self._update_sid_prefix_visibility()

    def on_checkbox_changed(self, event: Checkbox.Changed) -> None:
        # Recalculate new-tab checkbox visibility when the other-environment toggle changes.
        if event.checkbox.id == "forkname-other-env":
            self._update_newtab_visibility()

    def on_radio_set_changed(self, event: RadioSet.Changed) -> None:
        if event.radio_set.id == "forkname-open-target":
            self._update_sid_prefix_visibility()

    def _current_spawn_mode(self) -> str:
        try:
            newtab = self.query_one("#forkname-newtab", Checkbox).value
        except Exception:
            newtab = False
        return "tab" if newtab else "window"

    def _current_target_terminal(self) -> Optional[str]:
        """Return other_env when checked; otherwise None for auto-detection."""
        if not self.other_env:
            return None
        try:
            checked = self.query_one("#forkname-other-env", Checkbox).value
        except Exception:
            checked = False
        return self.other_env if checked else None

    def _current_open_target(self) -> str:
        if not self.open_target_options:
            return "claude"
        for value, _label, default_checked in self.open_target_options:
            try:
                rb = self.query_one(f"#forkname-open-{value}", RadioButton)
                if rb.value:
                    return value
            except Exception:
                continue
        for value, _label, default_checked in self.open_target_options:
            if default_checked:
                return value
        return self.open_target_options[0][0]

    def _result(self, name: str) -> None:
        final_name = name.strip()
        if self._sid_prefix_applies():
            # Convention: automatically prepend [XXXX] uppercase bracket prefix.
            # Avoid duplicates if the user typed the prefix manually.
            bracket_prefix = f"[{self.sid_prefix.upper()}]"
            if not final_name.startswith(bracket_prefix):
                final_name = f"{bracket_prefix} {final_name}".strip()
        self.dismiss({
            "name": final_name,
            "spawn_mode": self._current_spawn_mode(),
            "target_terminal": self._current_target_terminal(),
            "open_target": self._current_open_target(),
        })

    def on_input_submitted(self, event: Input.Submitted) -> None:
        self._result(event.value)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-forkname-save":
            self._result(self.query_one("#forkname-input", Input).value)
        elif bid == "btn-forkname-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)


class CodexImportOptionsScreen(ModalScreen[Optional[dict]]):
    """Modal for choosing Claude-to-Codex conversion scope.

    Codex context is smaller than Claude, so users choose recent raw and compact
    summary excerpt amounts.
    """

    PROFILES = {
        "light": {
            "label": "Light — context 120 + compact excerpt 1,600 chars",
            "recent_semantic": 120,
            "compact_excerpt_chars": 1600,
        },
        "balanced": {
            "label": "Recommended — context 240 + compact excerpt 4,000 chars",
            "recent_semantic": 240,
            "compact_excerpt_chars": 4000,
        },
        "deep": {
            "label": "Deep — context 480 + compact excerpt 8,000 chars",
            "recent_semantic": 480,
            "compact_excerpt_chars": 8000,
        },
    }

    def compose(self) -> ComposeResult:
        with Vertical(id="forkname-box"):
            with Horizontal(id="forkname-header"):
                yield Static("[b]GccForK[/]", id="forkname-brand", markup=True)
                yield Static("[b]Codex Conversion Options[/]", id="forkname-title", markup=True)
                yield Static(f"[dim]v{GCCFORK_VERSION}[/]", id="forkname-meta", markup=True)
            with Vertical(id="forkname-scroll"):
                with Vertical(classes="fkn-section"):
                    yield Static("[b][SCOPE][/] Transfer scope", classes="fkn-section-title", markup=True)
                    yield Static(
                        "Reduces a Claude 1M session for Codex 256k. "
                        "Compact summaries, recent context, and final raw protected turns are combined to preserve context.",
                        classes="fkn-option-label",
                    )
                    with RadioSet(id="codex-import-profile"):
                        yield RadioButton(self.PROFILES["light"]["label"], id="codex-profile-light")
                        yield RadioButton(self.PROFILES["balanced"]["label"], value=True, id="codex-profile-balanced")
                        yield RadioButton(self.PROFILES["deep"]["label"], id="codex-profile-deep")
                with Vertical(classes="fkn-section"):
                    yield Static("[b][RAW][/] Final protected turns", classes="fkn-section-title", markup=True)
                    yield Static(
                        "The latest N turns preserve user questions and assistant answers close to raw form.",
                        classes="fkn-option-label",
                    )
                    with RadioSet(id="codex-raw-turns"):
                        yield RadioButton("Preserve 3 raw turns", id="codex-raw-3")
                        yield RadioButton("Preserve 5 raw turns (recommended)", value=True, id="codex-raw-5")
                        yield RadioButton("Preserve 10 raw turns", id="codex-raw-10")
                        yield RadioButton("Preserve 20 raw turns", id="codex-raw-20")
                with Vertical(classes="fkn-section"):
                    yield Static("[b][FILTER][/] Exclude / include", classes="fkn-section-title", markup=True)
                    yield Checkbox(
                        "Include local command output such as /context (default OFF)",
                        value=False,
                        id="codex-include-local-commands",
                    )
            with Horizontal(id="forkname-btn-row"):
                yield Button("Esc 취소", id="btn-codex-import-cancel")
                yield Static("", id="forkname-btn-spacer")
                yield Button("Enter Convert", id="btn-codex-import-save", variant="primary")

    def _selected_profile(self) -> str:
        for key in ("light", "balanced", "deep"):
            try:
                if self.query_one(f"#codex-profile-{key}", RadioButton).value:
                    return key
            except Exception:
                pass
        return "balanced"

    def _selected_raw_turns(self) -> int:
        for n in (3, 5, 10, 20):
            try:
                if self.query_one(f"#codex-raw-{n}", RadioButton).value:
                    return n
            except Exception:
                pass
        return 5

    def _result(self) -> dict:
        key = self._selected_profile()
        prof = self.PROFILES[key]
        try:
            include_local = bool(self.query_one("#codex-include-local-commands", Checkbox).value)
        except Exception:
            include_local = False
        return {
            "profile": key,
            "recent_semantic": prof["recent_semantic"],
            "keep_raw_turns": self._selected_raw_turns(),
            "compact_excerpt_chars": prof["compact_excerpt_chars"],
            "include_local_commands": include_local,
        }

    def on_mount(self) -> None:
        try:
            self.query_one("#codex-import-profile", RadioSet).focus()
        except Exception:
            pass

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-codex-import-save":
            self.dismiss(self._result())
        elif event.button.id == "btn-codex-import-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)
        elif event.key == "enter":
            self.dismiss(self._result())


class ConfirmScreen(ModalScreen[bool]):
    def __init__(
        self,
        message: str,
        confirm_label: str = "삭제",
        confirm_variant: str = "error",
        title: str = "확인",
    ) -> None:
        super().__init__()
        self.message = message
        self.confirm_label = confirm_label
        self.confirm_variant = confirm_variant
        self.title_text = title

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label(self.title_text, id="confirm-title")
            yield SelectableTextArea(
                self.message,
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button(self.confirm_label, id="btn-confirm", variant=self.confirm_variant)
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-cancel", Button).focus()
        _configure_confirm_screen(self, self.message, {})

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            self.dismiss(True)
        elif event.button.id == "btn-cancel":
            self.dismiss(False)

    def on_key(self, event) -> None:
        if event.key == "escape":
            # Stop propagation so App-level escape->quit binding does not receive it.
            event.stop()
            self.dismiss(False)


class SummarizeProviderScreen(ModalScreen[Optional[str]]):
    """Choose which CLI should generate AI summaries."""

    BINDINGS = [
        Binding("escape", "cancel", "취소", show=False),
        Binding("q", "cancel", "취소", show=False),
    ]

    def __init__(self, *, has_claude: bool, has_codex: bool) -> None:
        super().__init__()
        self.has_claude = has_claude
        self.has_codex = has_codex

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label("📝 요약 LLM 선택", id="confirm-title")
            yield SelectableTextArea(
                "선택한 CLI로 세션 요약을 생성합니다.\n"
                "Claude는 Haiku 요약을 사용하고, Codex는 비대화형 exec 요약을 사용합니다.",
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            with RadioSet(id="summarize-provider-radio"):
                yield RadioButton(
                    "Claude",
                    value=self.has_claude,
                    id="summarize-provider-claude",
                    disabled=not self.has_claude,
                )
                yield RadioButton(
                    "Codex",
                    value=(not self.has_claude and self.has_codex),
                    id="summarize-provider-codex",
                    disabled=not self.has_codex,
                )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button("요약 시작", id="btn-confirm", variant="primary")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-confirm", Button).focus()

    def _selected_provider(self) -> Optional[str]:
        try:
            if self.query_one("#summarize-provider-claude", RadioButton).value:
                return "claude"
            if self.query_one("#summarize-provider-codex", RadioButton).value:
                return "codex"
        except Exception:
            pass
        return None

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id or ""
        if bid == "btn-confirm":
            self.dismiss(self._selected_provider())
        elif bid == "btn-cancel":
            self.dismiss(None)

    def action_cancel(self) -> None:
        self.dismiss(None)


class ResumeConflictScreen(ModalScreen[str]):
    """Safety confirmation when reopening an already open session."""

    BINDINGS = [
        Binding("escape", "cancel", "취소", show=False),
        Binding("q", "cancel", "취소", show=False),
    ]

    def __init__(
        self,
        *,
        session_label: str,
        source_label: str,
        pids: list[int],
    ) -> None:
        super().__init__()
        self.session_label = session_label
        self.source_label = source_label
        self.pids = pids
        pid_text = ", ".join(str(pid) for pid in self.pids) or "detected"
        self.message = (
            f"This {self.source_label} session is already open.\n\n"
            f"Session: {self.session_label}\n"
            f"Running PID: {pid_text}\n\n"
            f"Reopening the same SID lets multiple processes write to the same record file, "
            f"which may corrupt session history.\n\n"
            f"Close the existing process before resuming, or cancel."
        )

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label("⚠ 세션이 이미 열려 있음", id="confirm-title")
            yield SelectableTextArea(
                self.message,
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button("기존 종료 후 재개", id="btn-terminate-resume", variant="warning")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-cancel", Button).focus()
        _configure_confirm_screen(self, self.message, {})

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id or ""
        if bid == "btn-terminate-resume":
            self.dismiss("terminate")
        elif bid == "btn-cancel":
            self.dismiss("cancel")

    def action_cancel(self) -> None:
        self.dismiss("cancel")


class MultiDeleteImportantScreen(ModalScreen[str]):
    """Three-way choice when multi-delete includes sessions marked important.

    Return values:
      "exclude" — delete only non-important sessions
      "include" — delete all, including important sessions
      "cancel"  — do nothing

    Design tone matches ForkNameScreen: three-column brand/title/meta header,
    $accent 5% section cards, edge-aligned footer.

    Esc is handled by BINDINGS so it does not propagate to App-level quit binding.
    """

    BINDINGS = [
        Binding("escape", "cancel_screen", "취소", show=False),
    ]

    def __init__(self, total: int, important_count: int, important_titles: list[str]) -> None:
        super().__init__()
        self.total = total
        self.important_count = important_count
        self.safe_count = total - important_count
        self.important_titles = important_titles[:6]
        self.titles_more = max(0, important_count - len(self.important_titles))

    def compose(self) -> ComposeResult:
        with Vertical(id="mdi-box"):
            # Header matching ForkNameScreen: brand, title, meta.
            with Horizontal(id="mdi-header"):
                yield Static("[b]GccForK[/]", id="mdi-brand", markup=True)
                yield Static(
                    "[b]🍂 중요 항목 포함[/]",
                    id="mdi-title", markup=True,
                )
                yield Static(
                    f"[dim]v{GCCFORK_VERSION}[/]",
                    id="mdi-meta", markup=True,
                )

            # Body with two section cards.
            with Vertical(id="mdi-scroll"):
                with Vertical(classes="mdi-section"):
                    yield Static(
                        "[b][INFO][/] 선택 요약",
                        classes="mdi-section-title", markup=True,
                    )
                    yield Static(
                        f"Of {self.total} selected sessions, [b]{self.important_count}[/b] are "
                        f"marked important (★).",
                        markup=True,
                    )

                with Vertical(classes="mdi-section"):
                    yield Static(
                        "[b][★ 중요][/] 중요 세션",
                        classes="mdi-section-title", markup=True,
                    )
                    for title in self.important_titles:
                        yield Static(f"  ★ {title}")
                    if self.titles_more:
                        yield Static(f"  ... and {self.titles_more} more")

            # Footer: cancel, spacer, exclude important, delete all.
            with Horizontal(id="mdi-btn-row"):
                yield Button("Esc 취소", id="btn-mdi-cancel")
                yield Static("", id="mdi-btn-spacer")
                yield Button(f"Exclude important ({self.safe_count})", id="btn-mdi-exclude")
                yield Button(
                    f"Delete all ({self.total})",
                    id="btn-mdi-include", variant="error",
                )
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        # Initial focus on cancel prevents accidental destructive Enter.
        self.query_one("#btn-mdi-cancel", Button).focus()

    def action_cancel_screen(self) -> None:
        self.dismiss("cancel")

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-mdi-exclude":
            self.dismiss("exclude")
        elif bid == "btn-mdi-include":
            self.dismiss("include")
        elif bid == "btn-mdi-cancel":
            self.dismiss("cancel")


class TrashScreen(ModalScreen[None]):
    """Trash screen: deleted session list, restore, permanent delete."""

    def __init__(self) -> None:
        super().__init__()
        self.entries: list[dict] = []

    def compose(self) -> ComposeResult:
        with Vertical(id="trash-box"):
            yield Static("🗑 휴지통", id="trash-title")
            yield Static("", id="trash-summary", classes="hint")
            yield SelectableTextArea(
                "",
                id="trash-list",
                read_only=True,
                show_cursor=True,
                soft_wrap=False,
                compact=True,
                show_line_numbers=False,
                highlight_cursor_line=True,
            )
            with Horizontal(id="trash-btn-row"):
                yield Button("닫기", id="btn-trash-close")
                yield Button("전체 비우기", id="btn-trash-purge-all", variant="error")
                yield Button("영구 삭제", id="btn-trash-purge", variant="error")
                yield Button("복원", id="btn-trash-restore", variant="success")
            yield Label(
                "↑/↓ 이동 · Enter=복원 · Del=영구삭제 · Esc=닫기",
                classes="hint",
            )
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self._reload()
        try:
            self.query_one("#btn-trash-restore", Button).focus()
        except Exception:
            pass

    def _reload(self) -> None:
        self.entries = list_trash_entries()
        list_area = self.query_one("#trash-list", SelectableTextArea)
        summary = self.query_one("#trash-summary", Static)
        if not self.entries:
            list_area.text = "(비어 있음)"
            summary.update("휴지통이 비어 있습니다.")
            return
        lines: list[str] = []
        total_size = 0
        for e in self.entries:
            sid = (e["session_id"] or "")[:8]
            deleted = (e["deleted_at"] or "")[:19].replace("T", " ")
            size = e["size"]
            total_size += size
            if size < 1024:
                size_str = f"{size}B"
            elif size < 1024 * 1024:
                size_str = f"{size / 1024:.1f}KB"
            else:
                size_str = f"{size / (1024 * 1024):.1f}MB"
            name = e["name"] or "(untitled)"
            name = name.replace("\n", " ")[:60]
            lines.append(f"{sid}  {deleted}  {size_str:>8}  {name}")
        list_area.text = "\n".join(lines)
        if total_size < 1024 * 1024:
            ts = f"{total_size / 1024:.1f} KB"
        else:
            ts = f"{total_size / (1024 * 1024):.1f} MB"
        summary.update(f"{len(self.entries)} entries · total {ts}")

    def _current_entry(self) -> Optional[dict]:
        if not self.entries:
            return None
        list_area = self.query_one("#trash-list", SelectableTextArea)
        try:
            row = list_area.cursor_location[0]
        except Exception:
            row = 0
        if 0 <= row < len(self.entries):
            return self.entries[row]
        return None

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-trash-close":
            self.dismiss(None)
            return
        if bid == "btn-trash-restore":
            entry = self._current_entry()
            if not entry:
                return
            if restore_trash_entry(entry):
                self.app.notify(f"✓ Restored: {entry['session_id'][:8]}")
                # Also refresh the parent app's session list.
                try:
                    self.app.reload_sessions()  # type: ignore[attr-defined]
                except Exception:
                    pass
            else:
                self.app.notify("복원 실패: 원래 경로 충돌 가능성이 있습니다.", severity="error")
            self._reload()
            return
        if bid == "btn-trash-purge":
            entry = self._current_entry()
            if not entry:
                return
            if purge_trash_entry(entry):
                self.app.notify(f"Purged: {entry['session_id'][:8]}")
            else:
                self.app.notify("Permanent delete failed", severity="error")
            self._reload()
            return
        if bid == "btn-trash-purge-all":
            n = purge_all_trash()
            self.app.notify(f"Permanently deleted {n} trash entries")
            self._reload()
            return

    def on_key(self, event) -> None:
        key = event.key
        if key == "escape":
            self.dismiss(None)
            return
        if key == "enter":
            entry = self._current_entry()
            if entry and restore_trash_entry(entry):
                self.app.notify(f"✓ Restored: {entry['session_id'][:8]}")
                try:
                    self.app.reload_sessions()  # type: ignore[attr-defined]
                except Exception:
                    pass
                self._reload()
                event.stop()
            return
        if key in ("delete", "d"):
            entry = self._current_entry()
            if entry and purge_trash_entry(entry):
                self.app.notify(f"Purged: {entry['session_id'][:8]}")
                self._reload()
                event.stop()
            return


