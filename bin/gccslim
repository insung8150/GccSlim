def _file_contains(path: Path, needle: str) -> bool:
    try:
        return needle in path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return False


def _binary_contains(path: Path, needle: str) -> bool:
    if not path.exists():
        return False
    rg = shutil.which("rg")
    if rg:
        try:
            return subprocess.run(
                [rg, "-a", "-q", needle, str(path)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=8,
                check=False,
            ).returncode == 0
        except (OSError, subprocess.TimeoutExpired):
            return False
    try:
        return needle.encode("utf-8") in path.read_bytes()
    except OSError:
        return False


def _mtime(path: Path) -> float:
    try:
        return path.stat().st_mtime
    except OSError:
        return 0.0


def _codex_gccslim_patch_needs_update() -> tuple[bool, str]:
    """Return whether the local Codex patch should be re-applied.

    This is intentionally cheap enough to run on every gccfork startup.
    The expensive cargo build only happens when a marker is missing or the
    installed binary is older than watched Codex/GccSlim patch inputs.
    """
    if not CODEX_GCCSLIM_PATCH_SCRIPT.exists():
        return False, f"patch script missing: {CODEX_GCCSLIM_PATCH_SCRIPT}"
    if CODEX_RS_ROOT is None or not CODEX_RS_ROOT.is_dir():
        return False, "codex rust workspace not configured"
    compact_rs = CODEX_RS_ROOT / "core" / "src" / "compact.rs"
    slash_rs = CODEX_RS_ROOT / "tui" / "src" / "slash_command.rs"
    chat_rs = CODEX_RS_ROOT / "tui" / "src" / "chatwidget.rs"

    if not _file_contains(compact_rs, "CODEX_GCCSLIM_PLAINTEXT_COMPACT"):
        return True, "compact.rs plaintext compact gate missing"
    if not _file_contains(slash_rs, "SlashCommand::Slim"):
        return True, "slash_command.rs /slim command missing"
    if not (
        _file_contains(chat_rs, "SlashCommand::Slim =>")
        and _file_contains(chat_rs, "codex-slim-now")
    ):
        return True, "chatwidget.rs /slim handler missing"
    if not _file_contains(CODEX_WRAPPER_BIN, "CODEX_GCCSLIM_PLAINTEXT_COMPACT"):
        return True, "codex wrapper plaintext compact env missing"
    if not _binary_contains(CODEX_PATCHED_BIN, "CODEX_GCCSLIM_PLAINTEXT_COMPACT"):
        return True, "installed codex binary plaintext marker missing"
    if not _binary_contains(CODEX_PATCHED_BIN, "codex-slim-now"):
        return True, "installed codex binary /slim marker missing"

    watched = [compact_rs, slash_rs, chat_rs]
    newest_input = max((_mtime(path) for path in watched), default=0.0)
    installed_mtime = _mtime(CODEX_PATCHED_BIN)
    if installed_mtime <= 0:
        return True, "installed codex binary missing"
    if newest_input > installed_mtime + 1.0:
        return True, "codex patch inputs are newer than installed binary"
    return False, "codex gccslim patch current"


def _ensure_codex_gccslim_patch() -> tuple[str, str]:
    needs_update, reason = _codex_gccslim_patch_needs_update()
    if not needs_update:
        return "ok", reason

    CODEX_GCCSLIM_PATCH_LOCK.parent.mkdir(parents=True, exist_ok=True)
    with CODEX_GCCSLIM_PATCH_LOCK.open("w", encoding="utf-8") as lock_file:
        try:
            fcntl.flock(lock_file, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return "busy", "another gccfork instance is already patching Codex"

        needs_update, reason = _codex_gccslim_patch_needs_update()
        if not needs_update:
            return "ok", reason

        env = os.environ.copy()
        if CODEX_RS_ROOT is not None:
            env.setdefault("CODEX_RS_ROOT", str(CODEX_RS_ROOT))
        env.setdefault("PATCHED_CODEX", str(CODEX_PATCHED_BIN))
        env.setdefault("CODEX_WRAPPER", str(CODEX_WRAPPER_BIN))
        proc = subprocess.run(
            [str(CODEX_GCCSLIM_PATCH_SCRIPT)],
            cwd=str(GCCFORK_REPO_ROOT),
            env=env,
            text=True,
            capture_output=True,
            timeout=900,
            check=False,
        )
        output = "\n".join(part.strip() for part in (proc.stdout, proc.stderr) if part.strip())
        if proc.returncode != 0:
            return "error", f"{reason}; patch failed exit {proc.returncode}: {output[-1200:]}"
        return "patched", reason


def _gccfork_code_mtime() -> float:
    """Mtime of the running gccfork script (= build/deploy timestamp).

    Used to detect stale instances. Resolves via __file__ — works regardless
    of where gccfork is installed (cross-platform / multi-user).
    """
    try:
        return Path(__file__).stat().st_mtime
    except OSError:
        return 0.0


def _gccfork_bin_path() -> str:
    """Path to the currently running gccfork executable.

    Always derived from __file__, never hardcoded to a personal home path.
    """
    return str(Path(__file__).resolve())


def _gccfork_version_label() -> str:
    """타이틀 표시용 — 버전 + 코드 mtime (HHMM).

    같은 버전 0.1.0 도 mtime 다르면 다른 빌드 → 사용자가 명확히 구분 가능.
    """
    mt = _gccfork_code_mtime()
    if mt > 0:
        from datetime import datetime as _dt
        return f"v{GCCFORK_VERSION} ({_dt.fromtimestamp(mt).strftime('%m%d %H:%M')})"
    return f"v{GCCFORK_VERSION}"


def _find_other_gccfork_tuis(my_pid: Optional[int] = None) -> list[dict]:
    """현재 실행 중인 다른 gccfork TUI 프로세스 찾기 (자기 자신 제외).

    반환: [{pid, start_ts, code_mtime_at_start (없으면 0), is_old}]
    is_old = True 면 현재 코드 mtime 보다 옛 시점에 시작 → 새 코드 안 본 인스턴스.
    """
    if my_pid is None:
        my_pid = os.getpid()
    cur_mtime = _gccfork_code_mtime()
    gccfork_bin = _gccfork_bin_path()
    out: list[dict] = []
    try:
        result = subprocess.run(
            ["pgrep", "-f", gccfork_bin],
            capture_output=True, text=True, timeout=3,
        )
        pids = [int(p) for p in result.stdout.split() if p.isdigit()]
    except (subprocess.SubprocessError, OSError):
        return out

    for pid in pids:
        if pid == my_pid:
            continue
        try:
            # Cross-platform: prefer /proc on Linux, fall back to `ps` on macOS/BSD.
            cmd_str = ""
            try:
                cmdline = Path(f"/proc/{pid}/cmdline").read_bytes().decode("utf-8", "replace")
                cmd_str = cmdline.replace("\x00", " ")
            except OSError:
                ps_out = subprocess.run(
                    ["ps", "-p", str(pid), "-o", "args="],
                    capture_output=True, text=True, timeout=2,
                )
                if ps_out.returncode == 0:
                    cmd_str = ps_out.stdout.strip()
            # 메인 TUI 만 (subcommand 제외)
            if gccfork_bin not in cmd_str:
                continue
            if any(x in cmd_str for x in [
                "slim-and-reload", "slim-inplace", "hot-reload", "search ",
                "list ", "detail ", "ancestry", "parent-of", "rename ",
                "hard-fork ", "delete ", "prefs ", "stats", "patch-claude",
                "reconcile-live", "live-sessions", "--help", "-h",
            ]):
                continue
            # 프로세스 시작 시각 — /proc/<pid> 의 mtime 또는 stat
            stat_data = Path(f"/proc/{pid}").stat()
            proc_start = stat_data.st_mtime
            is_old = (cur_mtime > 0 and proc_start < cur_mtime - 30)
            out.append({
                "pid": pid,
                "start_ts": proc_start,
                "is_old": is_old,
                "cmd": cmd_str[:80],
            })
        except (OSError, ValueError):
            continue
    return out

TK_CLIPBOARD_OWNER_CODE = r"""
import signal
import sys
import tkinter as tk

data = sys.stdin.read()
root = tk.Tk()
root.withdraw()
root.clipboard_clear()
root.clipboard_append(data)
root.update_idletasks()
root.update()

def _shutdown(*_args):
    try:
        root.destroy()
    except Exception:
        pass

signal.signal(signal.SIGTERM, _shutdown)
signal.signal(signal.SIGINT, _shutdown)
root.after(600000, _shutdown)
root.mainloop()
"""


def fmt_size(n: int) -> str:
    if n >= 1_048_576:
        return f"{n / 1_048_576:.1f}M"
    if n >= 1024:
        return f"{n / 1024:.0f}K"
    return f"{n}B"


# 레거시 fork-name 포맷 변환:
#   "38222961[<= d8442afa] 이름"  →  "이름 2961[<= 2afa]"
#   "38222961[<= d8442afa]"        →  "2961[<= 2afa]"
# 매칭 안 되면 원본 그대로.
_LEGACY_CLONE_NAME_RE = re.compile(
    r"^([a-f0-9]{8})\[<=\s*([a-f0-9]{8})\](.*)$", re.IGNORECASE
)


@functools.lru_cache(maxsize=2048)
def _display_clone_name(title: str) -> str:
    """레거시 fork-name 포맷 변환 — 매 리스트 렌더마다 호출되므로 lru_cache.

    제목 문자열은 거의 안 바뀌므로 캐시 적중률 ~100%. 메모리 cap 2048.
    """
    if not title:
        return title
    m = _LEGACY_CLONE_NAME_RE.match(title.strip())
    if not m:
        return title
    new_id, parent_id, rest = m.group(1), m.group(2), m.group(3).strip()
    # 첫 4자 — ID 컬럼(`session.id[:4]`) 과 일치시켜 트리 매칭이 보이게
    suffix = f"{new_id[:4]}[<= {parent_id[:4]}]"
    return f"{rest} {suffix}".strip() if rest else suffix




class SelectableTextArea(TextArea):
    ALLOW_SELECT = False

    async def _on_mouse_down(self, event: events.MouseDown) -> None:
        if event.button == 3:
            event.prevent_default()
            if hasattr(self.app, "prepare_context_copy"):
                self.app.prepare_context_copy(self.id, self.selected_text)
            if hasattr(self.app, "remember_active_copy_widget"):
                self.app.remember_active_copy_widget(self.id)
            event.stop()
            return
        # 좌클릭이 session-list 의 체크박스 컬럼(맨 왼쪽 3칸 + 우측 여유 2칸)에
        # 떨어졌으면 다중 선택 토글로 처리. 클릭 정확도 너그러움 ↑.
        # 실제 [ ] 는 0~2, 그 뒤 spacer 2칸까지 포함 → x < 5.
        is_checkbox_click = (
            event.button == 1
            and self.id == "session-list"
            and event.x is not None
            and event.x < 5
            and hasattr(self.app, "handle_list_checkbox_click")
        )
        # 좌클릭이 마크 컬럼(▶★ 영역) 에 떨어지면 important 토글.
        # chk(3) + spacer(2) + mark(2) + spacer(2) → 마크 셀은 col 5~6, 너그럽게 5~8.
        is_mark_click = (
            event.button == 1
            and self.id == "session-list"
            and event.x is not None
            and 5 <= event.x <= 8
            and not (event.ctrl or event.shift)
            and hasattr(self.app, "handle_list_mark_click")
        )
        # Ctrl/Shift + 좌클릭은 best-effort (gnome-terminal 등에서만 동작)
        is_modifier_click = (
            event.button == 1
            and self.id == "session-list"
            and (event.ctrl or event.shift)
            and hasattr(self.app, "handle_list_modifier_click")
        )
        if event.button == 1 and hasattr(self.app, "begin_list_pointer_interaction"):
            self.app.begin_list_pointer_interaction(self.id)
        self.focus()
        if hasattr(self.app, "remember_active_copy_widget"):
            self.app.remember_active_copy_widget(self.id)
        if is_checkbox_click or is_mark_click or is_modifier_click:
            try:
                row = self.get_target_document_location(event)[0]
            except Exception:
                row = 0
            if is_checkbox_click:
                self.app.handle_list_checkbox_click(row=row)  # type: ignore[attr-defined]
            elif is_mark_click:
                self.app.handle_list_mark_click(row=row)  # type: ignore[attr-defined]
            else:
                self.app.handle_list_modifier_click(  # type: ignore[attr-defined]
                    row=row, ctrl=event.ctrl, shift=event.shift,
                )
            event.prevent_default()
            event.stop()
            return
        await super()._on_mouse_down(event)

    def _on_focus(self, event: events.Focus) -> None:
        if hasattr(self.app, "remember_active_copy_widget"):
            self.app.remember_active_copy_widget(self.id)
        super()._on_focus(event)

    async def _on_mouse_move(self, event: events.MouseMove) -> None:
        await super()._on_mouse_move(event)
        if not bool(getattr(self, "_selecting", False)):
            return

        height = max(1, int(self.size.height or 1))
        y = int(event.y or 0)
        delta = 0
        if y >= height - 1:
            delta = min(5, max(1, y - height + 2))
        elif y <= 0:
            delta = -min(5, max(1, 1 - y))
        if not delta:
            return

        self.scroll_relative(y=delta, animate=False, immediate=True)
        try:
            start, _ = self.selection
            self.selection = self.selection.__class__(start, self.get_target_document_location(event))
        except Exception:
            pass

    async def _on_mouse_up(self, event: events.MouseUp) -> None:
        if event.button == 3:
            event.prevent_default()
            if hasattr(self.app, "open_copy_context_menu"):
                self.app.open_copy_context_menu(
                    widget_id=self.id,
                    text=self.selected_text,
                    screen_x=int(event.screen_x or 0),
                    screen_y=int(event.screen_y or 0),
                )
            event.stop()
            return
        if (
            event.button == 1
            and self.id == "session-list"
            and bool(getattr(self.app, "_suppress_pointer_clear", False))
            and hasattr(self.app, "finish_list_pointer_interaction")
        ):
            event.prevent_default()
            event.stop()
            self.app.finish_list_pointer_interaction(self.id, False)  # type: ignore[attr-defined]
            return
        await super()._on_mouse_up(event)
        if event.button == 1 and hasattr(self.app, "finish_list_pointer_interaction"):
            self.app.finish_list_pointer_interaction(self.id, bool(self.selected_text))


class CopyMenuOverlay(Vertical):
    DEFAULT_CSS = """
    CopyMenuOverlay {
        layer: _tooltips;
        width: 12;
        height: auto;
        background: $accent 8%;
        border: round $accent 35%;
        padding: 0;
        constrain: inside;
        display: none;
    }

    CopyMenuOverlay .copy-menu-item {
        width: 100%;
        height: 3;
        text-align: left;
        content-align: left middle;
        background: $accent 5%;
        color: $text;
        border: round $accent 20%;
        padding: 0 1;
        margin-bottom: 0;
        text-style: bold;
    }

    CopyMenuOverlay .copy-menu-item:hover {
        background: $accent 10%;
        border: round $accent 35%;
    }
    CopyMenuOverlay .copy-menu-item.-disabled {
        color: $text-muted;
        border: round $accent 12%;
        background: $accent 3%;
    }
    #copy-menu-cancel {
        margin-bottom: 0;
    }
    """

    def compose(self) -> ComposeResult:
        yield CopyMenuItem("⎘ 복사", id="copy-menu-copy", classes="copy-menu-item")
        yield CopyMenuItem("✕ 취소", id="copy-menu-cancel", classes="copy-menu-item")


class CopyMenuItem(Static):
    def set_state(self, label: str, enabled: bool = True) -> None:
        self.update(label)
        if enabled:
            self.remove_class("-disabled")
        else:
            self.add_class("-disabled")

    def is_enabled(self) -> bool:
        return not self.has_class("-disabled")

    async def _on_mouse_down(self, event: events.MouseDown) -> None:
        event.prevent_default()
        event.stop()

    async def _on_mouse_up(self, event: events.MouseUp) -> None:
        if event.button != 1:
            event.stop()
            return
        event.prevent_default()
        event.stop()
        if not self.is_enabled():
            return
        if hasattr(self.app, "handle_copy_menu_action"):
            if self.id == "copy-menu-copy":
                self.app.handle_copy_menu_action("copy")
            elif self.id == "copy-menu-cancel":
                self.app.handle_copy_menu_action("cancel")


class PaneDivider(Static):
    async def _on_mouse_down(self, event: events.MouseDown) -> None:
        if event.button != 1:
            return
        event.prevent_default()
        event.stop()
        self.capture_mouse()
        self.add_class("-dragging")
        if hasattr(self.app, "begin_pane_drag"):
            self.app.begin_pane_drag(event.screen_x)

    async def _on_mouse_move(self, event: events.MouseMove) -> None:
        if not self.has_class("-dragging"):
            return
        event.prevent_default()
        event.stop()
        if hasattr(self.app, "update_pane_drag"):
            self.app.update_pane_drag(event.screen_x)

    async def _on_mouse_up(self, event: events.MouseUp) -> None:
        if not self.has_class("-dragging"):
            return
        event.prevent_default()
        event.stop()
        self.release_mouse()
        self.remove_class("-dragging")
        if hasattr(self.app, "finish_pane_drag"):
            self.app.finish_pane_drag(event.screen_x)


class FilterDot(Static):
    def __init__(self, color_style: str, **kwargs) -> None:
        super().__init__("", **kwargs)
        self.color_style = color_style

    def render(self) -> Text:
        dot = Text()
        dot.append("●", style=f"{self.color_style} bold")
        return dot


class FilterTool(Static, can_focus=True):
    class Activated(Message):
        def __init__(self, tool: "FilterTool") -> None:
            super().__init__()
            self.tool = tool

    def __init__(self, label: str, color_style: str, **kwargs) -> None:
        super().__init__("", **kwargs)
        self.tool_label = label
        self.color_style = color_style

    def set_label(self, label: str) -> None:
        self.tool_label = label
        self.refresh()

    def render(self) -> Text:
        # 라벨에 이모지를 직접 포함하므로 dot 불필요 — 라벨 그대로 표시.
        return Text(self.tool_label, style="bold")

    async def _on_mouse_down(self, event: events.MouseDown) -> None:
        if event.button != 1:
            return
        event.prevent_default()
        event.stop()
        self.focus()

    async def _on_mouse_up(self, event: events.MouseUp) -> None:
        if event.button != 1:
            return
        event.prevent_default()
        event.stop()
        self.focus()
        self.post_message(self.Activated(self))

    async def _on_key(self, event: events.Key) -> None:
        if event.key not in {"enter", "space"}:
            return
        event.prevent_default()
        event.stop()
        self.post_message(self.Activated(self))


def _single_line(text: Optional[str], default: str = "") -> str:
    if not text:
        return default
    collapsed = " ".join(part for part in text.splitlines() if part.strip())
    return collapsed.strip() or default


def _format_preview_messages(title: str, messages: list[Msg]) -> list[str]:
    lines = [title]
    if not messages:
        lines.append("(없음)")
        return lines

    for msg in messages:
        icon = "👤" if msg.role == "user" else "🤖"
        lines.append(f"{icon} [{msg.role}]")
        body_lines = msg.text.splitlines() or [""]
        for line in body_lines:
            lines.append(f"  {line}")
        lines.append("")
    if lines[-1] == "":
        lines.pop()
    return lines


def render_preview_text(session: Session, current_id: Optional[str], width: int = 80) -> str:
    lines: list[str] = []

    # AI요약 헤더 — registry 의 ai_summary 가 있으면 최상단에 강조 박스 형태로 prepend.
    # 다중 줄 요약 (주제/진행/결론) 도 지원 — 각 줄에 ❯ prefix.
    if session.ai_summary:
        title_label = " AI요약 "
        rule_char = "─"
        left = max(3, width - len(title_label) - 2 - 2)
        top_rule = rule_char * left + title_label + rule_char * 2
        bottom_rule = rule_char * max(10, width - 2)
        lines.append(top_rule)
        for ai_line in session.ai_summary.splitlines():
            ai_line = ai_line.strip()
            if ai_line:
                lines.append(f"❯ {ai_line}")
        lines.append(bottom_rule)

    title = session.custom_name or session.auto_summary or "(이름 없음)"

    lines.append(f"제목: {title}")
    if current_id and session.id == current_id:
        lines.append("상태: 현재 세션")
    lines.append(f"세션 ID: {session.id}")
    lines.append(f"파일: {session.jsonl_path}")
    lines.append(f"시각: {session.mtime:%Y-%m-%d %H:%M}")
    lines.append(f"턴/크기: {session.turn_count}턴 / {fmt_size(session.size_bytes)}")
    lines.append(f"작업 폴더: {session.cwd or '(cwd 없음)'}")
    lines.append(f"originator/source: {session.originator or '?'} / {session.source or '?'}")

    if session.parent_id:
        if session.fork_type == "hard":
            fork_note = "🪓 하드 분기 (jsonl 직접 복제 + sessionId 치환, 100% 보존)"
        elif session.fork_type == "soft":
            fork_note = "🔱 일반 분기 (claude --fork-session, 큰 세션은 자동 압축됨)"
        elif session.fork_type == "auto":
            fork_note = "🔱 일반 분기 (parentUuid 체인에서 자동 추론 — registry에 기록 없음)"
        elif session.fork_type == "convert":
            fork_note = "🔁 상호 변환 파생 세션 (원본 JSONL 보존 + 대상 CLI 포맷으로 재생성)"
        else:
            fork_note = "분기 타입 미상"
        lines.append(f"부모 세션: {session.parent_id}")
        lines.append(f"분기 타입: {fork_note}")

    if session.compact_count > 0:
        lines.append(f"압축 이력: 🔩 {session.compact_count}회 (isCompactSummary 마커 검출)")

    lines.append("")
    lines.extend(_format_preview_messages("FIRST", session.first_msgs))
    lines.append("")
    lines.append("⋯  중간 생략  ⋯")
    lines.append("")
    lines.extend(_format_preview_messages("LAST", session.last_msgs))
    return "\n".join(lines)


def _codex_session_id_from_path(path: Path) -> Optional[str]:
    match = UUID_ANY_RE.search(path.stem)
    return match.group(1) if match else None


def _codex_content_text(content: object) -> str:
    """Codex response_item content(list/dict/str)에서 사람이 읽을 텍스트만 추출."""
    if isinstance(content, str):
        return content
    if isinstance(content, dict):
        text = content.get("text")
        return text if isinstance(text, str) else ""
    if isinstance(content, list):
        parts: list[str] = []
        for item in content:
            if isinstance(item, str):
                parts.append(item)
                continue
            if not isinstance(item, dict):
                continue
            if item.get("type") in {"input_text", "output_text", "text"}:
                text = item.get("text")
                if isinstance(text, str) and text:
                    parts.append(text)
        return "\n".join(parts)
    return ""


def _codex_auto_summary(dev_text: str, messages: list[Msg], sid: str) -> str:
    m = re.search(r"원본 Claude SID:\s*([0-9a-f-]{36})", dev_text, re.IGNORECASE)
    if m:
        return f"Codex import <= {m.group(1)[:8]}"
    for msg in messages:
        if msg.role == "user" and msg.text.strip():
            return "Codex: " + _single_line(msg.text, default="")[:80]
    return f"Codex session {sid[:8]}"


def parse_codex_session(path: Path) -> Optional[Session]:
    """~/.codex/sessions JSONL을 GccSlim 공통 Session 모델로 축약 파싱."""
    sid: Optional[str] = None
    cwd: Optional[str] = None
    originator: Optional[str] = None
    source: Optional[str] = None
    dev_text = ""
    event_messages: list[Msg] = []
    response_messages: list[Msg] = []
    event_user_count = 0
    response_user_count = 0

    try:
        stat = path.stat()
    except OSError:
        return None

    try:
        with path.open("r", encoding="utf-8", errors="ignore") as fh:
            for raw in fh:
                raw = raw.strip()
                if not raw:
                    continue
                try:
                    obj = json.loads(raw)
                except json.JSONDecodeError:
                    continue
                typ = obj.get("type")
                payload = obj.get("payload") if isinstance(obj.get("payload"), dict) else {}

                if typ == "session_meta":
                    sid = payload.get("id") or sid
                    cwd = payload.get("cwd") or cwd
                    originator = payload.get("originator") or originator
                    src = payload.get("source")
                    if src:
                        source = f"codex:{src}"
                    continue

                if typ == "turn_context":
                    cwd = payload.get("cwd") or cwd
                    continue

                if typ == "event_msg":
                    ev_type = payload.get("type")
                    msg_text = payload.get("message")
                    if isinstance(msg_text, str) and msg_text.strip():
                        if ev_type == "user_message":
                            event_user_count += 1
                        if ev_type in {"user_message", "agent_message"}:
                            role = "user" if ev_type == "user_message" else "assistant"
                            event_messages.append(Msg(role, msg_text))
                    continue

                if typ != "response_item" or payload.get("type") != "message":
                    continue
                role = payload.get("role")
                text = _codex_content_text(payload.get("content"))
                if role == "developer" and text and not dev_text:
                    dev_text = text
                    continue
                if role not in {"user", "assistant"} or not text.strip():
                    continue
                if role == "user":
                    response_user_count += 1
                response_messages.append(Msg(role, text))
    except OSError:
        return None

    sid = sid or _codex_session_id_from_path(path)
    if not sid:
        return None

    messages = response_messages if response_messages else event_messages
    turn_count = response_user_count if response_user_count else event_user_count
    auto_summary = _codex_auto_summary(dev_text, messages, sid)
    reg = registry_get(sid)
    fork_type = reg.get("fork_type")
    if reg.get("parent_id") and not fork_type:
        fork_type = "convert"

    return Session(
        id=sid,
        jsonl_path=path,
        mtime=datetime.fromtimestamp(stat.st_mtime),
        turn_count=turn_count,
        size_bytes=stat.st_size,
        first_msgs=messages[:3],
        last_msgs=messages[-6:],
        auto_summary=auto_summary,
        cwd=normalize_cwd(cwd),
        source="codex",
        originator=originator or source or "codex",
        custom_name=reg.get("name"),
        parent_id=reg.get("parent_id"),
        fork_type=fork_type,
        ai_summary=reg.get("ai_summary"),
        important=bool(reg.get("important", False)),
        compact_count=0,
        live_turn_count=turn_count,
    )


def scan_codex_sessions(current_cwd: Optional[str], scope_all: bool) -> list[Session]:
    if not CODEX_SESSIONS_DIR.exists():
        return []
    normalized_current = normalize_cwd(current_cwd)
    out: list[Session] = []
    for path in CODEX_SESSIONS_DIR.glob("*/*/*/*.jsonl"):
        if ".bak." in path.name:
            continue
        sess = parse_codex_session(path)
        if not sess:
            continue
        if not scope_all and normalized_current and sess.cwd != normalized_current:
            continue
        out.append(sess)
    return out


def _read_codex_wrapper_states() -> list[dict]:
    """GccSlim wrapper가 남긴 Codex 활성 세션 state 파일을 읽는다.

    Codex는 Claude의 ~/.claude/sessions/<PID>.json 같은 공식 live 파일이 없으므로,
    GccSlim로 띄운 Codex는 /tmp/gccfork-codex-*.state-* 를 truth source로 쓴다.
    """
    states: list[dict] = []
    for state_path in sorted(glob.glob(CODEX_WRAPPER_STATE_GLOB), key=lambda p: os.path.getmtime(p), reverse=True):
        try:
            with open(state_path, "r", encoding="utf-8") as fh:
                data = json.load(fh)
        except Exception:
            continue
        sid = data.get("session_id")
        pid = data.get("codex_pid")
        session_file = data.get("session_file")
        if not isinstance(sid, str) or not sid:
            continue
        if not isinstance(pid, int) or not Path(f"/proc/{pid}").exists():
            continue
        if session_file and not Path(str(session_file)).exists():
            continue
        data["_state_path"] = state_path
        states.append(data)
    return states


def _codex_active_sid_pid_map() -> dict[str, list[int]]:
    out: dict[str, list[int]] = {}
    for data in _read_codex_wrapper_states():
        sid = data.get("session_id")
        pid = data.get("codex_pid")
        if isinstance(sid, str) and isinstance(pid, int):
            out.setdefault(sid, []).append(pid)
    return out


def _find_codex_session_by_id(session_id: str) -> Optional[Session]:
    if not session_id or not CODEX_SESSIONS_DIR.exists():
        return None
    best: Optional[Session] = None
    for path in CODEX_SESSIONS_DIR.glob("*/*/*/*.jsonl"):
        if ".bak." in path.name:
            continue
        if _codex_session_id_from_path(path) != session_id:
            continue
        sess = parse_codex_session(path)
        if not sess:
            continue
        if best is None or sess.mtime > best.mtime:
            best = sess
    return best


def _codex_wrapper_state_for_sid(session_id: str) -> Optional[dict]:
    best: Optional[dict] = None
    for data in _read_codex_wrapper_states():
        if data.get("session_id") != session_id:
            continue
        if best is None or float(data.get("updated_at") or 0) > float(best.get("updated_at") or 0):
            best = data
    return best


def _display_session_id(session: Session) -> str:
    if session.source == "codex":
        return f"~{session.id[-3:]}"
    return session.id[:4]


def _clean_parent_title(title: str) -> str:
    title = re.sub(r"^\[Clone of [a-f0-9]{8}\]\s*", "", title, flags=re.IGNORECASE)
    # 레거시 prefix 포맷: "XXXXXXXX[<= XXXXXXXX] 이름" / "XXXXXXXX 이름"
    title = re.sub(r"^[a-f0-9]{8}(?:\[<= [a-f0-9]{8}\])?\s*", "", title, flags=re.IGNORECASE)
    # 신규 suffix 포맷: "이름 XXXX[<= XXXX]"
    title = re.sub(r"\s*[a-f0-9]{4}\[<=\s*[a-f0-9]{4}\]\s*$", "", title, flags=re.IGNORECASE)
    return title.strip()


def make_new_session_path(parent_path: Path, new_session_id: str, parent_cwd: Optional[str] = None) -> Path:
    """새 세션 jsonl 경로 결정.

    원칙: claude --resume 은 cwd 의 슬러그 폴더에서 jsonl 을 찾으므로,
    새 jsonl 은 **`parent_cwd` 의 슬러그 폴더** 에 둬야 한다 (parent jsonl 이
    이동되어 슬러그가 cwd 와 어긋났을 때 대비).

    parent_cwd 가 None 이거나 슬러그가 다르지 않으면 parent jsonl 의 폴더 그대로.
    """
    if parent_cwd:
        try:
            cwd_slug = cwd_to_slug(parent_cwd)
            cwd_dir = PROJECTS_DIR / cwd_slug
            if cwd_dir != parent_path.parent:
                cwd_dir.mkdir(parents=True, exist_ok=True)
                return cwd_dir / f"{new_session_id}.jsonl"
        except Exception:
            pass
    return parent_path.parent / f"{new_session_id}.jsonl"


def _verify_hard_fork_copy(src_path: Path, dst_path: Path, src_stat_before: os.stat_result) -> None:
    """hard fork jsonl 카피본의 무결성 검증 — 카오스 race 의 *결과* 를 fail-fast.

    검사:
      1. 카피 도중 부모(src) 가 변경됐는지 (size/mtime 변화 = 다른 PID 가 동시 쓰기)
      2. 카피본(dst) 크기가 부모와 비슷한지 (>=95%) — 짧으면 read race 로 줄이 잘린 것

    실패 시 dst 를 즉시 제거하고 ValueError 를 던져 *부분 카피된 좀비 jsonl* 이
    registry 에 기록되는 것을 차단. 호출자는 카오스 정리 후 재시도하면 됨.

    배경: 같은 sid 를 옛 PID 다중이 점유한 카오스 상태에서 hard fork 시
    부모 jsonl 을 카피하던 도중 다른 PID 가 동시 쓰기를 하면 read 가 짧게
    끝나 빈/짧은 자식 jsonl 로 시작되는 사례가 발견됨 (2026-05-02 9ada).
    """
    src_stat_after = src_path.stat()
    dst_size = dst_path.stat().st_size
    src_size_before = src_stat_before.st_size

    if src_stat_after.st_size != src_size_before or src_stat_after.st_mtime_ns != src_stat_before.st_mtime_ns:
        try:
            dst_path.unlink()
        except OSError:
            pass
        raise ValueError(
            f"Hard fork 도중 부모 jsonl 변경됨 "
            f"({src_size_before:,}B → {src_stat_after.st_size:,}B). "
            f"부모 sid 를 점유한 다른 PID 가 동시 쓰기 중입니다. "
            f"점유 PID 종료 후 재시도하세요."
        )

    if src_size_before > 1024 and dst_size < src_size_before * 0.95:
        try:
            dst_path.unlink()
        except OSError:
            pass
        raise ValueError(
            f"Hard fork 카피본 크기 비정상 "
            f"(src={src_size_before:,}B, dst={dst_size:,}B, 비율={dst_size/src_size_before:.1%}). "
            f"카피 read race 의심 — 부모 sid 점유 PID 확인 후 재시도하세요."
        )


def hard_fork_session_with(session: Session, new_session_id: str, custom_name: str) -> Session:
    """new_uuid와 이름을 미리 정해 하드 분기 (ForkNameScreen 모달 연동용).

    본문 로직은 `hard_fork_session`과 동일하되 외부에서 결정한 값을 쓴다.
    """
    # 새 jsonl 은 parent.cwd 의 슬러그 폴더에 둠 (resume 이 거기서 찾음)
    new_path = make_new_session_path(session.jsonl_path, new_session_id, session.cwd)
    if new_path.exists():
        raise ValueError(f"이미 같은 ID 파일이 있습니다: {new_path.name}")

    old_marker = f'"sessionId":"{session.id}"'
    new_marker = f'"sessionId":"{new_session_id}"'
    new_path.parent.mkdir(parents=True, exist_ok=True)
    src_stat_before = session.jsonl_path.stat()
    with NamedTemporaryFile("w", delete=False, dir=new_path.parent, encoding="utf-8") as handle:
        tmp_path = Path(handle.name)
        with session.jsonl_path.open("r", encoding="utf-8") as fin:
            for line in fin:
                handle.write(line.replace(old_marker, new_marker))
    try:
        os.replace(tmp_path, new_path)
    except Exception:
        if tmp_path.exists():
            tmp_path.unlink()
        raise

    _verify_hard_fork_copy(session.jsonl_path, new_path, src_stat_before)

    clone_name = (custom_name or f"{new_session_id[:4]}[<= {session.id[:4]}]").strip()[:120]
    # 안전 가드 §7 — source 가 병합 결과면 마커 남김 (UnmergeConfirmScreen 안내용).
    src_entry = registry_get(session.id) or {}
    src_is_merged = bool(src_entry.get("is_merged"))
    extra: dict = {}
    if src_is_merged:
        extra["forked_from_merged"] = session.id
    registry_set(
        new_session_id,
        parent_id=session.id,
        fork_type="hard",
        name=clone_name,
        **extra,
    )

    cloned = parse_session(new_path)
    if not cloned:
        raise ValueError("복제한 세션을 다시 읽지 못했습니다.")
    cloned.custom_name = clone_name
    cloned.parent_id = session.id
    cloned.fork_type = "hard"
    return cloned


def _make_codex_clone_path(source_path: Path, source_sid: str, new_sid: str) -> Path:
    if source_sid in source_path.name:
        return source_path.with_name(source_path.name.replace(source_sid, new_sid, 1))
    return source_path.with_name(f"{source_path.stem}-{new_sid}.jsonl")


def _rewrite_codex_session_meta_line(raw: str, source_sid: str, new_sid: str) -> str:
    try:
        obj = json.loads(raw)
    except Exception:
        return raw
    if obj.get("type") != "session_meta":
        return raw
    payload = obj.get("payload")
    if not isinstance(payload, dict) or payload.get("id") != source_sid:
        return raw
    obj = dict(obj)
    payload = dict(payload)
    payload["id"] = new_sid
    payload["cloned_from_session_id"] = source_sid
    payload["cloned_by"] = "gccfork-hard-fork"
    obj["payload"] = payload
    return json.dumps(obj, ensure_ascii=False, separators=(",", ":")) + "\n"


def hard_fork_codex_session_with(session: Session, new_session_id: str, custom_name: str) -> Session:
    """Codex JSONL 하드 복제.

    Codex는 Claude의 `"sessionId"` 반복 마커가 아니라 첫 `session_meta.payload.id`
    를 세션 식별자로 사용하므로, 파일명과 session_meta id만 새 sid로 바꾼다.
    """
    new_path = _make_codex_clone_path(session.jsonl_path, session.id, new_session_id)
    if new_path.exists():
        raise ValueError(f"이미 같은 ID 파일이 있습니다: {new_path.name}")

    new_path.parent.mkdir(parents=True, exist_ok=True)
    src_stat_before = session.jsonl_path.stat()
    with NamedTemporaryFile("w", delete=False, dir=new_path.parent, encoding="utf-8") as handle:
        tmp_path = Path(handle.name)
        with session.jsonl_path.open("r", encoding="utf-8", errors="ignore") as fin:
            for line in fin:
                handle.write(_rewrite_codex_session_meta_line(line, session.id, new_session_id))
    try:
        os.replace(tmp_path, new_path)
    except Exception:
        if tmp_path.exists():
            tmp_path.unlink()
        raise

    _verify_hard_fork_copy(session.jsonl_path, new_path, src_stat_before)

    clone_name = (custom_name or f"~{new_session_id[-4:]}[<= ~{session.id[-4:]}]").strip()[:120]
    registry_set(
        new_session_id,
        parent_id=session.id,
        fork_type="hard",
        name=clone_name,
        source_cli="codex",
        source_session_id=session.id,
        source_jsonl=str(session.jsonl_path),
    )

    cloned = parse_codex_session(new_path)
    if not cloned:
        raise ValueError("복제한 Codex 세션을 다시 읽지 못했습니다.")
    cloned.custom_name = clone_name
    cloned.parent_id = session.id
    cloned.fork_type = "hard"
    cloned.source = "codex"
    return cloned


def _gccfork_repo_dir() -> Path:
    candidates: list[Path] = []
    env_repo = os.environ.get("GCCFORK_REPO_DIR")
    if env_repo:
        candidates.append(Path(env_repo).expanduser())
    here = Path(__file__).resolve()
    candidates.extend([
        here.parent.parent,
        Path.home(),
        Path.home() / "Projects" / "GccSlim",
    ])
    for cand in candidates:
        if (cand / "src" / "gccfork" / "codex_slim_reload.py").is_file():
            return cand
    return here.parent.parent


def _load_codex_slim_reload_module():
    import importlib.util

    sidecar_path = Path(__file__).resolve().parent / "gccfork_codex_slim_reload.py"
    module_path = _gccfork_repo_dir() / "src" / "gccfork" / "codex_slim_reload.py"
    if not module_path.is_file() and sidecar_path.is_file():
        module_path = sidecar_path
    if not module_path.is_file():
        raise FileNotFoundError(f"Codex slim module not found: {module_path}")
    spec = importlib.util.spec_from_file_location("_gccfork_codex_slim_reload", module_path)
    if spec is None or spec.loader is None:
        raise ImportError(f"Codex slim module load failed: {module_path}")
    module = importlib.util.module_from_spec(spec)
    sys.modules["_gccfork_codex_slim_reload"] = module
    spec.loader.exec_module(module)
    return module


def _write_codex_slim_restart_marker(
    *,
    session_id: str,
    session_file: Path,
    cwd: Optional[str],
    mode: str,
    keep_recent: int,
    source_pid: int,
    wrapper_id: Optional[str],
) -> None:
    payload = {
        "request_id": f"gccfork-tui-codex-slim-{uuid_lib.uuid4().hex[:10]}",
        "session_id": session_id,
        "session_file": str(session_file),
        "cwd": cwd,
        "mode": mode,
        "keep_recent": keep_recent,
        "created_at": time.time(),
        "source_pid": source_pid,
        "wrapper_id": wrapper_id,
    }
    tmp = CODEX_SLIM_MARKER_PATH.with_name(CODEX_SLIM_MARKER_PATH.name + f".tmp-{os.getpid()}")
    tmp.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    os.replace(tmp, CODEX_SLIM_MARKER_PATH)


def slim_codex_session_with(
    session: Session,
    *,
    mode: str,
    keep_recent: Optional[int],
    clone: bool,
    include_compact_summaries: bool = True,
    custom_name: Optional[str] = None,
) -> dict:
    module = _load_codex_slim_reload_module()
    plan = module.build_slim_plan(
        session.jsonl_path,
        mode=mode,
        keep_recent=keep_recent,
        codex_root=Path.home() / ".codex",
        include_compact_summaries=include_compact_summaries,
    )
    if clone:
        clone_result = module.apply_slim_plan_to_new_session(plan)
        new_sid = str(clone_result.cloned_session_id)
        clone_name = (
            custom_name.replace("????", new_sid[-4:]) if custom_name
            else f"{_clean_parent_title(session.title)} 🔻~{new_sid[-4:]}[<= ~{session.id[-4:]}]"
        ).strip()[:120]
        registry_set(
            new_sid,
            parent_id=session.id,
            fork_type="slim",
            name=clone_name,
            source_cli="codex",
            source_session_id=session.id,
            source_jsonl=str(session.jsonl_path),
        )
        cloned = parse_codex_session(Path(clone_result.cloned_file))
        if cloned:
            cloned.custom_name = clone_name
            cloned.parent_id = session.id
            cloned.fork_type = "slim"
        return {
            "sid": new_sid,
            "path": str(clone_result.cloned_file),
            "session": cloned,
            "backup": None,
            "old_size": plan.original_bytes,
            "new_size": clone_result.cloned_bytes,
            "old_lines": plan.original_lines,
            "new_lines": clone_result.cloned_lines,
            "saved_bytes": plan.original_bytes - clone_result.cloned_bytes,
            "saved_percent": (plan.original_bytes - clone_result.cloned_bytes) * 100.0 / max(plan.original_bytes, 1),
            "mode": plan.mode,
            "keep_recent": plan.keep_recent,
            "compact_summary_count": getattr(plan, "compact_summary_count", 0),
            "clone": True,
        }

    module.apply_slim_plan(plan)
    slimmed = parse_codex_session(session.jsonl_path)
    return {
        "sid": plan.session_id,
        "path": str(plan.session_file),
        "session": slimmed,
        "backup": str(plan.backup_path),
        "old_size": plan.original_bytes,
        "new_size": plan.slim_bytes,
        "old_lines": plan.original_lines,
        "new_lines": plan.slim_lines,
        "saved_bytes": plan.saved_bytes,
        "saved_percent": plan.saved_percent,
        "mode": plan.mode,
        "keep_recent": plan.keep_recent,
        "compact_summary_count": getattr(plan, "compact_summary_count", 0),
        "clone": False,
    }


def detect_compact_marker_index(jsonl_path: Path) -> Optional[int]:
    """jsonl 에서 마지막 isCompactSummary 마커의 라인 인덱스 반환.

    여러 번 압축됐을 수도 있는데 Claude resume 은 **마지막 마커** 만 본다.
    """
    last_idx = None
    try:
        with jsonl_path.open("r", encoding="utf-8", errors="ignore") as fh:
            for i, raw in enumerate(fh):
                try:
                    obj = json.loads(raw)
                except json.JSONDecodeError:
                    continue
                if obj.get("isCompactSummary") is True:
                    last_idx = i
    except OSError:
        pass
    return last_idx


def _call_rust_slim_general(
    *,
    jsonl_path: Path,
    sid: str,
    mode: str,
    keep_recent_turns: int = 0,
    keep_recent_lines: int = 0,
    backup: bool = True,
) -> dict:
    """일반 슬림 (verdict 기반) — Rust subprocess 위임.

    Phase E-7 (2026-05-06) 부터 Python verdict 본체 archive — Rust 단일 강제.
    """
    import subprocess
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim 바이너리 없음: {rust_bin}\n"
            "Phase E-7 부터 일반 슬림도 Rust 필수."
        )
    cmd = [
        str(rust_bin),
        "--jsonl", str(jsonl_path),
        "--mode", mode,
        "--skip-security", "--no-preflight", "--json",
    ]
    if keep_recent_turns:
        cmd.extend(["--keep-recent", str(keep_recent_turns)])
    elif keep_recent_lines:
        cmd.extend(["--keep-recent", str(keep_recent_lines)])
    if not backup:
        cmd.append("--no-backup")
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode != 0:
        raise RuntimeError(f"Rust slim 실패 (exit {res.returncode}):\n{res.stderr}")
    rust_result = json.loads(res.stdout)
    return {
        "sid": rust_result.get("sid", sid),
        "path": str(jsonl_path),
        "marker_idx": rust_result.get("marker_idx"),
        "pre_kept": rust_result.get("pre_kept", 0),
        "kept": rust_result.get("kept", 0),
        "stubbed": rust_result.get("stubbed", 0),
        "dropped": rust_result.get("dropped", 0),
        "rebinded": rust_result.get("rebinded", 0),
        "old_size": int(rust_result.get("old_kb", 0) * 1024),
        "new_size": int(rust_result.get("new_kb", 0) * 1024),
        "ratio_pct": 100.0 - rust_result.get("saved_pct", 0),
        "mode": mode,
        "in_place": True,
        "backup": rust_result.get("backup"),
        "committed": True,
    }


def _call_rust_unfold_inplace(
    *,
    session: "Session",
    keep_recent_turns_last: int = 5,
    mode: str = "strong",
) -> dict:
    """🪚 해제 in-place — Rust subprocess (gccfork-slim --unfold-inplace).

    Phase E (2026-05-06) — Python unfold_session archive,
    Rust 가 segment 차등 슬림 + atomic write 담당.
    """
    import subprocess
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim 바이너리 없음: {rust_bin}\n"
            "Phase E 부터 🪚 해제는 Rust 필수."
        )
    cmd = [
        str(rust_bin),
        "--jsonl", str(session.jsonl_path),
        "--mode", mode,
        "--unfold-inplace",
        "--keep-recent-turns", str(keep_recent_turns_last),
        "--skip-security", "--no-preflight", "--json",
    ]
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode == 2:
        # EXIT_INPUT — NoCompactionFound
        raise ValueError(f"🪚 {session.id[:8]} — auto-compact 마커 0개. 해제할 게 없음.")
    if res.returncode != 0:
        raise RuntimeError(f"Rust unfold-inplace 실패 (exit {res.returncode}):\n{res.stderr}")
    rust_result = json.loads(res.stdout)
    return {
        "sid": rust_result.get("sid", session.id),
        "bytes_before": int(rust_result.get("old_kb", 0) * 1024),
        "bytes_after": int(rust_result.get("new_kb", 0) * 1024),
        "n_segments": rust_result.get("n_segments", 0),
        "n_markers": rust_result.get("n_markers", 0),
        "kept": rust_result.get("kept", 0),
        "dropped": rust_result.get("dropped", 0),
        "elapsed_sec": rust_result.get("elapsed_ms", 0) / 1000.0,
        "backup_path": Path(rust_result["backup"]) if rust_result.get("backup") else None,
    }


def _call_rust_unfold_bundle(
    *,
    session: "Session",
    keep_recent_turns: int = 5,
    mode: str = "strong",
) -> dict:
    """🪚 번들 해제 — Rust subprocess (gccfork-slim --anti-frag --unfold-bundle).

    Phase E (2026-05-06) 부터 Python bundle_unfold_session archive,
    Rust 가 fork (새 sid + 새 jsonl 복사 후 처리) + registry 등록 담당.
    """
    import subprocess, uuid, shutil
    from gccfork_sessions import registry_set
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim 바이너리 없음: {rust_bin}\n"
            "Phase E 부터 🪚 번들 해제는 Rust 필수. install.sh 재실행 또는 "
            "bin/_archive_2026-05-06_phase_e_python/ 부활."
        )

    # 1. 새 sid 생성 + jsonl 복사 (fork)
    new_sid = str(uuid.uuid4())
    new_path = session.jsonl_path.parent / f"{new_sid}.jsonl"
    shutil.copy2(str(session.jsonl_path), str(new_path))

    # 2. Rust subprocess — preserve_markers=false (마커 무시 → 전체 bundle)
    cmd = [
        str(rust_bin),
        "--jsonl", str(new_path),
        "--mode", mode,
        "--anti-frag", "--unfold-bundle",
        "--keep-recent-turns", str(keep_recent_turns),
        "--no-backup",
        "--skip-security", "--no-preflight", "--json",
    ]
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode != 0:
        try: new_path.unlink()
        except Exception: pass
        raise RuntimeError(f"Rust unfold-bundle 실패 (exit {res.returncode}):\n{res.stderr}")
    rust_result = json.loads(res.stdout)

    # 3. 새 jsonl 의 sessionId 필드를 새 sid 로 치환
    #    (Rust 가 detect 한 sid 가 원본 — fork 후 새 sid 로 갱신)
    import re
    sid_re = re.compile(r'"sessionId":\s*"[^"]+"')
    new_marker = f'"sessionId":"{new_sid}"'
    content = new_path.read_text(encoding="utf-8")
    content = sid_re.sub(new_marker, content)
    new_path.write_text(content, encoding="utf-8")

    # 4. registry 등록 — parent = 원본
    parent_name = (session.custom_name or session.id[:4])
    registry_set(
        new_sid,
        parent_id=session.id,
        fork_type="hard",
        name=f"{parent_name} 🪚 번들[<= {session.id[:4]}]",
    )

    return {
        "new_sid": new_sid,
        "new_jsonl_path": new_path,
        "bytes_before": int(rust_result.get("old_kb", 0) * 1024),
        "bytes_after": int(rust_result.get("new_kb", 0) * 1024),
        "n_bundles": rust_result.get("n_bundles", 0),
        "n_recent": rust_result.get("n_recent", 0),
        "elapsed_sec": rust_result.get("elapsed_ms", 0) / 1000.0,
    }


def _call_rust_anti_frag(
    *,
    jsonl_path: Path,
    sid: str,
    mode: str,
    keep_recent_turns: int,
    backup: bool,
    dynamic_cap: bool,
    visible_cap: int = 0,
) -> dict:
    """Rust gccfork-slim --anti-frag 호출 wrapper.

    Phase D 에서 anti-frag + dynamic_cap 알고리즘 100% Rust 화.
    Python 본체는 bin/_archive_2026-05-06_phase_d_python/ 으로 archive.

    Returns dict — Python `slim_anti_frag_session` 와 같은 형태:
      bytes_before, bytes_after, kept, dropped, n_bundles, n_recent,
      effective_trim, dynamic_cap, backup_path, sid, jsonl_path, in_place.
    """
    import subprocess
    rust_bin = Path.home() / ".local/bin/gccfork-slim"
    if not rust_bin.is_file():
        raise FileNotFoundError(
            f"Rust gccfork-slim 바이너리 없음: {rust_bin}\n"
            f"(Phase D 부터 anti-frag 는 Rust 가 처리. install.sh 재실행 또는 "
            f"GCCFORK_DISABLE_RUST=1 + bin/_archive_2026-05-06_phase_d_python/ 부활)"
        )
    cmd = [
        str(rust_bin),
        "--jsonl", str(jsonl_path),
        "--mode", mode,
        "--anti-frag",
        "--keep-recent-turns", str(keep_recent_turns),
        "--skip-security",
        "--no-preflight",
        "--json",
    ]
    if not backup:
        cmd.append("--no-backup")
    if not dynamic_cap:
        cmd.append("--no-dynamic-cap")
    if visible_cap > 0:
        cmd.extend(["--visible-cap", str(visible_cap)])
    res = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if res.returncode != 0:
        raise RuntimeError(
            f"Rust anti-frag 실패 (exit {res.returncode}):\n{res.stderr}"
        )
    rust_result = json.loads(res.stdout)
    # Rust 출력 → Python 호환 dict 변환
    return {
        "in_place": True,
        "sid": rust_result.get("sid", sid),
        "jsonl_path": jsonl_path,
        "bytes_before": int(rust_result.get("old_kb", 0) * 1024),
        "bytes_after": int(rust_result.get("new_kb", 0) * 1024),
        "kept": rust_result.get("kept", 0),
        "dropped": rust_result.get("dropped", 0),
        "n_bundles": rust_result.get("n_bundles", 0),
        "n_recent": rust_result.get("n_recent", 0),
        "elapsed_sec": rust_result.get("elapsed_ms", 0) / 1000.0,
        "backup_path": Path(rust_result["backup"]) if rust_result.get("backup") else None,
        "dynamic_cap": rust_result.get("dynamic_cap", dynamic_cap),
        "effective_trim": rust_result.get("effective_trim", 0),
    }


def slim_fork_session_with(
    session: Session,
    new_session_id: str,
    custom_name: str,
    mode: str,
    *,
    in_place: bool = False,
    backup: bool = True,
    keep_recent_lines: int = 0,
    keep_recent_turns: int = 0,
    visible_cap: int = 0,
    dry_run: bool = False,
    defer_commit: bool = False,
    anti_fragmentation: bool = False,
) -> "Session | dict":
    """🔻 슬림 — 마커 인지 2-pass 슬림 (fork 또는 in-place).

    [실측 정책 — 사용자 검증]
      Claude Code 는 resume 시 마지막 isCompactSummary 마커 이후만 컨텍스트로 보냄.
      마커 이전은 archive 로 보존되되 토큰화 안 됨. 따라서:
        - 마커 전 라인 = 모두 KEEP_AS_IS (sessionId 만 치환). archive 보존.
        - 마커 라인 자체 = 항상 KEEP (verdict 첫 분기).
        - 마커 후 라인 = verdict (KEEP/STUB/DROP). 컨텍스트 절약 효과.

    압축 안 된 세션은 marker_idx=None → 전체가 마커 후 취급.

    mode: "strong" | "medium" | "weak"

    in_place=True:
        같은 sid 유지. 원본 jsonl 을 atomic os.replace 로 덮음. registry/
        parse_session 호출 안 함 (새 세션 등록 X). backup=True 면 .bak.<ts>.jsonl
        자동 생성. 반환은 stats dict (Session 대신).

    keep_recent_lines (>0):
        파일 마지막 N 라인은 무조건 KEEP_AS_IS — in-place 안전 가드 (현재
        활성 작업 영역 보호). 0 이면 무시.

    keep_recent_turns (>0):
        파일 끝에서부터 N 번째 user 메시지 (= 1턴) 부터 마지막까지 모두
        KEEP_AS_IS. `keep_recent_lines` 보다 우선. 1턴 ≈ 5~15 라인 변동을
        흡수해 사용자가 의도한 "최근 N턴 보호" 의미 그대로 작동.
        0 이면 무시 (keep_recent_lines 폴백).

    dry_run=True:
        임시 파일에 슬림 결과 만든 뒤 stats 만 계산하고 cleanup. 원본/registry
        변경 X. fork/in-place 양쪽 모두 사용 가능.
    """
    from gccfork_settings import SLIM_MODE_ALIASES

    # 옛 키 (strict/balanced/loose) → 새 키 (strong/medium/weak) 마이그레이션
    mode = SLIM_MODE_ALIASES.get(mode, mode)
    if mode not in {"strong", "medium", "weak"}:
        raise ValueError(f"Unknown slim mode: {mode}")

    # 번들(묶음) 처리 모드 — Phase D Rust 화 (2026-05-06).
    # Python 본체는 bin/_archive_2026-05-06_phase_d_python/ 으로 archive.
    # 호출은 ~/.local/bin/gccfork-slim --anti-frag --json subprocess.
    if anti_fragmentation and not dry_run:
        try:
            dynamic_cap = bool(pref_get("slim_default_dynamic_cap", True))
        except Exception:
            dynamic_cap = True
        # in_place=False (fork 모드) 는 Rust 가 미지원 — 현재 사용 X 라 raise
        if not in_place:
            raise NotImplementedError(
                "anti-frag fork 모드는 Rust 미지원. in_place=True 로만 호출하세요."
            )
        result = _call_rust_anti_frag(
            jsonl_path=session.jsonl_path,
            sid=session.id,
            mode=mode,
            keep_recent_turns=keep_recent_turns or 5,
            backup=backup,
            dynamic_cap=dynamic_cap,
            visible_cap=visible_cap,
        )
        if in_place:
            return result
        # fork 모드 — 새 세션 등록 후 Session 객체 반환
        registry_set(
            new_session_id,
            parent_id=session.id,
            fork_type="slim",
            name=custom_name or f"🔻[<= {session.id[:4]}]",
        )
        cloned = parse_session(result["jsonl_path"])
        if not cloned:
            raise ValueError("번들(묶음) 처리 슬림 결과를 다시 읽지 못했습니다.")
        cloned.custom_name = custom_name
        cloned.parent_id = session.id
        cloned.fork_type = "slim"
        return cloned
    # Phase E-7 (2026-05-06) — verdict 기반 일반 슬림 Python 본체 archive.
    # Rust gccfork-slim 이 단일 처리. fork 모드는 Rust 미지원 → deprecated.
    if not in_place:
        raise NotImplementedError(
            "fork 모드 (in_place=False) 는 Phase E-7 부터 Rust 미지원으로 deprecated. "
            "in_place=True 로 호출하세요. (TUI 의 모든 슬림 호출은 이미 in-place)"
        )

    if dry_run:
        # dry-run 도 Rust 가 처리 — gccfork-slim --dry-run flag (현재 미구현 시 보류)
        # 임시 단순 통계: 파일 크기만 반환
        old_size = session.jsonl_path.stat().st_size
        return {
            "sid": session.id, "path": str(session.jsonl_path),
            "marker_idx": detect_compact_marker_index(session.jsonl_path),
            "kept": 0, "stubbed": 0, "dropped": 0, "rebinded": 0,
            "old_size": old_size, "new_size": old_size,
            "ratio_pct": 100.0, "mode": mode, "in_place": True, "dry_run": True,
        }

    # 일반 in-place 슬림 — Rust subprocess 위임
    return _call_rust_slim_general(
        jsonl_path=session.jsonl_path,
        sid=session.id,
        mode=mode,
        keep_recent_turns=keep_recent_turns or 0,
        keep_recent_lines=keep_recent_lines or 0,
        backup=backup,
    )



def hard_fork_session(session: Session) -> Session:
    """Claude Code 세션 하드 분기.

    방식:
      1. 원본 jsonl을 줄 단위로 읽어
      2. 각 줄에 반복되는 `"sessionId":"<old>"` 마커를 `"sessionId":"<new>"`로 치환
      3. 같은 슬러그 폴더에 `<new_uuid>.jsonl`로 저장
      4. 레지스트리에 parent_id/fork_type="hard"/clone name 기록

    본문에 우연히 등장한 UUID 문자열은 `"sessionId":"` 접두사 매칭이라 영향 없음.
    `--fork-session`이 유도하는 auto-compact를 완전히 우회 → 883턴 20MB 세션도
    100% 보존된 채 resume 가능.
    """
    new_session_id = str(uuid_lib.uuid4())
    new_path = make_new_session_path(session.jsonl_path, new_session_id, session.cwd)
    if new_path.exists():
        raise ValueError(f"이미 같은 ID 파일이 있습니다: {new_path.name}")

    old_marker = f'"sessionId":"{session.id}"'
    new_marker = f'"sessionId":"{new_session_id}"'

    new_path.parent.mkdir(parents=True, exist_ok=True)
    src_stat_before = session.jsonl_path.stat()
    with NamedTemporaryFile("w", delete=False, dir=new_path.parent, encoding="utf-8") as handle:
        tmp_path = Path(handle.name)
        with session.jsonl_path.open("r", encoding="utf-8") as fin:
            for line in fin:
                handle.write(line.replace(old_marker, new_marker))

    try:
        os.replace(tmp_path, new_path)
    except Exception:
        if tmp_path.exists():
            tmp_path.unlink()
        raise

    _verify_hard_fork_copy(session.jsonl_path, new_path, src_stat_before)

    parent_title = _clean_parent_title(session.title)
    suffix = f"{new_session_id[:4]}[<= {session.id[:4]}]"
    clone_name = (f"{parent_title} {suffix}" if parent_title else suffix).strip()[:120]
    registry_set(new_session_id, parent_id=session.id, fork_type="hard", name=clone_name)

    cloned = parse_session(new_path)
    if not cloned:
        raise ValueError("복제한 세션을 다시 읽지 못했습니다.")
    cloned.custom_name = clone_name
    cloned.parent_id = session.id
    cloned.fork_type = "hard"
    return cloned


def snapshot_session_ids() -> set[str]:
    ids: set[str] = set()
    if not PROJECTS_DIR.exists():
        return ids
    for jsonl in PROJECTS_DIR.glob("*/*.jsonl"):
        sid = extract_session_id_from_path(jsonl)
        if sid:
            ids.add(sid)
    return ids


def find_newest_new_session(before_ids: set[str]) -> Optional[Session]:
    candidates: list[Session] = []
    for session in scan_sessions(current_cwd=None, scope_all=True):
        if session.id not in before_ids:
            candidates.append(session)
    if not candidates:
        return None
    return max(candidates, key=lambda item: item.mtime)


def find_claude_pids_for_session_id(session_id: str) -> list[int]:
    """sid → 활성 claude PID 들 — sessions/<PID>.json 이 truth source.

    포크_ccfork.md 핵심 원칙: cmdline / mtime / fd / env 기반 추측은 부정확.
    claude code 가 resume 후 sessionId 갈아치우는 케이스에서 cmdline 매치는
    잘못된 PID 잡음 (실제 활성 sid 와 시작 명령의 sid 가 다름).

    이 함수는 `gccfork_sessions.find_live_pids_by_sid` 의 thin wrapper —
    호환성 유지용. 새 코드는 직접 헬퍼 호출 권장.
    """
    return find_live_pids_by_sid(session_id) if session_id else []


def _is_claude_cmdline(cmdline: str) -> bool:
    """`claude` CLI 프로세스 식별.

    Claude Code는 `node /usr/lib/node_modules/@anthropic-ai/claude-code/cli.js`
    형태로 실행되므로, cmdline에 `claude-code/cli.js` 또는 argv[0]가 `claude`로
    끝나는 경우 매칭.
    """
    if not cmdline:
        return False
    if "claude-code/cli.js" in cmdline:
        return True
    if "@anthropic-ai/claude-code" in cmdline:
        return True
    first_arg = cmdline.split(" ", 1)[0]
    name = Path(first_arg).name
    return name == "claude" or first_arg.endswith("/claude")


def find_claude_processes_for_session(
    session_id: str,
    cwd: Optional[str] = None,
    jsonl_path: Optional[Path] = None,
) -> list[dict]:
    results = []
    proc_root = Path("/proc")
    if not proc_root.exists():
        return results

    session_start_ts = None
    jsonl_mtime = None
    if jsonl_path and jsonl_path.exists():
        try:
            jsonl_mtime = jsonl_path.stat().st_mtime
        except OSError:
            jsonl_mtime = None
        try:
            with jsonl_path.open("r", encoding="utf-8") as handle:
                for index, raw in enumerate(handle):
                    if index > 30:
                        break
                    try:
                        obj = json.loads(raw)
                    except json.JSONDecodeError:
                        continue
                    ts = obj.get("timestamp")
                    if isinstance(ts, str):
                        session_start_ts = datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
                        break
        except OSError:
            pass

    now = time.time()
    mtime_age = (now - jsonl_mtime) if jsonl_mtime else None
    target_cwd = normalize_cwd(cwd)

    for pid_dir in proc_root.iterdir():
        if not pid_dir.name.isdigit():
            continue
        try:
            cmdline_raw = (pid_dir / "cmdline").read_bytes().decode("utf-8", errors="ignore")
            cmdline = cmdline_raw.replace("\x00", " ").strip()
            if not _is_claude_cmdline(cmdline):
                continue

            try:
                proc_cwd = normalize_cwd((pid_dir / "cwd").resolve().as_posix())
            except Exception:
                proc_cwd = None
            try:
                tty = (pid_dir / "fd" / "0").resolve().as_posix()
                if not tty.startswith("/dev/pts") and not tty.startswith("/dev/tty"):
                    tty = ""
            except Exception:
                tty = ""
            try:
                proc_start = (pid_dir / "status").stat().st_mtime
            except OSError:
                proc_start = 0.0

            confidence = None
            birth_delta = None
            if session_id in cmdline:
                confidence = "exact"
            elif target_cwd and proc_cwd == target_cwd:
                if session_start_ts and proc_start:
                    birth_delta = abs(proc_start - session_start_ts)
                    if birth_delta <= 15.0:
                        confidence = "birth"
                if not confidence and jsonl_mtime and mtime_age is not None and mtime_age < 60:
                    if proc_start and proc_start < jsonl_mtime:
                        confidence = "recent"
                if not confidence:
                    confidence = "cwd"
            elif target_cwd and proc_cwd and proc_cwd.startswith(target_cwd + "/"):
                confidence = "cwd-sub"
            else:
                continue

            results.append({
                "pid": int(pid_dir.name),
                "tty": tty,
                "cwd": proc_cwd,
                "cmdline": cmdline[:120],
                "confidence": confidence,
                "proc_start": proc_start,
                "age_sec": int(now - proc_start) if proc_start else -1,
                "birth_delta": birth_delta,
            })
        except (OSError, PermissionError):
            continue

    order = {"exact": 0, "birth": 1, "recent": 2, "cwd": 3, "cwd-sub": 4}
    results.sort(key=lambda item: (order.get(item["confidence"], 9), item.get("birth_delta") or 9999))
    return results


def _session_from_proc_fds(pid: int) -> Optional[Session]:
    fd_dir = Path("/proc") / str(pid) / "fd"
    if not fd_dir.exists():
        return None
    for fd in fd_dir.iterdir():
        try:
            target = fd.resolve()
        except Exception:
            continue
        try:
            target_str = target.as_posix()
        except Exception:
            continue
        if not target_str.startswith(PROJECTS_DIR.as_posix() + "/") or target.suffix != ".jsonl":
            continue
        session = parse_session(target)
        if session:
            return session
    return None


def _session_from_cmdline(cmdline: str) -> Optional[Session]:
    for match in UUID_ANY_RE.finditer(cmdline):
        session = find_session_by_id(match.group(1))
        if session:
            return session
    return None


def _infer_process_session(
    proc: dict,
    target_session: Session,
    same_cwd_sessions: list[Session],
) -> Optional[Session]:
    session = _session_from_proc_fds(proc["pid"])
    if session:
        return session

    session = _session_from_cmdline(proc.get("cmdline", ""))
    if session:
        return session

    if proc.get("confidence") in {"exact", "birth", "recent"}:
        return target_session

    candidates = [item for item in same_cwd_sessions if item.id != target_session.id]
    proc_start = proc.get("proc_start")
    if proc_start and candidates:
        nearest = min(candidates, key=lambda item: abs(item.mtime.timestamp() - proc_start))
        if abs(nearest.mtime.timestamp() - proc_start) <= 86400:
            return nearest

    if proc.get("cwd") == target_session.cwd:
        return target_session
    return None


def _apply_confirm_text_theme(
    screen: ModalScreen,
    display_text: str,
    bullet_sessions: dict[int, str],
) -> None:
    try:
        text_area = screen.query_one("#confirm-text", TextArea)
    except Exception:
        return

    app_theme = screen.app.current_theme
    accent = Color.parse(app_theme.accent or app_theme.primary)
    surface = Color.parse(app_theme.surface or app_theme.background or "#202020")
    foreground = Color.parse(app_theme.foreground or "#f3f3f3")
    summary_bg = surface.blend(accent, 0.22)
    syntax_styles = {
        "confirm-summary-row": Style(
            bgcolor=summary_bg.rich_color,
            color=foreground.rich_color,
        )
    }
    syntax_styles.update(
        {
            f"session-color-{index}": Style(color=color, bold=True)
            for index, color in enumerate(_COLOR_STYLES)
        }
    )

    theme = TextAreaTheme(
        name="gccfork-confirm-text",
        cursor_line_style=Style(
            bgcolor=summary_bg.rich_color,
            color=foreground.rich_color,
        ),
        syntax_styles=syntax_styles,
    )
    text_area.register_theme(theme)
    text_area.theme = "gccfork-confirm-text"

    lines = display_text.splitlines()
    highlights: defaultdict[int, list[tuple[int, int, str]]] = defaultdict(list)
    for row in range(min(2, len(lines))):
        line_end = len(lines[row].encode("utf-8"))
        if line_end:
            highlights[row].append((0, line_end, "confirm-summary-row"))

    for row, session_id in bullet_sessions.items():
        if row >= len(lines):
            continue
        bullet_index = lines[row].find("●")
        if bullet_index < 0:
            continue
        start = len(lines[row][:bullet_index].encode("utf-8"))
        end = len(lines[row][: bullet_index + 1].encode("utf-8"))
        highlights[row].append((start, end, f"session-color-{_color_index_for_session(session_id)}"))

    text_area._highlights = highlights
    text_area._line_cache.clear()
    text_area.refresh()


def _configure_confirm_screen(
    screen: ModalScreen,
    message: str,
    bullet_sessions: dict[int, str],
) -> None:
    try:
        confirm_box = screen.query_one("#confirm-box", Vertical)
        text_area = screen.query_one("#confirm-text", TextArea)
    except Exception:
        return

    raw_lines = message.splitlines() or [""]
    screen_width = screen.size.width or 100
    max_line_width = max(cell_len(line) for line in raw_lines)
    desired_box_width = min(max(56, max_line_width + 6), max(40, screen_width - 4))
    confirm_box.styles.width = desired_box_width

    def finalize() -> None:
        content_width = max(20, (text_area.size.width or desired_box_width) - 2)
        display_lines = list(raw_lines)
        for row in range(min(2, len(display_lines))):
            pad = max(0, content_width - cell_len(display_lines[row]))
            if pad:
                display_lines[row] = display_lines[row] + (" " * pad)
        display_text = "\n".join(display_lines)
        text_area.load_text(display_text)
        wrapped_height = sum(max(1, math.ceil(cell_len(line) / content_width)) for line in display_lines)
        text_area.styles.height = max(3, wrapped_height)
        _apply_confirm_text_theme(screen, display_text, bullet_sessions)

    screen.call_after_refresh(finalize)


def _apply_bullet_highlights(text_area: TextArea, display_text: str, bullet_sessions: dict[int, str]) -> None:
    app_theme = text_area.app.current_theme
    syntax_styles = {
        f"session-color-{index}": Style(color=color, bold=True)
        for index, color in enumerate(_COLOR_STYLES)
    }
    theme = TextAreaTheme(
        name="gccfork-bullet-text",
        cursor_line_style=Style(
            bgcolor=Color.parse(app_theme.accent or app_theme.primary).blend(
                Color.parse(app_theme.surface or app_theme.background or "#202020"), 0.15
            ).rich_color,
            color=Color.parse(app_theme.foreground or "#f3f3f3").rich_color,
        ),
        syntax_styles=syntax_styles,
    )
    text_area.register_theme(theme)
    text_area.theme = "gccfork-bullet-text"

    lines = display_text.splitlines()
    highlights: defaultdict[int, list[tuple[int, int, str]]] = defaultdict(list)
    for row, session_id in bullet_sessions.items():
        if row >= len(lines):
            continue
        bullet_index = lines[row].find("●")
        if bullet_index < 0:
            continue
        start = len(lines[row][:bullet_index].encode("utf-8"))
        end = len(lines[row][: bullet_index + 1].encode("utf-8"))
        highlights[row].append((start, end, f"session-color-{_color_index_for_session(session_id)}"))
    text_area._highlights = highlights
    text_area._line_cache.clear()
    text_area.refresh()


class RenameScreen(ModalScreen[Optional[str]]):
    def __init__(self, current_name: str = "") -> None:
        super().__init__()
        self.current_name = current_name

    def compose(self) -> ComposeResult:
        with Vertical(id="rename-box"):
            yield Label("세션 이름 지정 (빈 값 → 이름 삭제):")
            yield Input(value=self.current_name, id="rename-input")
            with Horizontal(id="rename-btn-row"):
                yield Button("취소", id="btn-rename-cancel")
                yield Button("저장", id="btn-rename-save", variant="primary")
            yield Label("입력 후 Enter = 저장, Esc = 취소", classes="hint")

    def on_mount(self) -> None:
        inp = self.query_one("#rename-input", Input)
        inp.focus()
        # 디폴트 값이 채워진 경우 커서를 끝으로 — 바로 추가 입력/편집하기 자연스럽게
        try:
            inp.cursor_position = len(inp.value)
        except Exception:
            pass

    def on_input_submitted(self, event: Input.Submitted) -> None:
        self.dismiss(event.value)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-rename-save":
            self.dismiss(self.query_one("#rename-input", Input).value)
        elif event.button.id == "btn-rename-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)


class ForkNameScreen(ModalScreen[Optional[dict]]):
    """분기 직전 이름/옵션 확정 모달.

    결과:
      - None (취소)
      - {"name": str, "skip_future": bool} — 이름 확정
    """

    def __init__(
        self,
        default_name: str,
        title: str = "분기 이름 지정",
        other_env: Optional[str] = None,
        current_terminal: Optional[str] = None,
        allow_codex_open: bool = False,
        open_target_options: Optional[list[tuple[str, str, bool]]] = None,
        sid_prefix: Optional[str] = None,
    ) -> None:
        super().__init__()
        self.default_name = default_name
        self.title_text = title
        self.allow_codex_open = allow_codex_open
        self.open_target_options = open_target_options
        if self.open_target_options is None and allow_codex_open:
            self.open_target_options = [
                ("claude", "Claude로 재개", True),
                ("codex", "Codex로 열기", False),
            ]
        # other_env: "vscode" / "gnome-terminal" / None
        # 현재 터미널과 반대 환경이 떠 있을 때만 토글을 노출.
        self.other_env = other_env
        # current_terminal: 현재 gccfork가 돌고 있는 터미널. VSCode면 "탭/창" 구분이
        # 무의미(모두 패널 새 항목)하므로 그에 맞춰 📑 체크박스를 숨긴다.
        self.current_terminal = current_terminal
        # sid_prefix: 신규/하드분기처럼 spawn 전부터 sid 가 결정된 케이스 —
        # input 왼쪽에 readonly 4자 prefix 표시. _result() 가 결과 name 앞에
        # 자동으로 "<prefix> " 를 prepend 한다 (사용자는 뒤만 수정).
        self.sid_prefix = sid_prefix

    def _effective_target(self) -> Optional[str]:
        """현재 체크박스 상태 기준 최종 대상 터미널."""
        if self.other_env:
            try:
                if self.query_one("#forkname-other-env", Checkbox).value:
                    return self.other_env
            except Exception:
                pass
        return self.current_terminal

    def _update_newtab_visibility(self) -> None:
        """대상이 VSCode면 📑 새 탭 체크박스를 숨김(무효 옵션)."""
        try:
            newtab = self.query_one("#forkname-newtab", Checkbox)
        except Exception:
            return
        show = self._effective_target() != "vscode"
        newtab.display = show
        if not show:
            newtab.value = False  # 잔여 체크 상태 제거

    def compose(self) -> ComposeResult:
        with Vertical(id="forkname-box"):
            # ── 헤더 — 슬림 모달과 동일 톤 (좌 brand · 중 title · 우 meta) ──
            with Horizontal(id="forkname-header"):
                yield Static("[b]GccForK[/]", id="forkname-brand", markup=True)
                yield Static(
                    f"[b]{self.title_text}[/]",
                    id="forkname-title", markup=True,
                )
                yield Static(
                    f"[dim]v{GCCFORK_VERSION}[/]",
                    id="forkname-meta", markup=True,
                )

            # ── 본문 — 섹션 카드들 ─────────────────────────────────
            with Vertical(id="forkname-scroll"):
                # ─── [NAME] 이름 입력 ───────────────────────────────
                with Vertical(classes="fkn-section", id="forkname-name-section"):
                    yield Static(
                        "[b][NAME][/] 세션 이름",
                        classes="fkn-section-title", markup=True,
                    )
                    if self.sid_prefix:
                        # sid 4자가 이미 박힌 케이스 — 왼쪽 readonly [XXXX] + 편집 input
                        # 관례: 대괄호 + 대문자 hex (예: [9C64])
                        with Horizontal(id="forkname-input-row"):
                            yield Static(
                                f"[{self.sid_prefix.upper()}]  ",
                                id="forkname-sid-prefix", markup=False,
                            )
                            yield Input(value=self.default_name, id="forkname-input")
                    else:
                        yield Input(value=self.default_name, id="forkname-input")

                # ─── [OPTION] 옵션 ─────────────────────────────────
                # 순서: [🔁 대체 환경으로 보내기] → [📑 새 탭으로 열기]
                # 📑 는 🔁 상태 변경으로 숨었다/나타났다 하므로 🔁 아래에 둬야
                # 레이아웃 변화가 "사이에 뽕하고 튀어나오는" 게 아니라 자연스럽게 밀림.
                with Vertical(classes="fkn-section", id="forkname-option-section"):
                    yield Static(
                        "[b][OPTION][/] 옵션",
                        classes="fkn-section-title", markup=True,
                    )
                    if self.open_target_options:
                        yield Static("열기 방식", classes="fkn-option-label")
                        with RadioSet(id="forkname-open-target"):
                            for value, label, checked in self.open_target_options:
                                yield RadioButton(label, value=checked, id=f"forkname-open-{value}")
                    if self.other_env:
                        if self.other_env == "vscode":
                            other_label = "VSCode 로 보내기 (bridge 사용)"
                        elif self.other_env == "gnome-terminal":
                            other_label = "gnome-terminal 로 보내기"
                        else:
                            other_label = f"{self.other_env} 로 보내기"
                        yield Checkbox(
                            other_label,
                            value=False,
                            id="forkname-other-env",
                        )
                    # spawn mode: 기본 새 창 (체크 해제), 체크 시 새 탭
                    # VSCode 대상일 때는 on_mount/on_checkbox_changed에서 display=False.
                    yield Checkbox(
                        "새 탭으로 열기 (해제 = 새 창)",
                        value=False,
                        id="forkname-newtab",
                    )

            # ── 푸터 — 양 끝 정렬 (취소 ← spacer → 확인) ───────────
            with Horizontal(id="forkname-btn-row"):
                yield Button("Esc 취소", id="btn-forkname-cancel")
                yield Static("", id="forkname-btn-spacer")
                yield Button("Enter 확인", id="btn-forkname-save", variant="primary")

    def on_mount(self) -> None:
        inp = self.query_one("#forkname-input", Input)
        inp.focus()
        inp.cursor_position = len(inp.value)
        self._update_newtab_visibility()

    def on_checkbox_changed(self, event: Checkbox.Changed) -> None:
        # 🔁 다른 환경 토글이 바뀌면 📑 새 탭 체크박스의 표시 여부 재계산
        if event.checkbox.id == "forkname-other-env":
            self._update_newtab_visibility()

    def _current_spawn_mode(self) -> str:
        try:
            newtab = self.query_one("#forkname-newtab", Checkbox).value
        except Exception:
            newtab = False
        return "tab" if newtab else "window"

    def _current_target_terminal(self) -> Optional[str]:
        """체크박스가 켜져 있고 other_env가 있으면 그 값, 아니면 None (= 자동 감지)."""
        if not self.other_env:
            return None
        try:
            checked = self.query_one("#forkname-other-env", Checkbox).value
        except Exception:
            checked = False
        return self.other_env if checked else None

    def _current_open_target(self) -> str:
        if not self.open_target_options:
            return "claude"
        for value, _label, default_checked in self.open_target_options:
            try:
                rb = self.query_one(f"#forkname-open-{value}", RadioButton)
                if rb.value:
                    return value
            except Exception:
                continue
        for value, _label, default_checked in self.open_target_options:
            if default_checked:
                return value
        return self.open_target_options[0][0]

    def _result(self, name: str) -> None:
        final_name = name.strip()
        if self.sid_prefix:
            # 관례: [XXXX] 대괄호 + 대문자 형태로 결과 앞에 자동 prepend.
            # 사용자가 실수로 prefix 까지 입력해도 중복 방지.
            bracket_prefix = f"[{self.sid_prefix.upper()}]"
            if not final_name.startswith(bracket_prefix):
                final_name = f"{bracket_prefix} {final_name}".strip()
        self.dismiss({
            "name": final_name,
            "spawn_mode": self._current_spawn_mode(),
            "target_terminal": self._current_target_terminal(),
            "open_target": self._current_open_target(),
        })

    def on_input_submitted(self, event: Input.Submitted) -> None:
        self._result(event.value)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-forkname-save":
            self._result(self.query_one("#forkname-input", Input).value)
        elif bid == "btn-forkname-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)


class CodexImportOptionsScreen(ModalScreen[Optional[dict]]):
    """Claude → Codex 변환 범위 선택 모달.

    Codex는 Claude보다 컨텍스트가 작으므로 최근 raw / compact summary 발췌량을
    사용자가 고를 수 있게 한다.
    """

    PROFILES = {
        "light": {
            "label": "가볍게 — 맥락 120개 + 압축본 1,600자",
            "recent_semantic": 120,
            "compact_excerpt_chars": 1600,
        },
        "balanced": {
            "label": "권장 — 맥락 240개 + 압축본 4,000자",
            "recent_semantic": 240,
            "compact_excerpt_chars": 4000,
        },
        "deep": {
            "label": "깊게 — 맥락 480개 + 압축본 8,000자",
            "recent_semantic": 480,
            "compact_excerpt_chars": 8000,
        },
    }

    def compose(self) -> ComposeResult:
        with Vertical(id="forkname-box"):
            with Horizontal(id="forkname-header"):
                yield Static("[b]GccForK[/]", id="forkname-brand", markup=True)
                yield Static("[b]Codex 변환 옵션[/]", id="forkname-title", markup=True)
                yield Static(f"[dim]v{GCCFORK_VERSION}[/]", id="forkname-meta", markup=True)
            with Vertical(id="forkname-scroll"):
                with Vertical(classes="fkn-section"):
                    yield Static("[b][SCOPE][/] 이식 범위", classes="fkn-section-title", markup=True)
                    yield Static(
                        "Claude 1M 세션을 Codex 256k에 맞게 줄입니다. "
                        "압축본 요약, 최근 맥락, 마지막 raw 보호턴을 함께 넣어야 맥락이 살아납니다.",
                        classes="fkn-option-label",
                    )
                    with RadioSet(id="codex-import-profile"):
                        yield RadioButton(self.PROFILES["light"]["label"], id="codex-profile-light")
                        yield RadioButton(self.PROFILES["balanced"]["label"], value=True, id="codex-profile-balanced")
                        yield RadioButton(self.PROFILES["deep"]["label"], id="codex-profile-deep")
                with Vertical(classes="fkn-section"):
                    yield Static("[b][RAW][/] 마지막 보호턴", classes="fkn-section-title", markup=True)
                    yield Static(
                        "최근 N턴은 user 질문과 assistant 답변 묶음을 원문에 가깝게 보존합니다.",
                        classes="fkn-option-label",
                    )
                    with RadioSet(id="codex-raw-turns"):
                        yield RadioButton("3턴 raw 보존", id="codex-raw-3")
                        yield RadioButton("5턴 raw 보존 (권장)", value=True, id="codex-raw-5")
                        yield RadioButton("10턴 raw 보존", id="codex-raw-10")
                        yield RadioButton("20턴 raw 보존", id="codex-raw-20")
                with Vertical(classes="fkn-section"):
                    yield Static("[b][FILTER][/] 제외/포함", classes="fkn-section-title", markup=True)
                    yield Checkbox(
                        "/context 등 로컬 명령 출력도 포함 (기본 OFF)",
                        value=False,
                        id="codex-include-local-commands",
                    )
            with Horizontal(id="forkname-btn-row"):
                yield Button("Esc 취소", id="btn-codex-import-cancel")
                yield Static("", id="forkname-btn-spacer")
                yield Button("Enter 변환", id="btn-codex-import-save", variant="primary")

    def _selected_profile(self) -> str:
        for key in ("light", "balanced", "deep"):
            try:
                if self.query_one(f"#codex-profile-{key}", RadioButton).value:
                    return key
            except Exception:
                pass
        return "balanced"

    def _selected_raw_turns(self) -> int:
        for n in (3, 5, 10, 20):
            try:
                if self.query_one(f"#codex-raw-{n}", RadioButton).value:
                    return n
            except Exception:
                pass
        return 5

    def _result(self) -> dict:
        key = self._selected_profile()
        prof = self.PROFILES[key]
        try:
            include_local = bool(self.query_one("#codex-include-local-commands", Checkbox).value)
        except Exception:
            include_local = False
        return {
            "profile": key,
            "recent_semantic": prof["recent_semantic"],
            "keep_raw_turns": self._selected_raw_turns(),
            "compact_excerpt_chars": prof["compact_excerpt_chars"],
            "include_local_commands": include_local,
        }

    def on_mount(self) -> None:
        try:
            self.query_one("#codex-import-profile", RadioSet).focus()
        except Exception:
            pass

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-codex-import-save":
            self.dismiss(self._result())
        elif event.button.id == "btn-codex-import-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)
        elif event.key == "enter":
            self.dismiss(self._result())


class ConfirmScreen(ModalScreen[bool]):
    def __init__(
        self,
        message: str,
        confirm_label: str = "삭제",
        confirm_variant: str = "error",
        title: str = "확인",
    ) -> None:
        super().__init__()
        self.message = message
        self.confirm_label = confirm_label
        self.confirm_variant = confirm_variant
        self.title_text = title

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label(self.title_text, id="confirm-title")
            yield SelectableTextArea(
                self.message,
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button(self.confirm_label, id="btn-confirm", variant=self.confirm_variant)
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-cancel", Button).focus()
        _configure_confirm_screen(self, self.message, {})

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            self.dismiss(True)
        elif event.button.id == "btn-cancel":
            self.dismiss(False)

    def on_key(self, event) -> None:
        if event.key == "escape":
            # propagation 차단 — App 레벨의 escape→quit 바인딩까지 올라가는 거 방지
            event.stop()
            self.dismiss(False)


class ResumeConflictScreen(ModalScreen[str]):
    """이미 열린 세션을 다시 재개하려 할 때의 안전 확인."""

    BINDINGS = [
        Binding("escape", "cancel", "취소", show=False),
        Binding("q", "cancel", "취소", show=False),
    ]

    def __init__(
        self,
        *,
        session_label: str,
        source_label: str,
        pids: list[int],
    ) -> None:
        super().__init__()
        self.session_label = session_label
        self.source_label = source_label
        self.pids = pids
        pid_text = ", ".join(str(pid) for pid in self.pids) or "확인됨"
        self.message = (
            f"이미 열린 {self.source_label} 세션입니다.\n\n"
            f"세션: {self.session_label}\n"
            f"활성 PID: {pid_text}\n\n"
            f"같은 SID를 중복으로 열면 같은 기록 파일에 동시에 쓰게 되어 "
            f"세션 기록이 꼬일 수 있습니다.\n\n"
            f"기존 프로세스를 종료한 뒤 다시 열거나, 취소하세요."
        )

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label("⚠ 이미 열린 세션", id="confirm-title")
            yield SelectableTextArea(
                self.message,
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button("기존 종료 후 재개", id="btn-terminate-resume", variant="warning")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-cancel", Button).focus()
        _configure_confirm_screen(self, self.message, {})

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id or ""
        if bid == "btn-terminate-resume":
            self.dismiss("terminate")
        elif bid == "btn-cancel":
            self.dismiss("cancel")

    def action_cancel(self) -> None:
        self.dismiss("cancel")


class MultiDeleteImportantScreen(ModalScreen[str]):
    """다중 삭제 시 중요 표시(★) 가 일부 포함됐을 때 — 3-way 선택.

    반환값:
      "exclude" — important 인 것 제외하고 나머지만 삭제
      "include" — 모두 삭제 (중요 포함)
      "cancel"  — 아무것도 안 함

    디자인은 ForkNameScreen 과 동일 톤 (브랜드/타이틀/메타 3컬럼 헤더,
    $accent 5% 섹션 카드, 양 끝 정렬 푸터).

    Esc 는 BINDINGS 로 처리해서 App 레벨의 quit 바인딩까지 propagate 안 되게 함.
    """

    BINDINGS = [
        Binding("escape", "cancel_screen", "취소", show=False),
    ]

    def __init__(self, total: int, important_count: int, important_titles: list[str]) -> None:
        super().__init__()
        self.total = total
        self.important_count = important_count
        self.safe_count = total - important_count
        self.important_titles = important_titles[:6]
        self.titles_more = max(0, important_count - len(self.important_titles))

    def compose(self) -> ComposeResult:
        with Vertical(id="mdi-box"):
            # ── 헤더 ── ForkNameScreen 과 동일: 좌 brand · 중 title · 우 meta
            with Horizontal(id="mdi-header"):
                yield Static("[b]GccForK[/]", id="mdi-brand", markup=True)
                yield Static(
                    "[b]🍂 중요 파일 포함[/]",
                    id="mdi-title", markup=True,
                )
                yield Static(
                    f"[dim]v{GCCFORK_VERSION}[/]",
                    id="mdi-meta", markup=True,
                )

            # ── 본문 ── 섹션 카드 2개
            with Vertical(id="mdi-scroll"):
                with Vertical(classes="mdi-section"):
                    yield Static(
                        "[b][INFO][/] 선택분 요약",
                        classes="mdi-section-title", markup=True,
                    )
                    yield Static(
                        f"선택한 {self.total}개 중 [b]{self.important_count}개[/b]가 "
                        f"중요 표시(★) 되어 있습니다.",
                        markup=True,
                    )

                with Vertical(classes="mdi-section"):
                    yield Static(
                        "[b][★ IMPORTANT][/] 중요 표시된 세션",
                        classes="mdi-section-title", markup=True,
                    )
                    for title in self.important_titles:
                        yield Static(f"  ★ {title}")
                    if self.titles_more:
                        yield Static(f"  …외 {self.titles_more}개 더")

            # ── 푸터 ── 양 끝: [Esc 취소] · spacer · [중요 제외] [모두 삭제]
            with Horizontal(id="mdi-btn-row"):
                yield Button("Esc 취소", id="btn-mdi-cancel")
                yield Static("", id="mdi-btn-spacer")
                yield Button(f"중요 제외 ({self.safe_count}개)", id="btn-mdi-exclude")
                yield Button(
                    f"모두 삭제 ({self.total}개)",
                    id="btn-mdi-include", variant="error",
                )
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        # 첫 포커스: 가장 안전한 "취소" — 무심코 Enter 쳐도 destructive 액션 발동 안 함.
        self.query_one("#btn-mdi-cancel", Button).focus()

    def action_cancel_screen(self) -> None:
        self.dismiss("cancel")

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-mdi-exclude":
            self.dismiss("exclude")
        elif bid == "btn-mdi-include":
            self.dismiss("include")
        elif bid == "btn-mdi-cancel":
            self.dismiss("cancel")


class TrashScreen(ModalScreen[None]):
    """🗑 휴지통 — 삭제된 세션 목록 / 복원 / 영구 삭제."""

    def __init__(self) -> None:
        super().__init__()
        self.entries: list[dict] = []

    def compose(self) -> ComposeResult:
        with Vertical(id="trash-box"):
            yield Static("🗑 휴지통", id="trash-title")
            yield Static("", id="trash-summary", classes="hint")
            yield SelectableTextArea(
                "",
                id="trash-list",
                read_only=True,
                show_cursor=True,
                soft_wrap=False,
                compact=True,
                show_line_numbers=False,
                highlight_cursor_line=True,
            )
            with Horizontal(id="trash-btn-row"):
                yield Button("닫기", id="btn-trash-close")
                yield Button("전부 비우기", id="btn-trash-purge-all", variant="error")
                yield Button("영구 삭제", id="btn-trash-purge", variant="error")
                yield Button("복원", id="btn-trash-restore", variant="success")
            yield Label(
                "↑/↓ 이동 · Enter=복원 · Del=영구삭제 · Esc=닫기",
                classes="hint",
            )
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self._reload()
        try:
            self.query_one("#btn-trash-restore", Button).focus()
        except Exception:
            pass

    def _reload(self) -> None:
        self.entries = list_trash_entries()
        list_area = self.query_one("#trash-list", SelectableTextArea)
        summary = self.query_one("#trash-summary", Static)
        if not self.entries:
            list_area.text = "(비어있음)"
            summary.update("휴지통이 비어 있습니다.")
            return
        lines: list[str] = []
        total_size = 0
        for e in self.entries:
            sid = (e["session_id"] or "")[:8]
            deleted = (e["deleted_at"] or "")[:19].replace("T", " ")
            size = e["size"]
            total_size += size
            if size < 1024:
                size_str = f"{size}B"
            elif size < 1024 * 1024:
                size_str = f"{size / 1024:.1f}KB"
            else:
                size_str = f"{size / (1024 * 1024):.1f}MB"
            name = e["name"] or "(이름 없음)"
            name = name.replace("\n", " ")[:60]
            lines.append(f"{sid}  {deleted}  {size_str:>8}  {name}")
        list_area.text = "\n".join(lines)
        if total_size < 1024 * 1024:
            ts = f"{total_size / 1024:.1f} KB"
        else:
            ts = f"{total_size / (1024 * 1024):.1f} MB"
        summary.update(f"엔트리 {len(self.entries)}개 · 합계 {ts}")

    def _current_entry(self) -> Optional[dict]:
        if not self.entries:
            return None
        list_area = self.query_one("#trash-list", SelectableTextArea)
        try:
            row = list_area.cursor_location[0]
        except Exception:
            row = 0
        if 0 <= row < len(self.entries):
            return self.entries[row]
        return None

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-trash-close":
            self.dismiss(None)
            return
        if bid == "btn-trash-restore":
            entry = self._current_entry()
            if not entry:
                return
            if restore_trash_entry(entry):
                self.app.notify(f"✓ 복원: {entry['session_id'][:8]}")
                # 부모 앱의 세션 리스트도 갱신
                try:
                    self.app.reload_sessions()  # type: ignore[attr-defined]
                except Exception:
                    pass
            else:
                self.app.notify("복원 실패 (원본 경로 충돌 등)", severity="error")
            self._reload()
            return
        if bid == "btn-trash-purge":
            entry = self._current_entry()
            if not entry:
                return
            if purge_trash_entry(entry):
                self.app.notify(f"영구 삭제: {entry['session_id'][:8]}")
            else:
                self.app.notify("영구 삭제 실패", severity="error")
            self._reload()
            return
        if bid == "btn-trash-purge-all":
            n = purge_all_trash()
            self.app.notify(f"휴지통 {n}개 영구 삭제 완료")
            self._reload()
            return

    def on_key(self, event) -> None:
        key = event.key
        if key == "escape":
            self.dismiss(None)
            return
        if key == "enter":
            entry = self._current_entry()
            if entry and restore_trash_entry(entry):
                self.app.notify(f"✓ 복원: {entry['session_id'][:8]}")
                try:
                    self.app.reload_sessions()  # type: ignore[attr-defined]
                except Exception:
                    pass
                self._reload()
                event.stop()
            return
        if key in ("delete", "d"):
            entry = self._current_entry()
            if entry and purge_trash_entry(entry):
                self.app.notify(f"영구 삭제: {entry['session_id'][:8]}")
                self._reload()
                event.stop()
            return


class BridgeWarnScreen(ModalScreen[bool]):
    """VSCode 창이 여러 개일 때 "그대로 보낼까요?" 경고 모달.

    result:
      - True  → 그대로 보내기 (spawn 진행)
      - False → 취소
    """

    def __init__(self, count: int, target_sid: Optional[str]) -> None:
        super().__init__()
        self.count = count
        self.target_sid = target_sid

    def compose(self) -> ComposeResult:
        sid_hint = (self.target_sid[:8] + "…") if self.target_sid else "(지정 없음)"
        msg = (
            f"⚠ VSCode 창이 {self.count}개 실행 중입니다.\n"
            f"가장 최근 포커스된 창({sid_hint})으로 보내려 하지만,\n"
            f"확장이 각 창별로 처리하므로 엉뚱한 창에 열릴 가능성이 있습니다.\n\n"
            f"원하는 VSCode 창을 먼저 클릭(포커스)하고 다시 시도하면\n"
            f"해당 창에 확실히 열립니다. 그대로 진행할까요?"
        )
        with Vertical(id="confirm-box"):
            yield Label("⚠ VSCode 다중 인스턴스", id="confirm-title")
            yield SelectableTextArea(
                msg,
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button("그대로 보내기", id="btn-confirm", variant="warning")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-cancel", Button).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            self.dismiss(True)
        elif event.button.id == "btn-cancel":
            self.dismiss(False)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(False)


class BridgeTargetPickerScreen(ModalScreen[Optional[str]]):
    """N개 VSCode 인스턴스 중 어디로 spawn 할지 명시 선택.

    result:
      - sessionId (str) → 그 인스턴스로 명시 보내기
      - None → 취소
    """

    def __init__(self, instances: list[dict], session_cwd: Optional[str] = None) -> None:
        super().__init__()
        self.session_cwd = os.path.normpath(session_cwd) if session_cwd else None

        def _cwd_rank(inst: dict) -> int:
            if not self.session_cwd:
                return 3
            inst_cwd = _vscode_instance_cwd(inst)
            if not inst_cwd:
                return 3
            inst_cwd = os.path.normpath(inst_cwd)
            if inst_cwd == self.session_cwd:
                return 0
            if self.session_cwd.startswith(inst_cwd + os.sep):
                return 1
            if inst_cwd.startswith(self.session_cwd + os.sep):
                return 2
            return 3

        # 정렬 — cwd 매칭 먼저, 그 다음 포커스/최근 포커스 순.
        # 후보는 전체 VSCode 인스턴스를 유지해 사용자가 의도한 창을 직접 고를 수 있게 한다.
        def _key(i: dict) -> tuple:
            return (
                _cwd_rank(i),
                0 if i.get("isFocused") else 1,
                # 늦은 게 먼저 오게 reverse 정렬용 음수
                -(_iso_to_ts(i.get("lastFocusedAt") or i.get("updatedAt") or "")),
            )
        self.instances = sorted(instances, key=_key)

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label(
                f"📂 VSCode 창 선택 — {len(self.instances)} 개 실행 중",
                id="confirm-title",
            )
            yield Label(
                "어떤 창에 새 터미널을 열까요? (●=포커스, sid=sessionId 첫4자)",
                classes="hint",
            )
            with RadioSet(id="bridge-pick-radio"):
                for idx, inst in enumerate(self.instances):
                    yield RadioButton(_format_bridge_instance_label(inst), value=(idx == 0))
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button("이 창에 보내기", id="btn-confirm", variant="primary")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        try:
            self.query_one("#bridge-pick-radio", RadioSet).focus()
        except Exception:
            pass

    def _picked_sid(self) -> Optional[str]:
        try:
            radio = self.query_one("#bridge-pick-radio", RadioSet)
            idx = radio.pressed_index
            if 0 <= idx < len(self.instances):
                return self.instances[idx].get("sessionId")
        except Exception:
            pass
        return None

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            self.dismiss(self._picked_sid())
        elif event.button.id == "btn-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)
        elif event.key == "enter":
            self.dismiss(self._picked_sid())


class StaleInstanceConfirmScreen(ModalScreen[bool]):
    """옛 코드로 실행 중인 gccfork TUI 인스턴스 검출 후 종료 확인.

    사용자가 화면에 안 보이는 백그라운드 옛 TUI 가 있으면 spawn 우선순위 등
    동작 불일치 발생. 새 코드 적용된 TUI 시작 시 자동 검출 + 종료 옵션.
    """

    DEFAULT_CSS = """
    StaleInstanceConfirmScreen {
        align: center middle;
    }
    #stale-box {
        width: 80;
        height: auto;
        border: round $accent 35%;
        padding: 0;
        background: $surface;
    }
    #stale-header {
        padding: 1 2;
        border-bottom: hkey $accent 20%;
        height: auto;
    }
    #stale-title {
        color: $accent;
        text-style: bold;
    }
    #stale-meta {
        color: $foreground 60%;
    }
    #stale-body {
        padding: 1 2;
        height: auto;
    }
    .stale-row {
        background: $accent 5%;
        margin: 0 0 1 0;
        padding: 0 1;
        height: auto;
    }
    #stale-btn-row {
        padding: 1 2;
        border-top: hkey $accent 20%;
        height: auto;
    }
    .spacer { width: 1fr; }
    """

    def __init__(self, instances: list[dict]) -> None:
        super().__init__()
        self.instances = instances

    def compose(self) -> ComposeResult:
        with Vertical(id="stale-box"):
            with Vertical(id="stale-header"):
                yield Static(
                    "⚠️  옛 gccfork TUI 인스턴스 검출",
                    id="stale-title",
                )
                yield Static(
                    f"{len(self.instances)}개 인스턴스가 옛 코드 (fix 적용 전) 로 실행 중입니다.\n"
                    "정상 동작 (focused VSCode 자동 spawn 등) 위해 종료 권장.",
                    id="stale-meta",
                )
            with Vertical(id="stale-body"):
                for inst in self.instances:
                    age_min = (time.time() - inst["start_ts"]) / 60
                    if age_min < 60:
                        age_str = f"{age_min:.0f}분 전"
                    elif age_min < 1440:
                        age_str = f"{age_min/60:.1f}시간 전"
                    else:
                        age_str = f"{age_min/1440:.1f}일 전"
                    yield Static(
                        f"  PID {inst['pid']} — {age_str} 시작",
                        classes="stale-row",
                    )
            with Horizontal(id="stale-btn-row"):
                yield Button("나중에", id="btn-stale-skip")
                yield Static("", classes="spacer")
                yield Button("⚠ 종료 (SIGTERM)", id="btn-stale-kill", variant="warning")

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-stale-kill":
            self.dismiss(True)
        elif event.button.id == "btn-stale-skip":
            self.dismiss(False)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(False)


def _iso_to_ts(s: str) -> float:
    if not s:
        return 0.0
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp()
    except (ValueError, TypeError):
        return 0.0


def _format_bridge_instance_label(inst: dict) -> str:
    """Picker 라디오 버튼에 표시할 한 줄 라벨.

    워크스페이스 정보는 시스템 명령으로 추출 — bridge alive JSON 안 의존:
    - `wmctrl -lp` 창 제목에서 워크스페이스 이름
    - terminalPids 의 `/proc/<pid>/cwd` 에서 절대 경로
    """
    sid = (inst.get("sessionId") or "")[:4] or "????"
    focused_mark = "● " if inst.get("isFocused") else "  "
    last = inst.get("lastFocusedAt") or inst.get("updatedAt") or ""
    age = ""
    ts = _iso_to_ts(last)
    if ts > 0:
        delta = max(0, time.time() - ts)
        if delta < 60:
            age = f"{int(delta)}초전"
        elif delta < 3600:
            age = f"{int(delta // 60)}분전"
        else:
            age = f"{int(delta // 3600)}시간전"

    # 워크스페이스 경로 — terminalPids 중 첫 살아있는 셸의 cwd
    # Cross-platform: Linux /proc + macOS/BSD lsof fallback (shares _vscode_instance_cwd logic)
    workspace_path = _vscode_instance_cwd(inst) or ""
    workspace_name = Path(workspace_path).name if workspace_path else "(unknown)"
    short_path = workspace_path
    home = str(Path.home())
    if short_path.startswith(home):
        short_path = "~" + short_path[len(home):]
    if len(short_path) > 50:
        short_path = "…" + short_path[-49:]

    return f"{focused_mark}sid={sid}  📁 {workspace_name}  {short_path}  ({age})  pid={inst.get('pid', '?')}"


class OpenWorkspaceConfirmScreen(ModalScreen[bool]):
    """세션 cwd 와 매칭되는 VSCode 창이 없을 때 새 창 열기 확인.

    result:
      - True  → `code -n <cwd>` 새 창 열고 spawn 진행
      - False → 취소
    """

    def __init__(self, cwd: str) -> None:
        super().__init__()
        self.cwd = cwd

    def compose(self) -> ComposeResult:
        home = str(Path.home())
        display = ("~" + self.cwd[len(home):]) if self.cwd.startswith(home) else self.cwd
        msg = (
            f"이 세션의 워크스페이스가 열린 VSCode 창이 없습니다.\n\n"
            f"폴더:\n  {display}\n\n"
            f"새 VSCode 창을 자동으로 열고 그 안에 터미널을 시작할까요?\n"
            f"(약 10~15초 소요 — bridge 활성화 대기)"
        )
        with Vertical(id="confirm-box"):
            yield Label("📂 새 VSCode 창 열기", id="confirm-title")
            yield SelectableTextArea(
                msg, id="confirm-text", read_only=True, show_cursor=False,
                soft_wrap=True, compact=True, highlight_cursor_line=False,
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("아니오", id="btn-cancel")
                yield Button("예 — 새 창 열기", id="btn-confirm", variant="primary")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-confirm", Button).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            self.dismiss(True)
        else:
            self.dismiss(False)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(False)


class TreeOptionConfirmScreen(ModalScreen[Optional[dict]]):
    """이동/복사 확인 모달 + "트리 구조 유지" 토글.

    결과:
      - None (취소)
      - {"preserve_tree": bool}  (확인 시)
    """

    def __init__(
        self,
        message: str,
        confirm_label: str,
        confirm_variant: str = "primary",
        title: str = "확인",
        preserve_tree_label: str = "트리 구조 유지 (자손 자동 포함)",
        preserve_tree_default: bool = True,
    ) -> None:
        super().__init__()
        self.message = message
        self.confirm_label = confirm_label
        self.confirm_variant = confirm_variant
        self.title_text = title
        self.preserve_tree_label = preserve_tree_label
        self.preserve_tree_default = preserve_tree_default

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label(self.title_text, id="confirm-title")
            yield SelectableTextArea(
                self.message,
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            yield Checkbox(
                self.preserve_tree_label,
                value=self.preserve_tree_default,
                id="confirm-tree-toggle",
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button(self.confirm_label, id="btn-confirm", variant=self.confirm_variant)
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-confirm", Button).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            preserve = self.query_one("#confirm-tree-toggle", Checkbox).value
            self.dismiss({"preserve_tree": preserve})
        elif event.button.id == "btn-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)


class HelpScreen(ModalScreen[None]):
    HELP_TEXT = """\
[bold yellow]━━━ GccSlim 개요 ━━━[/]

Claude Code 와 Codex CLI 세션을 한 목록에서 보고, 이름 지정, 재개,
분기, 하드 복제, 슬림, 해제, 이동, 복사, 병합, 분해, 요약, 삭제를
처리하는 로컬 TUI 입니다. 설정의 [❓ 도움말] 탭도 이 도움말을 그대로
표시합니다.

[bold yellow]━━━ 상단 바 ━━━[/]

[bold cyan]🧠 지능[/]
  GccSlim 전용 assistant 세션을 새 터미널로 엽니다. 세션 위치, 슬림,
  설정, 배포, 오류 진단을 도와주며 공개 배포본에서는 공개 지식만 사용합니다.

[bold cyan]📊 claude / 📊 codex[/]
  각 서비스의 usage/analytics 페이지를 브라우저로 엽니다.

[bold cyan]🧭 범위[/]
  현재 cwd 프로젝트 세션만 보기 ↔ 모든 프로젝트 세션 보기.

[bold cyan]🗑 휴지통[/]
  GccSlim 휴지통 화면. 복원, 선택 영구 삭제, 전부 비우기를 제공합니다.

[bold cyan]🔬 깊이 + 필터[/]
  입력 중에는 제목/ID/cwd 필터. Enter 를 누르면 본문 전체 deep search.
  설정에서 attachment, fuzzy, sidechain 등 검색 포함 범위를 조절합니다.

[bold cyan]🌀 새로 / 🧩 보기 / ⚙ 설정 / 📝 편집[/]
  목록 reload, 트리/평면 보기 전환, 설정 모달, 설정 파일 편집 화면.

[bold yellow]━━━ 메인 액션 바 ━━━[/]

[bold cyan]🌱 신규[/]
  Claude 또는 Codex 새 루트 세션을 만듭니다. 이름, 환경, 터미널 대상,
  새 창/탭을 선택할 수 있고 생성된 jsonl 이 감지되면 이름을 자동 등록합니다.

[bold cyan]🌿 분기[/]
  Claude 공식 `--fork-session` 분기. Claude 정책상 큰 세션은 자동 압축될 수
  있습니다. Codex 세션에는 공식 분기 대신 복제/슬림 계열을 사용합니다.

[bold cyan]🍃 복제[/]
  원본 JSONL을 직접 복사하고 새 UUID를 부여하는 하드 복제입니다.
  Claude는 `sessionId`를 새 값으로 치환하고, Codex는 `session_meta.id`를
  새 값으로 바꿉니다. 자동 압축을 우회해 원본 턴을 보존합니다.

[bold cyan]🔻 슬림[/]
  선택 세션을 줄입니다. Claude는 strong/medium/weak, 번들 처리,
  context 비포함 압축본화, 최근 N턴 raw 보존, 백업, 슬림 후 자동 열기를
  지원합니다. Codex는 Codex JSONL 전용 슬림을 사용하며 최근 N턴 보존과
  5단계 시간대 요약 기반 맥락 보존을 적용합니다.

[bold cyan]🪚 해제[/]
  슬림 번들/압축 구조를 가능한 범위에서 원래 구조로 펼칩니다.
  Rust `gccfork-slim` 위임 경로를 사용합니다.

[bold cyan]🪴 재개[/]
  Claude 또는 Codex 세션을 새 터미널에서 재개합니다. 이미 같은 SID가
  열려 있으면 중복 실행하지 않고, 취소 또는 기존 프로세스 종료 후 재개를
  선택하게 합니다.

[bold cyan]📛 이름[/]
  표시 이름을 registry 에 저장합니다. 목록, 프리뷰, 터미널 탭 제목,
  resume 피커에 반영됩니다.

[bold cyan]🍂 종료[/]
  GccSlim TUI만 종료합니다. 이미 띄운 Claude/Codex 세션은 유지됩니다.

[bold yellow]━━━ 다중 선택 액션 ━━━[/]

리스트 첫 컬럼 `[ ]` 클릭, Ctrl/Shift 클릭, Ctrl+A 로 다중 선택합니다.
다중 선택 중에는 단일 선택 라인이 선택한 행으로 따라가며 스크롤 위치가
불필요하게 튀지 않도록 처리됩니다.

[bold cyan]📦 이동[/]
  선택 세션을 다른 cwd 프로젝트로 이동합니다. 자손 자동 포함 옵션,
  이동 마커, 감사 로그를 기록합니다.

[bold cyan]🧬 복사[/]
  선택 세션 트리를 새 UUID들로 복사하고 parent_id를 재매핑합니다.

[bold cyan]✨ 요약[/]
  선택 세션들을 배치로 AI 요약합니다. 코드 블록/노이즈를 줄이고,
  Codex 세션은 최근 대화에 치우치지 않도록 시간대별 5단계 발췌를 사용합니다.

[bold cyan]🗂 병합[/]
  공통 조상을 가진 세션들을 새 통합 세션으로 병합합니다.
  stitching 방식은 설정의 병합 탭에서 고릅니다.

[bold cyan]🔧 분해[/]
  병합 세션을 원래 세션들로 되돌립니다. 신규 병합 모델과 legacy 묶음
  해제를 자동 구분합니다.

[bold cyan]🧹 삭제[/]
  선택 세션을 휴지통으로 이동합니다. 활성 세션은 삭제를 거부합니다.
  중요 표시 세션은 추가 확인을 요구하고, 자식이 있으면 고아 경고를 보여줍니다.

[bold cyan]🔓 해제[/]
  다중 선택을 모두 해제하고 단일 선택 모드로 돌아갑니다.

[bold yellow]━━━ 설정 탭 ━━━[/]

[bold cyan]🔬 검색[/]
  deep search 에 포함할 JSONL 카테고리와 fuzzy 검색 기본값을 설정합니다.

[bold cyan]🔻 슬림[/]
  Claude / Codex 하위 탭으로 분리되어 있습니다. Claude는 모드, 번들 처리,
  context 비포함 압축본화, 자동 열기, 새 탭/창, 최근 raw 보존을 설정합니다.
  Codex는 안전/강력 모드, 이전 compact 요약 포함, 최근 raw 보존,
  clone/in-place 정책, 자동 열기 기본값을 설정합니다.

[bold cyan]🗂 병합[/]
  preview 방식, stitching 방식, 공통 조상 검사, 트리거 방식을 설정합니다.

[bold cyan]📝 편집기[/]
  설정 파일 편집 방식과 관련 기본값을 설정합니다.

[bold cyan]❓ 도움말[/]
  현재 화면의 이 도움말입니다.

[bold yellow]━━━ 리스트 컬럼 / ID 규칙 ━━━[/]

  [ ]    체크박스. 다중 선택 토글
  ▶      활성/live 세션 표시. GccSlim가 띄운 세션은 우선 표시
  ★ / ·  custom_name 있음 / auto_summary 만 있음
  ●      세션 색상 점. 루트 색상 상속, 기존 색은 순서대로 재사용
  ID     Claude는 UUID 앞 4자, Codex는 `~` + UUID 마지막 3자
  시각   MM-DD HH:MM
  턴     live 턴 수와 전체 턴 수
  크기   JSONL 파일 크기
  🔩 N   compact summary 마커 수
  └─     트리 들여쓰기

Codex UUID는 앞부분이 시간 성격을 강하게 띠어 비슷하게 보이므로 목록에서는
마지막 3자리 `~abc`를 표시합니다. 사용자가 `~abc id`라고 말하면 Codex
표시 ID로 해석합니다.

[bold yellow]━━━ 세션 위치 / truth source ━━━[/]

Claude 세션:
  `~/.claude/projects/<project-slug>/<sid>.jsonl`
  활성 SID가 필요하면 `~/.claude/sessions/<PID>.json` 의 `sessionId`.

Codex 세션:
  `~/.codex/sessions/YYYY/MM/DD/*.jsonl`
  GccSlim 래퍼로 띄운 활성 Codex는
  `/tmp/gccfork-codex-slim-reload-<uid>.json.state-*` 의 `session_id`.

GccSlim registry / prefs:
  `~/.claude/gccfork-registry.json`
  `<project-cwd>/.gccfork/ccfork-prefs.json`

[bold yellow]━━━ 트리 / 색상 / 이름 ━━━[/]

부모 관계는 registry `parent_id`, Claude `parentUuid`, 병합/복제 메타데이터를
함께 사용합니다. 루트 색상은 자식이 상속하고 터미널 탭 제목과 목록에서
같은 색상 태그를 사용합니다.

이름 규칙:
  Claude 표시 ID: `abcd`
  Codex 표시 ID: `~abc`
  파생 이름 예: `작업명 abcd[<= 1234]`, `작업명 ~abc[<= ~def]`

[bold yellow]━━━ VSCode / 터미널 라우팅 ━━━[/]

VSCode 창이 여러 개면 세션 cwd와 매칭되는 창을 찾습니다.
  • 1개 매칭: 자동으로 그 창에 spawn
  • 여러 개: 창 선택 모달
  • 0개: 새 VSCode 창 열기 확인

gnome-terminal, konsole, xfce4-terminal, iTerm2, Terminal.app, Windows Terminal,
alacritty, terminator, xterm 등은 가능한 방식으로 새 창/탭을 엽니다.

[bold yellow]━━━ CLI 서브커맨드 ━━━[/]

TUI 없이 실행 가능한 주요 명령:
  search, list, detail, ancestry, parent-of, rename, hard-fork,
  slim, slim-inplace, live-sessions, reconcile-live, delete,
  prefs get/set, stats, patch-claude, rust-status, hot-reload,
  slim-and-reload

[bold yellow]━━━ 마우스 / 키보드 ━━━[/]

  드래그                    경로/목록/프리뷰 텍스트 선택
  Ctrl+C / Ctrl+Shift+C     선택 텍스트 복사
  우클릭                    복사 / 취소 메뉴
  체크박스 클릭             다중 선택 토글
  Ctrl+클릭 / Shift+클릭    다중 선택 추가 / 범위 선택
  Ctrl+A                    필터된 세션 모두 선택
  Ctrl+Shift+M              병합 단축키
  Ctrl+E                    설정 파일 편집 화면
  ↑↓                        세션 이동
  Tab                       영역 이동
  ←→                        액션바 버튼 이동
  Enter                     목록에서는 분기 버튼 포커스, 버튼에서는 실행
  Esc / q                   모달 닫기 또는 앱 종료
"""

    def compose(self) -> ComposeResult:
        with Vertical(id="help-box"):
            yield Label("❓ gccslim 도움말", id="help-title")
            with VerticalScroll(id="help-scroll"):
                yield Static(self.HELP_TEXT, id="help-content")
            with Horizontal(id="help-btn-row"):
                yield Button("✖ 닫기", id="btn-help-close", variant="primary")

    def on_mount(self) -> None:
        self.query_one("#btn-help-close", Button).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-help-close":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key in {"escape", "q"}:
            self.dismiss(None)


class ModeCard(Static, can_focus=True):
    """🔻 슬림 모드 카드 — 클릭/Enter/Space 로 선택. selected 상태는 `.-selected` 클래스.

    RadioSet 의 한 줄 라벨 한계를 회피하기 위해 Static 기반.
    상위 ModalScreen 의 `_select_mode(mode)` 메서드를 호출.
    """
    def _trigger_select(self) -> None:
        screen = self.screen
        if not (screen and self.id):
            return
        # id 형식별 dispatch:
        #   <prefix>-mode-<name>  → screen._select_mode(name)   (예: slim-mode-strong)
        #   <prefix>-trig-<name>  → screen._select_trigger(name) (예: auto-trig-once)
        if "-mode-" in self.id:
            if hasattr(screen, "_select_mode"):
                screen._select_mode(self.id.rsplit("-mode-", 1)[1])
            return
        if "-trig-" in self.id:
            if hasattr(screen, "_select_trigger"):
                screen._select_trigger(self.id.rsplit("-trig-", 1)[1])
            return
        # 옛 호환 — slim-mode- prefix
        if hasattr(screen, "_select_mode"):
            screen._select_mode(self.id.replace("slim-mode-", ""))

    async def on_click(self) -> None:
        self._trigger_select()

    async def _on_key(self, event: events.Key) -> None:
        if event.key in {"enter", "space"}:
            event.prevent_default()
            event.stop()
            self._trigger_select()


class BrainButton(Static):
    """Brain-agent entry button shown on the right side of the title bar.

    Click dispatches to App.action_open_brain_agent, which surfaces a modal
    letting the user resume the latest brain session or start a fresh one.
    """

    def __init__(self) -> None:
        super().__init__("🧠 지능", id="title-bar-brain")

    async def on_click(self) -> None:
        app = self.app
        if hasattr(app, "action_open_brain_agent"):
            await app.action_open_brain_agent()


class UsageButton(Static):
    """Title-bar button that opens a CLI provider's usage/analytics page.

    Two instances mounted on the right of the title bar (next to BrainButton):
      - claude → Claude Max usage dashboard
      - codex  → ChatGPT Codex cloud analytics
    Click uses webbrowser.open which honors xdg-open / open on Linux/macOS.
    """

    def __init__(self, label: str, url: str, *, widget_id: str) -> None:
        super().__init__(label, id=widget_id)
        self._target_url = url
        self._label = label

    async def on_click(self) -> None:
        try:
            ok = webbrowser.open(self._target_url, new=2)
        except Exception:
            ok = False
        if ok:
            self.app.notify(f"열기: {self._label} → {self._target_url}", timeout=3)
        else:
            self.app.notify(
                f"브라우저 열기 실패. 수동 접속: {self._target_url}",
                severity="warning",
                timeout=6,
            )


class SlimBrainButton(Static, can_focus=True):
    """One-line brain button for the Slim modal header.

    Textual Button is three rows tall because of its border, so it clips inside
    the compact section header. Static keeps the header one line and avoids
    layout corruption.
    """

    def __init__(self) -> None:
        super().__init__("🧠 지능", id="btn-slim-brain")

    async def on_click(self) -> None:
        screen = self.screen
        if hasattr(screen, "_open_slim_brain_agent"):
            screen._open_slim_brain_agent()

    async def _on_key(self, event: events.Key) -> None:
        if event.key in {"enter", "space"}:
            event.prevent_default()
            event.stop()
            screen = self.screen
            if hasattr(screen, "_open_slim_brain_agent"):
                screen._open_slim_brain_agent()


class BrainAgentChoiceScreen(ModalScreen[Optional[str]]):
    """Modal: choose between resuming the latest brain session and new start.

    Result: 'resume' | 'new' | None (cancelled).
    Default selection picks 'resume' if a prior brain session exists,
    otherwise 'new'. The 'resume' radio is disabled when no prior session.
    """

    BINDINGS = [
        Binding("escape", "cancel", "취소"),
    ]

    def __init__(self, has_existing: bool, latest_label: Optional[str] = None) -> None:
        super().__init__()
        self._has_existing = has_existing
        self._latest_label = latest_label or ""
        self._choice = "resume" if has_existing else "new"

    def compose(self) -> ComposeResult:
        with Vertical(id="brain-box"):
            yield Static("🧠 GccSlim 지능에이전트", id="brain-title")
            yield Static(
                "이전 brain 세션을 이어가거나 새로 시작합니다.",
                id="brain-subtitle",
            )
            with Vertical(id="brain-options"):
                resume_label = (
                    f"이어가기 — {self._latest_label}"
                    if self._has_existing and self._latest_label
                    else "이어가기 — (이전 세션 없음)"
                )
                yield RadioSet(
                    RadioButton(
                        resume_label,
                        id="brain-opt-resume",
                        value=(self._choice == "resume" and self._has_existing),
                    ),
                    RadioButton(
                        "새로 시작",
                        id="brain-opt-new",
                        value=(self._choice == "new"),
                    ),
                    id="brain-radio",
                )
            with Horizontal(id="brain-btn-row"):
                yield Button("취소", id="brain-btn-cancel", variant="default")
                yield Static("", classes="brain-btn-spacer")
                yield Button("열기", id="brain-btn-confirm", variant="primary")

    def on_mount(self) -> None:
        # Disable the 'resume' option when no prior brain session exists.
        if not self._has_existing:
            try:
                rb = self.query_one("#brain-opt-resume", RadioButton)
                rb.disabled = True
            except Exception:
                pass
        # Move focus to the confirm button so Enter triggers it directly.
        try:
            self.query_one("#brain-btn-confirm", Button).focus()
        except Exception:
            pass

    def on_radio_set_changed(self, event: RadioSet.Changed) -> None:
        pressed = event.pressed
        rid = pressed.id if pressed else None
        if rid == "brain-opt-resume" and self._has_existing:
            self._choice = "resume"
        elif rid == "brain-opt-new":
            self._choice = "new"

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "brain-btn-cancel":
            self.dismiss(None)
        elif event.button.id == "brain-btn-confirm":
            self.dismiss(self._choice)

    def action_cancel(self) -> None:
        self.dismiss(None)


class SlimModeScreen(ModalScreen[Optional[dict]]):
    """🔻 슬림 fork — 모드 선택 + 이름 + 옵션.

    UI:
      ┌── 🔻 슬림 fork ──────────────────────┐
      │  원본: <short_id> · <KB> · <턴>       │
      │  ┌─ 📍 압축 이력 ─────────────────┐   │
      │  │  마커 전:  N 라인 · KB (archive)│   │
      │  │  마커 후:  N 라인 · KB (대상)   │   │
      │  └─────────────────────────────────┘   │
      │  ┌─ 슬림 이후 이름 ──────────────┐    │
      │  │  [입력란 — 자동 명명 가능]      │    │
      │  └────────────────────────────────┘    │
      │  ┌─ 모드 선택 ──────────────────┐     │
      │  │  ( ) strict   효과: 7×절약   │     │
      │  │  (•) balanced 효과: 5×절약   │     │
      │  │  ( ) loose    효과: 3×절약   │     │
      │  └────────────────────────────────┘    │
      │  ☐ 슬림 후 새 창에서 resume          │
      │  [취소]                  [🔻 시작]    │
      └──────────────────────────────────────┘

    반환 dict: {"mode": ..., "name": ..., "resume_after": bool}
    """

    BINDINGS = [
        Binding("escape", "cancel", "취소", show=False),
        Binding("q", "cancel", "취소", show=False),
    ]

    def __init__(self, session, default_mode: str = "strong",
                 default_name: Optional[str] = None,
                 other_env: Optional[str] = None,
                 current_terminal: Optional[str] = None) -> None:
        super().__init__()
        self.session = session
        self.default_mode = default_mode
        self._selected_mode = default_mode
        # 이름 자동 명명 — 최종 UUID 는 모르니 placeholder. action_slim_fork 가 결정.
        if default_name is None:
            parent_title = _clean_parent_title(session.title)
            default_name = (
                f"{parent_title} 🔻[<= {session.id[:4]}]" if parent_title
                else f"🔻[<= {session.id[:4]}]"
            ).strip()[:120]
        self.default_name = default_name
        # other_env / current_terminal — ForkNameScreen 과 동일 패턴
        self.other_env = other_env
        self.current_terminal = current_terminal
        self._details_open = False
        # 라이브 업데이트용
        self._estimates: dict[str, dict] = {}
        self._marker_idx: Optional[int] = None
        self._pre_bytes = 0
        self._post_bytes = 0

    def _resume_enabled(self) -> bool:
        try:
            return bool(self.query_one("#slim-resume-after", Checkbox).value)
        except Exception:
            return False

    def _effective_target(self) -> Optional[str]:
        if self.other_env:
            try:
                if self.query_one("#slim-other-env", Checkbox).value:
                    return self.other_env
            except Exception:
                pass
        return self.current_terminal

    def _update_sub_options_visibility(self) -> None:
        """메인 토글 (자동 열기) 상태 + VSCode 체크 상태에 따라 sub 옵션 표시."""
        resume = self._resume_enabled()

        # other-env 체크박스 — 메인 ON + other_env 가 있을 때만
        try:
            other_env_cb = self.query_one("#slim-other-env", Checkbox)
            show_other = bool(resume and self.other_env)
            other_env_cb.display = show_other
            if not show_other:
                other_env_cb.value = False
        except Exception:
            pass

        # newtab 체크박스 — 메인 ON 이고 VSCode 대상이 아닐 때만
        try:
            newtab = self.query_one("#slim-newtab", Checkbox)
        except Exception:
            return
        if not resume:
            newtab.display = False
            newtab.value = False
            return
        show = self._effective_target() != "vscode"
        newtab.display = show
        if not show:
            newtab.value = False

    def _compute_estimates(self) -> None:
        """모드별 절감률 정적 평균값 표시 (Phase E-7, 2026-05-06).

        verdict 본체 archive 됨 — 라이브 verdict 호출 시 Rust subprocess 가 필요한데
        모달 열 때마다 3번 (mode 별) subprocess 호출 = 1초+ 지연 → UX 저하.
        대안: 정적 평균값 (검증된 실측 기반).

        + visible_cap 분석 (2026-05-13) — Claude Code 의 메시지 카운트 cap (~115 turn /
        230 user+assistant 메시지) 기반으로 active 영역을 "context 비포함" / "context 포함"
        으로 분리. 사용자 멘붕 방지용.
        """
        self._marker_idx = detect_compact_marker_index(self.session.jsonl_path)
        pre_lines = pre_bytes = post_lines = post_bytes = 0
        # visible_cap 분석용 — active 영역의 user/assistant line idx 수집
        active_ua_lines: list[int] = []
        active_user_lines: list[int] = []
        line_bytes: list[int] = []
        try:
            import json as _json
            with self.session.jsonl_path.open("r", encoding="utf-8", errors="ignore") as fh:
                for i, raw in enumerate(fh):
                    line_bytes.append(len(raw))
                    if self._marker_idx is not None and i <= self._marker_idx:
                        pre_lines += 1; pre_bytes += len(raw)
                    else:
                        post_lines += 1; post_bytes += len(raw)
                        # active 영역의 user/assistant 추출
                        try:
                            d = _json.loads(raw)
                            if isinstance(d, dict) and d.get("type") in ("user", "assistant"):
                                active_ua_lines.append(i)
                                if d.get("type") == "user":
                                    active_user_lines.append(i)
                        except Exception:
                            pass
        except OSError:
            pass
        self._pre_lines = pre_lines
        self._pre_bytes = pre_bytes
        self._post_lines = post_lines
        self._post_bytes = post_bytes
        if len(active_user_lines) >= 5:
            recent_start = active_user_lines[-5]
            active_start = (self._marker_idx + 1) if self._marker_idx is not None else 0
            self._recent_raw_lines = max(0, (active_start + post_lines) - recent_start)
        else:
            self._recent_raw_lines = post_lines

        # visible_cap = 230 (Claude Code default cap 추정) 기준 분류
        VISIBLE_CAP = 230
        self._visible_cap = VISIBLE_CAP
        self._active_ua_count = len(active_ua_lines)
        if len(active_ua_lines) > VISIBLE_CAP:
            cut_line = active_ua_lines[-VISIBLE_CAP]
            invisible_lines = sum(1 for ln in range(self._marker_idx + 1 if self._marker_idx is not None else 0, cut_line))
            invisible_bytes = sum(line_bytes[ln] for ln in range(self._marker_idx + 1 if self._marker_idx is not None else 0, cut_line) if ln < len(line_bytes))
            visible_lines = post_lines - invisible_lines
            visible_bytes = post_bytes - invisible_bytes
            self._invisible_lines = invisible_lines
            self._invisible_bytes = invisible_bytes
            self._visible_lines = visible_lines
            self._visible_bytes = visible_bytes
            # 기본 옵션(context 비포함 압축본화 ON) 기준 실제 bundle/slim 대상.
            # 마커 후 active 전체가 아니라, cap 안의 "context 포함" 만 단편화 풀기 대상이다.
            self._bundle_target_lines = visible_lines
            self._bundle_target_bytes = visible_bytes
            self._cap_overflow = True  # active > cap → 잘리는 영역 있음
        else:
            self._invisible_lines = 0
            self._invisible_bytes = 0
            self._visible_lines = post_lines
            self._visible_bytes = post_bytes
            self._bundle_target_lines = post_lines
            self._bundle_target_bytes = post_bytes
            self._cap_overflow = False

        # 모드별 평균 절감률 (검증된 실측 기반 — ca09 22MB / cdb1 12MB 등)
        avg_saving = {"strong": 0.80, "medium": 0.50, "weak": 0.20}
        avg_drop_ratio = {"strong": 0.65, "medium": 0.40, "weak": 0.15}
        for mode in ("strong", "medium", "weak"):
            saving = avg_saving[mode]
            drop_r = avg_drop_ratio[mode]
            target_lines = self._bundle_target_lines
            target_bytes = self._bundle_target_bytes
            est_dropped = int(target_lines * drop_r) if target_lines else 0
            est_kept = target_lines - est_dropped if target_lines else 0
            est_after = int(target_bytes * (1 - saving)) if target_bytes else 0
            self._estimates[mode] = {
                "kept": est_kept, "stubbed": 0, "dropped": est_dropped,
                "post_after": est_after,
            }

    def _visible_cap_compact_default(self) -> bool:
        if not self._cap_overflow:
            return False
        try:
            return bool(pref_get("slim_default_visible_cap_compact", True))
        except Exception:
            return True

    def _estimate_for_target(self, mode: str, target_lines: int, target_bytes: int) -> dict:
        avg_saving = {"strong": 0.80, "medium": 0.50, "weak": 0.20}
        avg_drop_ratio = {"strong": 0.65, "medium": 0.40, "weak": 0.15}
        saving = avg_saving.get(mode, 0.80)
        drop_r = avg_drop_ratio.get(mode, 0.65)
        est_dropped = int(target_lines * drop_r) if target_lines else 0
        return {
            "kept": target_lines - est_dropped if target_lines else 0,
            "stubbed": 0,
            "dropped": est_dropped,
            "post_after": int(target_bytes * (1 - saving)) if target_bytes else 0,
        }

    def _current_bundle_on(self) -> bool:
        try:
            return bool(self.query_one("#slim-anti-frag", Checkbox).value)
        except Exception:
            try:
                return bool(pref_get("slim_default_anti_fragmentation", True))
            except Exception:
                return True

    def _current_anti_frag_on(self) -> bool:
        # 내부 옵션명은 anti_fragmentation 이지만, UI 의미는 "번들(묶음) 처리 ON".
        return self._current_bundle_on()

    def _current_visible_cap_compact_on(self) -> bool:
        if not self._cap_overflow or not self._current_anti_frag_on():
            return False
        try:
            return bool(self.query_one("#slim-visible-cap-compact", Checkbox).value)
        except Exception:
            return self._visible_cap_compact_default()

    def _plan_target(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> tuple[int, int, str]:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        if not anti_frag_on:
            return self._post_lines, self._post_bytes, "일반 슬림 대상"
        if self._cap_overflow and compact_on:
            return self._visible_lines, self._visible_bytes, "context 포함"
        return self._post_lines, self._post_bytes, "마커 후 전체"

    def _mode_card_text(self, mode: str, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        from gccfork_settings import SLIM_MODE_LABELS
        _, hint = SLIM_MODE_LABELS[mode]
        target_lines, target_bytes, target_label = self._plan_target(compact_on, anti_frag_on)
        e = self._estimate_for_target(mode, target_lines, target_bytes)
        ratio = e["post_after"] * 100 // max(target_bytes, 1)
        saving = round(target_bytes / max(e["post_after"], 1), 1)
        badge = " [b](기본)[/]" if mode == "strong" else ""
        return (
            f"[b]{mode}[/]{badge}\n"
            f"{target_bytes/1024:>4.0f} → {e['post_after']/1024:>4.0f} KB  {ratio}%\n"
            f"[b]{saving}× 절약[/] [dim]{target_label}[/]\n"
            f"[dim]{hint[:32]}[/]"
        )

    def _plan_summary_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        target_lines, target_bytes, target_label = self._plan_target(compact_on, anti_frag_on)
        selected_mode = getattr(self, "_selected_mode", "strong")
        e = self._estimate_for_target(selected_mode, target_lines, target_bytes)
        ratio = e["post_after"] * 100 // max(target_bytes, 1)
        saving = round(target_bytes / max(e["post_after"], 1), 1)
        estimate_line = (
            f"\n[b]{selected_mode} 예상[/] {target_bytes/1024:.1f} → "
            f"{e['post_after']/1024:.1f} KB ({ratio}%, {saving}× 절약)"
        )
        if not anti_frag_on:
            return (
                f"[b]적용 계획[/] 번들 미사용 · 일반 슬림 · 대상 [b]{target_label}[/] "
                f"{target_bytes/1024:.1f} KB ({target_lines} 라인)"
                f"{estimate_line}"
            )
        if self._cap_overflow and compact_on:
            return (
                f"[b]적용 계획[/] context 비포함 → native compact boundary 앞 / "
                f"[b]{target_label}[/] → bundle / 최근 raw → 원본 보존"
                f"{estimate_line}"
            )
        if self._cap_overflow:
            return (
                f"[b yellow]적용 계획[/] 마커 후 전체 bundle · context 비포함 영역이 다시 "
                f"컨텍스트에 들어올 수 있음"
                f"{estimate_line}"
            )
        return (
            f"[b]적용 계획[/] active 전체가 cap 안 · 대상 [b]{target_label}[/] "
            f"{target_bytes/1024:.1f} KB ({target_lines} 라인)"
            f"{estimate_line}"
        )

    def _scope_tree_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()

        archive_action = "보존"
        if not anti_frag_on:
            context_off_action = "일반 슬림 대상"
            context_on_action = "일반 슬림 대상"
            recent_action = "일반 슬림 규칙"
        elif self._cap_overflow and compact_on:
            context_off_action = "압축본화 예정"
            context_on_action = "bundle 대상"
            recent_action = "원본 보존"
        elif self._cap_overflow:
            context_off_action = "bundle 대상"
            context_on_action = "bundle 대상"
            recent_action = "원본 보존"
        else:
            context_off_action = "없음"
            context_on_action = "bundle 대상"
            recent_action = "원본 보존"

        active_lines = self._post_lines
        recent_lines = getattr(self, "_recent_raw_lines", 0)
        def _display_width(s: str) -> int:
            import unicodedata
            width = 0
            for ch in s:
                width += 2 if unicodedata.east_asian_width(ch) in ("F", "W") else 1
            return width

        def _pad(s: str, width: int) -> str:
            return s + (" " * max(0, width - _display_width(s)))

        def _row(prefix: str, label: str, lines: int, action: str = "") -> str:
            left = _pad(f"{prefix} {label}", 34)
            right = f"{lines:>6} lines"
            return f"{left} │ {right} │ {action}".rstrip()

        return (
            "[b]전체 세션[/]\n"
            f"{_row('├─', '압축본 / archive', self._pre_lines, archive_action)}\n"
            f"{_row('└─', 'active 영역', active_lines)}\n"
            f"{_row('   ├─', 'context 비포함', self._invisible_lines, context_off_action)}\n"
            f"{_row('   └─', 'context 포함', self._visible_lines, context_on_action)}\n"
            f"{_row('      └─', '최근 5턴 raw', recent_lines, recent_action)}"
        )

    def _scope_status_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        return (
            "[b]현재 상태[/]\n"
            f"- Claude cap 기준 active user/assistant {self._active_ua_count}개 / cap {self._visible_cap}개\n"
            f"- {'context 비포함 영역 있음' if self._cap_overflow else 'context 비포함 영역 없음'}"
        )

    def _scope_details_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        if not self._cap_overflow:
            context_off_after = "없음"
        elif compact_on and anti_frag_on:
            context_off_after = "native compact boundary 앞쪽으로 보냄"
        else:
            context_off_after = "bundle 대상에 포함"
        return (
            "[b]선택된 계획[/]\n"
            f"- {'☑' if anti_frag_on else '☐'} 번들(묶음) 처리\n"
            f"- {'☑' if compact_on else '☐'} context 비포함 압축본화\n\n"
            "[b]적용 후[/]\n"
            f"- context 비포함: {context_off_after}\n"
            f"- context 포함: {'bundle로 묶음' if anti_frag_on else '일반 슬림 적용'}\n"
            "- 최근 5턴: raw 원본 그대로 보존"
        )

    def _slim_brain_system_prompt(self) -> str:
        return (
            "당신은 GccSlim 슬림 모달 해설 전용 지능 에이전트입니다.\n"
            "목표는 사용자가 현재 슬림 계획을 바로 이해하도록, 제공된 숫자와 옵션 상태만 근거로 설명하는 것입니다.\n"
            "GccSlim 슬림이 다루는 Claude Code 세션 구조:\n"
            "- 세션은 ~/.claude/projects/<cwd-slug>/<sid>.jsonl 의 JSONL 파일입니다.\n"
            "- Claude Code 는 native compact marker(isCompactSummary / compact_boundary) 이후의 대화만 주로 컨텍스트로 재구성합니다.\n"
            "- 추가로 user/assistant 메시지 개수 cap 이 있어, 1M 토큰이 비어 있어도 오래된 active 메시지는 컨텍스트에 안 들어갈 수 있습니다.\n"
            "- 기존 압축본/archive 는 raw JSONL 에 남아 있지만 native compact boundary 앞 영역이라 일반 resume 컨텍스트에는 직접 들어가지 않는 영역입니다.\n"
            "- active 영역은 마지막 native compact marker 뒤의 원본 대화입니다.\n"
            "- context 비포함은 active 안에 있지만 Claude 메시지 cap 밖이라 현재 컨텍스트에 들어가지 않는 구간입니다.\n"
            "- context 포함은 현재 cap 안에 들어오는 active 구간이며 bundle 처리 대상입니다.\n"
            "- 최근 raw 보존 턴은 사용자가 방금 보던 마지막 흐름이므로 JSONL 라인을 원본 그대로 보존합니다.\n"
            "슬림 적용 구조:\n"
            "- 압축본/archive: 보존\n"
            "- context 비포함: native compact boundary 앞으로 분리해서 컨텍스트 밖으로 둠\n"
            "- context 포함: bundle 로 묶어 컨텍스트 부담을 줄임\n"
            "- 최근 N턴 raw: 원본 그대로 보존\n"
            "모드 의미:\n"
            "- strong: context 확보 우선. 가장 강하게 줄이고 최근 raw 기본 5턴만 보존합니다.\n"
            "- medium: 균형형. 흐름 가독성과 절감 사이 절충, 최근 raw 기본 10턴 보존입니다.\n"
            "- weak: 보수형. 더 많이 보존하고 절감은 작으며, 최근 raw 기본 30턴 보존입니다.\n"
            "용어 정의:\n"
            "- 압축본/archive: 기존 native compact summary 이전 영역이며 그대로 보존됩니다.\n"
            "- active 영역: 마지막 compact marker 이후 원본 대화 영역입니다.\n"
            "- context 비포함: Claude Code 메시지 cap 기준 현재 컨텍스트에 로드되지 않는 active 일부입니다.\n"
            "- context 포함: 현재 컨텍스트에 들어오는 active 일부이며 bundle 대상입니다.\n"
            "- 최근 5턴 raw: 사용자가 보던 마지막 흐름이며 원본 그대로 보존됩니다.\n"
            "설명 규칙:\n"
            "- 한국어로 답합니다.\n"
            "- 길이는 짧게 유지하되, 현재 상태와 적용 후 변화를 구분합니다.\n"
            "- raw가 삭제되는 것처럼 말하지 않습니다. 보존/압축본화/bundle/context 포함 여부를 분리해서 말합니다.\n"
            "- context 비포함 압축본화가 꺼져 있으면 슬림 후 컨텍스트가 오히려 늘 수 있음을 명확히 말합니다.\n"
            "- 사용자가 지금 무엇을 체크해야 하는지 결론을 한 줄로 제시합니다."
        )

    def _slim_brain_user_prompt(self) -> str:
        anti_on = self._current_anti_frag_on()
        compact_on = self._current_visible_cap_compact_on()
        target_lines, target_bytes, target_label = self._plan_target(compact_on, anti_on)
        selected_mode = getattr(self, "_selected_mode", "strong")
        e = self._estimate_for_target(selected_mode, target_lines, target_bytes)
        ratio = e["post_after"] * 100 // max(target_bytes, 1)
        saving = round(target_bytes / max(e["post_after"], 1), 1)
        return (
            "GccSlim 슬림 모달의 현재 상태를 사용자에게 상세하지만 간결하게 설명해줘.\n\n"
            f"세션: {self.session.short_id} / {self.session.title}\n"
            f"선택 모드: {selected_mode}\n"
            f"번들(묶음) 처리: {'ON' if anti_on else 'OFF'}\n"
            f"context 비포함 압축본화: {'ON' if compact_on else 'OFF'}\n"
            f"compact marker index: {self._marker_idx}\n\n"
            "[슬림 적용 범위]\n"
            f"{self._scope_tree_text(compact_on, anti_on)}\n\n"
            "[현재 상태]\n"
            f"- active user/assistant: {self._active_ua_count}개\n"
            f"- Claude cap: {self._visible_cap}개\n"
            f"- context 비포함 영역: {'있음' if self._cap_overflow else '없음'}\n\n"
            "[선택된 계획]\n"
            f"{self._scope_details_text(compact_on, anti_on)}\n\n"
            "[모드 예상]\n"
            f"- 대상: {target_label} {target_lines} lines / {target_bytes/1024:.1f} KB\n"
            f"- 예상: {target_bytes/1024:.1f} KB -> {e['post_after']/1024:.1f} KB "
            f"({ratio}%, {saving}x 절약)\n\n"
            "위 상태를 기준으로 사용자가 지금 무엇을 선택해야 하는지 설명해줘."
        )

    def _open_slim_brain_agent(self) -> None:
        app = self.app
        if not hasattr(app, "_spawn_slim_brain_agent"):
            try:
                app.notify("지능 에이전트 실행 함수를 찾지 못했습니다.", severity="error", timeout=5)
            except Exception:
                pass
            return
        app._spawn_slim_brain_agent(
            source_sid=self.session.id,
            system_prompt=self._slim_brain_system_prompt(),
            user_prompt=self._slim_brain_user_prompt(),
        )

    def _refresh_slim_plan_view(self) -> None:
        anti_on = self._current_anti_frag_on()
        compact_on = self._current_visible_cap_compact_on()
        try:
            self.query_one("#slim-scope-plan", Static).update(
                self._plan_summary_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            self.query_one("#slim-scope-tree", Static).update(
                self._scope_tree_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            self.query_one("#slim-scope-status", Static).update(
                self._scope_status_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            self.query_one("#slim-scope-details", Static).update(
                self._scope_details_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            warn = self.query_one("#slim-scope-warning", Static)
            warn.display = bool(self._details_open and self._cap_overflow and anti_on and not compact_on)
        except Exception:
            pass
        try:
            details = self.query_one("#slim-scope-details", Static)
            details.display = self._details_open
        except Exception:
            pass
        try:
            plan = self.query_one("#slim-scope-plan", Static)
            plan.display = self._details_open
        except Exception:
            pass
        try:
            btn = self.query_one("#btn-slim-details", Button)
            btn.label = "상세접기" if self._details_open else "상세보기"
        except Exception:
            pass
        try:
            vc = self.query_one("#slim-visible-cap-compact", Checkbox)
            vc.disabled = not anti_on
        except Exception:
            pass
        for mode in ("strong", "medium", "weak"):
            try:
                self.query_one(f"#slim-mode-{mode}", ModeCard).update(
                    self._mode_card_text(mode, compact_on, anti_on)
                )
            except Exception:
                pass

    def compose(self) -> ComposeResult:
        from gccfork_settings import SLIM_MODE_LABELS
        self._compute_estimates()
        marker_idx = self._marker_idx
        pre_bytes = self._pre_bytes
        post_bytes = self._post_bytes
        initial_anti_on = bool(pref_get("slim_default_anti_fragmentation", True))
        initial_compact_on = self._visible_cap_compact_default() if initial_anti_on else False

        with Vertical(id="slim-box"):
            # ── 헤더 (3-section) ──────────────────────────────────────
            with Horizontal(id="slim-header"):
                yield Static("[b]GccForK[/]", id="slim-brand", markup=True)
                yield Static(
                    f"[b]🔻 슬림 fork[/]  [dim]·  v{GCCFORK_VERSION}[/]",
                    id="slim-title", markup=True,
                )
                yield Static(
                    f"[dim]marker idx[/] [b]{marker_idx}[/]" if marker_idx is not None
                    else "[dim]압축 이력 없음[/]",
                    id="slim-marker-meta", markup=True,
                )

            # ── 본문 — 스크롤 없이 내용에 맞춰 자동 크기 ─────────
            with Vertical(id="slim-scroll"):
                # ─── [SESSION] 세션 이름 ────────────────────────────
                with Vertical(classes="slim-section", id="slim-session-section"):
                    with Horizontal(classes="slim-section-head"):
                        yield Static(
                            "[b][SESSION][/] 세션 이름",
                            classes="slim-section-title", markup=True,
                        )
                        yield Static("", classes="slim-spacer")
                        yield Static(
                            f"[dim]세션 ID:[/] [b]{self.session.short_id}[/]",
                            classes="slim-section-meta", markup=True,
                        )
                    yield Input(value=self.default_name, id="slim-name-input")

                # ─── [SCOPE] compact marker + context cap 통합 분석 ─────
                with Vertical(classes="slim-section", id="slim-result-section"):
                    with Horizontal(id="slim-analysis-head", classes="slim-section-head"):
                        yield Static(
                            "[b][ANALYSIS][/] 슬림 적용 범위",
                            classes="slim-section-title", markup=True,
                        )
                        yield Static("", classes="slim-spacer")
                        yield SlimBrainButton()
                    yield Static(
                        self._scope_tree_text(initial_compact_on, initial_anti_on),
                        id="slim-scope-tree",
                        markup=True,
                    )
                    yield Static(
                        self._scope_status_text(initial_compact_on, initial_anti_on),
                        id="slim-scope-status",
                        classes="slim-result-target",
                        markup=True,
                    )
                    yield Button("상세보기", id="btn-slim-details")
                    details = Static(
                        self._scope_details_text(initial_compact_on, initial_anti_on),
                        id="slim-scope-details",
                        classes="slim-result-target",
                        markup=True,
                    )
                    details.display = False
                    yield details
                    if marker_idx is not None:
                        plan = Static(
                            self._plan_summary_text(initial_compact_on, initial_anti_on),
                            id="slim-scope-plan",
                            classes="slim-result-target",
                            markup=True,
                        )
                        plan.display = False
                        yield plan
                        warning = Static(
                            "[b yellow]⚠ context 비포함 영역이 다시 컨텍스트에 들어올 수 있음[/]",
                            id="slim-scope-warning",
                            classes="slim-result-target",
                            markup=True,
                        )
                        warning.display = False
                        yield warning
                    else:
                        total_kb = (self.session.size_bytes or 0) / 1024
                        yield Static(
                            f"[dim]전체[/] [b]{total_kb:.1f} KB[/]",
                            markup=True,
                        )

                # ─── [MODE] 슬림 모드 선택 — 4-column 카드 ────────
                with Vertical(classes="slim-section", id="slim-mode-section"):
                    yield Static(
                        "[b][MODE][/] 슬림 모드 선택",
                        classes="slim-section-title", markup=True,
                    )
                    with Horizontal(id="slim-mode-row"):
                        for mode in ("strong", "medium", "weak"):
                            card = ModeCard(
                                self._mode_card_text(mode, initial_compact_on, initial_anti_on),
                                id=f"slim-mode-{mode}",
                                classes="slim-mode-card",
                                markup=True,
                            )
                            if mode == self._selected_mode:
                                card.add_class("-selected")
                            yield card

                # ─── [OPTION] 메인 토글 + sub 옵션 (체크 시 펼침) ──
                with Vertical(classes="slim-section", id="slim-option-section"):
                    yield Static(
                        "[b][OPTION][/] 옵션",
                        classes="slim-section-title", markup=True,
                    )
                    # 디폴트는 settings pref `slim_default_anti_fragmentation` 따름 (기본 ON).
                    # 내부 이름은 anti_fragmentation 이지만 UI 의미는 "번들(묶음) 처리".
                    yield Checkbox(
                        "번들(묶음) 처리 (context 포함 영역을 큰 묶음으로 정리)",
                        value=bool(pref_get("slim_default_anti_fragmentation", True)),
                        id="slim-anti-frag",
                    )
                    # 새 옵션 (2026-05-13) — context 비포함 영역을 native compact marker 앞으로 보냄.
                    # cap_overflow 일 때만 표시.
                    if self._cap_overflow:
                        yield Checkbox(
                            f"context 비포함 압축본화 (cap {self._visible_cap} 밖)",
                            value=initial_compact_on,
                            id="slim-visible-cap-compact",
                        )
                    # 슬림 후 자동 열기 — 디폴트는 settings pref `slim_default_reload`
                    yield Checkbox(
                        "슬림 후 자동 열기",
                        value=bool(pref_get("slim_default_reload", True)),
                        id="slim-resume-after",
                    )
                    if self.other_env:
                        if self.other_env == "vscode":
                            other_label = "    └ VSCode 로 보내기 (bridge 사용)"
                        elif self.other_env == "gnome-terminal":
                            other_label = "    └ gnome-terminal 로 보내기"
                        else:
                            other_label = f"    └ {self.other_env} 로 보내기"
                        # 디폴트는 settings pref `slim_default_send_other_env`
                        yield Checkbox(
                            other_label,
                            value=bool(pref_get("slim_default_send_other_env", False)),
                            id="slim-other-env",
                        )
                    # 디폴트는 settings pref `slim_default_newtab`
                    yield Checkbox(
                        "    └ 새 탭으로 열기 (해제 = 새 창)",
                        value=bool(pref_get("slim_default_newtab", False)),
                        id="slim-newtab",
                    )

            # ── 푸터 — 시작/취소 버튼만 (양 끝 정렬) ────────────
            with Horizontal(id="slim-btn-row"):
                yield Button("Esc 취소", id="btn-slim-cancel")
                yield Static("", id="slim-btn-spacer")
                yield Button("Enter 슬림 시작", id="btn-slim-go", variant="primary")

    def on_mount(self) -> None:
        try:
            self.query_one("#btn-slim-go", Button).focus()
        except Exception:
            pass
        self._update_sub_options_visibility()
        self._refresh_slim_plan_view()

    def on_checkbox_changed(self, event: Checkbox.Changed) -> None:
        if event.checkbox.id in ("slim-resume-after", "slim-other-env"):
            self._update_sub_options_visibility()
        if event.checkbox.id in ("slim-anti-frag", "slim-visible-cap-compact"):
            self._refresh_slim_plan_view()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id or ""
        if bid == "btn-slim-cancel":
            self.dismiss(None)
        elif bid == "btn-slim-go":
            self._submit()
        elif bid == "btn-slim-details":
            self._details_open = not self._details_open
            self._refresh_slim_plan_view()
        elif bid == "btn-slim-brain":
            self._open_slim_brain_agent()

    def on_input_submitted(self, event: Input.Submitted) -> None:
        if event.input.id == "slim-name-input":
            self._submit()

    def _select_mode(self, mode: str) -> None:
        """ModeCard 가 호출 — selected 상태 + 시각 갱신 + 모드 표시 카드 마커."""
        if mode not in ("strong", "medium", "weak"):
            return
        self._selected_mode = mode
        # 모든 카드의 -selected 클래스 토글 + ●/○ 마커 갱신
        from gccfork_settings import SLIM_MODE_LABELS
        for m in ("strong", "medium", "weak"):
            try:
                card = self.query_one(f"#slim-mode-{m}", ModeCard)
                if m == mode:
                    card.add_class("-selected")
                else:
                    card.remove_class("-selected")
                # 라벨 첫 글자 ●/○ 갱신 — 기존 텍스트 첫 줄 시작 부분만 교체
                # 텍스트 재생성은 비싸니 간단히 쓰지 않고 클래스만 토글 (CSS 로 시각 강조)
            except Exception:
                pass
        self._refresh_slim_plan_view()

    def _current_spawn_mode(self) -> str:
        try:
            newtab = self.query_one("#slim-newtab", Checkbox).value
        except Exception:
            newtab = False
        return "tab" if newtab else "window"

    def _current_target_terminal(self) -> Optional[str]:
        if not self.other_env:
            return None
        try:
            checked = self.query_one("#slim-other-env", Checkbox).value
        except Exception:
            checked = False
        return self.other_env if checked else None

    def _submit(self) -> None:
        mode = self._selected_mode
        try:
            name = self.query_one("#slim-name-input", Input).value.strip() or self.default_name
        except Exception:
            name = self.default_name
        try:
            resume_after = bool(self.query_one("#slim-resume-after", Checkbox).value)
        except Exception:
            resume_after = False
        try:
            anti_frag = bool(self.query_one("#slim-anti-frag", Checkbox).value)
        except Exception:
            anti_frag = False
        # visible_cap_compact (선택 A) — cap_overflow + checkbox ON 일 때만 활성.
        visible_cap = 0
        if self._cap_overflow:
            try:
                if self.query_one("#slim-visible-cap-compact", Checkbox).value:
                    visible_cap = self._visible_cap
            except Exception:
                pass
        self.dismiss({
            "mode": mode,
            "name": name,
            "resume_after": resume_after,
            "anti_fragmentation": anti_frag,
            "visible_cap": visible_cap,
            "spawn_mode": self._current_spawn_mode(),
            "target_terminal": self._current_target_terminal(),
        })

    def action_cancel(self) -> None:
        self.dismiss(None)


class CodexSlimModeScreen(ModalScreen[Optional[dict]]):
    """Codex JSONL slim 옵션 선택."""

    BINDINGS = [
        Binding("escape", "cancel", "취소", show=False),
        Binding("q", "cancel", "취소", show=False),
    ]

    DEFAULT_KEEP = {
        "safe": 10,
        "strong": 3,
    }

    MODE_HINTS = {
        "safe": "안전 · compact 요약 전부 + 최근 10턴 raw",
        "strong": "강력 · compact 요약 전부 + 최근 3턴 raw",
    }

    def __init__(
        self,
        session: Session,
        default_mode: str = "strong",
        other_env: Optional[str] = None,
        current_terminal: Optional[str] = None,
    ) -> None:
        super().__init__()
        self.session = session
        if default_mode in {"weak", "medium", "safe"}:
            default_mode = "safe"
        elif default_mode in {"heavy-strong", "strong"}:
            default_mode = "strong"
        self._selected_mode = default_mode if default_mode in self.DEFAULT_KEEP else "strong"
        self.other_env = other_env
        self.current_terminal = current_terminal

    def _mode_text(self, mode: str) -> str:
        keep = self.DEFAULT_KEEP[mode]
        return (
            f"[b]{mode}[/]\n"
            f"최근 [b]{keep}[/] user turn 원본 보존\n"
            f"[dim]{self.MODE_HINTS[mode]}[/]"
        )

    def _default_clone_name(self) -> str:
        parent_title = _clean_parent_title(self.session.title)
        base = f"{parent_title} " if parent_title else ""
        return f"{base}🔻~????[<= ~{self.session.id[-4:]}]"[:120]

    def _resume_enabled(self) -> bool:
        try:
            return bool(self.query_one("#codex-slim-resume-after", Checkbox).value)
        except Exception:
            return False

    def _default_keep_recent(self) -> int:
        try:
            value = int(pref_get("codex_slim_keep_recent", self.DEFAULT_KEEP[self._selected_mode]) or 0)
        except Exception:
            value = 0
        return value if value > 0 else self.DEFAULT_KEEP[self._selected_mode]

    def _effective_target(self) -> Optional[str]:
        if self.other_env:
            try:
                if self.query_one("#codex-slim-other-env", Checkbox).value:
                    return self.other_env
            except Exception:
                pass
        return self.current_terminal

    def _update_sub_options_visibility(self) -> None:
        resume = self._resume_enabled()
        try:
            other = self.query_one("#codex-slim-other-env", Checkbox)
            show_other = bool(resume and self.other_env)
            other.display = show_other
            if not show_other:
                other.value = False
        except Exception:
            pass
        try:
            newtab = self.query_one("#codex-slim-newtab", Checkbox)
        except Exception:
            return
        if not resume:
            newtab.display = False
            newtab.value = False
            return
        show = self._effective_target() != "vscode"
        newtab.display = show
        if not show:
            newtab.value = False

    def compose(self) -> ComposeResult:
        size_kb = (self.session.size_bytes or 0) / 1024
        with Vertical(id="slim-box"):
            with Horizontal(id="slim-header"):
                yield Static("[b]GccForK[/]", id="slim-brand", markup=True)
                yield Static("[b]🔻 Codex 슬림[/]", id="slim-title", markup=True)
                yield Static(
                    f"[dim]SID[/] [b]{_display_session_id(self.session)}[/]",
                    id="slim-marker-meta",
                    markup=True,
                )
            with Vertical(id="slim-scroll"):
                with Vertical(classes="slim-section"):
                    yield Static("[b][SESSION][/] 대상", classes="slim-section-title", markup=True)
                    yield Static(
                        f"{self.session.title}\n[dim]{self.session.jsonl_path} · {size_kb:.1f} KB[/]",
                        markup=True,
                    )
                with Vertical(classes="slim-section"):
                    yield Static("[b][MODE][/] 슬림 모드", classes="slim-section-title", markup=True)
                    with Horizontal(id="slim-mode-row"):
                        for mode in ("safe", "strong"):
                            card = ModeCard(
                                self._mode_text(mode),
                                id=f"codex-slim-mode-{mode}",
                                classes="slim-mode-card",
                                markup=True,
                            )
                            if mode == self._selected_mode:
                                card.add_class("-selected")
                            yield card
                with Vertical(classes="slim-section"):
                    yield Static("[b][OPTION][/] 옵션", classes="slim-section-title", markup=True)
                    yield Input(
                        value=str(self._default_keep_recent()),
                        id="codex-slim-keep-recent",
                        placeholder="최근 user turn 보존 개수",
                    )
                    yield Checkbox(
                        "이전 compact/압축 요약을 새 컨텍스트에 포함",
                        value=bool(pref_get("codex_slim_include_compact_summaries", True)),
                        id="codex-slim-include-compact-summaries",
                    )
                    yield Static(
                        "압축요약 #1..N → 현재 slim 본문 → 최근 raw 보호 턴 순서로 구성",
                        classes="settings-item-hint",
                    )
                    yield Checkbox(
                        "원본 보존: slim 복제본 생성",
                        value=bool(pref_get("codex_slim_default_clone", False)),
                        id="codex-slim-clone",
                    )
                    yield Input(
                        value=self._default_clone_name(),
                        id="codex-slim-name-input",
                        placeholder="복제본 이름",
                    )
                    yield Checkbox(
                        "슬림 후 자동 열기",
                        value=bool(pref_get("codex_slim_default_reload", True)),
                        id="codex-slim-resume-after",
                    )
                    if self.other_env:
                        yield Checkbox(
                            f"    └ {self.other_env} 로 보내기",
                            value=bool(pref_get("codex_slim_default_send_other_env", False)),
                            id="codex-slim-other-env",
                        )
                    yield Checkbox(
                        "    └ 새 탭으로 열기 (해제 = 새 창)",
                        value=bool(pref_get("codex_slim_default_newtab", False)),
                        id="codex-slim-newtab",
                    )
            with Horizontal(id="slim-btn-row"):
                yield Button("Esc 취소", id="btn-codex-slim-cancel")
                yield Static("", id="slim-btn-spacer")
                yield Button("Enter 슬림 시작", id="btn-codex-slim-go", variant="primary")

    def on_mount(self) -> None:
        self._update_sub_options_visibility()
        try:
            self.query_one("#btn-codex-slim-go", Button).focus()
        except Exception:
            pass

    def on_checkbox_changed(self, event: Checkbox.Changed) -> None:
        if event.checkbox.id in ("codex-slim-resume-after", "codex-slim-other-env"):
            self._update_sub_options_visibility()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id or ""
        if bid == "btn-codex-slim-cancel":
            self.dismiss(None)
        elif bid == "btn-codex-slim-go":
            self._submit()

    def _select_mode(self, mode: str) -> None:
        if mode not in self.DEFAULT_KEEP:
            return
        self._selected_mode = mode
        for m in self.DEFAULT_KEEP:
            try:
                card = self.query_one(f"#codex-slim-mode-{m}", ModeCard)
                if m == mode:
                    card.add_class("-selected")
                else:
                    card.remove_class("-selected")
            except Exception:
                pass
        try:
            self.query_one("#codex-slim-keep-recent", Input).value = str(self.DEFAULT_KEEP[mode])
        except Exception:
            pass

    def _current_spawn_mode(self) -> str:
        try:
            return "tab" if self.query_one("#codex-slim-newtab", Checkbox).value else "window"
        except Exception:
            return "window"

    def _current_target_terminal(self) -> Optional[str]:
        if not self.other_env:
            return None
        try:
            return self.other_env if self.query_one("#codex-slim-other-env", Checkbox).value else None
        except Exception:
            return None

    def _submit(self) -> None:
        try:
            keep_recent = int(self.query_one("#codex-slim-keep-recent", Input).value.strip())
        except Exception:
            keep_recent = self.DEFAULT_KEEP[self._selected_mode]
        if keep_recent < 1:
            keep_recent = self.DEFAULT_KEEP[self._selected_mode]
        try:
            clone = bool(self.query_one("#codex-slim-clone", Checkbox).value)
        except Exception:
            clone = False
        try:
            include_compact_summaries = bool(
                self.query_one("#codex-slim-include-compact-summaries", Checkbox).value
            )
        except Exception:
            include_compact_summaries = True
        try:
            clone_name = self.query_one("#codex-slim-name-input", Input).value.strip()
        except Exception:
            clone_name = self._default_clone_name()
        try:
            resume_after = bool(self.query_one("#codex-slim-resume-after", Checkbox).value)
        except Exception:
            resume_after = False
        self.dismiss({
            "mode": self._selected_mode,
            "keep_recent": keep_recent,
            "include_compact_summaries": include_compact_summaries,
            "clone": clone,
            "name": clone_name,
            "resume_after": resume_after,
            "spawn_mode": self._current_spawn_mode(),
            "target_terminal": self._current_target_terminal(),
        })

    def action_cancel(self) -> None:
        self.dismiss(None)


class SmartDeleteScreen(ModalScreen[str]):
    DEFAULT_BOX_WIDTH = 82
    MIN_BOX_WIDTH = 64

    def __init__(
        self,
        session_id: str,
        session_title: str,
        note_text: str,
        pid_lines: list[str],
        exact_pids: list[int],
        bullet_sessions: Optional[dict[int, str]] = None,
    ) -> None:
        super().__init__()
        self.session_id = session_id
        self.session_title = session_title or "(이름 없음)"
        self.note_text = note_text
        self.pid_lines = pid_lines if pid_lines else ["표시할 프로세스 정보가 없습니다."]
        self.exact_pids = exact_pids
        self.bullet_sessions = bullet_sessions or {}

    def compose(self) -> ComposeResult:
        with Vertical(id="delete-box"):
            yield Static("세션 삭제 확인 (휴지통으로 이동)", id="delete-header")
            with Vertical(id="delete-info"):
                yield Static(
                    f"세션ID : {self.session_id}",
                    id="delete-row-sid",
                    classes="delete-info-row -filled",
                )
                yield Static(
                    f"제목/이름 : {self.session_title}",
                    id="delete-row-title",
                    classes="delete-info-row -filled",
                )
                yield Static(
                    self.note_text,
                    id="delete-row-note",
                    classes="delete-info-row -note",
                )
            with Vertical(id="delete-pid-panel"):
                yield SelectableTextArea(
                    "\n".join(self.pid_lines),
                    id="delete-pid-list",
                    read_only=True,
                    show_cursor=False,
                    soft_wrap=True,
                    compact=True,
                    highlight_cursor_line=False,
                )
            with Horizontal(id="delete-footer"):
                yield Static("Esc", id="delete-esc")
                yield Static("", id="delete-footer-spacer")
                yield Button("취소", id="btn-del-cancel")
                if self.exact_pids:
                    yield Button(
                        f"닫고 삭제 ({len(self.exact_pids)})",
                        id="btn-kill-delete",
                        variant="warning",
                    )
                yield Button("삭제", id="btn-delete-only", variant="error")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-del-cancel", Button).focus()
        self.call_after_refresh(self._finalize_layout)

    def _finalize_layout(self) -> None:
        delete_box = self.query_one("#delete-box", Vertical)
        pid_area = self.query_one("#delete-pid-list", TextArea)

        screen_width = self.size.width or 100
        box_width = min(
            self.DEFAULT_BOX_WIDTH,
            max(self.MIN_BOX_WIDTH, screen_width - 4),
        )
        delete_box.styles.width = box_width

        # 박스 테두리(2) + 박스 패딩(2) + 패널 테두리(2) + 패널 패딩(2) = 8
        content_width = max(10, box_width - 8)
        total_rows = sum(
            max(1, math.ceil(cell_len(line) / content_width)) for line in self.pid_lines
        )
        pid_area.styles.height = max(1, total_rows)
        _apply_bullet_highlights(pid_area, pid_area.text, self.bullet_sessions)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-kill-delete":
            self.dismiss("kill-and-delete")
        elif bid == "btn-delete-only":
            self.dismiss("delete-only")
        elif bid == "btn-del-cancel":
            self.dismiss("cancel")

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss("cancel")


class GCCForkApp(MergeMixin, ArchiveMixin, DeepSearchMixin, TuiRequestPollerMixin, ConfigFilesMixin, App):
    ALLOW_SELECT = False
    LIST_THEME_NAME = "gccfork-session-list"
    LIST_HEADER_ROWS = 2
    LIST_CHECKBOX_WIDTH = 3  # "[ ] " 또는 "[x] " 다중선택 체크박스 컬럼
    LIST_MARK_WIDTH = 2
    LIST_ID_WIDTH = 6   # "● " + 4-char display id ("019e" / "~e94")
    LIST_TIME_WIDTH = 11
    LIST_TURN_WIDTH = 9   # "999(999)" = 8자 → 9 여유
    LIST_SIZE_WIDTH = 5   # 원래대로 — 12.5M 소수점 표시 그대로
    MIN_PANE_WIDTH = 24
    PANE_DIVIDER_WIDTH = 1

    CSS = """
    Screen { layout: vertical; }

    /* 토스트 알림을 기본 우하단 → 상단 중앙 맞춤으로.
       Textual의 기본 CSS:
         ToastRack   → dock: bottom; align: right bottom;
         ToastHolder → align-horizontal: right;
       두 곳 다 override 필요. */
    ToastRack {
        dock: top;
        align: center top;
        margin-top: 1;
        margin-bottom: 0;
    }
    ToastHolder {
        align-horizontal: center;
    }

    #title-bar {
        height: 3;
        background: $accent 30%;
        color: $text;
        border-bottom: heavy $accent;
        padding: 0 2;
    }

    #title-bar-spacer {
        height: 1;
    }

    #title-bar-row {
        height: 1;
        width: 1fr;
