def _read_path_marker(path: Path) -> Optional[Path]:
    try:
        value = path.read_text(encoding="utf-8").strip()
    except OSError:
        return None
    if not value:
        return None
    return Path(value).expanduser()


def _default_repo_root() -> Path:
    env_value = os.environ.get("GCCFORK_REPO_ROOT")
    if env_value:
        return Path(env_value).expanduser()
    marker = _read_path_marker(Path.home() / ".local" / "share" / "gccfork" / "repo-root")
    if marker is not None:
        return marker
    return Path(__file__).resolve().parent.parent


def _default_codex_rs_root() -> Optional[Path]:
    env_value = os.environ.get("CODEX_RS_ROOT")
    if env_value:
        return Path(env_value).expanduser()
    return _read_path_marker(Path.home() / ".local" / "share" / "gccfork" / "codex-rs-root")


