    async def action_open_brain_agent(self) -> None:
        """🧠 Brain agent entry — title-bar BrainButton click handler.

        Surfaces a modal letting the user choose between resuming the
        most recent brain session and starting a fresh one. The chosen
        path is dispatched to `_spawn_brain_agent`.
        """
        latest = self._find_latest_brain_session()
        has_existing = latest is not None
        label = ""
        if latest is not None:
            try:
                ts = latest.jsonl_path.stat().st_mtime
                import datetime as _dt
                label = _dt.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M")
            except Exception:
                label = ""

        def _on_choice(choice: Optional[str]) -> None:
            if not choice:
                return
            if choice == "resume" and latest is not None:
                self._spawn_brain_agent(resume_sid=latest.id)
            elif choice == "new":
                self._spawn_brain_agent(resume_sid=None)

        self.push_screen(
            BrainAgentChoiceScreen(has_existing=has_existing, latest_label=label),
            _on_choice,
        )

    def action_unfold(self) -> None:
        """Unfold: segmented slimming by auto-compact boundary.

        ca09 experiment validation on 5/4: 21.9 MB -> 5.27 MB (-75.9%),
        about 12x better than simple slim at -6.3%.

        Flow:
          1. Check selected_session() for single selection.
          2. detect_compact_boundaries; if zero, notify and exit.
          3. UnfoldConfirmScreen shows N markers and choices.
          4. Run unfold with automatic backup, in-place.
          5. Notify result with savings and segment stats.
          6. Refresh the tree.
        """
        # Phase E (2026-05-06): unfold_session / format_unfold_summary were archived.
        # Calls now go through _call_rust_unfold_inplace() / _call_rust_unfold_bundle().
        from gccfork_unfold import (
            UnfoldConfirmScreen,
            detect_compact_boundaries,
        )

        session = self.selected_session()
        if not session:
            try:
                self.notify("🪚 Unfold: select a session.", severity="warning")
            except Exception:
                pass
            return
        if session.source == "codex":
            self.notify("Codex sessions are not unfold targets.", severity="warning", timeout=6)
            return

        # Refuse active sessions at TUI level; backend also blocks again.
        try:
            from gccfork_sessions import all_active_sid_pid_map
            if session.id in all_active_sid_pid_map():
                self.notify(
                    f"🪚 Unfold refused: active session {session.id[:8]} cannot be unfolded. "
                    f"Run /quit first and retry.",
                    severity="error",
                    timeout=8.0,
                )
                return
        except Exception:
            pass

        # Boundary detection: if zero, only notify.
        boundaries = detect_compact_boundaries(session.jsonl_path)
        if not boundaries:
            try:
                self.notify(
                    f"🪚 {session.id[:8]} — 0 auto-compact markers; nothing to unfold.",
                    severity="information",
                )
            except Exception:
                pass
            return

        # Modal callback.
        def on_choice(result: Optional[dict]) -> None:
            if not result:
                return
            choice = result.get("choice", "rb-all")

            # Bundle mode: since Phase E (2026-05-06), Rust handles it in one pass.
            # Python bundle_unfold_session body was archived.
            if choice == "rb-bundle":
                recent_keep = result.get("recent_keep", 5)
                try:
                    bundle_result = _call_rust_unfold_bundle(
                        session=session,
                        keep_recent_turns=recent_keep,
                    )
                    summary = (
                        f"🪚 Bundle: {bundle_result['bytes_before']/1024/1024:.1f}MB → "
                        f"{bundle_result['bytes_after']/1024/1024:.2f}MB "
                        f"({100*(1-bundle_result['bytes_after']/max(bundle_result['bytes_before'],1)):+.1f}%)\n"
                        f"  new sid: {bundle_result['new_sid'][:8]}, "
                        f"bundles {bundle_result['n_bundles']}"
                    )
                    try:
                        self.notify(summary, severity="information", timeout=10.0)
                    except Exception:
                        pass
                    try:
                        self.reload_sessions()
                    except Exception:
                        pass
                except FileNotFoundError as e:
                    try:
                        self.notify(f"🪚 Bundle refused: {e}", severity="error", timeout=8.0)
                    except Exception:
                        pass
                except Exception as e:
                    try:
                        self.notify(f"🪚 Bundle failed: {e}", severity="error", timeout=8.0)
                    except Exception:
                        pass
                return

            # Choice mapping for in-place mode.
            if choice == "rb-all":
                selected = None  # All except the last one, default.
            elif choice == "rb-except-last":
                selected = list(range(len(boundaries)))  # 0..N-1, equivalent to excluding the last.
                # N boundaries means N+1 segments and the last index is N; handle as default.
                selected = None
            else:
                return

            # Phase E (2026-05-06): Rust unfold-inplace handles this in one pass.
            # Python unfold_session body was archived. selected_segments is unsupported
            # by Rust, so use the default behavior of fully slimming all except the last.
            try:
                result_obj = _call_rust_unfold_inplace(
                    session=session,
                    keep_recent_turns_last=5,
                    mode="strong",
                )
            except FileNotFoundError as e:
                try:
                    self.notify(f"🪚 Unfold refused: {e}", severity="error", timeout=8.0)
                except Exception:
                    pass
                return
            except ValueError as e:
                # Zero markers, no compaction.
                try:
                    self.notify(str(e), severity="information")
                except Exception:
                    pass
                return
            except Exception as e:
                try:
                    self.notify(f"🪚 Unfold failed: {e}", severity="error", timeout=8.0)
                except Exception:
                    pass
                return

            # Result notification.
            summary = (
                f"🪚 Unfold: {result_obj['bytes_before']/1024/1024:.1f}MB → "
                f"{result_obj['bytes_after']/1024/1024:.2f}MB "
                f"({100*(1-result_obj['bytes_after']/max(result_obj['bytes_before'],1)):+.1f}%)\n"
                f"  segments={result_obj['n_segments']} markers={result_obj['n_markers']} "
                f"kept={result_obj['kept']} dropped={result_obj['dropped']}"
            )
            try:
                self.notify(summary, severity="information", timeout=10.0)
            except Exception:
                pass

            # Refresh tree.
            try:
                self.reload_sessions()
            except Exception:
                pass

        try:
            self.push_screen(UnfoldConfirmScreen(session, boundaries), on_choice)
        except Exception as e:
            try:
                self.notify(f"🪚 Modal failed: {e}", severity="error")
            except Exception:
                pass

    def action_slim_fork(self) -> None:
        """Slim: always in-place with the same SID; bundle option is also in-place.

        Generalized flow as of 2026-05-06:
          1. SlimModeScreen with strong/medium/weak plus bundle option.
          2. On selection, call slim_fork_session_with(in_place=True).
          3. Update only the same SID JSONL; tree does not change; .bak backup is automatic.
          4. /slim command, TUI button, and CLI all use the same in-place behavior.
        """
        session = self.selected_session()
        if not session:
            return
        if session.source == "codex":
            self._action_codex_slim(session)
            return

        # Refuse active sessions; in-place slim is risky while Claude is writing JSONL.
        try:
            from gccfork_sessions import all_active_sid_pid_map as _amap
            if session.id in _amap():
                self.notify(
                    f"🔻 Slim refused: active session {session.id[:8]} cannot be slimmed in-place. "
                    f"Run /quit first and retry.",
                    severity="error", timeout=8.0,
                )
                return
        except Exception:
            pass

        current_terminal = _detect_terminal()
        other_env = _other_environment(current_terminal)

        def on_mode_done(result: Optional[dict]) -> None:
            if not result:
                return
            mode = result.get("mode", "strong")
            resume_after = bool(result.get("resume_after", False))
            anti_frag = bool(result.get("anti_fragmentation", False))
            visible_cap = int(result.get("visible_cap", 0) or 0)
            spawn_mode = result.get("spawn_mode", "window")
            target_terminal = result.get("target_terminal")

            try:
                # In-place slim: same SID, JSONL only.
                keep_turns = int(
                    pref_get(
                        f"slim_{mode}_keep_recent_turns",
                        {"strong": 5, "medium": 10, "weak": 30}.get(mode, 5),
                    ) or 5
                )
                stats_dict = slim_fork_session_with(
                    session, session.id, session.custom_name or "", mode,
                    in_place=True,
                    anti_fragmentation=anti_frag,
                    visible_cap=visible_cap,
                    keep_recent_turns=keep_turns,
                )
            except Exception as exc:
                self.notify(
                    f"Slim failed: {type(exc).__name__}: {exc}",
                    severity="error",
                )
                return
            # In-place result is a dict from slim_anti_frag_session or stats.
            stats = ""
            if isinstance(stats_dict, dict):
                if "kept" in stats_dict:
                    bb = stats_dict.get("bytes_before", 0)
                    ba = stats_dict.get("bytes_after", 0)
                    pct = (1 - ba / max(bb, 1)) * 100
                    stats = f" — {bb/1024/1024:.1f}MB → {ba/1024/1024:.2f}MB ({pct:+.0f}%)"
                    if "n_bundles" in stats_dict:
                        stats += f" / bundles {stats_dict['n_bundles']}"
            vc_label = f" + compact cap={visible_cap}" if visible_cap > 0 else ""
            mode_label = ("bundle processing" + vc_label) if anti_frag else mode
            self.notify(
                f"✓ Slim complete ({mode_label}): {session.short_id}{stats}"
            )
            self.reload_sessions()

            # resume_after option: spawn again with the same SID.
            if resume_after:
                try:
                    self._launch_claude_new_terminal(
                        "resume", session,
                        spawn_mode=spawn_mode,
                        target_terminal=target_terminal,
                    )
                except Exception as exc:
                    self.notify(
                        f"Resume failed: {type(exc).__name__}: {exc}",
                        severity="warning",
                    )

        self.push_screen(
            SlimModeScreen(
                session,
                default_mode=str(pref_get("slim_default_mode", "strong")),
                other_env=other_env,
                current_terminal=current_terminal,
            ),
            on_mode_done,
        )

    def _action_codex_slim(self, session: Session) -> None:
        current_terminal = _detect_terminal()
        other_env = _other_environment(current_terminal)

        def on_done(result: Optional[dict]) -> None:
            if not result:
                return
            mode = str(result.get("mode") or "strong")
            keep_recent = int(result.get("keep_recent") or 0) or None
            include_compact_summaries = bool(result.get("include_compact_summaries", True))
            trim_recent_tools = bool(result.get("trim_recent_tools", True))
            clone = bool(result.get("clone", False))
            name = result.get("name") or None
            resume_after = bool(result.get("resume_after", True))
            spawn_mode = result.get("spawn_mode", "window")
            target_terminal = result.get("target_terminal")
            active_state = _codex_wrapper_state_for_sid(session.id)

            if active_state and not clone:
                self.notify(
                    "Slimming active Codex session in-place. It will automatically restart in the same terminal after completion.",
                    timeout=8,
                )

            try:
                slimmed = slim_codex_session_with(
                    session,
                    mode=mode,
                    keep_recent=keep_recent,
                    include_compact_summaries=include_compact_summaries,
                    trim_recent_tools=trim_recent_tools,
                    clone=clone,
                    custom_name=name,
                )
            except Exception as exc:
                self.notify(f"Codex slim failed: {type(exc).__name__}: {exc}", severity="error", timeout=10)
                return

            target_sid = str(slimmed.get("sid") or session.id)
            target_path = Path(str(slimmed.get("path") or session.jsonl_path))
            target_session = slimmed.get("session")
            old_size = int(slimmed.get("old_size") or 0)
            new_size = int(slimmed.get("new_size") or 0)
            saved_pct = float(slimmed.get("saved_percent") or 0.0)

            restarted_same_terminal = False
            if active_state:
                try:
                    _write_codex_slim_restart_marker(
                        session_id=target_sid,
                        session_file=target_path,
                        cwd=session.cwd,
                        mode=str(slimmed.get("mode") or mode),
                        keep_recent=int(slimmed.get("keep_recent") or keep_recent or 1),
                        source_pid=int(active_state.get("codex_pid") or 0),
                        wrapper_id=str(active_state.get("wrapper_id") or "") or None,
                    )
                    restarted_same_terminal = True
                except Exception as exc:
                    self.notify(f"Failed to write Codex restart marker: {exc}", severity="error", timeout=10)

            self.reload_sessions()
            self.notify(
                f"✓ Codex slim complete: {old_size/1024:.1f}KB → {new_size/1024:.1f}KB "
                f"({saved_pct:.1f}% saved, mode={slimmed.get('mode')}, "
                f"keep={slimmed.get('keep_recent')}, compact summaries={slimmed.get('compact_summary_count', 0)})",
                timeout=10,
            )

            if restarted_same_terminal:
                self.notify("✓ Sent restart marker to the active Codex terminal.", timeout=8)
                return
            if resume_after:
                reopened = target_session if isinstance(target_session, Session) else _find_codex_session_by_id(target_sid)
                if reopened:
                    self._launch_existing_codex_session(
                        reopened,
                        None,
                        spawn_mode=spawn_mode,
                        target_terminal=target_terminal,
                    )
                else:
                    self.notify(f"Could not find the slimmed session in the list again: {target_sid}", severity="warning", timeout=8)

        self.push_screen(
            CodexSlimModeScreen(
                session,
                default_mode=str(pref_get("codex_slim_default_mode", "strong")),
                other_env=other_env,
                current_terminal=current_terminal,
            ),
            on_done,
        )

    def action_resume(self) -> None:
        """Resume: use ForkNameScreen to choose environment and tab/window each time.

        If the name is changed, apply rename at the same time for convenience.
        """
        session = self.selected_session()
        if not session:
            return
        if session.source == "codex":
            default_name = (
                _display_clone_name(session.custom_name or "")
                or session.auto_summary
                or ""
            )
            current_terminal = _detect_terminal()
            other_env = _other_environment(current_terminal)

            def on_codex_done(result: Optional[dict]) -> None:
                if result is None:
                    return
                new_name = (result.get("name") or "").strip()
                spawn_mode = result.get("spawn_mode", "window")
                target_terminal = result.get("target_terminal")
                open_target = result.get("open_target", "codex")
                if new_name and new_name != default_name.strip():
                    registry_set(session.id, name=new_name)
                    self.reload_sessions()
                    refreshed = next((s for s in self.sessions if s.id == session.id), session)
                else:
                    refreshed = session
                if open_target == "claude":
                    self._launch_claude_from_codex_session(
                        refreshed,
                        new_name or default_name,
                        spawn_mode=spawn_mode,
                        target_terminal=target_terminal,
                    )
                    return
                self._guard_same_session_resume(
                    refreshed,
                    lambda: self._launch_existing_codex_session(
                        refreshed,
                        new_name or default_name,
                        spawn_mode=spawn_mode,
                        target_terminal=target_terminal,
                    ),
                )

            self.push_screen(
                ForkNameScreen(
                    default_name,
                    title="Codex resume — environment / tab / name (optional)",
                    other_env=other_env,
                    current_terminal=current_terminal,
                    open_target_options=[
                        ("codex", "Resume in Codex", True),
                        ("claude", "Open in Claude", False),
                    ],
                ),
                on_codex_done,
            )
            return

        default_name = (
            _display_clone_name(session.custom_name or "")
            or session.auto_summary
            or ""
        )
        current_terminal = _detect_terminal()
        other_env = _other_environment(current_terminal)

        def on_done(result: Optional[dict]) -> None:
            if result is None:
                return
            new_name = (result.get("name") or "").strip()
            spawn_mode = result.get("spawn_mode", "window")
            target_terminal = result.get("target_terminal")
            open_target = result.get("open_target", "claude")

            if open_target == "codex":
                def on_import_options(import_options: Optional[dict]) -> None:
                    if import_options is None:
                        return
                    self._launch_codex_from_claude_session(
                        session,
                        new_name or default_name,
                        spawn_mode=spawn_mode,
                        target_terminal=target_terminal,
                        import_options=import_options,
                    )

                self.push_screen(CodexImportOptionsScreen(), on_import_options)
                return

            # If the user changed the name, apply rename too; skip unchanged defaults.
            if new_name and new_name != default_name.strip():
                registry_set(session.id, name=new_name)
                self.reload_sessions()
                refreshed = find_session_by_id(session.id) or session
            else:
                refreshed = session

            self._guard_same_session_resume(
                refreshed,
                lambda: self._launch_claude_new_terminal(
                    "resume", refreshed, spawn_mode=spawn_mode, target_terminal=target_terminal,
                ),
            )

        self.push_screen(
            ForkNameScreen(
                default_name,
                title="🪴 Resume — environment / tab / name (optional)",
                other_env=other_env,
                current_terminal=current_terminal,
                allow_codex_open=True,
            ),
            on_done,
        )

    def _active_resume_pids_for_session(self, session: Session) -> list[int]:
        if session.source == "codex":
            return sorted(set(_codex_active_sid_pid_map().get(session.id, [])))
        return sorted(set(find_live_pids_by_sid(session.id)))

    def _terminate_resume_pids(self, pids: list[int]) -> list[int]:
        """Terminate active session PIDs and parent bash processes created by gccfork."""
        killed: list[int] = []
        parent_bashes: set[int] = set()
        for pid in pids:
            if pid <= 1:
                continue
            try:
                status = Path(f"/proc/{pid}/status").read_text(errors="ignore")
            except OSError:
                status = ""
            if status:
                m = re.search(r"^PPid:\s*(\d+)", status, re.MULTILINE)
                if m:
                    ppid = int(m.group(1))
                    try:
                        pcmd = Path(f"/proc/{ppid}/cmdline").read_bytes().decode("utf-8", errors="ignore")
                    except OSError:
                        pcmd = ""
                    if "[gccfork]" in pcmd and ("bash" in pcmd or "/bash" in pcmd):
                        parent_bashes.add(ppid)
            try:
                os.kill(pid, signal.SIGTERM)
                killed.append(pid)
            except (ProcessLookupError, PermissionError, OSError):
                pass
        if parent_bashes:
            time.sleep(0.3)
            for ppid in sorted(parent_bashes):
                try:
                    os.kill(ppid, signal.SIGTERM)
                    killed.append(ppid)
                except (ProcessLookupError, PermissionError, OSError):
                    pass
        return killed

    def _wait_resume_pids_exit(self, pids: list[int], timeout: float = 2.0) -> None:
        deadline = time.time() + timeout
        while time.time() < deadline:
            alive = [pid for pid in pids if pid > 1 and Path(f"/proc/{pid}").exists()]
            if not alive:
                return
            time.sleep(0.1)

    def _guard_same_session_resume(self, session: Session, launch: Callable[[], None]) -> None:
        """Prevent duplicate resume for the same SID; allow only terminate-then-resume."""
        pids = self._active_resume_pids_for_session(session)
        if not pids:
            launch()
            return

        source_label = "Codex" if session.source == "codex" else "Claude"
        session_label = f"{_display_session_id(session)}  {_single_line(session.title, default='(untitled)')[:80]}"

        def _on_choice(choice: Optional[str]) -> None:
            if choice != "terminate":
                self.notify("Resume cancelled: already-open session was not duplicated.", severity="information", timeout=5)
                return

            def _worker() -> None:
                killed = self._terminate_resume_pids(pids)
                self._wait_resume_pids_exit(pids)
                def _finish() -> None:
                    if killed:
                        self.notify(f"Resuming after closing existing session: PID {', '.join(str(pid) for pid in killed)}", timeout=6)
                    launch()
                self.call_from_thread(_finish)

            threading.Thread(target=_worker, daemon=True).start()

        self.push_screen(
            ResumeConflictScreen(
                session_label=session_label,
                source_label=source_label,
                pids=pids,
            ),
            _on_choice,
        )

    def action_new_root(self) -> None:
        """New root session: name modal, then `claude --session-id <uuid>` in a new terminal.

        Same pattern as hard fork: gccfork preselects SID before spawn and injects it
        through `claude --session-id <new_uuid>`. The modal shows the first four SID
        chars as a prefix, so the user edits only the suffix. If older claude lacks
        --session-id support, fallback uses cwd+timing heuristics.
        """
        # Pre-generate SID before spawn and enforce through claude --session-id.
        # Older claude falls back when option detection fails; then claude creates its own SID.
        supports_sid = _claude_supports_session_id_option()
        new_uuid: Optional[str] = str(uuid_lib.uuid4()) if supports_sid else None
        sid_prefix = new_uuid[:4] if new_uuid else None

        # Default name: when Claude accepts SID injection, the four chars are separate
        # modal prefix; fallback keeps the old time-based default.
        default_name = f"New session {datetime.now().strftime('%m-%d %H:%M')}"
        current_terminal = _detect_terminal()
        other_env = _other_environment(current_terminal)

        def on_done(result: Optional[dict]) -> None:
            if result is None:
                return
            name = (result.get("name") or default_name).strip() or default_name
            spawn_mode = result.get("spawn_mode", "window")
            target_terminal = result.get("target_terminal")
            open_target = result.get("open_target", "claude")

            cwd = self.current_cwd or os.environ.get("PWD") or os.getcwd()
            if open_target == "codex":
                self._pending_new_roots.append({
                    "name": name,
                    "cwd": normalize_cwd(cwd),
                    "created_at": time.time(),
                    "source": "codex",
                })
                self._launch_codex_new_root(
                    name=name,
                    cwd=cwd,
                    spawn_mode=spawn_mode,
                    target_terminal=target_terminal,
                )
                return

            # Pending registration: direct match if SID exists, else cwd+timing heuristic.
            self._pending_new_roots.append({
                "name": name,
                "cwd": normalize_cwd(cwd),
                "created_at": time.time(),
                "sid": new_uuid,  # None means fallback matching.
            })

            self._launch_claude_new_root(
                name=name,
                cwd=cwd,
                spawn_mode=spawn_mode,
                target_terminal=target_terminal,
                session_id=new_uuid,
            )

        self.push_screen(
            ForkNameScreen(
                default_name,
                title="✨ New session — target / name",
                other_env=other_env,
                current_terminal=current_terminal,
                sid_prefix=sid_prefix,
                open_target_options=[
                    ("claude", "New Claude session", True),
                    ("codex", "New Codex session", False),
                ],
            ),
            on_done,
        )

    def _launch_claude_new_root(
        self,
        name: str,
        cwd: str,
        spawn_mode: str = "window",
        target_terminal: Optional[str] = None,
        session_id: Optional[str] = None,
    ) -> None:
        """Spawn `claude` without --resume in a new terminal.

        If session_id exists, preselect SID through `claude --session-id <uuid>`,
        matching the hard-fork pattern. Otherwise claude creates it itself.

        For VS Code targets with two or more bridge instances, ask via
        BridgeTargetPickerScreen, same routing as fork/resume. Without the picker,
        _preferred_vscode_session_id() could choose focused VS Code and route to a
        window different from the user's intent.
        """
        env = _sanitize_env_for_claude()
        env["GCCFORK_PENDING_NEW_ROOT_NAME"] = name
        cmd = ["claude"]
        _add_claude_session_id_if_supported(cmd, session_id)
        _add_claude_name_if_supported(cmd, name[:80])

        effective_target = target_terminal or _detect_terminal()
        # Preselected SID: use sha256-based 12-color selection like fork/resume.
        # color_tag is the VS Code panel ThemeColor; tab_title uses the same 12-color
        # emoji as the gccfork session list.
        if session_id:
            color_tag = _vscode_terminal_color_for_session(session_id)
            color_emoji = _color_for_session(session_id)
            tab_title = f"{color_emoji} 💬 {name}"[:80]
        else:
            color_tag = None
            tab_title = name

        def _do_spawn(pinned_sid: Optional[str] = None) -> None:
            global _pinned_vscode_target_sid
            old_pin = _pinned_vscode_target_sid
            if pinned_sid:
                _pinned_vscode_target_sid = pinned_sid
            try:
                ok, used = _spawn_claude_in_new_terminal(
                    effective_target, cmd, cwd, env, tab_title, spawn_mode, color_tag=color_tag,
                )
            finally:
                _pinned_vscode_target_sid = old_pin
            mode_label = "🪟 new window" if spawn_mode == "window" else "📑 new tab"
            if ok:
                if used == "vscode-bridge":
                    self.notify(f"✓ Created VS Code terminal (new session: {name[:30]})")
                else:
                    self.notify(f"✓ Started new claude session in {used} ({mode_label})")
            else:
                self.notify(f"New terminal spawn failed ({used})", severity="error")

        if effective_target != "vscode":
            _do_spawn()
            return

        # Six-step VS Code routing, same as _launch_claude_new_terminal.
        matches = _find_vscode_for_cwd(cwd) if cwd else []
        all_insts = _bridge_instances()

        # 1. Multiple instances always use picker.
        if len(all_insts) >= 2:
            def _on_pick_strict(picked_sid: Optional[str]) -> None:
                if not picked_sid:
                    return
                _do_spawn(pinned_sid=picked_sid)
            self.push_screen(
                BridgeTargetPickerScreen(all_insts, session_cwd=cwd),
                _on_pick_strict,
            )
            return

        # 2. One focused/self-host target routes automatically.
        focused_sid = _focused_vscode_session_id() or _self_hosting_vscode_session_id()
        if focused_sid:
            _do_spawn(pinned_sid=focused_sid)
            return

        # 3. One cwd match routes automatically.
        if len(matches) == 1:
            _do_spawn(pinned_sid=matches[0].get("sessionId"))
            return

        # 4. Multiple cwd matches use picker.
        if len(matches) > 1:
            def _on_pick_multi(picked_sid: Optional[str]) -> None:
                if not picked_sid:
                    return
                _do_spawn(pinned_sid=picked_sid)
            self.push_screen(
                BridgeTargetPickerScreen(matches, session_cwd=cwd),
                _on_pick_multi,
            )
            return

        # 5. No match with cwd: ask before opening a new VS Code window.
        if cwd:
            def _on_open_confirm(decision: Optional[bool]) -> None:
                if not decision:
                    return
                self.notify(f"📂 Opening VS Code window… ({cwd})", timeout=15)

                def _bg() -> None:
                    new_sid = _open_vscode_for_cwd(cwd)
                    if new_sid:
                        self.call_from_thread(_do_spawn, new_sid)
                    else:
                        self.call_from_thread(
                            self.notify,
                            "Failed to open VS Code window: `code` CLI is not in PATH or bridge did not respond",
                            severity="error",
                        )

                threading.Thread(target=_bg, daemon=True).start()

            self.push_screen(OpenWorkspaceConfirmScreen(cwd), _on_open_confirm)
            return

        # 6. No-cwd fallback: picker over live instances.
        insts = _bridge_instances()
        self_sid = _self_hosting_vscode_session_id()
        if len(insts) > 1 and not self_sid:
            def _on_pick_fb(picked_sid: Optional[str]) -> None:
                if not picked_sid:
                    return
                _do_spawn(pinned_sid=picked_sid)
            self.push_screen(
                BridgeTargetPickerScreen(insts, session_cwd=cwd),
                _on_pick_fb,
            )
            return

        _do_spawn()

    def action_rename(self) -> None:
        session = self.selected_session()
        if not session:
            return

        def on_done(value: Optional[str]) -> None:
            if value is None:
                return
            stripped = value.strip()
            registry_set(session.id, name=stripped if stripped else None)
            # Invalidate parse cache; otherwise reload could return the old custom_name.
            try:
                invalidate_parse_cache(session.jsonl_path)
            except Exception:
                pass
            self.reload_sessions()

        # Default: exactly the visible list name, including legacy format conversion.
        # Fall back to auto_summary when custom_name is missing, making edits easier.
        default = _display_clone_name(session.custom_name or "") or (session.auto_summary or "")
        self.push_screen(RenameScreen(default), on_done)

    def action_trash(self) -> None:
        """Open trash screen and refresh the session list when it closes."""
        def _on_close(_: Optional[None]) -> None:
            self.reload_sessions()
        self.push_screen(TrashScreen(), _on_close)

    def action_delete(self) -> None:
        session = self.selected_session()
        if not session:
            return
        if self._refuse_if_active_sessions([session]):
            return

        # Important sessions get one extra confirmation to prevent mistakes.
        if session.important:
            session_title_short = _single_line(session.title, default="(untitled)")[:80]
            def _on_important_confirm(ok: Optional[bool]) -> None:
                if ok:
                    self._proceed_delete(session)
            self.push_screen(
                ConfirmScreen(
                    message=(
                        f"This session is marked important (★).\n\n"
                        f"  {session.short_id}  {session_title_short}\n\n"
                        f"You are about to delete an important file. Continue?"
                    ),
                    confirm_label="Continue",
                    confirm_variant="error",
                    title="🍂 Delete important file",
                ),
                _on_important_confirm,
            )
            return

        self._proceed_delete(session)

    def _proceed_delete(self, session: "Session") -> None:
        """Original action_delete body, called after important confirmation or for normal sessions."""
        if self._refuse_if_active_sessions([session]):
            return
        # Fast path: match only claude processes with session_id directly in cmdline.
        # Skip fuzzy matching and full rescan so the delete modal opens in milliseconds.
        likely_pids = find_claude_pids_for_session_id(session.id)

        # Find child sessions from cached self.sessions where parent is this session.
        # Deleting a parent orphans children, so warn visibly.
        children: list[Session] = []
        for s in self.sessions:
            if s.id == session.id:
                continue
            if _parent_for(s.id) == session.id:
                children.append(s)

        session_title_for_modal = _single_line(session.title, default="(untitled)")[:120]
        process_lines: list[str] = []
        bullet_sessions: dict[int, str] = {}

        # 1) Child session warning shown first when present.
        if children:
            warn_line = (
                f"⚠ Warning: this session is the parent of {len(children)} child session(s). "
                f"Deleting it will orphan them in the tree."
            )
            process_lines.append(warn_line)
            bullet_sessions[len(process_lines) - 1] = session.id
            for child in children[:8]:
                ctitle = _single_line(child.title, default="(untitled)")[:48]
                process_lines.append(f"   └ {child.short_id}  {ctitle}")
                bullet_sessions[len(process_lines) - 1] = child.id
            if len(children) > 8:
                process_lines.append(f"   …and {len(children) - 8} more")
            process_lines.append("")  # Blank line separator.

        # 2) Running claude process information.
        if likely_pids:
            note_text = f"Note: {len(likely_pids)} Claude process(es) directly linked to this session are running."
            title = _single_line(session.title, default="(untitled)")[:48]
            for pid in likely_pids[:6]:
                process_lines.append(
                    f"● PID={pid}  session={session.short_id}  title={title}"
                )
                bullet_sessions[len(process_lines) - 1] = session.id
        else:
            note_text = "Note: no Claude process directly linked to this session is currently running."
            if not children:
                process_lines.append("● No process information to display.")
                bullet_sessions[len(process_lines) - 1] = session.id

        # Prefix note_text with child warning using Rich markup for color emphasis.
        if children:
            note_text = (
                f"[bold yellow]⚠ Has {len(children)} child session(s); deleting breaks the tree.[/] "
                + note_text
            )

        def do_delete_file() -> bool:
            # Move to trash instead of immediate unlink; fall back to unlink on failure.
            if move_session_to_trash(session.id, session.jsonl_path):
                return True
            try:
                session.jsonl_path.unlink()
            except FileNotFoundError:
                pass
            except OSError as exc:
                self.notify(f"Delete failed: {exc}", severity="error")
                return False
            registry_remove(session.id)
            return True

        def do_kill_pids(pids: list[int]) -> list[int]:
            """Terminate claude and its parent bash so the terminal closes automatically.

            Previous behavior killed only claude, causing bash to enter `echo; read`
            and requiring manual Enter. New behavior sends SIGTERM to claude, waits
            briefly, then SIGTERM to parent bash so the terminal closes.
            """
            import signal

            # 1. Collect parent bash processes of claude spawned by gccfork wrappers.
            #    Protect unrelated bash processes by requiring a '[gccfork]' cmdline marker.
            parent_bashes: set[int] = set()
            for pid in pids:
                try:
                    status = Path(f"/proc/{pid}/status").read_text(errors="ignore")
                except OSError:
                    continue
                m = re.search(r"^PPid:\s*(\d+)", status, re.MULTILINE)
                if not m:
                    continue
                ppid = int(m.group(1))
                if ppid <= 1:
                    continue
                try:
                    pcmd = Path(f"/proc/{ppid}/cmdline").read_bytes().decode("utf-8", errors="ignore")
                except OSError:
                    continue
                # Bash processes created by gccfork always include a '[gccfork]' message in cmdline.
                if "[gccfork]" in pcmd and ("bash" in pcmd or "/bash" in pcmd):
                    parent_bashes.add(ppid)

            killed: list[int] = []
            # 2. Send SIGTERM to claude first.
            for pid in pids:
                try:
                    os.kill(pid, signal.SIGTERM)
                    killed.append(pid)
                except (ProcessLookupError, PermissionError):
                    continue
            # 3. Send SIGTERM to parent bash after giving claude a short cleanup window.
            #    When bash exits, the pty closes and the terminal tab disappears automatically,
            #    or briefly shows "Process exited" before closing.
            if parent_bashes:
                time.sleep(0.3)
                for ppid in parent_bashes:
                    try:
                        os.kill(ppid, signal.SIGTERM)
                        killed.append(ppid)
                    except (ProcessLookupError, PermissionError):
                        continue
            return killed

        def on_done(choice: str) -> None:
            if choice == "cancel":
                return
            if choice == "kill-and-delete":
                killed = do_kill_pids(likely_pids)
                if killed:
                    self.notify(f"✓ Sent SIGTERM: PID {', '.join(str(pid) for pid in killed)}")
                    time.sleep(1.0)
                if do_delete_file():
                    self.notify(f"Deleted: {session.short_id}")
                    self.reload_sessions()
                return
            if choice == "delete-only":
                if do_delete_file():
                    self.notify(f"Deleted: {session.short_id}")
                    self.reload_sessions()

        self.push_screen(
            SmartDeleteScreen(
                session_id=session.id,
                session_title=session_title_for_modal,
                note_text=note_text,
                pid_lines=process_lines,
                exact_pids=likely_pids,
                bullet_sessions=bullet_sessions,
            ),
            on_done,
        )


def _sanitize_env_for_claude() -> dict:
    """Remove uv-script venv pollution so child claude hooks see system Python.

    `gccfork` runs as a uv PEP 723 single-file script, so it may carry
    `VIRTUAL_ENV`, `UV_*`, and `PYTHONHOME`. If subprocess calls inherit that
    environment, child claude Stop/PreCompact hooks may see uv venv Python and
    behave as if system packages such as numpy disappeared.
    """
    env = os.environ.copy()
    venv = env.pop("VIRTUAL_ENV", None)
    env.pop("UV", None)
    env.pop("UV_RUN_RECURSION_DEPTH", None)
    env.pop("UV_PROJECT_ENVIRONMENT", None)
    env.pop("PYTHONHOME", None)
    if venv:
        venv_bin = f"{venv}/bin"
        parts = env.get("PATH", "").split(":")
        env["PATH"] = ":".join(part for part in parts if part and part != venv_bin)
    return env


def _compute_tree_prefix(session_id: str) -> str:
    depth = _compute_fork_depth(session_id)
    if depth <= 0:
        return ""
    return ("  " * depth) + "└─ "


def _tab_display_name(session: Session) -> str:
    """Body text for VS Code terminal tab title before color/tree prefixes.

    - `<display_id> <title>`, or existing title unchanged when it already starts with display_id.
    - `Session <display_id>` when title is missing.
    """
    raw_title = session.custom_name or session.auto_summary or ""
    display_id = _display_session_id(session)
    if session.source == "codex":
        codex_prefix = f"🤖 [{display_id}]"
        if raw_title and raw_title.startswith(codex_prefix):
            return raw_title
        if raw_title:
            return f"{codex_prefix} {raw_title}"
        return f"{codex_prefix} Codex"
    claude_prefix = "💬 "
    if raw_title and raw_title.startswith(claude_prefix):
        return raw_title
    if raw_title and re.match(rf"^{re.escape(display_id)}\b", raw_title):
        return f"{claude_prefix}{raw_title}"
    if raw_title:
        return f"{claude_prefix}{display_id} {raw_title}"
    return f"{claude_prefix}Session {display_id}"


def _tab_title_for(session: Session) -> str:
    """Final tab title in `<color_emoji> <tree_prefix><display_name>` format, capped at 80 chars."""
    if session.source == "codex":
        color = _color_for_session(session.id)
        prefix = _compute_tree_prefix(session.id)
        return f"{color} {prefix}{_tab_display_name(session)}"[:80]
    color = _color_for_session(session.id)
    prefix = _compute_tree_prefix(session.id)
    return f"{color} {prefix}{_tab_display_name(session)}"[:80]


def _tab_title_for_values(
    *,
    session_id: str,
    title: str,
    source: Optional[str] = None,
    parent_id: Optional[str] = None,
    fork_type: Optional[str] = None,
) -> str:
    """Build tab title for derived/new sessions before their JSONL has been scanned."""
    temp = Session(
        id=session_id,
        jsonl_path=Path(""),
        mtime=datetime.now(),
        turn_count=0,
        source=source,
        custom_name=title,
        parent_id=parent_id,
        fork_type=fork_type,
    )
    return _tab_title_for(temp)


def _detect_terminal() -> str:
    """Identify the terminal emulator currently running gccfork.

    Returns:
      "vscode", "wezterm", "iterm", "apple-terminal", "kitty", "konsole",
      "gnome-terminal", "alacritty", "windows-terminal", "terminator",
      "xterm", "unknown"
    """
    env = os.environ
    if env.get("VSCODE_IPC_HOOK_CLI") or env.get("VSCODE_INJECTION") == "1":
        return "vscode"
    tp = (env.get("TERM_PROGRAM") or "").lower()
    if tp == "vscode":
        return "vscode"
    if tp == "wezterm":
        return "wezterm"
    if tp == "iterm.app":
        return "iterm"
    if tp == "apple_terminal":
        return "apple-terminal"
    if env.get("WEZTERM_PANE") or env.get("WEZTERM_EXECUTABLE"):
        return "wezterm"
    if env.get("KITTY_WINDOW_ID"):
        return "kitty"
    if env.get("KONSOLE_VERSION"):
        return "konsole"
    if env.get("GNOME_TERMINAL_SERVICE") or env.get("VTE_VERSION"):
        return "gnome-terminal"
    if env.get("ALACRITTY_SOCKET") or env.get("ALACRITTY_LOG"):
        return "alacritty"
    if env.get("WT_SESSION"):
        return "windows-terminal"
    if env.get("TERMINATOR_UUID"):
        return "terminator"
    if env.get("XTERM_VERSION"):
        return "xterm"
    # If VS Code bridge knows the ancestor PID of current gccfork, classify it as
    # VS Code terminal even when env is missing. This prevents opening in the wrong
    # external terminal on some spawn/alias paths where VSCODE_* env is absent.
    try:
        if _self_hosting_vscode_session_id():
            return "vscode"
    except Exception:
        pass
    return "unknown"


def _find_fallback_terminal() -> Optional[str]:
    """Return the first installed terminal that supports new tab/window spawn."""
    for cand in ("gnome-terminal", "konsole", "wezterm", "kitty", "alacritty", "xterm"):
        if shutil.which(cand):
            return cand
    return None


def _bridge_instances() -> list[dict]:
    """Return currently live VS Code bridge extension instances.

    Returns: [{pid, sessionId, updatedAt, lastFocusedAt, isFocused}, ...]

    Prefer `BRIDGE_ALIVE_DIR/*.json` per-instance files, then fall back to
    `BRIDGE_ALIVE_FILE_LEGACY` single legacy file.
    """
    instances: list[dict] = []
    now = time.time()

    if BRIDGE_ALIVE_DIR.exists():
        for f in BRIDGE_ALIVE_DIR.glob("*.json"):
            try:
                if now - f.stat().st_mtime > BRIDGE_ALIVE_MAX_AGE:
                    continue
                data = json.loads(f.read_text(encoding="utf-8"))
                if isinstance(data, dict) and data.get("sessionId"):
                    instances.append(data)
            except (OSError, json.JSONDecodeError):
                continue
        if instances:
            return instances

    # Legacy fallback
    try:
        if BRIDGE_ALIVE_FILE_LEGACY.exists():
            age = now - BRIDGE_ALIVE_FILE_LEGACY.stat().st_mtime
            if age < BRIDGE_ALIVE_MAX_AGE:
                lines = BRIDGE_ALIVE_FILE_LEGACY.read_text(encoding="utf-8").strip().split("\n")
                if len(lines) >= 3:
                    return [{
                        "pid": int(lines[0]) if lines[0].isdigit() else 0,
                        "updatedAt": lines[1],
                        "sessionId": lines[2],
                        "lastFocusedAt": lines[1],
                        "isFocused": False,
                    }]
    except (OSError, ValueError):
        pass
    return instances


def _bridge_is_alive() -> bool:
    """Return whether at least one VS Code bridge extension instance is alive."""
    return len(_bridge_instances()) > 0


def _most_recent_vscode_session_id() -> Optional[str]:
    """Return sessionId of the most recently focused VS Code instance.

    Priority:
      1. latest lastFocusedAt among currently focused instances
      2. latest lastFocusedAt among all other instances
    Returns None when no bridge is alive.
    """
    insts = _bridge_instances()
    if not insts:
        return None
    focused = [i for i in insts if i.get("isFocused")]
    pool = focused or insts
    pool.sort(key=lambda i: i.get("lastFocusedAt", "") or i.get("updatedAt", ""), reverse=True)
    return pool[0].get("sessionId")


def _self_ancestor_pids() -> list[int]:
    """Collect ancestor PID chain of current process (gccfork) up to PID 1.

    Walks the `PPid:` field in `/proc/<pid>/status`.
    """
    acc: list[int] = []
    cur = os.getpid()
    for _ in range(32):
        acc.append(cur)
        try:
            data = Path(f"/proc/{cur}/status").read_text(encoding="utf-8", errors="ignore")
        except OSError:
            break
        m = re.search(r"^PPid:\s*(\d+)", data, re.MULTILINE)
        if not m:
            break
        ppid = int(m.group(1))
        if not ppid or ppid == cur or ppid == 1:
            break
        cur = ppid
    return acc


def _self_hosting_vscode_session_id() -> Optional[str]:
    """Return sessionId of the VS Code window currently hosting gccfork.

    Matching priority, high to low:
      1. terminalPids matching, most accurate. The bridge records terminal shell PIDs
         in its window via vscode.window.terminals. If gccfork's ancestor chain contains
         that PID, it is the same window.
      2. ancestorPids matching, a process-tree common ancestor fallback. It may be
         imprecise when one VS Code main process hosts multiple windows.
      3. VSCODE_IPC_HOOK_CLI env matching, legacy fallback.

    Returns None when gccfork is not in a VS Code terminal or no instance matches.
    """
    insts = _bridge_instances()
    if not insts:
        return None

    my_anc = _self_ancestor_pids()
    my_anc_set = set(my_anc)

    # 1. Direct terminalPids matching, most accurate.
    if my_anc_set:
        for inst in insts:
            tpids = inst.get("terminalPids") or []
            if isinstance(tpids, list):
                for p in tpids:
                    try:
                        pid_int = int(p)
                    except (TypeError, ValueError):
                        continue
                    if pid_int in my_anc_set:
                        return inst.get("sessionId")

    # 2. ancestorPids matching, less accurate fallback.
    if my_anc_set:
        for inst in insts:
            anc = inst.get("ancestorPids") or []
            if isinstance(anc, list):
                for p in anc:
                    try:
                        pid_int = int(p)
                    except (TypeError, ValueError):
                        continue
                    if pid_int in my_anc_set:
                        # Multiple windows attached to one main process can match multiple
                        # instances. Return the first match because no better signal exists.
                        return inst.get("sessionId")

    # 3. Env matching, legacy fallback.
    my_hook = os.environ.get("VSCODE_IPC_HOOK_CLI", "").strip()
    if my_hook:
        for inst in insts:
            if inst.get("ipcHook") == my_hook:
                return inst.get("sessionId")

    return None


def _focused_vscode_session_id() -> Optional[str]:
    """Return sessionId of the currently focused VS Code window.

    The bridge extension updates isFocused through onDidChangeWindowState and records
    it in heartbeat. If multiple instances are focused, prefer latest lastFocusedAt.
    """
    insts = _bridge_instances()
    focused = [i for i in insts if i.get("isFocused") is True]
    if not focused:
        return None
    if len(focused) == 1:
        return focused[0].get("sessionId")
    # Multiple focused instances: choose latest lastFocusedAt.
    focused.sort(key=lambda i: i.get("lastFocusedAt", ""), reverse=True)
    return focused[0].get("sessionId")


def _preferred_vscode_session_id() -> Optional[str]:
    """Return target VS Code sessionId for spawn, prioritizing focused window.

    Priority, final as of 2026-05-06:
      1. focused VS Code, the window the user is watching
      2. self-hosting window containing the TUI when focus data is unavailable
      3. most recent active instance fallback
    """
    return (_focused_vscode_session_id()
            or _self_hosting_vscode_session_id()
            or _most_recent_vscode_session_id())


# Picker modal stores the user's explicit choice for one spawn call only.
# `_write_bridge_spawn_request` prefers this value.
_pinned_vscode_target_sid: Optional[str] = None


def _vscode_instance_cwd(inst: dict) -> Optional[str]:
    """First-alive terminal shell cwd of a bridge instance (workspace root heuristic).

    Cross-platform:
      - Linux: /proc/<pid>/cwd symlink (fast, no subprocess)
      - macOS / BSD: lsof -a -p <pid> -d cwd -Fn (fallback)
    """
    for pid in inst.get("terminalPids") or []:
        # Linux fast path
        try:
            return os.readlink(f"/proc/{pid}/cwd")
        except (OSError, PermissionError):
            pass
        # macOS / BSD fallback via lsof
        try:
            result = subprocess.run(
                ["lsof", "-a", "-p", str(pid), "-d", "cwd", "-Fn"],
                capture_output=True, text=True, timeout=2,
            )
            if result.returncode == 0:
                for line in result.stdout.splitlines():
                    if line.startswith("n"):
                        path = line[1:].strip()
                        if path and path != "/":
                            return path
        except (subprocess.SubprocessError, FileNotFoundError, OSError):
            pass
    return None


def _find_vscode_for_cwd(cwd: str) -> list[dict]:
    """Find live bridge instances matching the session cwd.

    Matching policy by priority:
      0. exact same cwd
      1. workspace contains session cwd
      2. session cwd contains workspace, uncommon reverse direction

    Returns instances sorted by priority.
    """
    if not cwd:
        return []
    cwd_norm = os.path.normpath(cwd)
    matches: list[tuple[int, dict]] = []
    for inst in _bridge_instances():
        inst_cwd = _vscode_instance_cwd(inst)
        if not inst_cwd:
            continue
        inst_cwd_norm = os.path.normpath(inst_cwd)
        if inst_cwd_norm == cwd_norm:
            matches.append((0, inst))
        elif cwd_norm.startswith(inst_cwd_norm + os.sep):
            matches.append((1, inst))
        elif inst_cwd_norm.startswith(cwd_norm + os.sep):
            matches.append((2, inst))
    matches.sort(key=lambda x: x[0])
    return [m[1] for m in matches]


def _open_vscode_for_cwd(cwd: str, timeout: float = 15.0) -> Optional[str]:
    """Spawn a new window with `code -n <cwd>` and wait for a new bridge heartbeat.

    Returns the new sessionId, or None on failure/timeout.
    """
    if not shutil.which("code"):
        return None
    try:
        existing = {f.stem for f in BRIDGE_ALIVE_DIR.glob("*.json")} if BRIDGE_ALIVE_DIR.exists() else set()
    except OSError:
        existing = set()
    try:
        subprocess.Popen(
            ["code", "-n", cwd],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except (FileNotFoundError, OSError):
        return None
    deadline = time.time() + timeout
    while time.time() < deadline:
        time.sleep(0.5)
        try:
            current = {f.stem for f in BRIDGE_ALIVE_DIR.glob("*.json")} if BRIDGE_ALIVE_DIR.exists() else set()
        except OSError:
            continue
        added = current - existing
        for stem in added:
            try:
                data = json.loads((BRIDGE_ALIVE_DIR / f"{stem}.json").read_text(encoding="utf-8"))
                sid = data.get("sessionId")
                if sid:
                    return sid
            except (OSError, json.JSONDecodeError):
                continue
    return None


def _pick_directory_via_zenity(initial: Optional[str] = None) -> Optional[str]:
    """Select a directory with zenity file dialog; new folders can be created inside it.

    Returns selected absolute path, or None on cancel/failure.
    """
    if not shutil.which("zenity"):
        return None
    args = [
        "zenity", "--file-selection", "--directory",
        "--title=Select destination folder (right-click to create one if needed)",
    ]
    if initial:
        # zenity uses a directory argument with trailing slash as the start folder.
        args.extend(["--filename", initial.rstrip("/") + "/"])
    try:
        result = subprocess.run(
            args, capture_output=True, text=True, timeout=600,
        )
    except (subprocess.SubprocessError, OSError):
        return None
    if result.returncode != 0:
        return None
    path = result.stdout.strip()
    return path or None


_CODE_BLOCK_RE = re.compile(r"```[\s\S]*?```", re.MULTILINE)
_INLINE_CODE_RE = re.compile(r"`[^`\n]{40,}`")  # Inline backticks with 40+ chars may be code.


def _strip_noise(text: str) -> str:
    """Remove code blocks and long inline code from assistant messages."""
    text = _CODE_BLOCK_RE.sub("[code block omitted]", text)
    text = _INLINE_CODE_RE.sub("", text)
    # Collapse repeated blank lines.
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text.strip()


def _looks_like_codex_context_summary(text: str) -> bool:
    """Use only real migration/summary context from Codex developer messages."""
    head = text[:3000]
    if head.lstrip().startswith(("<permissions instructions>", "<collaboration_mode>")):
        return False
    if "Knowledge cutoff:" in head or "You are Codex" in head:
        return False
    markers = (
        "\u0043laude \uc138\uc158",
        "\u0043odex \uc138\uc158",
        "\uc774\uc2dd \uc138\uc158",
        "\uac80\uc99d\ud615 \uc774\uc2dd",
        "compact summary",
        "developer summary",
        "\uc6d0\ubcf8 Claude SID",
    )
    return any(marker in head for marker in markers)


def _is_summary_internal_text(text: str) -> bool:
    stripped = text.strip()
    if not stripped:
        return True
    if _is_internal_user_text(stripped):
        return True
    return stripped.startswith((
        "# AGENTS.md instructions",
        "<environment_context>",
        "<permissions instructions>",
        "<collaboration_mode>",
    ))


def _clip_summary_piece(text: str, limit: int) -> str:
    text = re.sub(r"\s+", " ", text.strip())
    if len(text) <= limit:
        return text
    return text[: max(0, limit - 1)].rstrip() + "…"


def _pick_evenly(items: list[tuple[int, str, str]], limit: int) -> list[tuple[int, str, str]]:
    if limit <= 0 or not items:
        return []
    if len(items) <= limit:
        return items
    if limit == 1:
        return [items[len(items) // 2]]
    idxs = {round(i * (len(items) - 1) / (limit - 1)) for i in range(limit)}
    return [items[i] for i in sorted(idxs)]


def _build_codex_staged_summary_excerpts(
    *,
    compact_summaries: list[str],
    user_msgs: list[tuple[int, str]],
    asst_msgs: list[tuple[int, str]],
    max_chars: int,
) -> str:
    """Codex summary only: evenly excerpt the full flow across five time stages."""
    merged: list[tuple[int, str, str]] = (
        [(idx, "user", text) for idx, text in user_msgs]
        + [(idx, "assistant", text) for idx, text in asst_msgs]
    )
    merged.sort(key=lambda item: item[0])
    if not merged and not compact_summaries:
        return ""

    parts: list[str] = []
    used = 0
    if compact_summaries:
        context_budget = min(max_chars // 5, 1200)
        context = _clip_summary_piece(compact_summaries[-1], context_budget)
        parts.extend(["### Codex Migration/Compact Summary Context ###", context])
        used += len(context)

    if not merged:
        excerpt = "\n\n---\n\n".join(parts)
        return excerpt[:max_chars]

    parts.append("### Codex Five-Stage Timeline Excerpts ###")
    stage_count = 5
    remaining = max(1000, max_chars - used)
    per_stage_budget = max(500, remaining // stage_count)
    labels = ("1/5 early", "2/5 development", "3/5 middle", "4/5 late", "5/5 latest")
    n = len(merged)

    for stage in range(stage_count):
        start = stage * n // stage_count
        end = (stage + 1) * n // stage_count
        bucket = merged[start:end]
        if not bucket:
            continue
        bucket_users = [item for item in bucket if item[1] == "user"]
        bucket_assts = [item for item in bucket if item[1] == "assistant"]
        chosen = _pick_evenly(bucket_users, 2) + _pick_evenly(bucket_assts, 2)
        if not chosen:
            chosen = _pick_evenly(bucket, 3)
        chosen.sort(key=lambda item: item[0])

        stage_lines = [f"### {labels[stage]} · L{bucket[0][0]}~L{bucket[-1][0]} ###"]
        stage_used = 0
        piece_limit = max(180, per_stage_budget // max(1, len(chosen)))
        for idx, role, text in chosen:
            piece = _clip_summary_piece(text, piece_limit)
            if stage_used + len(piece) > per_stage_budget and stage_used > 0:
                continue
            label = "user" if role == "user" else "assistant"
            stage_lines.append(f"[L{idx} {label}] {piece}")
            stage_used += len(piece)
        parts.append("\n".join(stage_lines))

    excerpt = "\n\n---\n\n".join(parts)
    if len(excerpt) > max_chars:
        excerpt = excerpt[:max_chars] + "\n\n[…truncated by total limit…]"
    return excerpt


def _extract_summary_excerpts(jsonl_path: Path, max_chars: int = 8000) -> str:
    """Extract meaningful conversation body from JSONL efficiently, including large files.

    Principles:
      - No per-message length cap, because truncation loses meaning.
      - Remove noise: code blocks, long inline code, tool_use, tool_result,
        attachment, file-history-snapshot, sidechain, system, gccfork-marker
      - Preserve `isCompactSummary` text with separate priority.
      - Priority-based trim when total exceeds max_chars:
        1. compact summary text
        2. all user messages
        3. recent assistant messages, dropping older ones first

    Returns sorted excerpt text with separators.
    """
    compact_summaries: list[str] = []
    user_msgs: list[tuple[int, str]] = []   # (line_index, text)
    asst_msgs: list[tuple[int, str]] = []
    codex_developer_msgs: list[str] = []
    codex_response_user_msgs: list[tuple[int, str]] = []
    codex_response_asst_msgs: list[tuple[int, str]] = []
    codex_event_user_msgs: list[tuple[int, str]] = []
    codex_event_asst_msgs: list[tuple[int, str]] = []
    line_idx = 0
    try:
        with jsonl_path.open("r", encoding="utf-8") as fh:
            for raw in fh:
                line_idx += 1
                line = raw.strip()
                if not line:
                    continue
                # Fast isCompactSummary check before JSON parsing.
                is_compact = '"isCompactSummary":true' in line or '"isCompactSummary": true' in line
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if d.get("isSidechain"):
                    continue
                # Codex JSONL:
                #   {"type":"response_item","payload":{"type":"message","role":"user|assistant|developer",...}}
                #   {"type":"event_msg","payload":{"type":"user_message|agent_message","message":"..."}}
                # Match the existing Claude excerpt priority; prefer response_item over
                # duplicate event_msg when response_item exists.
                typ = d.get("type")
                payload = d.get("payload") if isinstance(d.get("payload"), dict) else {}
                if typ == "response_item" and payload.get("type") == "message":
                    role = payload.get("role")
                    text = _codex_content_text(payload.get("content")).strip()
                    if not text:
                        continue
                    if role == "developer":
                        cleaned = _strip_noise(text)
                        if (
                            cleaned
                            and len(cleaned) > 30
                            and _looks_like_codex_context_summary(cleaned)
                        ):
                            codex_developer_msgs.append(cleaned)
                    elif role == "user":
                        if not _is_summary_internal_text(text):
                            codex_response_user_msgs.append((line_idx, text))
                    elif role == "assistant":
                        cleaned = _strip_noise(text)
                        if cleaned and len(cleaned) > 20:
                            codex_response_asst_msgs.append((line_idx, cleaned))
                    continue
                if typ == "event_msg":
                    ev_type = payload.get("type")
                    text = payload.get("message")
                    if not isinstance(text, str) or not text.strip():
                        continue
                    text = text.strip()
                    if ev_type == "user_message":
                        if not _is_summary_internal_text(text):
                            codex_event_user_msgs.append((line_idx, text))
                    elif ev_type == "agent_message":
                        cleaned = _strip_noise(text)
                        if cleaned and len(cleaned) > 20:
                            codex_event_asst_msgs.append((line_idx, cleaned))
                    continue
                # Exclude gccfork markers.
                content_str = ""
                msg = d.get("message")
                if isinstance(msg, dict):
                    c = msg.get("content")
                    if isinstance(c, str):
                        content_str = c
                    elif isinstance(c, list):
                        # Extract only text blocks; ignore tool_use/tool_result blocks.
                        parts = []
                        for b in c:
                            if isinstance(b, dict) and b.get("type") == "text":
                                t = b.get("text", "")
                                if isinstance(t, str):
                                    parts.append(t)
                        content_str = " ".join(parts).strip()
                # Exclude system+isMeta gccfork markers.
                if d.get("type") == "system" and d.get("isMeta"):
                    if "[gccfork-" in (d.get("content") or ""):
                        continue
                # Compact summaries may appear as user messages but carry a meta flag.
                if is_compact and content_str:
                    cleaned = _strip_noise(content_str)
                    if cleaned and len(cleaned) > 30:
                        compact_summaries.append(cleaned)
                    continue
                if not content_str:
                    continue
                if "[gccfork-" in content_str[:50]:  # gccfork marker itself.
                    continue
                t = d.get("type")
                if t == "user":
                    if not _is_summary_internal_text(content_str):
                        user_msgs.append((line_idx, content_str.strip()))
                elif t == "assistant":
                    cleaned = _strip_noise(content_str)
                    if cleaned and len(cleaned) > 20:
                        asst_msgs.append((line_idx, cleaned))
    except OSError:
        return ""

    if not user_msgs and not asst_msgs and (
        codex_developer_msgs
        or codex_response_user_msgs
        or codex_response_asst_msgs
        or codex_event_user_msgs
        or codex_event_asst_msgs
    ):
        if codex_developer_msgs:
            compact_summaries.extend(codex_developer_msgs[-2:])
        if codex_response_user_msgs or codex_response_asst_msgs:
            user_msgs = codex_response_user_msgs
            asst_msgs = codex_response_asst_msgs
        else:
            user_msgs = codex_event_user_msgs
            asst_msgs = codex_event_asst_msgs
        return _build_codex_staged_summary_excerpts(
            compact_summaries=compact_summaries,
            user_msgs=user_msgs,
            asst_msgs=asst_msgs,
            max_chars=max_chars,
        )

    if not compact_summaries and not user_msgs and not asst_msgs:
        return ""

    # Merge by priority.
    parts: list[str] = []
    used = 0
    if compact_summaries:
        parts.append("### Automatic Compact Summary (Prior Conversation Core) ###")
        # The last compact is enough; earlier compacts are absorbed into it.
        last_compact = compact_summaries[-1]
        # Keep only part if too long.
        if len(last_compact) > max_chars // 2:
            last_compact = last_compact[: max_chars // 2] + "…"
        parts.append(last_compact)
        used += len(last_compact)

    # User messages: try including all; sample evenly if too many.
    if user_msgs:
        budget_user = (max_chars - used) // 2
        # Include all when user utterances are short enough or there are at most 12.
        if sum(len(m) for _, m in user_msgs) <= budget_user or len(user_msgs) <= 12:
            chosen = user_msgs
        else:
            # Even sample of 12: first 4, evenly spaced 4, last 4.
            n = len(user_msgs)
            indices = (
                list(range(0, min(4, n)))
                + [i * n // 4 for i in range(1, 4)]
                + list(range(max(0, n - 4), n))
            )
            indices = sorted(set(indices))
            chosen = [user_msgs[i] for i in indices]
        parts.append("### User Messages ###")
        for idx, msg in chosen:
            if used + len(msg) > max_chars - 500:
                break
            parts.append(f"[L{idx}] {msg}")
            used += len(msg)

    # Assistant messages: add newest first within remaining budget.
    if asst_msgs:
        parts.append("### Assistant Key Responses (Newest First) ###")
        for idx, msg in reversed(asst_msgs):
            if used + len(msg) > max_chars - 200:
                break
            parts.insert(len(parts), f"[L{idx}] {msg}")  # Add.
            used += len(msg)

    excerpt = "\n\n---\n\n".join(parts)
    if len(excerpt) > max_chars:
        excerpt = excerpt[:max_chars] + "\n\n[…truncated by total limit…]"
    return excerpt


def _generate_ai_summary(jsonl_path: Path) -> Optional[str]:
    """Generate a one-line summary with Haiku via claude CLI -p and forced system prompt.

    Post-process output by taking only the first non-empty line and removing
    markdown/quotes/bullets with a length cap.
    """
    if not shutil.which("claude"):
        return None
    excerpts = _extract_summary_excerpts(jsonl_path)
    if not excerpts:
        return None
    # System prompt: make Haiku summarize only, not answer.
    system_prompt = (
        "You are a dedicated conversation-record summarizer. "
        "Output only one Korean noun-phrase line, 30 to 80 characters, describing the user's work topic. "
        "Do not answer or explain; output only the summary line. "
        "No periods, quotes, markdown, or emoji."
    )
    user_prompt = (
        f"Summarize the following conversation record as one Korean noun-phrase line.\n"
        f"Example output: `Python TUI multi-select debugging`, `OneNote parser implementation and verification`\n\n"
        f"=== Conversation record start ===\n{excerpts}\n=== Conversation record end ===\n\n"
        f"Summary (one noun-phrase line):"
    )
    try:
        env = os.environ.copy()
        env.pop("VIRTUAL_ENV", None)
        env.pop("UV_PROJECT_ENVIRONMENT", None)
        env.pop("PYTHONHOME", None)
        # Auth-mode branch:
        #  - With ANTHROPIC_API_KEY, --bare is possible and skips hooks/CLAUDE.md/skills.
        #  - Without it, OAuth requires non-bare mode. Use cleanup flags instead:
        #    cwd=/tmp to avoid project CLAUDE.md, --no-session-persistence to avoid JSONL,
        #    --disable-slash-commands, and --exclude-dynamic-system-prompt-sections.
        #    Hooks may still run in OAuth mode.
        has_api_key = bool(env.get("ANTHROPIC_API_KEY"))
        if has_api_key:
            args = [
                "claude", "--bare", "-p", user_prompt, "--model", "haiku",
                "--append-system-prompt", system_prompt,
            ]
            cwd = None
        else:
            args = [
                "claude", "-p", user_prompt, "--model", "haiku",
                "--no-session-persistence",
                "--disable-slash-commands",
                "--exclude-dynamic-system-prompt-sections",
                "--append-system-prompt", system_prompt,
            ]
            cwd = "/tmp"  # Avoid project CLAUDE.md.
        result = subprocess.run(
            args, capture_output=True, text=True, timeout=60, env=env, cwd=cwd,
        )
        if result.returncode != 0:
            return None
        raw = result.stdout
        # Extract the first non-empty line that is not a format marker.
        for line in raw.splitlines():
            stripped = line.strip()
            if not stripped:
                continue
            # Remove markdown headers/lists/quotes.
            if stripped.startswith(("#", ">", "*", "-", "•", "1.", "2.", "3.")):
                stripped = stripped.lstrip("#>*-•0123456789. ").strip()
            # Remove quotes/backticks.
            stripped = stripped.strip("`\"'“”‘’")
            # Remove trailing period/question/exclamation marks.
            stripped = stripped.rstrip(".!?。 ")
            if stripped and len(stripped) >= 5:  # Too short is not meaningful.
                return stripped[:200]
        return None
    except (subprocess.SubprocessError, OSError):
        return None


def _append_copy_marker(jsonl_path: Path, original_id: str, new_id: str, dest_cwd: str) -> None:
    """Append copy provenance to copied JSONL as `system` + `isMeta:true`.

    Record copy information both inside JSONL and in a separate
    `~/.claude/gccfork-copy-log.jsonl` log.
    """
    marker_text = (
        f"[gccfork-copy] This session is a copy of original `{original_id[:8]}` "
        f"(destination: `{dest_cwd}`). Copy time: {datetime.now().isoformat(timespec='seconds')}."
    )
    iso_now = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    marker = {
        "type": "system",
        "content": marker_text,
        "isMeta": True,
        "timestamp": iso_now,
        "sessionId": new_id,
        "cwd": dest_cwd,
        "uuid": str(uuid_lib.uuid4()),
    }
    try:
        with jsonl_path.open("a", encoding="utf-8") as fh:
            fh.write(json.dumps(marker, ensure_ascii=False) + "\n")
    except OSError:
        pass
    try:
        log_path = CLAUDE_ROOT / "gccfork-copy-log.jsonl"
        log_entry = {
            "original_id": original_id,
            "new_id": new_id,
            "dest_cwd": dest_cwd,
            "copied_at": iso_now,
        }
        with log_path.open("a", encoding="utf-8") as fh:
            fh.write(json.dumps(log_entry, ensure_ascii=False) + "\n")
    except OSError:
        pass


def _rewrite_all_cwd_fields(jsonl_path: Path, old_cwd: str, new_cwd: str) -> int:
    """Rewrite all message cwd fields in JSONL to a new path.

    Must run before _append_migration_marker so all tools, including gccfork TUI,
    VS Code, and claude --resume, consistently see the new cwd.

    Implementation uses line-by-line json.loads/dumps instead of string replacement
    to avoid escaping and partial-match risk.

    Returns number of updated lines.
    """
    if not old_cwd or not new_cwd or old_cwd == new_cwd:
        return 0
    try:
        text = jsonl_path.read_text(encoding="utf-8")
    except OSError:
        return 0
    out_lines: list[str] = []
    changed = 0
    old_norm = old_cwd.rstrip("/")
    for line in text.splitlines():
        if not line.strip():
            out_lines.append(line)
            continue
        try:
            obj = json.loads(line)
        except (json.JSONDecodeError, ValueError):
            out_lines.append(line)
            continue
        line_changed = False
        # top-level cwd
        if isinstance(obj.get("cwd"), str):
            cur = obj["cwd"].rstrip("/")
            if cur == old_norm or cur.startswith(old_norm + "/"):
                obj["cwd"] = new_cwd + cur[len(old_norm):]
                line_changed = True
        # Some messages may have nested cwd fields such as toolUseResult.cwd/message.cwd.
        # Do not recurse; top-level cwd is the Claude Code standard.
        if line_changed:
            out_lines.append(json.dumps(obj, ensure_ascii=False))
            changed += 1
        else:
            out_lines.append(line)
    if changed > 0:
        try:
            tmp = jsonl_path.with_suffix(jsonl_path.suffix + ".tmp")
            tmp.write_text("\n".join(out_lines) + "\n", encoding="utf-8")
            tmp.replace(jsonl_path)
        except OSError:
            return 0
    return changed


def _append_migration_marker(jsonl_path: Path, old_cwd: str, new_cwd: str, session_id: str) -> None:
    """Append move history to JSONL as a `system` + `isMeta:true` event.

    Earlier versions used `type:user`, which made claude resume interpret the marker
    as the user's latest unanswered message. The screen then showed only the marker
    and did not repaint previous conversation. system+isMeta enters context without
    being prominent in the user UI, so the previous conversation displays normally.

    Also write a separate grep/audit log at `~/.claude/gccfork-move-log.jsonl`.
    """
    marker_text = (
        f"[gccfork-move] This session was moved from `{old_cwd}` to `{new_cwd}`. "
        f"Move time: {datetime.now().isoformat(timespec='seconds')}. "
        f"Continue future work using the new cwd."
    )
    iso_now = datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")
    marker = {
        "type": "system",
        "content": marker_text,
        "isMeta": True,
        "timestamp": iso_now,
        "sessionId": session_id,
        "cwd": new_cwd,
        "uuid": str(uuid_lib.uuid4()),
    }
    try:
        with jsonl_path.open("a", encoding="utf-8") as fh:
            fh.write(json.dumps(marker, ensure_ascii=False) + "\n")
    except OSError:
        pass
    # Separate audit log outside JSONL for grep, stats, restore, and similar operations.
    try:
        log_path = CLAUDE_ROOT / "gccfork-move-log.jsonl"
        log_entry = {
            "session_id": session_id,
            "from": old_cwd,
            "to": new_cwd,
            "moved_at": iso_now,
        }
        with log_path.open("a", encoding="utf-8") as fh:
            fh.write(json.dumps(log_entry, ensure_ascii=False) + "\n")
    except OSError:
        pass


def _gnome_terminal_is_running() -> bool:
    """Return whether gnome-terminal-server is running on the current system."""
    if not shutil.which("pgrep"):
        return False
    try:
        r = subprocess.run(
            ["pgrep", "-x", "gnome-terminal-"],
            capture_output=True, timeout=1,
        )
        if r.returncode == 0 and r.stdout.strip():
            return True
        # Some distributions use a different process name, so try -f once more.
        r2 = subprocess.run(
            ["pgrep", "-f", "gnome-terminal-server"],
            capture_output=True, timeout=1,
        )
        return r2.returncode == 0 and bool(r2.stdout.strip())
    except (subprocess.SubprocessError, FileNotFoundError, OSError):
        return False


def _other_environment(current: str) -> Optional[str]:
    """Return the "other" terminal environment available, if any.

    - current="vscode" + gnome-terminal-server running → "gnome-terminal"
    - any non-vscode terminal (gnome-terminal / apple-terminal / iterm /
      wezterm / kitty / konsole / alacritty / terminator / xterm / unknown)
      + VSCode bridge heartbeat alive → "vscode"
      (this enables "Send to VSCode" option on macOS Terminal.app, iTerm2, etc.)
    - otherwise → None
    """
    if current == "vscode":
        return "gnome-terminal" if _gnome_terminal_is_running() else None
    # All non-VSCode terminals: offer VSCode option if bridge is alive
    return "vscode" if _bridge_is_alive() else None


# gccfork-side call dedup: ignore the second and later same-cmd calls inside
# _SPAWN_DEDUP_WINDOW so the bridge receives only one write even if the source duplicates.
_SPAWN_DEDUP_WINDOW = 5.0
_recent_spawn_keys: dict[str, float] = {}
# Debug log: append spawn call records to ~/.claude/gccfork-debug-spawn.log.
_DEBUG_LOG = CLAUDE_ROOT / "gccfork-debug-spawn.log"


def _write_bridge_spawn_request(
    cmd: list[str],
    cwd: Optional[str],
    env: dict,
    tab_title: str,
    spawn_mode: str,
    color_tag: Optional[str] = None,
) -> bool:
    """Write spawn request JSON for the VS Code bridge extension.

    Ignore the same cmd repeated within 5 seconds so the bridge receives one write.
    """
    import shlex as _shlex
    # Call dedup key: cmd + cwd.
    dedup_key = "|".join(cmd) + "|" + (cwd or "")
    now = time.time()
    last = _recent_spawn_keys.get(dedup_key, 0.0)
    # Remove expired keys.
    for k in list(_recent_spawn_keys.keys()):
        if now - _recent_spawn_keys[k] > _SPAWN_DEDUP_WINDOW * 2:
            _recent_spawn_keys.pop(k, None)
    # Debug logging, ignoring errors.
    try:
        with _DEBUG_LOG.open("a", encoding="utf-8") as fh:
            fh.write(f"{datetime.now().isoformat(timespec='milliseconds')} [_write_bridge_spawn_request] caller_dedup_age={now - last:.3f}s cmd={' '.join(cmd)[:80]}\n")
    except OSError:
        pass
    if now - last < _SPAWN_DEDUP_WINDOW:
        # Same call re-entered within 5 seconds; skip and report success.
        try:
            with _DEBUG_LOG.open("a", encoding="utf-8") as fh:
                fh.write(f"{datetime.now().isoformat(timespec='milliseconds')} [_write_bridge_spawn_request] DEDUP-SKIP age={now - last:.3f}s\n")
        except OSError:
            pass
        return True
    _recent_spawn_keys[dedup_key] = now

    try:
        BRIDGE_SPAWN_DIR.mkdir(parents=True, exist_ok=True)
    except OSError:
        return False
    # Pass only GCCFORK_* from env to avoid polluting VS Code's own environment.
    passthrough_env = {
        k: v for k, v in env.items()
        if k.startswith("GCCFORK_") or k in {"CLAUDE_PROJECT_DIR"}
    }
    # requestId is determined only by cmd+cwd, with no timestamp. Re-spawning the
    # same session within 30 seconds yields the same ID, so bridge processes it once.
    # After 30 seconds it expires from the bridge map and can spawn again.
    request_id_seed = f"{' '.join(cmd)}|{cwd or ''}"
    request_id = hashlib.sha256(request_id_seed.encode("utf-8")).hexdigest()[:16]
    payload = {
        "cwd": cwd,
        "cmd": " ".join(_shlex.quote(c) for c in cmd),
        "title": tab_title,
        "mode": spawn_mode,
        "env": passthrough_env,
        "requestId": request_id,
    }
    if color_tag:
        # Bridge sets terminal panel color tag through vscode.ThemeColor(color_tag).
        payload["colorTag"] = color_tag
    # Prefer explicit picker selection stored in _pinned_vscode_target_sid.
    # Otherwise auto-select, preferring self-hosting then recent focus.
    target_sid = _pinned_vscode_target_sid or _preferred_vscode_session_id()
    pin_source = "pinned" if _pinned_vscode_target_sid else (
        "self-host" if _self_hosting_vscode_session_id() else "most-recent"
    )
    if target_sid:
        payload["targetSessionId"] = target_sid
    # Debug log with target SID and source for tracking wrong-window routing.
    try:
        with _DEBUG_LOG.open("a", encoding="utf-8") as fh:
            fh.write(
                f"{datetime.now().isoformat(timespec='milliseconds')} "
                f"[_write_bridge_spawn_request] target_sid={(target_sid or 'none')[:8]} "
                f"source={pin_source} cmd={' '.join(cmd)[:60]}\n"
            )
    except OSError:
        pass
    req_file = BRIDGE_SPAWN_DIR / f"{uuid_lib.uuid4()}.json"
    try:
        tmp = req_file.with_suffix(".json.tmp")
        tmp.write_text(json.dumps(payload, ensure_ascii=False), encoding="utf-8")
        os.replace(tmp, req_file)
        return True
    except OSError:
        return False


_CLAUDE_NAME_SUPPORT: Optional[bool] = None


def _claude_supports_name_option() -> bool:
    """Return whether the installed Claude CLI accepts --name.

    Public users can have older Claude CLI builds. Passing --name to those
    versions aborts startup, so detect support and fall back silently.
    """
    global _CLAUDE_NAME_SUPPORT
    if _CLAUDE_NAME_SUPPORT is not None:
        return _CLAUDE_NAME_SUPPORT
    if not shutil.which("claude"):
        _CLAUDE_NAME_SUPPORT = False
        return False
    try:
        res = subprocess.run(
            ["claude", "--help"],
            capture_output=True,
            text=True,
            timeout=3,
            check=False,
        )
        help_text = f"{res.stdout}\n{res.stderr}"
        _CLAUDE_NAME_SUPPORT = "--name" in help_text
    except Exception:
        _CLAUDE_NAME_SUPPORT = False
    return _CLAUDE_NAME_SUPPORT


def _add_claude_name_if_supported(cmd: list[str], display_name: Optional[str]) -> None:
    if display_name and _claude_supports_name_option():
        cmd.extend(["--name", display_name[:80]])


_CLAUDE_SESSION_ID_SUPPORT: Optional[bool] = None


def _claude_supports_session_id_option() -> bool:
    """Return whether the installed Claude CLI accepts --session-id <uuid>.

    Older Claude builds may lack it; detect support and fall back when unsupported,
    letting claude generate its own UUID. Result is cached for process lifetime.
    """
    global _CLAUDE_SESSION_ID_SUPPORT
    if _CLAUDE_SESSION_ID_SUPPORT is not None:
        return _CLAUDE_SESSION_ID_SUPPORT
    if not shutil.which("claude"):
        _CLAUDE_SESSION_ID_SUPPORT = False
        return False
    try:
        res = subprocess.run(
            ["claude", "--help"],
            capture_output=True,
            text=True,
            timeout=3,
            check=False,
        )
        help_text = f"{res.stdout}\n{res.stderr}"
        _CLAUDE_SESSION_ID_SUPPORT = "--session-id" in help_text
    except Exception:
        _CLAUDE_SESSION_ID_SUPPORT = False
    return _CLAUDE_SESSION_ID_SUPPORT


def _add_claude_session_id_if_supported(cmd: list[str], session_id: Optional[str]) -> None:
    if session_id and _claude_supports_session_id_option():
        cmd.extend(["--session-id", session_id])


def _build_claude_cmd(action: str, session: Session, display_name: str) -> list[str]:
    """Build `claude` CLI argv; action==fork adds --fork-session."""
    cmd = ["claude", "--resume", session.id]
    _add_claude_name_if_supported(cmd, display_name)
    if action == "fork":
        cmd.append("--fork-session")
    return cmd


def _build_bash_script(cmd: list[str], cwd: Optional[str], exit_label: str = "claude session") -> str:
    """Build bash command executed inside the new terminal.

    - cd to cwd and run claude
    - after claude exits, keep the tab/window open with `read` for output/error review
    - env is already sanitized from uv venv before Popen
    - `trap '' INT` prevents bash from dying with SIGINT; Ctrl+C reaches only claude
      so claude exits normally and then echo/read runs.
    """
    import shlex
    parts: list[str] = []
    parts.append("trap '' INT")
    if cwd:
        parts.append(f"cd {shlex.quote(cwd)}")
    parts.append(" ".join(shlex.quote(c) for c in cmd))
    parts.append("echo")
    parts.append(f"echo '[gccfork] {exit_label} exited. Press Enter to close this window.'")
    parts.append("read")
    # trap + cd use an AND chain; post-claude commands are guaranteed with semicolons.
    if cwd:
        head = " && ".join(parts[:3])  # trap && cd && claude
        tail = "; ".join(parts[3:])    # echo; echo; read
    else:
        head = " && ".join(parts[:2])  # trap && claude
        tail = "; ".join(parts[2:])
    return head + "; " + tail


def _spawn_claude_in_new_terminal(
    terminal: str,
    cmd: list[str],
    cwd: Optional[str],
    env: dict,
    tab_title: str,
    spawn_mode: str = "window",
    color_tag: Optional[str] = None,
    exit_label: str = "claude session",
) -> tuple[bool, str]:
    """Run claude in a new tab/window according to terminal type.

    spawn_mode: "window" for new window by default, or "tab" for same-window tab.
    color_tag is used only in the VS Code bridge path as terminal panel color tag ID.
    Terminals without tab support, such as alacritty/xterm, fall back to new window.

    Returns: (success, actual terminal name used).
    """
    import shlex
    bash_script = _build_bash_script(cmd, cwd, exit_label=exit_label)

    if terminal == "gnome-terminal":
        flag = "--tab" if spawn_mode == "tab" else "--window"
        args = ["gnome-terminal", flag, "--title", tab_title, "--", "bash", "-c", bash_script]
    elif terminal == "konsole":
        if spawn_mode == "tab":
            args = ["konsole", "--new-tab", "-p", f"tabtitle={tab_title}",
                    "-e", "bash", "-c", bash_script]
        else:
            # New window: no --new-tab flag.
            args = ["konsole", "-p", f"tabtitle={tab_title}",
                    "-e", "bash", "-c", bash_script]
    elif terminal == "wezterm":
        if spawn_mode == "tab":
            # New tab in existing mux.
            wez = ["wezterm", "cli", "spawn"]
            if cwd:
                wez += ["--cwd", cwd]
            wez += ["--", "bash", "-c", bash_script]
            args = wez
        else:
            # New OS window.
            wez = ["wezterm", "start"]
            if cwd:
                wez += ["--cwd", cwd]
            wez += ["--", "bash", "-c", bash_script]
            args = wez
    elif terminal == "kitty":
        type_arg = "tab" if spawn_mode == "tab" else "os-window"
        args = ["kitty", "@", "launch", f"--type={type_arg}",
                "--title", tab_title, "bash", "-c", bash_script]
    elif terminal == "iterm":
        quoted = bash_script.replace('"', '\\"')
        if spawn_mode == "tab":
            osa = (
                f'tell application "iTerm2" to tell current window to '
                f'create tab with default profile command "bash -c \\"{quoted}\\""'
            )
        else:
            osa = (
                f'tell application "iTerm2" to create window with default profile '
                f'command "bash -c \\"{quoted}\\""'
            )
        args = ["osascript", "-e", osa]
    elif terminal == "apple-terminal":
        quoted = bash_script.replace('"', '\\"')
        if spawn_mode == "tab":
            # New tab in existing window via AppleScript.
            osa = (
                f'tell application "Terminal" to do script "bash -c \\"{quoted}\\"" '
                f'in selected tab of window 1'
            )
        else:
            osa = f'tell application "Terminal" to do script "bash -c \\"{quoted}\\""'
        args = ["osascript", "-e", osa]
    elif terminal == "windows-terminal":
        sub = "new-tab" if spawn_mode == "tab" else "new-window"
        args = ["wt", "-w", "0", sub, "--title", tab_title, "bash", "-c", bash_script]
    elif terminal == "alacritty":
        # alacritty has no tabs, always new window.
        args = ["alacritty", "--title", tab_title, "-e", "bash", "-c", bash_script]
    elif terminal == "terminator":
        if spawn_mode == "tab":
            args = ["terminator", "--new-tab", "-e", f"bash -c {shlex.quote(bash_script)}"]
        else:
            args = ["terminator", "-e", f"bash -c {shlex.quote(bash_script)}"]
    elif terminal == "xterm":
        # xterm has no tabs, always new window.
        args = ["xterm", "-T", tab_title, "-e", "bash", "-c", bash_script]
    elif terminal == "vscode":
        # Priority 1: if VS Code bridge is alive, request through IPC file.
        if _bridge_is_alive():
            if _write_bridge_spawn_request(cmd, cwd, env, tab_title, spawn_mode, color_tag=color_tag):
                return (True, "vscode-bridge")
        # Priority 2: external terminal fallback.
        fb = _find_fallback_terminal()
        if fb and fb != "vscode":
            return _spawn_claude_in_new_terminal(fb, cmd, cwd, env, tab_title, spawn_mode, color_tag=color_tag, exit_label=exit_label)
        return (False, "vscode")
    else:
        fb = _find_fallback_terminal()
        if fb:
            return _spawn_claude_in_new_terminal(fb, cmd, cwd, env, tab_title, spawn_mode, color_tag=color_tag, exit_label=exit_label)
        return (False, terminal)

    # Verify binary exists.
    if not shutil.which(args[0]):
        fb = _find_fallback_terminal()
        if fb and fb != args[0]:
            return _spawn_claude_in_new_terminal(fb, cmd, cwd, env, tab_title, spawn_mode, color_tag=color_tag, exit_label=exit_label)
        return (False, terminal)

    try:
        subprocess.Popen(
            args,
            cwd=cwd,
            env=env,
            start_new_session=True,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return (True, terminal)
    except FileNotFoundError:
        return (False, terminal)


def run_claude_command(
    action: str,
    session: Session,
    pending_fork_name: Optional[str] = None,
    spawn_mode: str = "window",
    target_terminal: Optional[str] = None,
) -> tuple[bool, str]:
    """Spawn `claude` CLI detached in a new terminal tab/window.

    Returns: (success, terminal name used). gccfork TUI keeps app.run() after this returns.

    spawn_mode: "window" by default, or "tab".
    target_terminal is the user-specified target terminal; None auto-detects.
    action:
      - "fork"   → `claude --resume <id> --fork-session`
      - "resume" → `claude --resume <id>`
    """
    env = _sanitize_env_for_claude()
    env["GCCFORK_PARENT_SESSION_ID"] = session.id
    if pending_fork_name:
        env["GCCFORK_PENDING_NAME"] = pending_fork_name
    cwd = session.cwd if session.cwd and Path(session.cwd).exists() else None

    display_name = _tab_title_for(session)
    cmd = _build_claude_cmd(action, session, display_name)
    terminal = target_terminal or _detect_terminal()
    color_tag = _vscode_terminal_color_for_session(session.id)
    ok, used = _spawn_claude_in_new_terminal(
        terminal, cmd, cwd, env, display_name, spawn_mode, color_tag=color_tag,
    )
    return (ok, used)


def detect_current_claude_session() -> Optional[str]:
    """Walk PPID ancestors and extract session id from claude cmdline.

    Used for the marker when gccfork runs inside a `claude` session. Returns None if not found.
    """
    try:
        pid = os.getppid()
        for _ in range(8):
            if pid <= 1:
                break
            try:
                cmdline_raw = (Path("/proc") / str(pid) / "cmdline").read_bytes()
            except OSError:
                break
            cmdline = cmdline_raw.decode("utf-8", "ignore").replace("\x00", " ")
            if _is_claude_cmdline(cmdline):
                match = UUID_ANY_RE.search(cmdline)
                if match:
                    return match.group(1)
            try:
                stat_text = (Path("/proc") / str(pid) / "stat").read_text()
            except OSError:
                break
            try:
                after_comm = stat_text.rsplit(")", 1)[1].split()
                pid = int(after_comm[1])
            except (IndexError, ValueError):
                break
    except Exception:
        pass
    return None


def _format_ancestry(session_id: str) -> list[dict]:
    """Return shallow metadata for the ancestor chain from session_id to root."""
    chain: list[dict] = []
    current: Optional[str] = session_id
    visited: set[str] = set()
    depth = 0
    while current and depth < 30:
        if current in visited:
            break
        visited.add(current)
        sess = find_session_by_id(current)
        reg = registry_get(current)
        node = {
            "session_id": current,
            "short_id": current[:8],
            "name": reg.get("name"),
            "parent_id": reg.get("parent_id") or _RUNTIME_PARENT_OVERRIDE.get(current),
            "fork_type": reg.get("fork_type"),
            "jsonl_path": sess.jsonl_path.as_posix() if sess else None,
            "cwd": sess.cwd if sess else None,
            "turn_count": sess.turn_count if sess else None,
            "mtime": sess.mtime.isoformat() if sess else None,
        }
        chain.append(node)
        nxt = node["parent_id"]
        if not nxt:
            break
        current = nxt
        depth += 1
    return chain


def cmd_parent_of(session_id: str, as_json: bool = False) -> int:
    """Print one direct parent session."""
    # Scan once so _RUNTIME_PARENT_OVERRIDE is populated.
    scan_sessions(current_cwd=None, scope_all=True)
    reg = registry_get(session_id)
    parent_id = reg.get("parent_id") or _RUNTIME_PARENT_OVERRIDE.get(session_id)
    if not parent_id:
        if as_json:
            print(json.dumps({"session_id": session_id, "parent_id": None}, ensure_ascii=False))
        else:
            print(f"{session_id[:8]}: no parent (root)")
        return 0
    parent = find_session_by_id(parent_id)
    info = {
        "session_id": session_id,
        "parent_id": parent_id,
        "parent_short": parent_id[:8],
        "parent_name": registry_get(parent_id).get("name"),
        "parent_jsonl": parent.jsonl_path.as_posix() if parent else None,
        "parent_cwd": parent.cwd if parent else None,
    }
    if as_json:
        print(json.dumps(info, ensure_ascii=False))
    else:
        print(f"child: {session_id}")
        print(f"parent: {parent_id}  ({info['parent_name'] or '(untitled)'})")
        if info["parent_jsonl"]:
            print(f"parent jsonl: {info['parent_jsonl']}")
    return 0


def cmd_ancestry(session_id: str, as_json: bool = False) -> int:
    """Print the full ancestor chain from session to root."""
    scan_sessions(current_cwd=None, scope_all=True)
    chain = _format_ancestry(session_id)
    if as_json:
        print(json.dumps(chain, ensure_ascii=False, indent=2))
        return 0
    if not chain:
        print(f"{session_id}: no information")
        return 1
    for i, node in enumerate(chain):
        arrow = "└─" if i > 0 else "  "
        indent = "  " * i
        title = node["name"] or "(untitled)"
        turns = f"{node['turn_count']} turns" if node["turn_count"] is not None else "? turns"
        print(f"{indent}{arrow} {node['short_id']}  [{turns}]  {title}")
    return 0


def main() -> int:
    # Headless CLI subcommand dispatch without opening the TUI.
    # Delegate when first arg is search/list/detail/rename/hard-fork/delete, etc.
    # Keep existing TUI behavior and old --parent-of / --ancestry flags.
    try:
        _gccfork_boot_trace("main entered")
        from gccfork_cli import is_subcommand, dispatch
        _gccfork_boot_trace("gccfork_cli imported")
        if is_subcommand(sys.argv[1:]):
            _gccfork_boot_trace("dispatch start")
            return dispatch(sys.argv[1:])
    except Exception as exc:
        print(f"❌ gccfork-cli dispatch failed: {type(exc).__name__}: {exc}", file=sys.stderr)
        return 3

    parser = argparse.ArgumentParser(description="gccslim - drag-selectable Claude Code session fork/resume TUI")
    parser.add_argument("--all", action="store_true", help="Show sessions from all projects")
    parser.add_argument("--cwd", default=None, help="Override current directory, default: $PWD")
    parser.add_argument("--parent-of", metavar="SESSION_ID",
                        help="Print direct parent information for the specified session and exit")
    parser.add_argument("--ancestry", metavar="SESSION_ID",
                        help="Print ancestor chain from the specified session to root and exit")
    parser.add_argument("--json", action="store_true",
                        help="Output --parent-of/--ancestry as JSON")
    args = parser.parse_args()

    # Query-only subcommands: print results to stdout without opening TUI.
    if args.parent_of:
        return cmd_parent_of(args.parent_of, as_json=args.json)
    if args.ancestry:
        return cmd_ancestry(args.ancestry, as_json=args.json)

    # Set terminal panel/tab name to "gccfork" for VS Code terminal list,
    # gnome-terminal tabs, tmux pane title, and similar surfaces.
    # Send once before Textual enters alternate screen, while stdout is still plain;
    # inside Textual it can be swallowed between alt-screen toggles.
    try:
        sys.stdout.write("\033]0;⭐ GccForK ⭐\007\033]2;⭐ GccForK ⭐\007")
        sys.stdout.flush()
    except Exception:
        pass

    cwd = args.cwd or os.environ.get("PWD") or os.getcwd()
    current_session_id = (
        os.environ.get("CLAUDE_SESSION_ID")
        or detect_current_claude_session()
    )

    app = GCCForkApp(
        current_cwd=cwd,
        current_session_id=current_session_id,
        scope_all=args.all,
    )
    # Fork/resume now spawn in a new terminal, so exit directly when app.run() ends.
    # The previous (action, session) result-based claude launch flow is removed.
    app.run()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
