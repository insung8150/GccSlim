#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "textual>=0.85",
#   "rapidfuzz>=3.0",
# ]
# ///
"""
gccslim — Claude Code and Codex CLI session manager with slim workflows.

Reuses the `cdfork` UI/UX while replacing the backend with the Claude Code
session format. The top path, left list, and right preview are all built on
drag-selectable TextArea panels.

Storage:
  - sessions: ~/.claude/projects/<slug>/<session_id>.jsonl
  - registry: ~/.claude/gccfork-registry.json

Slug rule:
  - replace `/`, `_`, and non-ASCII characters in cwd with `-`

Hard fork method:
  - copy the session JSONL and use a new UUID for the file name
  - replace repeated `"sessionId":"<old>"` markers with `"sessionId":"<new>"`
  - accidental old session id text in conversation bodies is unaffected because
    replacement matches only the `"sessionId":"` prefix form
"""
from __future__ import annotations

import sys as _gccfork_boot_sys
import time as _gccfork_boot_time

_GCCFORK_BOOT_T0 = _gccfork_boot_time.perf_counter()


def _gccfork_boot_trace(label: str) -> None:
    if len(_gccfork_boot_sys.argv) > 1 and _gccfork_boot_sys.argv[1] in {
        "hot-reload",
        "slim-and-reload",
    }:
        elapsed_ms = (_gccfork_boot_time.perf_counter() - _GCCFORK_BOOT_T0) * 1000
        print(f"  [boot +{elapsed_ms:7.1f}ms] {label}", file=_gccfork_boot_sys.stderr, flush=True)


_gccfork_boot_trace("python entered gccslim")

