    BINDINGS = [
        Binding("q", "quit", show=False),
        Binding("escape", "quit", show=False),
        Binding("ctrl+c,super+c,ctrl+shift+c", "copy_selection", show=False, priority=True),
        Binding("left", "focus_prev_button", show=False),
        Binding("right", "focus_next_button", show=False),
        Binding("ctrl+a", "select_all_visible", show=False, priority=True),
        # 🗂 병합 — opt 5 (trigger_mode) 가 keybinding/both 일 때만 발동.
        # 발동 시 action_archive_selected 안에서 멀티 선택 비어있으면 notify 후 종료.
        Binding("ctrl+shift+m", "archive_selected_via_key", show=False),
        # 📝 편집 — Ctrl+E 로 설정/메모리 파일 편집 모달. ConfigFilesMixin 이 처리.
        Binding("ctrl+e", "show_config_files", show=False),
    ]

    def action_archive_selected_via_key(self) -> None:
        """Ctrl+Shift+M 키 핸들러 — model B (true merge) 로 dispatch.

        opt 5 (archive_trigger_mode) 가 button-only 면 키 무시.
        Model A (단순 archive_session) 는 더 이상 키/버튼에서 직접 안 쓰임 —
        백엔드 함수만 merge 의 내부에서 자식 archive 용으로 재사용.
        """
        trigger_mode = str(get_archive_pref("archive_trigger_mode"))
        if trigger_mode not in {"keybinding", "both"}:
            return
        self.action_merge_selected()

    sessions: reactive[list[Session]] = reactive([], recompose=False)

    def __init__(self, current_cwd: Optional[str], current_session_id: Optional[str], scope_all: bool) -> None:
        super().__init__()
        self.current_cwd = normalize_cwd(current_cwd)
        self.current_session_id = current_session_id
        self.scope_all = scope_all
        self.filter_text = ""
        self.view_mode = "tree"
        self.list_sessions: list[Session] = []
        self.selected_session_id = current_session_id
        self._active_copy_widget_id: Optional[str] = None
        self._programmatic_update = False
        self._pending_context_widget_id: Optional[str] = None
        self._pending_context_text = ""
        self._menu_text = ""
        self._list_pointer_interacting = False
        self._current_list_lines: list[str] = []
        self._current_list_items: list[tuple[Session, str]] = []
        # Restore last divider position (clamped 0.2~0.8). Default 0.46.
        try:
            saved_ratio = float(pref_get("left_pane_ratio", 0.46))
        except Exception:
            saved_ratio = 0.46
        self.left_pane_ratio = max(0.05, min(0.95, saved_ratio))
        self._pane_dragging = False
        # 소프트 분기 보류: parent_id → {parent_id, name, created_at}.
        # claude가 새 jsonl을 만들면 _reconcile_pending_soft_forks가 parent/name 등록.
        self._pending_soft_forks: dict[str, dict] = {}
        # 신규 루트 세션 보류: list of {name, cwd, created_at}.
        # claude 가 --resume 없이 spawn 되어 새 jsonl 만들면 cwd + timing 매치로 이름 등록.
        self._pending_new_roots: list[dict] = []
        # 이전 스캔의 세션 ID set — 자동 reload 시 새 세션 감지용
        self._last_known_session_ids: set[str] = set()
        # 다중 선택 (Ctrl/Shift + 좌클릭). 일반 클릭은 selected_session_id 만 갱신,
        # 이 set 은 비어있을 때 single-select 모드, 비어있지 않을 때 multi-select.
        self._multi_selected_ids: set[str] = set()
        # Shift+click 시 범위 시작점 — 마지막으로 일반/Ctrl 클릭한 세션의 row index.
        self._multi_anchor_row: Optional[int] = None
        # 체크박스/modifier 클릭 직후 mouse_up 이 multi_selected 를 클리어하는
        # 것을 방지하기 위한 일회성 플래그.
        self._suppress_pointer_clear: bool = False
        # AI요약 생성 백그라운드 작업 중 표시 — UI 가 진행 상태 보여주도록.
        self._summarize_in_progress: bool = False
        # 🔬 깊이 검색 state — Mixin 의 helper 가 초기화
        self._init_deep_search_state()

        # 자동 슬림 (auto-reload trigger) archive 됨 (2026-05-06) — init 호출 제거.

        # ▶ 마커 동적 추적 (라이브 세션):
        #   _spawned_sids — 이 gccfork 가 신규/분기/복제/재개 로 직접 spawn 한 세션
        #     → ▶ 빨강 (자기 책임).
        #   _spawned_confirmed_sids — 위 중 "한 번이라도 라이브로 관측된 적 있는" sid.
        #     라이브 등록은 spawn 후 수 초 늦게 되므로, "잠깐 spawn 직후 라이브 미등록"
        #     상태에서 _spawned 가 즉시 비워지지 않게 confirmed 가 게이트 역할. 죽은
        #     spawn 정리는 (confirmed AND now-dead) 기준으로만 수행.
        #   _live_sids    — read_live_sessions() 의 모든 활성 sid 스냅샷
        #     → ▶ 초록 (다른 경로지만 동일 sid 가 살아있음). 스폰 set 와 교집합은 빨강 우선.
        # 매 _auto_reload_tick 에서 동기화. detect_current_claude_session() 의 PPID 기반
        # ▶ 결정 로직 (startup 1회) 은 더 이상 마커 색상에 영향 안 줌.
        self._spawned_sids: set[str] = set()
        self._spawned_confirmed_sids: set[str] = set()
        # spawn 한 sid 별 첫 등록 timestamp — 라이브 등록 안 된 채 60초 지나면 폐기.
        self._spawned_at: dict[str, float] = {}
        self._live_sids: set[str] = set()

