class BridgeTargetPickerScreen(ModalScreen[Optional[str]]):
    """Explicitly choose which VSCode instance should receive spawn request.

    result:
      - sessionId (str) -> send explicitly to that instance
      - None -> cancel
    """

    def __init__(self, instances: list[dict], session_cwd: Optional[str] = None) -> None:
        super().__init__()
        self.session_cwd = os.path.normpath(session_cwd) if session_cwd else None

        def _cwd_rank(inst: dict) -> int:
            if not self.session_cwd:
                return 3
            inst_cwd = _vscode_instance_cwd(inst)
            if not inst_cwd:
                return 3
            inst_cwd = os.path.normpath(inst_cwd)
            if inst_cwd == self.session_cwd:
                return 0
            if self.session_cwd.startswith(inst_cwd + os.sep):
                return 1
            if inst_cwd.startswith(self.session_cwd + os.sep):
                return 2
            return 3

        # Sort by cwd match first, then focused/recently focused state.
        # Keep all VSCode instances as candidates so users can choose the intended window.
        def _key(i: dict) -> tuple:
            return (
                _cwd_rank(i),
                0 if i.get("isFocused") else 1,
                # Negative value makes later focus times sort first.
                -(_iso_to_ts(i.get("lastFocusedAt") or i.get("updatedAt") or "")),
            )
        self.instances = sorted(instances, key=_key)

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label(
                f"📂 Pick a VSCode window — {len(self.instances)} running",
                id="confirm-title",
            )
            yield Label(
                "새 터미널을 어느 창에 열까요? (●=포커스, sid=앞 4자)",
                classes="hint",
            )
            with RadioSet(id="bridge-pick-radio"):
                for idx, inst in enumerate(self.instances):
                    yield RadioButton(_format_bridge_instance_label(inst), value=(idx == 0))
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button("이 창으로 보내기", id="btn-confirm", variant="primary")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        try:
            self.query_one("#bridge-pick-radio", RadioSet).focus()
        except Exception:
            pass

    def _picked_sid(self) -> Optional[str]:
        try:
            radio = self.query_one("#bridge-pick-radio", RadioSet)
            idx = radio.pressed_index
            if 0 <= idx < len(self.instances):
                return self.instances[idx].get("sessionId")
        except Exception:
            pass
        return None

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            self.dismiss(self._picked_sid())
        elif event.button.id == "btn-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)
        elif event.key == "enter":
            self.dismiss(self._picked_sid())


class StaleInstanceConfirmScreen(ModalScreen[bool]):
    """Confirm termination after detecting gccfork TUI instances running old code.

    Background old TUI instances can cause behavior mismatches such as stale spawn
    priority. New-code TUI startup detects them automatically and offers termination.
    """

    DEFAULT_CSS = """
    StaleInstanceConfirmScreen {
        align: center middle;
    }
    #stale-box {
        width: 80;
        height: auto;
        border: round $accent 35%;
        padding: 0;
        background: $surface;
    }
    #stale-header {
        padding: 1 2;
        border-bottom: hkey $accent 20%;
        height: auto;
    }
    #stale-title {
        color: $accent;
        text-style: bold;
    }
    #stale-meta {
        color: $foreground 60%;
    }
    #stale-body {
        padding: 1 2;
        height: auto;
    }
    .stale-row {
        background: $accent 5%;
        margin: 0 0 1 0;
        padding: 0 1;
        height: auto;
    }
    #stale-btn-row {
        padding: 1 2;
        border-top: hkey $accent 20%;
        height: auto;
    }
    .spacer { width: 1fr; }
    """

    def __init__(self, instances: list[dict]) -> None:
        super().__init__()
        self.instances = instances

    def compose(self) -> ComposeResult:
        with Vertical(id="stale-box"):
            with Vertical(id="stale-header"):
                yield Static(
                    "⚠️  Old gccfork TUI Instances Detected",
                    id="stale-title",
                )
                yield Static(
                    f"{len(self.instances)} instances are running old code from before the fix.\n"
                    "Termination is recommended for correct behavior such as focused VSCode auto-spawn.",
                    id="stale-meta",
                )
            with Vertical(id="stale-body"):
                for inst in self.instances:
                    age_min = (time.time() - inst["start_ts"]) / 60
                    if age_min < 60:
                        age_str = f"{age_min:.0f} min ago"
                    elif age_min < 1440:
                        age_str = f"{age_min/60:.1f} hours ago"
                    else:
                        age_str = f"{age_min/1440:.1f} days ago"
                    yield Static(
                        f"  PID {inst['pid']} — started {age_str}",
                        classes="stale-row",
                    )
            with Horizontal(id="stale-btn-row"):
                yield Button("Later", id="btn-stale-skip")
                yield Static("", classes="spacer")
                yield Button("⚠ Terminate (SIGTERM)", id="btn-stale-kill", variant="warning")

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-stale-kill":
            self.dismiss(True)
        elif event.button.id == "btn-stale-skip":
            self.dismiss(False)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(False)


def _iso_to_ts(s: str) -> float:
    if not s:
        return 0.0
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp()
    except (ValueError, TypeError):
        return 0.0


def _format_bridge_instance_label(inst: dict) -> str:
    """One-line label shown on picker radio buttons.

    Workspace info is extracted with system commands, not bridge alive JSON:
    - workspace name from `wmctrl -lp` window title
    - absolute path from `/proc/<pid>/cwd` for terminalPids
    """
    sid = (inst.get("sessionId") or "")[:4] or "????"
    focused_mark = "● " if inst.get("isFocused") else "  "
    last = inst.get("lastFocusedAt") or inst.get("updatedAt") or ""
    age = ""
    ts = _iso_to_ts(last)
    if ts > 0:
        delta = max(0, time.time() - ts)
        if delta < 60:
            age = f"{int(delta)}s ago"
        elif delta < 3600:
            age = f"{int(delta // 60)}m ago"
        else:
            age = f"{int(delta // 3600)}h ago"

    # Workspace path from the first live shell cwd among terminalPids.
    # Cross-platform: Linux /proc + macOS/BSD lsof fallback (shares _vscode_instance_cwd logic)
    workspace_path = _vscode_instance_cwd(inst) or ""
    workspace_name = Path(workspace_path).name if workspace_path else "(unknown)"
    short_path = workspace_path
    home = str(Path.home())
    if short_path.startswith(home):
        short_path = "~" + short_path[len(home):]
    if len(short_path) > 50:
        short_path = "…" + short_path[-49:]

    return f"{focused_mark}sid={sid}  📁 {workspace_name}  {short_path}  ({age})  pid={inst.get('pid', '?')}"


class OpenWorkspaceConfirmScreen(ModalScreen[bool]):
    """Confirm opening a new VSCode window when no window matches session cwd.

    result:
      - True  -> open `code -n <cwd>` and continue spawn
      - False -> cancel
    """

    def __init__(self, cwd: str) -> None:
        super().__init__()
        self.cwd = cwd

    def compose(self) -> ComposeResult:
        home = str(Path.home())
        display = ("~" + self.cwd[len(home):]) if self.cwd.startswith(home) else self.cwd
        msg = (
            f"No VSCode window matches this session workspace.\n\n"
            f"Folder:\n  {display}\n\n"
            f"Open a new VSCode window and start the terminal there?\n"
            f"(takes about 10-15 seconds while waiting for bridge activation)"
        )
        with Vertical(id="confirm-box"):
            yield Label("📂 Open New VSCode Window", id="confirm-title")
            yield SelectableTextArea(
                msg, id="confirm-text", read_only=True, show_cursor=False,
                soft_wrap=True, compact=True, highlight_cursor_line=False,
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("No", id="btn-cancel")
                yield Button("Yes — Open New Window", id="btn-confirm", variant="primary")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-confirm", Button).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            self.dismiss(True)
        else:
            self.dismiss(False)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(False)


class TreeOptionConfirmScreen(ModalScreen[Optional[dict]]):
    """Move/copy confirmation modal with a preserve-tree toggle.

    Result:
      - None for cancel
      - {"preserve_tree": bool} on confirm
    """

    def __init__(
        self,
        message: str,
        confirm_label: str,
        confirm_variant: str = "primary",
        title: str = "Confirm",
        preserve_tree_label: str = "Preserve tree structure (auto-include descendants)",
        preserve_tree_default: bool = True,
    ) -> None:
        super().__init__()
        self.message = message
        self.confirm_label = confirm_label
        self.confirm_variant = confirm_variant
        self.title_text = title
        self.preserve_tree_label = preserve_tree_label
        self.preserve_tree_default = preserve_tree_default

    def compose(self) -> ComposeResult:
        with Vertical(id="confirm-box"):
            yield Label(self.title_text, id="confirm-title")
            yield SelectableTextArea(
                self.message,
                id="confirm-text",
                read_only=True,
                show_cursor=False,
                soft_wrap=True,
                compact=True,
                highlight_cursor_line=False,
            )
            yield Checkbox(
                self.preserve_tree_label,
                value=self.preserve_tree_default,
                id="confirm-tree-toggle",
            )
            with Horizontal(id="confirm-btn-row"):
                yield Button("취소", id="btn-cancel")
                yield Button(self.confirm_label, id="btn-confirm", variant=self.confirm_variant)
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-confirm", Button).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-confirm":
            preserve = self.query_one("#confirm-tree-toggle", Checkbox).value
            self.dismiss({"preserve_tree": preserve})
        elif event.button.id == "btn-cancel":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss(None)


class HelpScreen(ModalScreen[None]):
    HELP_TEXT = """\
[bold yellow]━━━ GccSlim Overview ━━━[/]

Local TUI for managing Claude Code and Codex CLI sessions in one list:
name, resume, fork, hard clone, slim, unfold, move, copy, merge, unmerge,
summarize, and delete. The settings [❓ Help] tab shows this same help text.

[bold yellow]━━━ Top Bar ━━━[/]

[bold cyan]🧠 AI[/]
  Opens a GccSlim-dedicated assistant session in a new terminal. It helps with
  session locations, slim, settings, release work, and error diagnosis. Public
  builds use only public knowledge.

[bold cyan]📊 claude / 📊 codex[/]
  Opens each service's usage/analytics page in the browser.

[bold cyan]🧭 Scope[/]
  Toggle between sessions for current cwd project and all projects.

[bold cyan]🗑 Trash[/]
  Opens the GccSlim trash screen. Supports restore, selected permanent delete,
  and empty all.

[bold cyan]🔬 Deep + Filter[/]
  While typing, filters title/ID/cwd. Press Enter for full body deep search.
  Settings control whether attachment, fuzzy, sidechain, and related categories
  are included.

[bold cyan]🌀 Reload / 🧩 View / ⚙ Settings / 📝 Edit[/]
  Reload list, switch tree/flat view, open settings modal, or edit settings files.

[bold yellow]━━━ Main Action Bar ━━━[/]

[bold cyan]🌱 New[/]
  Creates a new Claude or Codex root session. You can choose name, environment,
  terminal target, and window/tab behavior. The name is registered automatically
  when the generated jsonl is detected.

[bold cyan]🌿 Fork[/]
  Claude official `--fork-session` fork. Large sessions may be auto-compacted by
  Claude policy. Codex sessions use clone/slim workflows instead of official fork.

[bold cyan]🍃 Clone[/]
  Hard clone that directly copies the original JSONL and assigns a new UUID.
  Claude replaces `sessionId`; Codex replaces `session_meta.id`. This bypasses
  auto-compact and preserves original turns.

[bold cyan]🔻 Slim[/]
  Reduces the selected session. Claude supports strong/medium/weak, bundling,
  non-context compacting, latest N raw turns, backup, and auto-open after slim.
  Codex uses Codex JSONL-specific slim with latest N turns plus five time-slice
  summary preservation.

[bold cyan]🪚 Unfold[/]
  Expands slim bundle/compact structures back toward original form where possible.
  Uses the Rust `gccfork-slim` delegation path.

[bold cyan]🪴 Resume[/]
  Resumes a Claude or Codex session in a new terminal. If the same SID is already
  open, duplicate launch is blocked and you can cancel or terminate the existing
  process before resuming.

[bold cyan]📛 Name[/]
  Saves display name in registry. It appears in list, preview, terminal tab title,
  and resume picker.

[bold cyan]🍂 Exit[/]
  Exits only the GccSlim TUI. Already launched Claude/Codex sessions remain open.

[bold yellow]━━━ Multi-Select Actions ━━━[/]

Use the first `[ ]` column, Ctrl/Shift click, or Ctrl+A for multi-select. During
multi-select, the single-selection line follows the selected row and avoids
unnecessary scroll jumps.

[bold cyan]📦 Move[/]
  Moves selected sessions to another cwd project. Supports auto-include descendants,
  move markers, and audit logs.

[bold cyan]🧬 Copy[/]
  Copies selected session trees to new UUIDs and remaps parent_id values.

[bold cyan]✨ Summary[/]
  Batch AI summary for selected sessions. Reduces code-block/noise content.
  Codex sessions use five time-slice excerpts to avoid over-weighting recent chat.

[bold cyan]🗂 Merge[/]
  Merges sessions with a common ancestor into a new integrated session.
  Stitching method is chosen in the settings Merge tab.

[bold cyan]🔧 Unmerge[/]
  Restores merged sessions back to originals. Automatically distinguishes the
  new merge model from legacy bundle unfold.

[bold cyan]🧹 Delete[/]
  Moves selected sessions to trash. Active sessions are refused. Important sessions
  require extra confirmation, and child sessions trigger orphan warnings.

[bold cyan]🔓 Clear[/]
  Clears all multi-selection and returns to single-selection mode.

[bold yellow]━━━ Settings Tabs ━━━[/]

[bold cyan]🔬 Search[/]
  Configure JSONL categories included in deep search and fuzzy-search defaults.

[bold cyan]🔻 Slim[/]
  Split into Claude and Codex subtabs. Claude configures mode, bundling,
  non-context compacting, auto-open, tab/window behavior, and recent raw turns.
  Codex configures safe/strong mode, previous compact summaries, recent raw turns,
  clone/in-place policy, and auto-open defaults.

[bold cyan]🗂 Merge[/]
  Configure preview mode, stitching method, common ancestor checks, and triggers.

[bold cyan]📝 Editor[/]
  Configure settings-file editing method and related defaults.

[bold cyan]❓ Help[/]
  This help screen.

[bold yellow]━━━ List Columns / ID Rules ━━━[/]

  [ ]    checkbox; toggles multi-select
  ▶      active/live session marker; GccSlim-launched sessions are prioritized
  ★ / ·  custom_name exists / only auto_summary exists
  ●      session color dot; children inherit root color, existing colors reused in order
  ID     Claude uses first 4 UUID chars; Codex uses `~` + last 3 UUID chars
  time   MM-DD HH:MM
  turns  live turn count and total turn count
  size   JSONL file size
  🔩 N   compact summary marker count
  └─     tree indentation

Codex UUID prefixes are strongly time-like and often look similar, so the list
shows the last three characters as `~abc`. When a user says `~abc id`, interpret
it as the Codex display ID.

[bold yellow]━━━ Session Locations / Truth Sources ━━━[/]

Claude sessions:
  `~/.claude/projects/<project-slug>/<sid>.jsonl`
  For active SID, use `sessionId` in `~/.claude/sessions/<PID>.json`.

Codex sessions:
  `~/.codex/sessions/YYYY/MM/DD/*.jsonl`
  Active Codex launched by the GccSlim wrapper uses `session_id` in
  `/tmp/gccfork-codex-slim-reload-<uid>.json.state-*`.

GccSlim registry / prefs:
  `~/.claude/gccfork-registry.json`
  `<project-cwd>/.gccfork/ccfork-prefs.json`

[bold yellow]━━━ Tree / Color / Name ━━━[/]

Parent relationships combine registry `parent_id`, Claude `parentUuid`, and
merge/clone metadata. Children inherit root color, and the same color tag is used
in terminal title and list.

Name rules:
  Claude display ID: `abcd`
  Codex display ID: `~abc`
  derived name examples: `task abcd[<= 1234]`, `task ~abc[<= ~def]`

[bold yellow]━━━ VSCode / Terminal Routing ━━━[/]

When multiple VSCode windows exist, GccSlim looks for one matching session cwd.
  • one match: automatically spawn in that window
  • multiple matches: window picker modal
  • zero matches: confirm opening a new VSCode window

gnome-terminal, konsole, xfce4-terminal, iTerm2, Terminal.app, Windows Terminal,
alacritty, terminator, xterm, and others open a new window/tab when supported.

[bold yellow]━━━ CLI Subcommands ━━━[/]

Main commands available without TUI:
  search, list, detail, ancestry, parent-of, rename, hard-fork,
  slim, slim-inplace, live-sessions, reconcile-live, delete,
  prefs get/set, stats, patch-claude, rust-status, hot-reload,
  slim-and-reload

[bold yellow]━━━ Mouse / Keyboard ━━━[/]

  drag                      select path/list/preview text
  Ctrl+C / Ctrl+Shift+C     copy selected text
  right click                copy / cancel menu
  checkbox click             toggle multi-select
  Ctrl-click / Shift-click   add to multi-select / range select
  Ctrl+A                     select all filtered sessions
  Ctrl+Shift+M               merge shortcut
  Ctrl+E                     settings-file editor screen
  ↑↓                        move between sessions
  Tab                       move between regions
  ←→                        move action-bar focus
  Enter                     focus fork button in list, execute on buttons
  Esc / q                   close modal or exit app
"""

    def compose(self) -> ComposeResult:
        with Vertical(id="help-box"):
            yield Label("❓ gccfork 도움말", id="help-title")
            with VerticalScroll(id="help-scroll"):
                yield Static(self.HELP_TEXT, id="help-content")
            with Horizontal(id="help-btn-row"):
                yield Button("✖ 닫기", id="btn-help-close", variant="primary")

    def on_mount(self) -> None:
        self.query_one("#btn-help-close", Button).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "btn-help-close":
            self.dismiss(None)

    def on_key(self, event) -> None:
        if event.key in {"escape", "q"}:
            self.dismiss(None)


class ModeCard(Static, can_focus=True):
    """Slim mode card selected by click, Enter, or Space; selected state is `.-selected`.

    Static-based to avoid RadioSet's one-line label limitation.
    Calls the parent ModalScreen's `_select_mode(mode)` method.
    """
    def _trigger_select(self) -> None:
        screen = self.screen
        if not (screen and self.id):
            return
        # Dispatch by id shape:
        #   <prefix>-mode-<name>  -> screen._select_mode(name), e.g. slim-mode-strong
        #   <prefix>-trig-<name>  -> screen._select_trigger(name), e.g. auto-trig-once
        if "-mode-" in self.id:
            if hasattr(screen, "_select_mode"):
                screen._select_mode(self.id.rsplit("-mode-", 1)[1])
            return
        if "-trig-" in self.id:
            if hasattr(screen, "_select_trigger"):
                screen._select_trigger(self.id.rsplit("-trig-", 1)[1])
            return
        # Legacy compatibility for slim-mode- prefix.
        if hasattr(screen, "_select_mode"):
            screen._select_mode(self.id.replace("slim-mode-", ""))

    async def on_click(self) -> None:
        self._trigger_select()

    async def _on_key(self, event: events.Key) -> None:
        if event.key in {"enter", "space"}:
            event.prevent_default()
            event.stop()
            self._trigger_select()


class BrainButton(Static):
    """Brain-agent entry button shown on the right side of the title bar.

    Click dispatches to App.action_open_brain_agent, which surfaces a modal
    letting the user resume the latest brain session or start a fresh one.
    """

    def __init__(self) -> None:
        super().__init__("🧠 AI", id="title-bar-brain")

    async def on_click(self) -> None:
        app = self.app
        if hasattr(app, "action_open_brain_agent"):
            await app.action_open_brain_agent()


class UsageButton(Static):
    """Title-bar button that opens a CLI provider's usage/analytics page.

    Two instances mounted on the right of the title bar (next to BrainButton):
      - claude → Claude Max usage dashboard
      - codex  → ChatGPT Codex cloud analytics
    Click uses webbrowser.open which honors xdg-open / open on Linux/macOS.
    """

    def __init__(self, label: str, url: str, *, widget_id: str) -> None:
        super().__init__(label, id=widget_id)
        self._target_url = url
        self._label = label

    async def on_click(self) -> None:
        try:
            ok = webbrowser.open(self._target_url, new=2)
        except Exception:
            ok = False
        if ok:
            self.app.notify(f"Open: {self._label} -> {self._target_url}", timeout=3)
        else:
            self.app.notify(
                f"Failed to open browser. Please open manually: {self._target_url}",
                severity="warning",
                timeout=6,
            )


class SlimBrainButton(Static, can_focus=True):
    """One-line brain button for the Slim modal header.

    Textual Button is three rows tall because of its border, so it clips inside
    the compact section header. Static keeps the header one line and avoids
    layout corruption.
    """

    def __init__(self) -> None:
        super().__init__("🧠 AI", id="btn-slim-brain")

    async def on_click(self) -> None:
        screen = self.screen
        if hasattr(screen, "_open_slim_brain_agent"):
            screen._open_slim_brain_agent()

    async def _on_key(self, event: events.Key) -> None:
        if event.key in {"enter", "space"}:
            event.prevent_default()
            event.stop()
            screen = self.screen
            if hasattr(screen, "_open_slim_brain_agent"):
                screen._open_slim_brain_agent()


class BrainAgentChoiceScreen(ModalScreen[Optional[str]]):
    """Modal: choose between resuming the latest brain session and new start.

    Result: 'resume' | 'new' | None (cancelled).
    Default selection picks 'resume' if a prior brain session exists,
    otherwise 'new'. The 'resume' radio is disabled when no prior session.
    """

    BINDINGS = [
        Binding("escape", "cancel", "취소"),
    ]

    def __init__(self, has_existing: bool, latest_label: Optional[str] = None) -> None:
        super().__init__()
        self._has_existing = has_existing
        self._latest_label = latest_label or ""
        self._choice = "resume" if has_existing else "new"

    def compose(self) -> ComposeResult:
        with Vertical(id="brain-box"):
            yield Static("🧠 GccSlim AI Agent", id="brain-title")
            yield Static(
                "이전 지능 세션을 재개하거나 새로 시작합니다.",
                id="brain-subtitle",
            )
            with Vertical(id="brain-options"):
                resume_label = (
                    f"Resume — {self._latest_label}"
                    if self._has_existing and self._latest_label
                    else "재개 — (이전 세션 없음)"
                )
                yield RadioSet(
                    RadioButton(
                        resume_label,
                        id="brain-opt-resume",
                        value=(self._choice == "resume" and self._has_existing),
                    ),
                    RadioButton(
                        "새로 시작",
                        id="brain-opt-new",
                        value=(self._choice == "new"),
                    ),
                    id="brain-radio",
                )
            with Horizontal(id="brain-btn-row"):
                yield Button("취소", id="brain-btn-cancel", variant="default")
                yield Static("", classes="brain-btn-spacer")
                yield Button("열기", id="brain-btn-confirm", variant="primary")

    def on_mount(self) -> None:
        # Disable the 'resume' option when no prior brain session exists.
        if not self._has_existing:
            try:
                rb = self.query_one("#brain-opt-resume", RadioButton)
                rb.disabled = True
            except Exception:
                pass
        # Move focus to the confirm button so Enter triggers it directly.
        try:
            self.query_one("#brain-btn-confirm", Button).focus()
        except Exception:
            pass

    def on_radio_set_changed(self, event: RadioSet.Changed) -> None:
        pressed = event.pressed
        rid = pressed.id if pressed else None
        if rid == "brain-opt-resume" and self._has_existing:
            self._choice = "resume"
        elif rid == "brain-opt-new":
            self._choice = "new"

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "brain-btn-cancel":
            self.dismiss(None)
        elif event.button.id == "brain-btn-confirm":
            self.dismiss(self._choice)

    def action_cancel(self) -> None:
        self.dismiss(None)


class SlimModeScreen(ModalScreen[Optional[dict]]):
    """Slim fork modal for mode, name, and options.

    UI:
      ┌── 🔻 Slim fork ──────────────────────┐
      │  source: <short_id> · <KB> · <turns>   │
      │  ┌─ compact history ───────────────┐   │
      │  │  before marker: N lines · KB    │   │
      │  │  after marker:  N lines · KB    │   │
      │  └─────────────────────────────────┘   │
      │  ┌─ name after slim ───────────────┐   │
      │  │  [input; auto-name allowed]     │   │
      │  └────────────────────────────────┘    │
      │  ┌─ mode selection ───────────────┐    │
      │  │  ( ) strong   effect: 7x save │    │
      │  │  (•) medium   effect: 5x save │    │
      │  │  ( ) weak     effect: 3x save │    │
      │  └────────────────────────────────┘    │
      │  ☐ resume in new window after slim     │
      │  [Cancel]                [🔻 Start]    │
      └──────────────────────────────────────┘

    Returns dict: {"mode": ..., "name": ..., "resume_after": bool}
    """

    BINDINGS = [
        Binding("escape", "cancel", "취소", show=False),
        Binding("q", "cancel", "취소", show=False),
    ]

    def __init__(self, session, default_mode: str = "strong",
                 default_name: Optional[str] = None,
                 other_env: Optional[str] = None,
                 current_terminal: Optional[str] = None) -> None:
        super().__init__()
        self.session = session
        self.default_mode = default_mode
        self._selected_mode = default_mode
        # Auto-name with a placeholder because final UUID is not known here.
        # action_slim_fork decides the final value.
        if default_name is None:
            parent_title = _clean_parent_title(session.title)
            default_name = (
                f"{parent_title} 🔻[<= {session.id[:4]}]" if parent_title
                else f"🔻[<= {session.id[:4]}]"
            ).strip()[:120]
        self.default_name = default_name
        # other_env / current_terminal follow the same pattern as ForkNameScreen.
        self.other_env = other_env
        self.current_terminal = current_terminal
        self._details_open = False
        # Live update state.
        self._estimates: dict[str, dict] = {}
        self._marker_idx: Optional[int] = None
        self._pre_bytes = 0
        self._post_bytes = 0

    def _resume_enabled(self) -> bool:
        try:
            return bool(self.query_one("#slim-resume-after", Checkbox).value)
        except Exception:
            return False

    def _effective_target(self) -> Optional[str]:
        if self.other_env:
            try:
                if self.query_one("#slim-other-env", Checkbox).value:
                    return self.other_env
            except Exception:
                pass
        return self.current_terminal

    def _update_sub_options_visibility(self) -> None:
        """Show sub-options based on the main auto-open toggle and VSCode target state."""
        resume = self._resume_enabled()

        # other-env checkbox: only when main toggle is ON and other_env exists.
        try:
            other_env_cb = self.query_one("#slim-other-env", Checkbox)
            show_other = bool(resume and self.other_env)
            other_env_cb.display = show_other
            if not show_other:
                other_env_cb.value = False
        except Exception:
            pass

        # newtab checkbox: only when main toggle is ON and target is not VSCode.
        try:
            newtab = self.query_one("#slim-newtab", Checkbox)
        except Exception:
            return
        if not resume:
            newtab.display = False
            newtab.value = False
            return
        show = self._effective_target() != "vscode"
        newtab.display = show
        if not show:
            newtab.value = False

    def _compute_estimates(self) -> None:
        """Display static average savings per mode, Phase E-7, 2026-05-06.

        The verdict body is archived. Live verdict calls require Rust subprocess,
        and running three subprocesses per modal open adds 1s+ latency. Use
        static averages based on verified measurements instead.

        visible_cap analysis added on 2026-05-13 separates active region into
        non-context and context-included areas using Claude Code message-count cap
        of about 115 turns / 230 user+assistant messages.
        """
        self._marker_idx = detect_compact_marker_index(self.session.jsonl_path)
        pre_lines = pre_bytes = post_lines = post_bytes = 0
        # Collect user/assistant line indices in active region for visible_cap analysis.
        active_ua_lines: list[int] = []
        active_user_lines: list[int] = []
        line_bytes: list[int] = []
        try:
            import json as _json
            with self.session.jsonl_path.open("r", encoding="utf-8", errors="ignore") as fh:
                for i, raw in enumerate(fh):
                    line_bytes.append(len(raw))
                    if self._marker_idx is not None and i <= self._marker_idx:
                        pre_lines += 1; pre_bytes += len(raw)
                    else:
                        post_lines += 1; post_bytes += len(raw)
                        # Extract user/assistant lines in active region.
                        try:
                            d = _json.loads(raw)
                            if isinstance(d, dict) and d.get("type") in ("user", "assistant"):
                                active_ua_lines.append(i)
                                if d.get("type") == "user":
                                    active_user_lines.append(i)
                        except Exception:
                            pass
        except OSError:
            pass
        self._pre_lines = pre_lines
        self._pre_bytes = pre_bytes
        self._post_lines = post_lines
        self._post_bytes = post_bytes
        if len(active_user_lines) >= 5:
            recent_start = active_user_lines[-5]
            active_start = (self._marker_idx + 1) if self._marker_idx is not None else 0
            self._recent_raw_lines = max(0, (active_start + post_lines) - recent_start)
        else:
            self._recent_raw_lines = post_lines

        # Classify using visible_cap = 230, estimated Claude Code default cap.
        VISIBLE_CAP = 230
        self._visible_cap = VISIBLE_CAP
        self._active_ua_count = len(active_ua_lines)
        if len(active_ua_lines) > VISIBLE_CAP:
            cut_line = active_ua_lines[-VISIBLE_CAP]
            invisible_lines = sum(1 for ln in range(self._marker_idx + 1 if self._marker_idx is not None else 0, cut_line))
            invisible_bytes = sum(line_bytes[ln] for ln in range(self._marker_idx + 1 if self._marker_idx is not None else 0, cut_line) if ln < len(line_bytes))
            visible_lines = post_lines - invisible_lines
            visible_bytes = post_bytes - invisible_bytes
            self._invisible_lines = invisible_lines
            self._invisible_bytes = invisible_bytes
            self._visible_lines = visible_lines
            self._visible_bytes = visible_bytes
            # With default non-context compacting ON, the real bundle/slim target is
            # only the context-included area inside the cap, not all post-marker active.
            self._bundle_target_lines = visible_lines
            self._bundle_target_bytes = visible_bytes
            self._cap_overflow = True  # active > cap means some region is excluded.
        else:
            self._invisible_lines = 0
            self._invisible_bytes = 0
            self._visible_lines = post_lines
            self._visible_bytes = post_bytes
            self._bundle_target_lines = post_lines
            self._bundle_target_bytes = post_bytes
            self._cap_overflow = False

        # Average saving rates per mode, based on verified measurements.
        avg_saving = {"strong": 0.80, "medium": 0.50, "weak": 0.20}
        avg_drop_ratio = {"strong": 0.65, "medium": 0.40, "weak": 0.15}
        for mode in ("strong", "medium", "weak"):
            saving = avg_saving[mode]
            drop_r = avg_drop_ratio[mode]
            target_lines = self._bundle_target_lines
            target_bytes = self._bundle_target_bytes
            est_dropped = int(target_lines * drop_r) if target_lines else 0
            est_kept = target_lines - est_dropped if target_lines else 0
            est_after = int(target_bytes * (1 - saving)) if target_bytes else 0
            self._estimates[mode] = {
                "kept": est_kept, "stubbed": 0, "dropped": est_dropped,
                "post_after": est_after,
            }

    def _visible_cap_compact_default(self) -> bool:
        if not self._cap_overflow:
            return False
        try:
            return bool(pref_get("slim_default_visible_cap_compact", True))
        except Exception:
            return True

    def _estimate_for_target(self, mode: str, target_lines: int, target_bytes: int) -> dict:
        avg_saving = {"strong": 0.80, "medium": 0.50, "weak": 0.20}
        avg_drop_ratio = {"strong": 0.65, "medium": 0.40, "weak": 0.15}
        saving = avg_saving.get(mode, 0.80)
        drop_r = avg_drop_ratio.get(mode, 0.65)
        est_dropped = int(target_lines * drop_r) if target_lines else 0
        return {
            "kept": target_lines - est_dropped if target_lines else 0,
            "stubbed": 0,
            "dropped": est_dropped,
            "post_after": int(target_bytes * (1 - saving)) if target_bytes else 0,
        }

    def _current_bundle_on(self) -> bool:
        try:
            return bool(self.query_one("#slim-anti-frag", Checkbox).value)
        except Exception:
            try:
                return bool(pref_get("slim_default_anti_fragmentation", True))
            except Exception:
                return True

    def _current_anti_frag_on(self) -> bool:
        # Internal option name is anti_fragmentation; UI meaning is bundle processing ON.
        return self._current_bundle_on()

    def _current_visible_cap_compact_on(self) -> bool:
        if not self._cap_overflow or not self._current_anti_frag_on():
            return False
        try:
            return bool(self.query_one("#slim-visible-cap-compact", Checkbox).value)
        except Exception:
            return self._visible_cap_compact_default()

    def _plan_target(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> tuple[int, int, str]:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        if not anti_frag_on:
            return self._post_lines, self._post_bytes, "general slim target"
        if self._cap_overflow and compact_on:
            return self._visible_lines, self._visible_bytes, "context-included"
        return self._post_lines, self._post_bytes, "full post-marker"

    def _mode_card_text(self, mode: str, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        from gccfork_settings import SLIM_MODE_LABELS
        _, hint = SLIM_MODE_LABELS[mode]
        target_lines, target_bytes, target_label = self._plan_target(compact_on, anti_frag_on)
        e = self._estimate_for_target(mode, target_lines, target_bytes)
        ratio = e["post_after"] * 100 // max(target_bytes, 1)
        saving = round(target_bytes / max(e["post_after"], 1), 1)
        badge = " [b](default)[/]" if mode == "strong" else ""
        return (
            f"[b]{mode}[/]{badge}\n"
            f"{target_bytes/1024:>4.0f} → {e['post_after']/1024:>4.0f} KB  {ratio}%\n"
            f"[b]{saving}x saved[/] [dim]{target_label}[/]\n"
            f"[dim]{hint[:32]}[/]"
        )

    def _plan_summary_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        target_lines, target_bytes, target_label = self._plan_target(compact_on, anti_frag_on)
        selected_mode = getattr(self, "_selected_mode", "strong")
        e = self._estimate_for_target(selected_mode, target_lines, target_bytes)
        ratio = e["post_after"] * 100 // max(target_bytes, 1)
        saving = round(target_bytes / max(e["post_after"], 1), 1)
        estimate_line = (
            f"\n[b]{selected_mode} estimate[/] {target_bytes/1024:.1f} -> "
            f"{e['post_after']/1024:.1f} KB ({ratio}%, {saving}x saved)"
        )
        if not anti_frag_on:
            return (
                f"[b]Plan[/] no bundle · general slim · target [b]{target_label}[/] "
                f"{target_bytes/1024:.1f} KB ({target_lines} lines)"
                f"{estimate_line}"
            )
        if self._cap_overflow and compact_on:
            return (
                f"[b]Plan[/] non-context -> before native compact boundary / "
                f"[b]{target_label}[/] -> bundle / recent raw -> preserved"
                f"{estimate_line}"
            )
        if self._cap_overflow:
            return (
                f"[b yellow]Plan[/] bundle entire post-marker region · non-context region may "
                f"enter context again"
                f"{estimate_line}"
            )
        return (
            f"[b]Plan[/] all active is inside cap · target [b]{target_label}[/] "
            f"{target_bytes/1024:.1f} KB ({target_lines} lines)"
            f"{estimate_line}"
        )

    def _scope_tree_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()

        archive_action = "preserve"
        if not anti_frag_on:
            context_off_action = "general slim target"
            context_on_action = "general slim target"
            recent_action = "general slim rules"
        elif self._cap_overflow and compact_on:
            context_off_action = "will compact"
            context_on_action = "bundle target"
            recent_action = "preserve raw"
        elif self._cap_overflow:
            context_off_action = "bundle target"
            context_on_action = "bundle target"
            recent_action = "preserve raw"
        else:
            context_off_action = "none"
            context_on_action = "bundle target"
            recent_action = "preserve raw"

        active_lines = self._post_lines
        recent_lines = getattr(self, "_recent_raw_lines", 0)
        def _display_width(s: str) -> int:
            import unicodedata
            width = 0
            for ch in s:
                width += 2 if unicodedata.east_asian_width(ch) in ("F", "W") else 1
            return width

        def _pad(s: str, width: int) -> str:
            return s + (" " * max(0, width - _display_width(s)))

        def _row(prefix: str, label: str, lines: int, action: str = "") -> str:
            left = _pad(f"{prefix} {label}", 34)
            right = f"{lines:>6} lines"
            return f"{left} │ {right} │ {action}".rstrip()

        return (
            "[b]Full session[/]\n"
            f"{_row('├─', 'compact/archive', self._pre_lines, archive_action)}\n"
            f"{_row('└─', 'active region', active_lines)}\n"
            f"{_row('   ├─', 'non-context', self._invisible_lines, context_off_action)}\n"
            f"{_row('   └─', 'context-included', self._visible_lines, context_on_action)}\n"
            f"{_row('      └─', 'latest 5 raw turns', recent_lines, recent_action)}"
        )

    def _scope_status_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        return (
            "[b]Current state[/]\n"
            f"- active user/assistant by Claude cap: {self._active_ua_count} / cap {self._visible_cap}\n"
            f"- {'has non-context region' if self._cap_overflow else 'no non-context region'}"
        )

    def _scope_details_text(self, compact_on: Optional[bool] = None, anti_frag_on: Optional[bool] = None) -> str:
        if anti_frag_on is None:
            anti_frag_on = self._current_anti_frag_on()
        if compact_on is None:
            compact_on = self._current_visible_cap_compact_on()
        if not self._cap_overflow:
            context_off_after = "none"
        elif compact_on and anti_frag_on:
            context_off_after = "move before native compact boundary"
        else:
            context_off_after = "included in bundle target"
        return (
            "[b]Selected plan[/]\n"
            f"- {'☑' if anti_frag_on else '☐'} bundle processing\n"
            f"- {'☑' if compact_on else '☐'} non-context compacting\n\n"
            "[b]After applying[/]\n"
            f"- non-context: {context_off_after}\n"
            f"- context-included: {'bundled' if anti_frag_on else 'general slim applied'}\n"
            "- latest 5 turns: preserved exactly as raw"
        )

    def _slim_brain_system_prompt(self) -> str:
        return (
            "You are an AI explainer dedicated to the GccSlim slim modal.\n"
            "Your goal is to explain the current slim plan using only the supplied numbers and option states.\n"
            "Claude Code session structure handled by GccSlim slim:\n"
            "- Sessions are JSONL files at ~/.claude/projects/<cwd-slug>/<sid>.jsonl.\n"
            "- Claude Code mainly reconstructs context from messages after the native compact marker (isCompactSummary / compact_boundary).\n"
            "- There is also a user/assistant message-count cap, so old active messages may be excluded from context even with unused 1M token budget.\n"
            "- Existing compact summaries/archive remain in raw JSONL, but they are before the native compact boundary and are not normally injected into resume context.\n"
            "- The active region is the raw conversation after the latest native compact marker.\n"
            "- The non-context region is inside active but outside the Claude message cap.\n"
            "- The context-included region is inside the current cap and is the bundle target.\n"
            "- Recent raw protected turns preserve the exact JSONL lines for the last flow the user was viewing.\n"
            "Slim application structure:\n"
            "- compact summaries/archive: preserved\n"
            "- non-context region: moved before native compact boundary to stay outside context\n"
            "- context-included region: bundled to reduce context load\n"
            "- latest N raw turns: preserved exactly\n"
            "Mode meanings:\n"
            "- strong: prioritizes context space; trims most aggressively and preserves 5 recent raw turns by default.\n"
            "- medium: balanced; trades off flow readability and reduction, preserving 10 recent raw turns by default.\n"
            "- weak: conservative; preserves more and reduces less, preserving 30 recent raw turns by default.\n"
            "Term definitions:\n"
            "- compact/archive: region before existing native compact summary, preserved as-is.\n"
            "- active region: raw conversation after the latest compact marker.\n"
            "- non-context: active portion not loaded into current context by Claude Code message cap.\n"
            "- context-included: active portion loaded into current context and targeted for bundle.\n"
            "- latest 5 raw turns: final flow the user saw, preserved exactly.\n"
            "Explanation rules:\n"
            "- Answer in Korean.\n"
            "- Keep it short, but distinguish current state from after-apply state.\n"
            "- Never imply raw data is deleted; distinguish preserve, compact, bundle, and context inclusion.\n"
            "- Clearly state that if non-context compacting is off, slim may increase loaded context after resume.\n"
            "- End with one line telling the user what to check right now."
        )

    def _slim_brain_user_prompt(self) -> str:
        anti_on = self._current_anti_frag_on()
        compact_on = self._current_visible_cap_compact_on()
        target_lines, target_bytes, target_label = self._plan_target(compact_on, anti_on)
        selected_mode = getattr(self, "_selected_mode", "strong")
        e = self._estimate_for_target(selected_mode, target_lines, target_bytes)
        ratio = e["post_after"] * 100 // max(target_bytes, 1)
        saving = round(target_bytes / max(e["post_after"], 1), 1)
        return (
            "Explain the current GccSlim slim modal state to the user in detail but concisely.\n\n"
            f"Session: {self.session.short_id} / {self.session.title}\n"
            f"Selected mode: {selected_mode}\n"
            f"bundle processing: {'ON' if anti_on else 'OFF'}\n"
            f"non-context compacting: {'ON' if compact_on else 'OFF'}\n"
            f"compact marker index: {self._marker_idx}\n\n"
            "[Slim application scope]\n"
            f"{self._scope_tree_text(compact_on, anti_on)}\n\n"
            "[Current state]\n"
            f"- active user/assistant: {self._active_ua_count}\n"
            f"- Claude cap: {self._visible_cap}\n"
            f"- non-context region: {'exists' if self._cap_overflow else 'none'}\n\n"
            "[Selected plan]\n"
            f"{self._scope_details_text(compact_on, anti_on)}\n\n"
            "[Mode estimate]\n"
            f"- target: {target_label} {target_lines} lines / {target_bytes/1024:.1f} KB\n"
            f"- estimate: {target_bytes/1024:.1f} KB -> {e['post_after']/1024:.1f} KB "
            f"({ratio}%, {saving}x saved)\n\n"
            "Based on this state, explain what the user should select now."
        )

    def _open_slim_brain_agent(self) -> None:
        app = self.app
        if not hasattr(app, "_spawn_slim_brain_agent"):
            try:
                app.notify("Could not find the AI agent launcher.", severity="error", timeout=5)
            except Exception:
                pass
            return
        app._spawn_slim_brain_agent(
            source_sid=self.session.id,
            system_prompt=self._slim_brain_system_prompt(),
            user_prompt=self._slim_brain_user_prompt(),
        )

    def _refresh_slim_plan_view(self) -> None:
        anti_on = self._current_anti_frag_on()
        compact_on = self._current_visible_cap_compact_on()
        try:
            self.query_one("#slim-scope-plan", Static).update(
                self._plan_summary_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            self.query_one("#slim-scope-tree", Static).update(
                self._scope_tree_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            self.query_one("#slim-scope-status", Static).update(
                self._scope_status_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            self.query_one("#slim-scope-details", Static).update(
                self._scope_details_text(compact_on, anti_on)
            )
        except Exception:
            pass
        try:
            warn = self.query_one("#slim-scope-warning", Static)
            warn.display = bool(self._details_open and self._cap_overflow and anti_on and not compact_on)
        except Exception:
            pass
        try:
            details = self.query_one("#slim-scope-details", Static)
            details.display = self._details_open
        except Exception:
            pass
        try:
            plan = self.query_one("#slim-scope-plan", Static)
            plan.display = self._details_open
        except Exception:
            pass
        try:
            btn = self.query_one("#btn-slim-details", Button)
            btn.label = "Hide Details" if self._details_open else "Show Details"
        except Exception:
            pass
        try:
            vc = self.query_one("#slim-visible-cap-compact", Checkbox)
            vc.disabled = not anti_on
        except Exception:
            pass
        for mode in ("strong", "medium", "weak"):
            try:
                self.query_one(f"#slim-mode-{mode}", ModeCard).update(
                    self._mode_card_text(mode, compact_on, anti_on)
                )
            except Exception:
                pass

    def compose(self) -> ComposeResult:
        from gccfork_settings import SLIM_MODE_LABELS
        self._compute_estimates()
        marker_idx = self._marker_idx
        pre_bytes = self._pre_bytes
        post_bytes = self._post_bytes
        initial_anti_on = bool(pref_get("slim_default_anti_fragmentation", True))
        initial_compact_on = self._visible_cap_compact_default() if initial_anti_on else False

        with Vertical(id="slim-box"):
            # Header with three sections.
            with Horizontal(id="slim-header"):
                yield Static("[b]GccForK[/]", id="slim-brand", markup=True)
                yield Static(
                    f"[b]🔻 Slim fork[/]  [dim]·  v{GCCFORK_VERSION}[/]",
                    id="slim-title", markup=True,
                )
                yield Static(
                    f"[dim]marker idx[/] [b]{marker_idx}[/]" if marker_idx is not None
                    else "[dim]no compact history[/]",
                    id="slim-marker-meta", markup=True,
                )

            # Body uses automatic height without scroll.
            with Vertical(id="slim-scroll"):
                # Session name section.
                with Vertical(classes="slim-section", id="slim-session-section"):
                    with Horizontal(classes="slim-section-head"):
                        yield Static(
                            "[b][SESSION][/] Session name",
                            classes="slim-section-title", markup=True,
                        )
                        yield Static("", classes="slim-spacer")
                        yield Static(
                            f"[dim]Session ID:[/] [b]{self.session.short_id}[/]",
                            classes="slim-section-meta", markup=True,
                        )
                    yield Input(value=self.default_name, id="slim-name-input")

                # Integrated compact marker and context cap analysis.
                with Vertical(classes="slim-section", id="slim-result-section"):
                    with Horizontal(id="slim-analysis-head", classes="slim-section-head"):
                        yield Static(
                            "[b][ANALYSIS][/] Slim application scope",
                            classes="slim-section-title", markup=True,
                        )
                        yield Static("", classes="slim-spacer")
                        yield SlimBrainButton()
                    yield Static(
                        self._scope_tree_text(initial_compact_on, initial_anti_on),
                        id="slim-scope-tree",
                        markup=True,
                    )
                    yield Static(
                        self._scope_status_text(initial_compact_on, initial_anti_on),
                        id="slim-scope-status",
                        classes="slim-result-target",
                        markup=True,
                    )
                    yield Button("Show Details", id="btn-slim-details")
                    details = Static(
                        self._scope_details_text(initial_compact_on, initial_anti_on),
                        id="slim-scope-details",
                        classes="slim-result-target",
                        markup=True,
                    )
                    details.display = False
                    yield details
                    if marker_idx is not None:
                        plan = Static(
                            self._plan_summary_text(initial_compact_on, initial_anti_on),
                            id="slim-scope-plan",
                            classes="slim-result-target",
                            markup=True,
                        )
                        plan.display = False
                        yield plan
                        warning = Static(
                            "[b yellow]⚠ non-context region may enter context again[/]",
                            id="slim-scope-warning",
                            classes="slim-result-target",
                            markup=True,
                        )
                        warning.display = False
                        yield warning
                    else:
                        total_kb = (self.session.size_bytes or 0) / 1024
                        yield Static(
                            f"[dim]total[/] [b]{total_kb:.1f} KB[/]",
                            markup=True,
                        )

                # Slim mode selection cards.
                with Vertical(classes="slim-section", id="slim-mode-section"):
                    yield Static(
                        "[b][MODE][/] Slim mode",
                        classes="slim-section-title", markup=True,
                    )
                    with Horizontal(id="slim-mode-row"):
                        for mode in ("strong", "medium", "weak"):
                            card = ModeCard(
                                self._mode_card_text(mode, initial_compact_on, initial_anti_on),
                                id=f"slim-mode-{mode}",
                                classes="slim-mode-card",
                                markup=True,
                            )
                            if mode == self._selected_mode:
                                card.add_class("-selected")
                            yield card

                # Options: main toggles and sub-options.
                with Vertical(classes="slim-section", id="slim-option-section"):
                    yield Static(
                        "[b][OPTION][/] Options",
                        classes="slim-section-title", markup=True,
                    )
                    # Default follows settings pref `slim_default_anti_fragmentation`, usually ON.
                    # Internal name is anti_fragmentation; UI meaning is bundle processing.
                    yield Checkbox(
                        "Bundle processing (condense context-included region into large bundles)",
                        value=bool(pref_get("slim_default_anti_fragmentation", True)),
                        id="slim-anti-frag",
                    )
                    # Option added on 2026-05-13: move non-context region before native compact marker.
                    # Visible only on cap_overflow.
                    if self._cap_overflow:
                        yield Checkbox(
                            f"Compact non-context region (outside cap {self._visible_cap})",
                            value=initial_compact_on,
                            id="slim-visible-cap-compact",
                        )
                    # Auto-open after slim; default follows settings pref `slim_default_reload`.
                    yield Checkbox(
                        "Auto-open after slim",
                        value=bool(pref_get("slim_default_reload", True)),
                        id="slim-resume-after",
                    )
                    if self.other_env:
                        if self.other_env == "vscode":
                            other_label = "    └ Send to VSCode using bridge"
                        elif self.other_env == "gnome-terminal":
                            other_label = "    └ Send to gnome-terminal"
                        else:
                            other_label = f"    └ Send to {self.other_env}"
                        # Default follows settings pref `slim_default_send_other_env`.
                        yield Checkbox(
                            other_label,
                            value=bool(pref_get("slim_default_send_other_env", False)),
                            id="slim-other-env",
                        )
                    # Default follows settings pref `slim_default_newtab`.
                    yield Checkbox(
                        "    └ 새 탭으로 열기 (해제 = 새 창)",
                        value=bool(pref_get("slim_default_newtab", False)),
                        id="slim-newtab",
                    )

            # Footer with start/cancel buttons.
            with Horizontal(id="slim-btn-row"):
                yield Button("Esc 취소", id="btn-slim-cancel")
                yield Static("", id="slim-btn-spacer")
                yield Button("Enter 슬림 시작", id="btn-slim-go", variant="primary")

    def on_mount(self) -> None:
        try:
            self.query_one("#btn-slim-go", Button).focus()
        except Exception:
            pass
        self._update_sub_options_visibility()
        self._refresh_slim_plan_view()

    def on_checkbox_changed(self, event: Checkbox.Changed) -> None:
        if event.checkbox.id in ("slim-resume-after", "slim-other-env"):
            self._update_sub_options_visibility()
        if event.checkbox.id in ("slim-anti-frag", "slim-visible-cap-compact"):
            self._refresh_slim_plan_view()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id or ""
        if bid == "btn-slim-cancel":
            self.dismiss(None)
        elif bid == "btn-slim-go":
            self._submit()
        elif bid == "btn-slim-details":
            self._details_open = not self._details_open
            self._refresh_slim_plan_view()
        elif bid == "btn-slim-brain":
            self._open_slim_brain_agent()

    def on_input_submitted(self, event: Input.Submitted) -> None:
        if event.input.id == "slim-name-input":
            self._submit()

    def _select_mode(self, mode: str) -> None:
        """Called by ModeCard; update selected state and visual mode card marker."""
        if mode not in ("strong", "medium", "weak"):
            return
        self._selected_mode = mode
        # Toggle -selected class for every card.
        from gccfork_settings import SLIM_MODE_LABELS
        for m in ("strong", "medium", "weak"):
            try:
                card = self.query_one(f"#slim-mode-{m}", ModeCard)
                if m == mode:
                    card.add_class("-selected")
                else:
                    card.remove_class("-selected")
                # CSS handles visual emphasis; avoid regenerating text just to update markers.
            except Exception:
                pass
        self._refresh_slim_plan_view()

    def _current_spawn_mode(self) -> str:
        try:
            newtab = self.query_one("#slim-newtab", Checkbox).value
        except Exception:
            newtab = False
        return "tab" if newtab else "window"

    def _current_target_terminal(self) -> Optional[str]:
        if not self.other_env:
            return None
        try:
            checked = self.query_one("#slim-other-env", Checkbox).value
        except Exception:
            checked = False
        return self.other_env if checked else None

    def _submit(self) -> None:
        mode = self._selected_mode
        try:
            name = self.query_one("#slim-name-input", Input).value.strip() or self.default_name
        except Exception:
            name = self.default_name
        try:
            resume_after = bool(self.query_one("#slim-resume-after", Checkbox).value)
        except Exception:
            resume_after = False
        try:
            anti_frag = bool(self.query_one("#slim-anti-frag", Checkbox).value)
        except Exception:
            anti_frag = False
        # visible_cap_compact is active only when cap_overflow and checkbox are ON.
        visible_cap = 0
        if self._cap_overflow:
            try:
                if self.query_one("#slim-visible-cap-compact", Checkbox).value:
                    visible_cap = self._visible_cap
            except Exception:
                pass
        self.dismiss({
            "mode": mode,
            "name": name,
            "resume_after": resume_after,
            "anti_fragmentation": anti_frag,
            "visible_cap": visible_cap,
            "spawn_mode": self._current_spawn_mode(),
            "target_terminal": self._current_target_terminal(),
        })

    def action_cancel(self) -> None:
        self.dismiss(None)


class CodexSlimModeScreen(ModalScreen[Optional[dict]]):
    """Codex JSONL slim option chooser."""

    BINDINGS = [
        Binding("escape", "cancel", "취소", show=False),
        Binding("q", "cancel", "취소", show=False),
    ]

    DEFAULT_KEEP = {
        "safe": 10,
        "strong": 3,
    }

    MODE_HINTS = {
        "safe": "safe · all compact summaries + latest 10 raw turns",
        "strong": "strong · all compact summaries + latest 3 raw turns",
    }

    def __init__(
        self,
        session: Session,
        default_mode: str = "strong",
        other_env: Optional[str] = None,
        current_terminal: Optional[str] = None,
    ) -> None:
        super().__init__()
        self.session = session
        if default_mode in {"weak", "medium", "safe"}:
            default_mode = "safe"
        elif default_mode in {"heavy-strong", "strong"}:
            default_mode = "strong"
        self._selected_mode = default_mode if default_mode in self.DEFAULT_KEEP else "strong"
        self.other_env = other_env
        self.current_terminal = current_terminal

    def _mode_text(self, mode: str) -> str:
        keep = self.DEFAULT_KEEP[mode]
        return (
            f"[b]{mode}[/]\n"
            f"Preserve latest [b]{keep}[/] user turns as raw\n"
            f"[dim]{self.MODE_HINTS[mode]}[/]"
        )

    def _default_clone_name(self) -> str:
        parent_title = _clean_parent_title(self.session.title)
        base = f"{parent_title} " if parent_title else ""
        return f"{base}🔻~????[<= {_codex_sid_label(self.session.id)}]"[:120]

    def _resume_enabled(self) -> bool:
        try:
            return bool(self.query_one("#codex-slim-resume-after", Checkbox).value)
        except Exception:
            return False

    def _default_keep_recent(self) -> int:
        try:
            value = int(pref_get("codex_slim_keep_recent", self.DEFAULT_KEEP[self._selected_mode]) or 0)
        except Exception:
            value = 0
        return value if value > 0 else self.DEFAULT_KEEP[self._selected_mode]

    def _effective_target(self) -> Optional[str]:
        if self.other_env:
            try:
                if self.query_one("#codex-slim-other-env", Checkbox).value:
                    return self.other_env
            except Exception:
                pass
        return self.current_terminal

    def _update_sub_options_visibility(self) -> None:
        resume = self._resume_enabled()
        try:
            other = self.query_one("#codex-slim-other-env", Checkbox)
            show_other = bool(resume and self.other_env)
            other.display = show_other
            if not show_other:
                other.value = False
        except Exception:
            pass
        try:
            newtab = self.query_one("#codex-slim-newtab", Checkbox)
        except Exception:
            return
        if not resume:
            newtab.display = False
            newtab.value = False
            return
        show = self._effective_target() != "vscode"
        newtab.display = show
        if not show:
            newtab.value = False

    def compose(self) -> ComposeResult:
        size_kb = (self.session.size_bytes or 0) / 1024
        with Vertical(id="slim-box"):
            with Horizontal(id="slim-header"):
                yield Static("[b]GccForK[/]", id="slim-brand", markup=True)
                yield Static("[b]🔻 Codex Slim[/]", id="slim-title", markup=True)
                yield Static(
                    f"[dim]SID[/] [b]{_display_session_id(self.session)}[/]",
                    id="slim-marker-meta",
                    markup=True,
                )
            with Vertical(id="slim-scroll"):
                with Vertical(classes="slim-section"):
                    yield Static("[b][SESSION][/] Target", classes="slim-section-title", markup=True)
                    yield Static(
                        f"{self.session.title}\n[dim]{self.session.jsonl_path} · {size_kb:.1f} KB[/]",
                        markup=True,
                    )
                with Vertical(classes="slim-section"):
                    yield Static("[b][MODE][/] Slim mode", classes="slim-section-title", markup=True)
                    with Horizontal(id="slim-mode-row"):
                        for mode in ("safe", "strong"):
                            card = ModeCard(
                                self._mode_text(mode),
                                id=f"codex-slim-mode-{mode}",
                                classes="slim-mode-card",
                                markup=True,
                            )
                            if mode == self._selected_mode:
                                card.add_class("-selected")
                            yield card
                with Vertical(classes="slim-section"):
                    yield Static("[b][OPTION][/] Options", classes="slim-section-title", markup=True)
                    yield Input(
                        value=str(self._default_keep_recent()),
                        id="codex-slim-keep-recent",
                        placeholder="number of recent user turns to preserve",
                    )
                    yield Checkbox(
                        "Include previous compact summaries in new context",
                        value=bool(pref_get("codex_slim_include_compact_summaries", True)),
                        id="codex-slim-include-compact-summaries",
                    )
                    yield Static(
                        "Structure: compact summaries #1..N -> current slim body -> recent raw protected turns",
                        classes="settings-item-hint",
                    )
                    yield Checkbox(
                        "Trim tool calls/results even inside recent raw protected turns",
                        value=bool(pref_get("codex_slim_trim_recent_tools", True)),
                        id="codex-slim-trim-recent-tools",
                    )
                    yield Static(
                        "Keeps recent conversation text but removes old tool output, token logs, and plumbing rows.",
                        classes="settings-item-hint",
                    )
                    yield Checkbox(
                        "Preserve original: create slim clone",
                        value=bool(pref_get("codex_slim_default_clone", False)),
                        id="codex-slim-clone",
                    )
                    yield Input(
                        value=self._default_clone_name(),
                        id="codex-slim-name-input",
                        placeholder="clone name",
                    )
                    yield Checkbox(
                        "Auto-open after slim",
                        value=bool(pref_get("codex_slim_default_reload", True)),
                        id="codex-slim-resume-after",
                    )
                    if self.other_env:
                        yield Checkbox(
                            f"    └ Send to {self.other_env}",
                            value=bool(pref_get("codex_slim_default_send_other_env", False)),
                            id="codex-slim-other-env",
                        )
                    yield Checkbox(
                        "    └ 새 탭으로 열기 (해제 = 새 창)",
                        value=bool(pref_get("codex_slim_default_newtab", False)),
                        id="codex-slim-newtab",
                    )
            with Horizontal(id="slim-btn-row"):
                yield Button("Esc 취소", id="btn-codex-slim-cancel")
                yield Static("", id="slim-btn-spacer")
                yield Button("Enter 슬림 시작", id="btn-codex-slim-go", variant="primary")

    def on_mount(self) -> None:
        self._update_sub_options_visibility()
        try:
            self.query_one("#btn-codex-slim-go", Button).focus()
        except Exception:
            pass

    def on_checkbox_changed(self, event: Checkbox.Changed) -> None:
        if event.checkbox.id in ("codex-slim-resume-after", "codex-slim-other-env"):
            self._update_sub_options_visibility()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id or ""
        if bid == "btn-codex-slim-cancel":
            self.dismiss(None)
        elif bid == "btn-codex-slim-go":
            self._submit()

    def _select_mode(self, mode: str) -> None:
        if mode not in self.DEFAULT_KEEP:
            return
        self._selected_mode = mode
        for m in self.DEFAULT_KEEP:
            try:
                card = self.query_one(f"#codex-slim-mode-{m}", ModeCard)
                if m == mode:
                    card.add_class("-selected")
                else:
                    card.remove_class("-selected")
            except Exception:
                pass
        try:
            self.query_one("#codex-slim-keep-recent", Input).value = str(self.DEFAULT_KEEP[mode])
        except Exception:
            pass

    def _current_spawn_mode(self) -> str:
        try:
            return "tab" if self.query_one("#codex-slim-newtab", Checkbox).value else "window"
        except Exception:
            return "window"

    def _current_target_terminal(self) -> Optional[str]:
        if not self.other_env:
            return None
        try:
            return self.other_env if self.query_one("#codex-slim-other-env", Checkbox).value else None
        except Exception:
            return None

    def _submit(self) -> None:
        try:
            keep_recent = int(self.query_one("#codex-slim-keep-recent", Input).value.strip())
        except Exception:
            keep_recent = self.DEFAULT_KEEP[self._selected_mode]
        if keep_recent < 1:
            keep_recent = self.DEFAULT_KEEP[self._selected_mode]
        try:
            clone = bool(self.query_one("#codex-slim-clone", Checkbox).value)
        except Exception:
            clone = False
        try:
            include_compact_summaries = bool(
                self.query_one("#codex-slim-include-compact-summaries", Checkbox).value
            )
        except Exception:
            include_compact_summaries = True
        try:
            trim_recent_tools = bool(
                self.query_one("#codex-slim-trim-recent-tools", Checkbox).value
            )
        except Exception:
            trim_recent_tools = True
        try:
            clone_name = self.query_one("#codex-slim-name-input", Input).value.strip()
        except Exception:
            clone_name = self._default_clone_name()
        try:
            resume_after = bool(self.query_one("#codex-slim-resume-after", Checkbox).value)
        except Exception:
            resume_after = False
        self.dismiss({
            "mode": self._selected_mode,
            "keep_recent": keep_recent,
            "include_compact_summaries": include_compact_summaries,
            "trim_recent_tools": trim_recent_tools,
            "clone": clone,
            "name": clone_name,
            "resume_after": resume_after,
            "spawn_mode": self._current_spawn_mode(),
            "target_terminal": self._current_target_terminal(),
        })

    def action_cancel(self) -> None:
        self.dismiss(None)


class SmartDeleteScreen(ModalScreen[str]):
    DEFAULT_BOX_WIDTH = 82
    MIN_BOX_WIDTH = 64

    def __init__(
        self,
        session_id: str,
        session_title: str,
        note_text: str,
        pid_lines: list[str],
        exact_pids: list[int],
        bullet_sessions: Optional[dict[int, str]] = None,
    ) -> None:
        super().__init__()
        self.session_id = session_id
        self.session_title = session_title or "(제목 없음)"
        self.note_text = note_text
        self.pid_lines = pid_lines if pid_lines else ["표시할 프로세스 정보가 없습니다."]
        self.exact_pids = exact_pids
        self.bullet_sessions = bullet_sessions or {}

    def compose(self) -> ComposeResult:
        with Vertical(id="delete-box"):
            yield Static("세션 삭제 확인 (휴지통으로 이동)", id="delete-header")
            with Vertical(id="delete-info"):
                yield Static(
                    f"Session ID : {self.session_id}",
                    id="delete-row-sid",
                    classes="delete-info-row -filled",
                )
                yield Static(
                    f"Title/name : {self.session_title}",
                    id="delete-row-title",
                    classes="delete-info-row -filled",
                )
                yield Static(
                    self.note_text,
                    id="delete-row-note",
                    classes="delete-info-row -note",
                )
            with Vertical(id="delete-pid-panel"):
                yield SelectableTextArea(
                    "\n".join(self.pid_lines),
                    id="delete-pid-list",
                    read_only=True,
                    show_cursor=False,
                    soft_wrap=True,
                    compact=True,
                    highlight_cursor_line=False,
                )
            with Horizontal(id="delete-footer"):
                yield Static("Esc", id="delete-esc")
                yield Static("", id="delete-footer-spacer")
                yield Button("취소", id="btn-del-cancel")
                if self.exact_pids:
                    yield Button(
                        f"Close and delete ({len(self.exact_pids)})",
                        id="btn-kill-delete",
                        variant="warning",
                    )
                yield Button("삭제", id="btn-delete-only", variant="error")
        yield CopyMenuOverlay(id="copy-menu")

    def on_mount(self) -> None:
        self.query_one("#btn-del-cancel", Button).focus()
        self.call_after_refresh(self._finalize_layout)

    def _finalize_layout(self) -> None:
        delete_box = self.query_one("#delete-box", Vertical)
        pid_area = self.query_one("#delete-pid-list", TextArea)

        screen_width = self.size.width or 100
        box_width = min(
            self.DEFAULT_BOX_WIDTH,
            max(self.MIN_BOX_WIDTH, screen_width - 4),
        )
        delete_box.styles.width = box_width

        # Box border(2) + box padding(2) + panel border(2) + panel padding(2) = 8.
        content_width = max(10, box_width - 8)
        total_rows = sum(
            max(1, math.ceil(cell_len(line) / content_width)) for line in self.pid_lines
        )
        pid_area.styles.height = max(1, total_rows)
        _apply_bullet_highlights(pid_area, pid_area.text, self.bullet_sessions)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-kill-delete":
            self.dismiss("kill-and-delete")
        elif bid == "btn-delete-only":
            self.dismiss("delete-only")
        elif bid == "btn-del-cancel":
            self.dismiss("cancel")

    def on_key(self, event) -> None:
        if event.key == "escape":
            self.dismiss("cancel")


