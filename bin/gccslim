    def on_mount(self) -> None:
        self.title = "gccslim"
        try:
            sys.stdout.write("\033]0;⭐ GccForK ⭐\007")
            sys.stdout.flush()
        except Exception:
            pass
        # Active project cwd for project-local prefs
        # (<cwd>/.gccfork/ccfork-prefs.json overrides global registry prefs).
        # Default scope = "project" per user policy 2026-05-08.
        try:
            set_active_project_cwd(os.getcwd())
            set_active_pref_scope("project")
        except Exception:
            pass
        # Re-read divider ratio now that project scope is active
        # (__init__ ran before set_active_project_cwd, so it only saw global).
        try:
            saved_ratio = float(pref_get("left_pane_ratio", self.left_pane_ratio))
            self.left_pane_ratio = max(0.05, min(0.95, saved_ratio))
        except Exception:
            pass
        self._configure_list_theme()
        self._update_title_bar()
        self.reload_sessions()
        self._apply_pane_widths(refresh=False)
        # First call often runs before layout is sized (main.size.width=0),
        # so schedule a second pass after the initial refresh.
        self.call_after_refresh(self._apply_pane_widths, refresh=True)
        # Detect stale TUI instances started before this code mtime and offer a kill option.
        try:
            self.call_later(self._check_stale_instances)
        except Exception:
            pass
        # cleanupPeriodDays guard — claude's silent purge of old jsonl
        # would also wipe archive/merge variants. Warn once per startup
        # if the value is below the safe threshold.
        try:
            self.call_later(self._check_cleanup_period)
        except Exception:
            pass
        # Codex/GccSlim runtime patch guard. Codex updates can replace upstream
        # or installed binaries behind the user's back, so verify on every
        # gccfork startup and rebuild only when a required marker is stale.
        try:
            self.call_later(self._start_codex_gccslim_patch_guard)
        except Exception:
            pass
        # Periodic reload: pref `auto_reload_seconds` defaults to 2, disabled at 0.
        auto_reload = pref_get("auto_reload_seconds", 2)
        try:
            auto_reload = int(auto_reload)
        except (TypeError, ValueError):
            auto_reload = 2
        if auto_reload > 0:
            self.set_interval(float(auto_reload), self._auto_reload_tick)
        # TUI request polling: receive work requests from the claude hook.
        try:
            self._tui_request_poller_start()
        except Exception:
            pass

    def _auto_reload_tick(self) -> None:
        """Periodic polling: detect new JSONL files using disk globs only.

        The previous implementation parsed every session on each tick, causing
        hundreds of MB of IO. This version collects only filename stems and calls
        `reload_sessions()` only when changes are detected.

        Additionally, each tick syncs the live-session snapshot (`_live_sids`) and
        cleans dead spawned SIDs so marker colors update dynamically.
        """
        # Sync live sessions every tick, independent of JSONL changes.
        live_changed = self._sync_live_session_markers()

        try:
            current_snapshot: set[str] = set()
            if PROJECTS_DIR.exists():
                for p in PROJECTS_DIR.glob("*/*.jsonl"):
                    stem = p.stem
                    if UUID_ANY_RE.match(stem):
                        current_snapshot.add(stem)
            if CODEX_SESSIONS_DIR.exists():
                for p in CODEX_SESSIONS_DIR.glob("*/*/*/*.jsonl"):
                    sid = _codex_session_id_from_path(p)
                    if sid:
                        current_snapshot.add(sid)

            codex_reconciled = self._reconcile_pending_codex_new_roots_from_state()

            if not self._last_known_session_ids:
                # First tick only records the baseline; no scan required.
                self._last_known_session_ids = current_snapshot
                # A screen refresh is still needed if live/name registration changed.
                if live_changed or codex_reconciled:
                    try:
                        self.reload_sessions() if codex_reconciled else self.refresh_list()
                    except Exception:
                        pass
                return

            newly_added = current_snapshot - self._last_known_session_ids
            removed = self._last_known_session_ids - current_snapshot

            if not newly_added and not removed:
                # Refresh even without JSONL changes if live/name registration changed.
                if live_changed or codex_reconciled:
                    try:
                        self.reload_sessions() if codex_reconciled else self.refresh_list()
                    except Exception:
                        pass
                return

            self._last_known_session_ids = current_snapshot

            if newly_added and self._pending_soft_forks:
                self._reconcile_pending_soft_forks(newly_added)
            if newly_added and self._pending_new_roots:
                self._reconcile_pending_new_roots(newly_added)

            # Register newly added live JSONLs in spawn tracking; new JSONLs are almost
            # always the result of this gccfork's new/fork/clone/resume operations.
            now_ts = time.time()
            for sid in newly_added:
                if sid in self._live_sids:
                    self._spawned_sids.add(sid)
                    self._spawned_at.setdefault(sid, now_ts)

            # Prune stale cache for removed JSONLs before reload.
            if removed:
                prune_parse_cache()

            self.reload_sessions()
        except Exception:
            pass

    def _sync_live_session_markers(self) -> bool:
        """Refresh live-session snapshot and clean dead spawned SIDs.

        - A new spawn may not show up live immediately because bridge alive
          registration can lag by a few seconds. Cleaning with a simple
          `_spawned & live` intersection would drop newly spawned SIDs for a tick
          or two, causing the wrong marker color once they appear live.
        - Solution: gate with `_spawned_confirmed_sids`. Only SIDs seen live at
          least once are removed when they are now dead; pre-registration SIDs are kept.

        Returns:
            True when marker state changed and the caller should refresh_list.
        """
        try:
            live_map = all_active_sid_pid_map()
            for sid, pids in _codex_active_sid_pid_map().items():
                live_map.setdefault(sid, []).extend(pids)
            new_live = set(live_map.keys())
        except Exception:
            return False
        prev_live = self._live_sids
        prev_spawned = set(self._spawned_sids)
        self._live_sids = new_live
        # Promote spawned SIDs to confirmed when first observed live.
        self._spawned_confirmed_sids |= self._spawned_sids & new_live
        # Confirmed SIDs missing from live are dead spawns; remove them from both sets.
        dead = self._spawned_confirmed_sids - new_live
        if dead:
            self._spawned_sids -= dead
            self._spawned_confirmed_sids -= dead
            for sid in dead:
                self._spawned_at.pop(sid, None)
        # Spawns not live after 60 seconds are failed spawns; discard to avoid residue.
        now = time.time()
        stale = {
            sid for sid, ts in self._spawned_at.items()
            if sid not in self._spawned_confirmed_sids and (now - ts) > 60
        }
        if stale:
            self._spawned_sids -= stale
            for sid in stale:
                self._spawned_at.pop(sid, None)
        return new_live != prev_live or self._spawned_sids != prev_spawned

    def _reconcile_pending_soft_forks(self, newly_added: set[str]) -> None:
        """Record parent/name when a new JSONL matches a pending soft fork.

        Matching criteria:
          - the new session's `first_parent_uuid` matches one parent message uuid
          - or the new session cwd matches the parent cwd near the pending creation time

        When strict matching is difficult, use parent.cwd plus nearby creation time
        within 60 seconds as a heuristic.
        """
        if not newly_added:
            return
        now = time.time()
        # Drop stale pending entries older than five minutes.
        stale = [k for k, v in self._pending_soft_forks.items() if now - v["created_at"] > 300]
        for k in stale:
            self._pending_soft_forks.pop(k, None)
        if not self._pending_soft_forks:
            return

        # Find the closest pending entry for each newly added SID.
        for new_id in newly_added:
            new_sess = find_session_by_id(new_id)
            if not new_sess:
                continue
            # Skip if parent is already recorded, either legacy or previously registered.
            if new_sess.parent_id:
                continue
            # Heuristic: matching cwd and nearby creation time.
            best_match_parent = None
            best_delta = float("inf")
            for parent_id, pending in self._pending_soft_forks.items():
                parent = find_session_by_id(parent_id)
                if not parent:
                    continue
                if parent.cwd and new_sess.cwd and parent.cwd != new_sess.cwd:
                    continue
                delta = now - pending["created_at"]
                if delta < best_delta:
                    best_delta = delta
                    best_match_parent = (parent_id, pending)
            if best_match_parent is None:
                continue
            parent_id, pending = best_match_parent
            name = pending.get("name") or f"{new_sess.id[:4]}[<= {parent_id[:4]}]"
            # Replace the new four-char placeholder and support the old eight-char placeholder.
            if name and "????????" in name:
                name = name.replace("????????", new_sess.short_id)
            if name and "????" in name:
                name = name.replace("????", new_sess.id[:4])
            registry_set(new_id, parent_id=parent_id, fork_type="soft", name=name)
            self._pending_soft_forks.pop(parent_id, None)
            self.notify(f"🔱 Soft fork registered: {new_sess.short_id} <- parent {parent_id[:8]}")

    def _reconcile_pending_new_roots(self, newly_added: set[str]) -> None:
        """Assign pending new-root names to newly created parentless JSONLs.

        Matching priority:
          1. direct SID match, used when we pre-seeded --session-id
          2. cwd + timing heuristic for older claude fallback where claude creates its own SID
        """
        if not newly_added:
            return
        now = time.time()
        # Drop stale pending entries.
        self._pending_new_roots = [
            p for p in self._pending_new_roots if now - p["created_at"] <= 300
        ]
        if not self._pending_new_roots:
            return
        for new_id in newly_added:
            new_sess = find_session_by_id(new_id)
            if not new_sess or new_sess.parent_id:
                continue

            # 1. Prefer direct SID matching.
            sid_idx: Optional[int] = None
            for idx, pending in enumerate(self._pending_new_roots):
                if pending.get("sid") == new_id:
                    sid_idx = idx
                    break
            if sid_idx is not None:
                entry = self._pending_new_roots.pop(sid_idx)
                name = entry.get("name") or f"New session {new_sess.short_id}"
                registry_set(new_id, name=name)
                self.notify(f"✨ New root registered: {new_sess.short_id}  ({name[:30]})")
                continue

            # 2. cwd + timing heuristic for claude fallback without --session-id.
            best_idx: Optional[int] = None
            best_delta = float("inf")
            for idx, pending in enumerate(self._pending_new_roots):
                if pending.get("sid"):
                    # If SID exists but did not match above, it is a different new session.
                    continue
                if pending.get("cwd") and new_sess.cwd and pending["cwd"] != new_sess.cwd:
                    continue
                delta = now - pending["created_at"]
                if delta < best_delta:
                    best_delta = delta
                    best_idx = idx
            if best_idx is None:
                continue
            entry = self._pending_new_roots.pop(best_idx)
            name = entry.get("name") or f"New session {new_sess.short_id}"
            registry_set(new_id, name=name)
            self.notify(f"✨ New root registered: {new_sess.short_id}  ({name[:30]})")

    def _reconcile_pending_codex_new_roots_from_state(self) -> bool:
        """Link the Codex New button pending name to the actual SID from wrapper state."""
        now = time.time()
        self._pending_new_roots = [
            p for p in self._pending_new_roots if now - p["created_at"] <= 300
        ]
        pending_codex = [
            (idx, p)
            for idx, p in enumerate(self._pending_new_roots)
            if p.get("source") == "codex"
        ]
        if not pending_codex:
            return False

        changed = False
        remove_indices: set[int] = set()
        for data in _read_codex_wrapper_states():
            sid = data.get("session_id")
            if not isinstance(sid, str) or registry_get(sid).get("name"):
                continue
            state_cwd = normalize_cwd(data.get("cwd"))
            best_idx: Optional[int] = None
            best_delta = float("inf")
            for idx, pending in pending_codex:
                if idx in remove_indices:
                    continue
                pending_cwd = pending.get("cwd")
                if pending_cwd and state_cwd and pending_cwd != state_cwd:
                    continue
                delta = abs(float(data.get("updated_at") or now) - pending["created_at"])
                if delta < best_delta:
                    best_delta = delta
                    best_idx = idx
            if best_idx is None:
                continue
            entry = self._pending_new_roots[best_idx]
            name = entry.get("name") or f"New Codex session {sid[:8]}"
            registry_set(sid, name=name)
            self._spawned_sids.add(sid)
            self._spawned_at.setdefault(sid, now)
            remove_indices.add(best_idx)
            changed = True
            try:
                self.notify(f"✨ Codex new root registered: {sid[:8]}  ({name[:30]})")
            except Exception:
                pass

        if remove_indices:
            self._pending_new_roots = [
                p for idx, p in enumerate(self._pending_new_roots)
                if idx not in remove_indices
            ]
        return changed

    def on_resize(self, event: events.Resize) -> None:
        if self.is_mounted:
            self._apply_pane_widths(refresh=True)

    def _apply_pane_widths(self, refresh: bool) -> None:
        try:
            main = self.query_one("#main", Horizontal)
            left = self.query_one("#left", Vertical)
            right = self.query_one("#right", Vertical)
        except Exception:
            return

        total_width = max(0, (main.size.width or 0) - self.PANE_DIVIDER_WIDTH)
        if total_width <= 0:
            return

        min_pane = max(8, min(self.MIN_PANE_WIDTH, total_width // 3))
        max_left = max(min_pane, total_width - min_pane)
        left_width = int(round(total_width * self.left_pane_ratio))
        left_width = max(min_pane, min(max_left, left_width))
        right_width = max(min_pane, total_width - left_width)
        left_width = max(min_pane, total_width - right_width)

        left.styles.width = left_width
        right.styles.width = right_width

        if refresh:
            # styles.width assignment is async — actual size updates after
            # the next layout pass. refresh_list() reads list_area.size.width
            # to compute title_width, so defer it one frame to avoid using
            # the stale (old) width and producing truncated lines.
            self.call_after_refresh(self.refresh_list)

    def _set_pane_ratio_from_screen_x(self, screen_x: int, refresh: bool) -> None:
        try:
            main = self.query_one("#main", Horizontal)
        except Exception:
            return

        total_width = max(0, (main.size.width or 0) - self.PANE_DIVIDER_WIDTH)
        if total_width <= 0:
            return

        min_pane = max(8, min(self.MIN_PANE_WIDTH, total_width // 3))
        max_left = max(min_pane, total_width - min_pane)
        main_left = main.region.x
        left_width = screen_x - main_left
        left_width = max(min_pane, min(max_left, left_width))
        self.left_pane_ratio = left_width / total_width
        self._apply_pane_widths(refresh=refresh)

    def begin_pane_drag(self, screen_x: int) -> None:
        self._pane_dragging = True
        self._set_pane_ratio_from_screen_x(screen_x, refresh=False)

    def update_pane_drag(self, screen_x: int) -> None:
        if not self._pane_dragging:
            return
        self._set_pane_ratio_from_screen_x(screen_x, refresh=False)

    def finish_pane_drag(self, screen_x: int) -> None:
        if not self._pane_dragging:
            return
        self._pane_dragging = False
        self._set_pane_ratio_from_screen_x(screen_x, refresh=True)
        # Persist divider position so next TUI launch restores it.
        try:
            pref_set("left_pane_ratio", round(self.left_pane_ratio, 4))
        except Exception:
            pass

    def _scope_label(self) -> str:
        if self.scope_all:
            return "All projects"
        if self.current_cwd:
            return f"Current project · {self.current_cwd}"
        return "Current project (no cwd)"

    def _scope_text(self) -> str:
        base = f"scope: {self._scope_label()}"
        # Show count while multi-select is active.
        n = len(self._multi_selected_ids)
        if n > 0:
            base += f"   ✓ {n} selected (Esc to clear)"
        return base

    def _update_title_bar(self) -> None:
        try:
            scope_info = self.query_one("#scope-info", SelectableTextArea)
        except Exception:
            return
        full = self._scope_text()
        # Trim against the actual inner widget width: border 2 + padding 2 = 4.
        try:
            w = scope_info.size.width
        except Exception:
            w = 0
        # If the widget is not sized yet, e.g. during on_mount, do not trim and
        # retry after the next repaint.
        if w <= 4:
            self._programmatic_update = True
            try:
                scope_info.load_text(full)
            finally:
                self._programmatic_update = False
            self.call_after_refresh(self._update_title_bar)
            return
        inner_w = w - 4
        if cell_len(full) > inner_w:
            target = inner_w - 1  # Reserve space for the trailing ellipsis.
            truncated = ""
            cur = 0
            for ch in full:
                cur += cell_len(ch)
                if cur > target:
                    break
                truncated += ch
            full = truncated + "…"
        self._programmatic_update = True
        try:
            scope_info.load_text(full)
        finally:
            self._programmatic_update = False

    def _check_stale_instances(self) -> None:
        """Detect other gccfork TUI instances started with old code and offer a kill modal."""
        stale = [i for i in _find_other_gccfork_tuis() if i["is_old"]]
        if not stale:
            return

        def _on_decision(should_kill: Optional[bool]) -> None:
            if not should_kill:
                return
            killed = []
            for inst in stale:
                try:
                    os.kill(inst["pid"], 15)  # SIGTERM
                    killed.append(inst["pid"])
                except (OSError, ProcessLookupError):
                    pass
            try:
                self.notify(
                    f"✓ Closed {len(killed)} old instance(s) (PID: {killed})",
                    severity="information",
                    timeout=6,
                )
            except Exception:
                pass

        try:
            self.push_screen(StaleInstanceConfirmScreen(stale), _on_decision)
        except Exception:
            pass

    def _check_cleanup_period(self) -> None:
        """Warn user when claude's cleanupPeriodDays is small enough to risk
        silent deletion of archive/merge variants.

        Reads ~/.claude/settings.json. If value < THRESHOLD_DAYS (5y),
        push CleanupConfirmScreen with one-click "set to 9999 days" action.
        """
        try:
            current = cleanup_needs_warning()
        except Exception:
            return
        if current is None:
            return  # safe — no warning needed

        def _on_decision(applied: Optional[bool]) -> None:
            # No follow-up needed — modal already updated settings.json
            # and notify()'d the user on success/failure.
            return

        try:
            self.push_screen(CleanupConfirmScreen(current), _on_decision)
        except Exception:
            pass

    def _start_codex_gccslim_patch_guard(self) -> None:
        def _worker() -> None:
            try:
                status, detail = _ensure_codex_gccslim_patch()
            except Exception as exc:
                status, detail = "error", f"{type(exc).__name__}: {exc}"
            self.call_from_thread(self._finish_codex_gccslim_patch_guard, status, detail)

        threading.Thread(
            target=_worker,
            name="gccfork-codex-gccslim-patch-guard",
            daemon=True,
        ).start()

    def _finish_codex_gccslim_patch_guard(self, status: str, detail: str) -> None:
        if status == "patched":
            self.notify(
                f"Codex GccSlim patch auto-refresh complete: {detail}",
                severity="information",
                timeout=8,
            )
        elif status == "busy":
            self.notify(
                "Codex GccSlim patch refresh is already being handled by another gccfork instance.",
                severity="information",
                timeout=5,
            )
        elif status == "error":
            self.notify(
                f"Codex GccSlim auto patch failed: {detail}",
                severity="error",
                timeout=12,
            )

    def on_resize(self, event) -> None:
        # Re-trim the scope display when window size changes.
        self._update_title_bar()

    def reload_sessions(self) -> None:
        """Fast scan for initial display and restart the backfill worker.

        - Cache hit JSONL: full data with exact turn_count.
        - Cache miss: metadata only, head 5KB + tail 16KB, turn_count = -1 placeholder.
        - Backfill worker fully parses metadata-only sessions by priority and updates reactively.

        Before scanning, sweep stale metadata-only stub JSONLs created by the
        claude hook for archived SIDs in main, preventing 0-turn residue in the tree.
        """
        try:
            swept = sweep_all_known_projects()
            if swept:
                count = sum(len(v) for v in swept.values())
                try:
                    self.notify(f"🧹 stale stub sweep: cleaned {count}")
                except Exception:
                    pass
        except Exception:
            pass
        self.sessions = scan_sessions_fast(self.current_cwd, self.scope_all)
        self.sessions.extend(scan_codex_sessions(self.current_cwd, self.scope_all))
        self.sessions.sort(key=lambda s: s.mtime, reverse=True)
        known_ids = {session.id for session in self.sessions}
        if self.selected_session_id not in known_ids:
            self.selected_session_id = self.current_session_id if self.current_session_id in known_ids else None
        self.refresh_list()
        # Start backfill worker; same-group exclusive cancels the previous worker.
        try:
            self.run_worker(
                self._backfill_sessions(),
                group="backfill",
                exclusive=True,
                description="Backfill (turn_count + uuid index)",
            )
        except Exception:
            # Ignore if the Textual app is not mounted yet or worker startup fails.
            pass

    async def _backfill_sessions(self) -> None:
        """Fully parse metadata-only sessions one by one and update reactively.

        Priority: selected first, then descending mtime. This fills the selected
        session first so the clicked preview becomes accurate immediately.

        Responsiveness safeguards:
        - Full parsing runs via `asyncio.to_thread`, keeping the main event loop free.
        - `refresh_list()` is debounced at 0.3 seconds or more to avoid stutter in
          100+ session environments.
        - After each session, `asyncio.sleep(0.03)` yields to the main loop so keys
          and clicks respond promptly.

        After completion, rerun `reinfer_parents_from_cache` so inferred parents can
        reposition parts of the tree.
        """
        import asyncio
        from gccfork_sessions import parse_session as _full_parse

        # Priority queue of metadata-only sessions (turn_count == -1).
        todo = [s for s in self.sessions if s.turn_count == -1 and s.source != "codex"]
        selected_id = self.selected_session_id

        def _priority(sess: Session) -> tuple[int, float]:
            return (
                0 if sess.id == selected_id else 1,
                -sess.mtime.timestamp(),  # Descending order.
            )

        todo.sort(key=_priority)

        had_any = bool(todo)
        last_refresh = 0.0
        REFRESH_MIN_INTERVAL = 0.3  # 300 ms debounce.
        YIELD_AFTER_EACH = 0.03     # Yield 30 ms to the main loop.

        try:
            loop = asyncio.get_event_loop()
        except Exception:
            loop = None

        def _now() -> float:
            return loop.time() if loop is not None else 0.0

        for idx, sess in enumerate(todo):
            try:
                full = await asyncio.to_thread(_full_parse, sess.jsonl_path)
            except Exception:
                continue
            if full is None:
                continue
            # In-place update; tree/list references point at the same Session object.
            sess.turn_count = full.turn_count
            sess.first_msgs = full.first_msgs
            sess.last_msgs = full.last_msgs
            if full.auto_summary:
                sess.auto_summary = full.auto_summary
            sess.compact_count = full.compact_count
            sess.live_turn_count = full.live_turn_count
            sess.first_parent_uuid = full.first_parent_uuid

            # Selected session is likely visible, so refresh immediately; debounce others.
            now = _now()
            is_selected = (sess.id == selected_id)
            if is_selected or (now - last_refresh) >= REFRESH_MIN_INTERVAL:
                try:
                    self.refresh_list()
                except Exception:
                    pass
                last_refresh = now

            # Yield to the main event loop for key handling.
            try:
                await asyncio.sleep(YIELD_AFTER_EACH)
            except Exception:
                pass

        # After full parsing, rerun parent inference and reposition the tree.
        if had_any:
            try:
                reinfer_parents_from_cache(self.sessions)
                self.refresh_list()
            except Exception:
                pass

    def _build_tree(self, sessions: list[Session]) -> list[tuple[Session, str]]:
        by_id = {session.id: session for session in sessions}

        def _effective_parent(sid: str, max_depth: int = 30) -> Optional[str]:
            """Walk the parent_id chain and return None when a cycle is found.

            Defensive detection keeps tree rendering safe even if legacy or inferred
            data unexpectedly contains cycles.
            """
            sess = by_id.get(sid)
            if not sess or not sess.parent_id or sess.parent_id not in by_id:
                return None
            parent = sess.parent_id
            cur: Optional[str] = parent
            visited = {sid}
            for _ in range(max_depth):
                if cur is None or cur not in by_id:
                    return parent
                if cur in visited:
                    return None  # Cycle detected; isolate this session as a root.
                visited.add(cur)
                nxt = by_id[cur].parent_id
                if not nxt or nxt not in by_id:
                    return parent
                cur = nxt
            return parent

        children_of: dict[Optional[str], list[Session]] = {}
        for session in sessions:
            parent = _effective_parent(session.id)
            children_of.setdefault(parent, []).append(session)
        for parent, items in children_of.items():
            if parent is None:
                items.sort(key=lambda item: item.mtime, reverse=True)
            else:
                items.sort(key=lambda item: item.mtime)

        out: list[tuple[Session, str]] = []
        placed: set[str] = set()

        def walk(node: Session, prefix: str, is_last: bool, depth: int) -> None:
            if node.id in placed:
                return
            placed.add(node.id)
            display_prefix = "" if depth == 0 else prefix + ("└─ " if is_last else "├─ ")
            out.append((node, display_prefix))
            kids = children_of.get(node.id, [])
            child_prefix = prefix + ("   " if is_last else "│  ") if depth > 0 else ""
            for index, child in enumerate(kids):
                walk(child, child_prefix, index == len(kids) - 1, depth + 1)

        for root in children_of.get(None, []):
            walk(root, "", True, 0)
        # Force missing nodes, e.g. cycle fallout not attached to roots, into root placement.
        for session in sessions:
            if session.id not in placed:
                out.append((session, ""))
                placed.add(session.id)
        return out

    def filtered_sessions(self) -> list[Session]:
        # Deep mode: after scan completes show only results; before scan show everything.
        if self._deep_mode:
            if self._deep_scan_done:
                ids = self._deep_search_results
                return [s for s in self.sessions if s.id in ids]
            return self.sessions
        query = self.filter_text.strip().lower()
        if not query:
            return self.sessions
        out = []
        for session in self.sessions:
            hay = " ".join(filter(None, [
                session.id,
                _display_session_id(session),
                session.custom_name,
                session.auto_summary,
                session.cwd or "",
                session.originator or "",
                session.source or "",
            ])).lower()
            if query in hay:
                out.append(session)
        return out

    def _build_list_items(self) -> list[tuple[Session, str]]:
        filtered = self.filtered_sessions()
        if self.view_mode == "tree":
            return self._build_tree(filtered)
        return [(session, "") for session in filtered]

    def _list_title_width(self, available_width: int) -> int:
        fixed_width = (
            self.LIST_CHECKBOX_WIDTH
            + self.LIST_MARK_WIDTH
            + self.LIST_ID_WIDTH
            + self.LIST_TIME_WIDTH
            + self.LIST_TURN_WIDTH
            + self.LIST_SIZE_WIDTH
            + 2 * 6  # Spacing between columns: two cells times six separators.
        )
        return max(20, available_width - fixed_width)

    def _list_header_lines(self, title_width: int) -> list[str]:
        header = (
            f"{set_cell_size('☐', self.LIST_CHECKBOX_WIDTH)}  "
            f"{set_cell_size('★', self.LIST_MARK_WIDTH)}  "
            f"{set_cell_size('ID', self.LIST_ID_WIDTH)}  "
            f"{set_cell_size('Time', self.LIST_TIME_WIDTH)}  "
            f"{set_cell_size('Turns', self.LIST_TURN_WIDTH)}  "
            f"{set_cell_size('Size', self.LIST_SIZE_WIDTH)}  "
            f"{set_cell_size('Name / first question', title_width)}"
        )
        ruler = (
            f"{'─' * self.LIST_CHECKBOX_WIDTH}  "
            f"{'─' * self.LIST_MARK_WIDTH}  "
            f"{'─' * self.LIST_ID_WIDTH}  "
            f"{'─' * self.LIST_TIME_WIDTH}  "
            f"{'─' * self.LIST_TURN_WIDTH}  "
            f"{'─' * self.LIST_SIZE_WIDTH}  "
            f"{'─' * title_width}"
        )
        return [header, ruler]

    def _configure_list_theme(self) -> None:
        list_area = self.query_one("#session-list", TextArea)
        app_theme = self.current_theme
        accent = Color.parse(app_theme.accent or app_theme.primary)
        surface = Color.parse(app_theme.surface or app_theme.background or "#202020")
        foreground = Color.parse(app_theme.foreground or "#f3f3f3")
        selected_row_bg = surface.blend(accent, 0.3)
        # Multi-select uses a stronger success-like highlight.
        success_color = Color.parse(getattr(app_theme, "success", None) or "#26a269")
        multi_selected_bg = surface.blend(success_color, 0.45)
        # Deep-search term highlight: error-toned background plus bold.
        error_color = Color.parse(getattr(app_theme, "error", None) or "#e01b24")
        deep_match_bg = surface.blend(error_color, 0.55)
        # Whole matched session line: light red tone, weaker than individual terms.
        deep_match_line_bg = surface.blend(error_color, 0.18)
        syntax_styles = {
            "session-selected-row": Style(
                bgcolor=selected_row_bg.rich_color,
                color=foreground.rich_color,
            ),
            "session-multi-selected": Style(
                bgcolor=multi_selected_bg.rich_color,
                color=foreground.rich_color,
                bold=True,
            ),
            "deep-search-match": Style(
                bgcolor=deep_match_bg.rich_color,
                color=foreground.rich_color,
                bold=True,
            ),
            # Whole-line background makes matched sessions easy to spot.
            "deep-match-line": Style(
                bgcolor=deep_match_line_bg.rich_color,
                color=foreground.rich_color,
            ),
        }
        syntax_styles.update(
            {
                f"session-color-{index}": Style(color=color, bold=True)
                for index, color in enumerate(_COLOR_STYLES)
            }
        )
        # Important marker (★) in red. This is a semantic exception equivalent to
        # Textual's error variant.
        syntax_styles["important-star"] = Style(
            color=Color.parse("#ff4d4d").rich_color, bold=True
        )
        # Live marker: same shape, different colors for owned spawn vs external live.
        # Like ★, this is a semantic exception using success/error tones.
        syntax_styles["current-spawned"] = Style(
            color=Color.parse("#ff4d4d").rich_color, bold=True
        )
        syntax_styles["current-live"] = Style(
            color=Color.parse(getattr(app_theme, "success", None) or "#26a269").rich_color,
            bold=True,
        )
        theme = TextAreaTheme(
            name=self.LIST_THEME_NAME,
            cursor_line_style=Style(
                bgcolor=selected_row_bg.rich_color,
                color=foreground.rich_color,
            ),
            syntax_styles=syntax_styles,
        )
        list_area.register_theme(theme)
        list_area.theme = self.LIST_THEME_NAME

    def _apply_list_color_highlights(
        self,
        list_area: TextArea,
        lines: list[str],
        items: list[tuple[Session, str]],
    ) -> None:
        highlights: defaultdict[int, list[tuple[int, int, str]]] = defaultdict(list)
            # Deep-search term: highlight all case-insensitive substrings in each line.
        deep_q = self._deep_search_query.strip().lower() if (self._deep_mode and self._deep_scan_done) else ""
        deep_matched_ids = self._deep_search_results if (self._deep_mode and self._deep_scan_done) else set()
        for offset, (session, _prefix) in enumerate(items, start=self.LIST_HEADER_ROWS):
            line = lines[offset]
            line_end = len(line.encode("utf-8"))
            # Priority: multi-select > selected > deep-match-line.
            if session.id in self._multi_selected_ids and line_end:
                highlights[offset].append((0, line_end, "session-multi-selected"))
            elif session.id == self.selected_session_id and line_end:
                highlights[offset].append((0, line_end, "session-selected-row"))
            elif session.id in deep_matched_ids and line_end:
                # Body-matched session: light red whole-line background.
                highlights[offset].append((0, line_end, "deep-match-line"))
            bullet_index = line.find("●")
            if bullet_index >= 0:
                start = len(line[:bullet_index].encode("utf-8"))
                end = len(line[: bullet_index + 1].encode("utf-8"))
                highlight_name = f"session-color-{_color_index_for_session(session.id)}"
                highlights[offset].append((start, end, highlight_name))
            # Important marker: only ★ is red. Add last so it remains visible over
            # multi-select/selected backgrounds.
            if session.important:
                star_idx = line.find("★")
                if star_idx >= 0:
                    s = len(line[:star_idx].encode("utf-8"))
                    e = len(line[:star_idx + 1].encode("utf-8"))
                    highlights[offset].append((s, e, "important-star"))
            # Live marker: color by spawn source; owned spawn wins when both apply.
            curr_idx = line.find("▶")
            if curr_idx >= 0:
                if session.id in self._spawned_sids:
                    style_name = "current-spawned"
                elif session.id in self._live_sids:
                    style_name = "current-live"
                else:
                    style_name = None
                if style_name:
                    s = len(line[:curr_idx].encode("utf-8"))
                    e = len(line[:curr_idx + 1].encode("utf-8"))
                    highlights[offset].append((s, e, style_name))
            # Deep-search term highlight inside body-matched session lines.
            if deep_q:
                line_lower = line.lower()
                qlen = len(deep_q)
                pos = 0
                while True:
                    idx = line_lower.find(deep_q, pos)
                    if idx < 0:
                        break
                    s = len(line[:idx].encode("utf-8"))
                    e = len(line[:idx + qlen].encode("utf-8"))
                    highlights[offset].append((s, e, "deep-search-match"))
                    pos = idx + qlen
        list_area._highlights = highlights
        list_area._line_cache.clear()
        list_area.refresh()

    def _format_session_line(self, session: Session, prefix: str, title_width: int) -> str:
        # ★ = important flag. Red color is applied by _apply_list_color_highlights.
        # Visual markers for custom_name / auto_summary are no longer shown; data remains.
        star = "★" if session.important else " "
        # ▶ = live session; one shape, source separated by color in _apply_list_color_highlights:
        #   in _spawned_sids: owned spawn color
        #   only in _live_sids: external live color
        #   in neither: blank, dead or not running
        curr = "▶" if (session.id in self._spawned_sids or session.id in self._live_sids) else " "
        title = _single_line(_display_clone_name(session.title), default="(empty)")
        title_prefix = prefix
        if session.source == "codex":
            title_prefix += "🤖 "
        if session.fork_type == "convert":
            title_prefix += "🔁 "
        elif session.fork_type == "hard":
            title_prefix += "🪓 "
        elif session.fork_type == "slim":
            title_prefix += "🔻 "
        elif session.fork_type in {"soft", "auto"}:
            title_prefix += "🔱 "
        if session.compact_count > 0:
            title_prefix += f"🔩{session.compact_count} "
        # Model B true merge: is_merged sessions are merged containers, marker 🗂N.
        # Model A legacy archive: parent nodes with archive children get marker 📦N.
        try:
            from gccfork_sessions import registry_get as _rg
            n_archived = archived_children_count(session.id)
            if _rg(session.id).get("is_merged") and n_archived > 0:
                title_prefix += f"🗂{n_archived} "
            elif n_archived > 0:
                title_prefix += f"📦{n_archived} "
        except Exception:
            pass
        # Multi-select checkbox toggles with left click in columns 0-2.
        chk = "[x]" if session.id in self._multi_selected_ids else "[ ]"
        chk_cell = set_cell_size(chk, self.LIST_CHECKBOX_WIDTH)
        mark_cell = set_cell_size(f"{curr}{star}", self.LIST_MARK_WIDTH)
        id_cell = set_cell_size(f"● {_display_session_id(session)}", self.LIST_ID_WIDTH)
        time_cell = set_cell_size(f"{session.mtime:%m-%d %H:%M}", self.LIST_TIME_WIDTH)
        # Turns: if compacted, show live(total); otherwise a single value.
        if session.compact_count > 0:
            turn_str = f"{session.live_turn_count}({session.turn_count})"
        else:
            turn_str = f"{session.turn_count}"
        turn_cell = set_cell_size(f"{turn_str:>{self.LIST_TURN_WIDTH}}", self.LIST_TURN_WIDTH)
        size_cell = set_cell_size(f"{fmt_size(session.size_bytes):>5}", self.LIST_SIZE_WIDTH)
        title_cell = set_cell_size(f"{title_prefix}{title}", title_width)
        return f"{chk_cell}  {mark_cell}  {id_cell}  {time_cell}  {turn_cell}  {size_cell}  {title_cell}"

    def refresh_list(self) -> None:
        list_area = self.query_one("#session-list", TextArea)
        items = self._build_list_items()
        self.list_sessions = [session for session, _prefix in items]
        self._current_list_items = items
        # Update color map: unique root of every visible session maps to a color index.
        # Use max-contrast six colors up to six roots, then 12-color sha256 distribution.
        roots = [_root_session_id(s.id) for s in self.list_sessions]
        _set_root_color_map(roots)
        available_width = max(40, list_area.size.width or 80)
        title_width = self._list_title_width(available_width)

        if not items:
            self.list_sessions = []
            self.selected_session_id = None
            self._current_list_lines = []
            self._programmatic_update = True
            try:
                list_area.load_text("세션 없음")
                list_area._highlights = defaultdict(list)
                list_area._line_cache.clear()
                list_area.move_cursor((0, 0))
            finally:
                self._programmatic_update = False
            self.update_preview()
            return

        lines = self._list_header_lines(title_width)
        lines.extend(self._format_session_line(session, prefix, title_width) for session, prefix in items)
        self._current_list_lines = lines
        target_index = 0
        if self.selected_session_id:
            for index, session in enumerate(self.list_sessions):
                if session.id == self.selected_session_id:
                    target_index = index
                    break
        self.selected_session_id = self.list_sessions[target_index].id
        self._programmatic_update = True
        try:
            list_area.load_text("\n".join(lines))
            self._apply_list_color_highlights(list_area, lines, items)
            list_area.move_cursor((target_index + self.LIST_HEADER_ROWS, 0))
        finally:
            self._programmatic_update = False
        self.update_preview()

    def _list_cursor_row(self) -> int:
        list_area = self.query_one("#session-list", TextArea)
        row = list_area.cursor_location[0] - self.LIST_HEADER_ROWS
        if not self.list_sessions:
            return 0
        return max(0, min(row, len(self.list_sessions) - 1))

    def selected_session(self) -> Optional[Session]:
        if not self.list_sessions:
            return None
        return self.list_sessions[self._list_cursor_row()]

    def update_preview(self) -> None:
        preview = self.query_one("#preview-text", TextArea)
        session = self.selected_session()
        if not session:
            self._hide_deep_preview()
            self._programmatic_update = True
            try:
                preview.load_text("세션 없음")
            finally:
                self._programmatic_update = False
            self._refresh_list_selection_highlight()
            return
        self.selected_session_id = session.id
        # Deep matched sessions render Rich panel stacks in deep-preview via the mixin.
        # If no match or not in deep mode, use the normal TextArea preview.
        is_deep_match = (
            self._deep_mode
            and self._deep_scan_done
            and session.id in self._deep_search_results
            and self._deep_search_query
        )
        if is_deep_match:
            rendered = self._render_deep_preview(session, self._deep_search_query)
            if rendered:
                self._refresh_list_selection_highlight()
                return
            # Match flag exists but excerpt is empty; fall back to normal preview.
        self._hide_deep_preview()
        self._programmatic_update = True
        try:
            width = max(40, preview.size.width or 80)
            text = render_preview_text(session, self.current_session_id, width=width)
            # If archive children exist, append a merged section to the preview.
            # Dispatch one of four modes according to opt 1 (preview_mode).
            try:
                archive_section = build_archived_children_section(session, width=width)
                if archive_section:
                    text = text + "\n" + archive_section
            except Exception:
                pass
            preview.load_text(text)
            if session.ai_summary:
                self._apply_ai_summary_highlight(preview, text)
        finally:
            self._programmatic_update = False
        self._refresh_list_selection_highlight()
        self._update_multi_action_visibility()

    # _apply_deep_block_bg / _extract_deep_match_snippet / _apply_deep_snippet_highlight
    # Deep search logic lives in `gccfork_search.py` as `DeepSearchMixin`.

    def _apply_ai_summary_highlight(self, preview: TextArea, text: str) -> None:
        """Apply background highlight to the three AI-summary header lines in preview."""
        try:
            # Register theme once; later calls reuse the existing registration.
            app_theme = self.current_theme
            accent = Color.parse(app_theme.accent or app_theme.primary)
            surface = Color.parse(app_theme.surface or app_theme.background or "#202020")
            foreground = Color.parse(app_theme.foreground or "#f3f3f3")
            error_color = Color.parse(getattr(app_theme, "error", None) or "#e01b24")
            ai_bg = surface.blend(accent, 0.22)  # Light accent background.
            divider_color = accent.blend(foreground, 0.3)
            deep_match_bg = surface.blend(error_color, 0.55)
            syntax_styles = {
                "ai-summary-bg": Style(
                    bgcolor=ai_bg.rich_color,
                    color=foreground.rich_color,
                ),
                "ai-summary-divider": Style(
                    bgcolor=ai_bg.rich_color,
                    color=divider_color.rich_color,
                ),
                # Deep match word highlights inside preview use the same style as the list.
                "deep-search-match": Style(
                    bgcolor=deep_match_bg.rich_color,
                    color=foreground.rich_color,
                    bold=True,
                ),
            }
            theme = TextAreaTheme(
                name="gccfork-preview-ai",
                cursor_line_style=Style(bgcolor=surface.blend(accent, 0.15).rich_color),
                syntax_styles=syntax_styles,
            )
            preview.register_theme(theme)
            preview.theme = "gccfork-preview-ai"
            # Variable line count: highlight top divider, content lines, and bottom divider.
            highlights: defaultdict[int, list[tuple[int, int, str]]] = defaultdict(list)
            lines = text.splitlines()
            # Find AI-summary box start/end using divider-line patterns.
            ai_start = ai_end = None
            for i, line in enumerate(lines):
                stripped = line.strip()
                if not stripped:
                    continue
                if stripped.startswith("─") and "AI Summary" in stripped:
                    ai_start = i
                elif ai_start is not None and stripped.startswith("─") and "AI Summary" not in stripped:
                    ai_end = i
                    break
            if ai_start is not None and ai_end is not None:
                for row in range(ai_start, ai_end + 1):
                    line_bytes = len(lines[row].encode("utf-8"))
                    style = "ai-summary-divider" if row in (ai_start, ai_end) else "ai-summary-bg"
                    highlights[row].append((0, line_bytes, style))
            preview._highlights = highlights
            preview._line_cache.clear()
            preview.refresh()
        except Exception:
            pass

    def _refresh_list_selection_highlight(self) -> None:
        if not self._current_list_lines or not self._current_list_items:
            return
        try:
            list_area = self.query_one("#session-list", TextArea)
        except Exception:
            return
        self._apply_list_color_highlights(list_area, self._current_list_lines, self._current_list_items)

    def _focus_list(self) -> None:
        self.query_one("#session-list", TextArea).focus()

    def remember_active_copy_widget(self, widget_id: Optional[str]) -> None:
        self._active_copy_widget_id = widget_id

    def prepare_context_copy(self, widget_id: Optional[str], text: str) -> None:
        self._pending_context_widget_id = widget_id
        self._pending_context_text = text

    def begin_list_pointer_interaction(self, widget_id: Optional[str]) -> None:
        if widget_id == "session-list":
            self._list_pointer_interacting = True

    def finish_list_pointer_interaction(self, widget_id: Optional[str], has_selection: bool) -> None:
        if widget_id != "session-list":
            return
        self._list_pointer_interacting = False
        # Skip plain-click post-processing right after checkbox/modifier click.
        if self._suppress_pointer_clear:
            self._suppress_pointer_clear = False
            return
        if has_selection:
            return
        session = self.selected_session()
        if session:
            # Multi-select changes only through [ ]/[x] clicks. Plain clicks outside
            # the checkbox update cursor/preview and preserve multi_selected so an
            # accidental click elsewhere does not clear accumulated selection.
            self.selected_session_id = session.id
            self._multi_anchor_row = self._cursor_row_for_session(session.id)
            self.update_preview()
            self._refresh_list_selection_highlight()

    def _cursor_row_for_session(self, session_id: str) -> Optional[int]:
        for index, sess in enumerate(self.list_sessions):
            if sess.id == session_id:
                return index
        return None

    def _move_list_cursor_to_body_row(self, body_row: int) -> None:
        if body_row < 0 or body_row >= len(self.list_sessions):
            return
        try:
            list_area = self.query_one("#session-list", TextArea)
            list_area.move_cursor((body_row + self.LIST_HEADER_ROWS, 0))
        except Exception:
            pass

    def _capture_list_scroll(self) -> Optional[tuple[float, float]]:
        try:
            list_area = self.query_one("#session-list", TextArea)
            return (float(list_area.scroll_x), float(list_area.scroll_y))
        except Exception:
            return None

    def _restore_list_scroll(self, scroll_pos: Optional[tuple[float, float]]) -> None:
        if scroll_pos is None:
            return
        def _apply() -> None:
            try:
                list_area = self.query_one("#session-list", TextArea)
                list_area.scroll_to(
                    x=scroll_pos[0],
                    y=scroll_pos[1],
                    animate=False,
                    force=True,
                    immediate=True,
                )
            except Exception:
                pass
        _apply()
        try:
            self.call_after_refresh(_apply)
        except Exception:
            pass

    def _update_multi_action_visibility(self) -> None:
        """Toggle top area and single-action buttons according to multi-select count.

        - N == 0: show filter-row, hide multi-action-row, enable all action-bar buttons.
        - N >= 1: hide filter-row, show multi-action-row, disable single-session action
          buttons (new/fork/clone/slim/resume/name), and keep only Quit enabled.
          Auto slim was archived on 2026-05-06.
        """
        try:
            filter_row = self.query_one("#filter-row")
            multi_row = self.query_one("#multi-action-row")
            count_label = self.query_one("#multi-action-count", Static)
        except Exception:
            return
        n = len(self._multi_selected_ids)
        if n > 0:
            filter_row.styles.display = "none"
            multi_row.styles.display = "block"
            count_label.update(f"✓ {n} selected")
        else:
            filter_row.styles.display = "block"
            multi_row.styles.display = "none"

        # Bottom action bar: disable single-session buttons in multi mode.
        # For Codex, only soft fork/unfold are blocked; hard clone/slim work through JSONL.
        selected = self.selected_session()
        is_codex = bool(selected and selected.source == "codex")
        disabled_by_codex = {"btn-fork", "btn-unfold"}
        single_only_ids = (
            "btn-new-root", "btn-fork", "btn-hard-fork",
            "btn-slim", "btn-unfold", "btn-resume", "btn-rename",
        )
        for bid in single_only_ids:
            try:
                self.query_one(f"#{bid}", Button).disabled = (n > 0) or (is_codex and bid in disabled_by_codex)
            except Exception:
                pass

        # Merge button: hide when opt 5 (archive.trigger_mode) is keybinding.
        try:
            archive_btn = self.query_one("#btn-multi-archive", Button)
            trigger_mode = str(get_archive_pref("archive_trigger_mode"))
            archive_btn.display = trigger_mode in {"button", "both"}
        except Exception:
            pass

        # Split button: show for single selection (n==1) when either:
        #   (a) is_merged=true, model B merged container N
        #   (b) marker 📦N, legacy model A archive parent
        # Even in permanent mode, show the button and reject on click for trash-pattern consistency.
        try:
            from gccfork_sessions import registry_get as _rg
            unmerge_btn = self.query_one("#btn-multi-unmerge", Button)
            show_unmerge = False
            if n == 1:
                only_sid = next(iter(self._multi_selected_ids))
                if _rg(only_sid).get("is_merged"):
                    show_unmerge = True
                elif archived_children_count(only_sid) > 0:
                    show_unmerge = True
            unmerge_btn.display = show_unmerge
        except Exception:
            pass

    def _collect_with_descendants(self, session_ids: set[str]) -> list[Session]:
        """Return selected sessions plus all descendants transitively, deterministically sorted.

        Moving a parent should move its children too to preserve tree consistency.
        """
        result_ids = set(session_ids)
        # Iteratively collect and add children.
        changed = True
        while changed:
            changed = False
            for s in self.sessions:
                if s.id in result_ids:
                    continue
                p = _parent_for(s.id)
                if p in result_ids:
                    result_ids.add(s.id)
                    changed = True
        # Session object mapping.
        return sorted(
            (s for s in self.sessions if s.id in result_ids),
            key=lambda s: s.short_id,
        )

    def action_multi_move(self) -> None:
        """Multi-select move: zenity folder picker, confirmation modal, move plus migration marker."""
        if not self._multi_selected_ids:
            return
        if not shutil.which("zenity"):
            self.notify(
                "zenity is not installed. Install it with `sudo apt install zenity` and retry.",
                severity="error",
            )
            return

        sel_ids = set(self._multi_selected_ids)
        direct_sessions = [s for s in self.sessions if s.id in sel_ids]
        all_with_desc = self._collect_with_descendants(sel_ids)
        descendants = [s for s in all_with_desc if s.id not in sel_ids]
        extra = len(descendants)

        # Launching zenity blocks the main thread briefly.
        initial = self.current_cwd or os.path.expanduser("~")
        dest = _pick_directory_via_zenity(initial)
        if not dest:
            self.notify("이동 취소")
            return

        # Guard against selecting the same folder.
        if dest == initial:
            self.notify("같은 폴더가 선택되어 이동하지 않았습니다", severity="warning")
            return

        msg_lines = [
            f"📦 Move {len(direct_sessions)} directly selected session(s) to:",
            f"   → {dest}",
            "",
        ]
        if extra > 0:
            msg_lines.append(
                f"Child sessions ({extra}):"
            )
            for child in descendants[:8]:
                ctitle = _single_line(child.title, default="(untitled)")[:50]
                msg_lines.append(f"   └ {child.short_id}  {ctitle}")
            if len(descendants) > 8:
                msg_lines.append(f"   … and {len(descendants) - 8} more")
            msg_lines.append("")
            msg_lines.append("아래 토글: ON=자식 포함(트리 유지), OFF=선택 항목만 이동")
        else:
            msg_lines.append("(이 세션에는 자식 세션이 없습니다.)")
            msg_lines.append("")
        msg_lines.append("각 JSONL 끝에는 이동 메타데이터가 추가됩니다.")

        def on_confirm(result: Optional[dict]) -> None:
            if not result:
                return
            preserve_tree = bool(result.get("preserve_tree", True))
            all_to_move = all_with_desc if preserve_tree else direct_sessions
            new_slug = cwd_to_slug(dest)
            new_dir = PROJECTS_DIR / new_slug
            try:
                new_dir.mkdir(parents=True, exist_ok=True)
            except OSError as exc:
                self.notify(f"Failed to create target folder: {exc}", severity="error")
                return
            moved = 0
            failed = 0
            failure_details: list[str] = []
            for sess in all_to_move:
                try:
                    new_path = new_dir / sess.jsonl_path.name
                    # Same path, destination slug is current slug; nothing to move.
                    if new_path == sess.jsonl_path:
                        failed += 1
                        failure_details.append(
                            f"{sess.short_id}: already in target slug"
                        )
                        continue
                    if new_path.exists():
                        failed += 1
                        failure_details.append(
                            f"{sess.short_id}: a file with the same name exists at target -> {new_path}"
                        )
                        continue
                    if not sess.jsonl_path.exists():
                        failed += 1
                        failure_details.append(
                            f"{sess.short_id}: source file missing -> {sess.jsonl_path}"
                        )
                        continue
                    shutil.move(str(sess.jsonl_path), str(new_path))
                    # Replace cwd fields in all messages so gccfork TUI, VS Code, and
                    # claude --resume consistently see the new cwd.
                    _rewrite_all_cwd_fields(
                        new_path,
                        old_cwd=sess.cwd or "",
                        new_cwd=dest,
                    )
                    _append_migration_marker(
                        new_path,
                        old_cwd=sess.cwd or "",
                        new_cwd=dest,
                        session_id=sess.id,
                    )
                    moved += 1
                except OSError as exc:
                    failed += 1
                    failure_details.append(f"{sess.short_id}: {exc}")
            if failed:
                detail_msg = "\n".join(failure_details[:5])
                if len(failure_details) > 5:
                    detail_msg += f"\n… and {len(failure_details) - 5} more"
                self.notify(
                    f"Moved: {moved} / Failed: {failed}\n{detail_msg}",
                    severity="warning",
                    timeout=12,
                )
            else:
                self.notify(f"✓ Moved {moved} session(s) (target: {dest})")
            self._multi_selected_ids.clear()
            self.reload_sessions()
            self._update_multi_action_visibility()

        # Preserve-tree toggle matters only when children exist; otherwise use plain ConfirmScreen.
        if extra > 0:
            self.push_screen(
                TreeOptionConfirmScreen(
                    "\n".join(msg_lines),
                    confirm_label="OK",
                    confirm_variant="primary",
                    title="📦 이동 확인",
                    preserve_tree_label="트리 구조 유지 (자식 자동 포함)",
                    preserve_tree_default=True,
                ),
                on_confirm,
            )
        else:
            # Without children the toggle is meaningless; use bool ConfirmScreen.
            def _on_simple(ok: bool) -> None:
                if ok:
                    on_confirm({"preserve_tree": True})
            self.push_screen(
                ConfirmScreen(
                    "\n".join(msg_lines),
                    confirm_label="OK",
                    confirm_variant="primary",
                    title="📦 이동 확인",
                ),
                _on_simple,
            )

    def action_multi_copy(self) -> None:
        """Multi-select copy: hard-fork each session with a new UUID into a chosen folder.

        Originals are preserved. Copies:
          - get a new UUID plus sessionId line replacement
          - are placed in the destination cwd slug folder
          - registry: parent_id=original, fork_type="hard", name="[Copy] {original}"
          - get a `[gccfork-copy]` system+isMeta marker appended to JSONL
        Descendants are not auto-included unless tree preservation is selected.
        """
        if not self._multi_selected_ids:
            return
        if not shutil.which("zenity"):
            self.notify(
                "zenity is not installed. Install it with `sudo apt install zenity` and retry.",
                severity="error",
            )
            return
        sel_ids = set(self._multi_selected_ids)
        direct_sessions = [s for s in self.sessions if s.id in sel_ids]
        if not direct_sessions:
            self.notify("복사 대상 없음", severity="warning")
            return
        all_with_desc = self._collect_with_descendants(sel_ids)
        descendants = [s for s in all_with_desc if s.id not in sel_ids]
        extra = len(descendants)

        initial = self.current_cwd or os.path.expanduser("~")
        dest = _pick_directory_via_zenity(initial)
        if not dest:
            self.notify("복사 취소")
            return

        msg_lines = [
            f"📋 Copy {len(direct_sessions)} directly selected session(s) to:",
            f"   → {dest}",
            "",
        ]
        if extra > 0:
            msg_lines.append(f"Child sessions ({extra}):")
            for child in descendants[:8]:
                ctitle = _single_line(child.title, default="(untitled)")[:50]
                msg_lines.append(f"   └ {child.short_id}  {ctitle}")
            if len(descendants) > 8:
                msg_lines.append(f"   … and {len(descendants) - 8} more")
            msg_lines.append("")
            msg_lines.append("아래 토글: ON=전체 트리 복제(parent_id 재매핑), OFF=선택 항목만 복사")
        else:
            msg_lines.append("(이 세션에는 자식 세션이 없습니다.)")
            msg_lines.append("")
        msg_lines.append("각 복사본은 새 UUID로 생성되고 [gccfork-copy] 마커가 추가됩니다.")
        msg_lines.append("원본 세션의 위치와 내용은 변경되지 않습니다.")

        def on_confirm(result: Optional[dict]) -> None:
            if not result:
                return
            preserve_tree = bool(result.get("preserve_tree", True))
            sessions_to_copy = all_with_desc if preserve_tree else direct_sessions
            new_slug = cwd_to_slug(dest)
            new_dir = PROJECTS_DIR / new_slug
            try:
                new_dir.mkdir(parents=True, exist_ok=True)
            except OSError as exc:
                self.notify(f"Failed to create target folder: {exc}", severity="error")
                return

            # Preserve-tree mode: precompute old_id -> new_id for every copy target,
            # then set parent_id to the mapped value for tree consistency.
            id_map: dict[str, str] = {sess.id: str(uuid_lib.uuid4()) for sess in sessions_to_copy}

            copied = 0
            failed = 0
            failure_details: list[str] = []
            for sess in sessions_to_copy:
                try:
                    new_uuid = id_map[sess.id]
                    new_path = new_dir / f"{new_uuid}.jsonl"
                    if new_path.exists():
                        failed += 1
                        failure_details.append(
                            f"{sess.short_id}: a file with the same name exists at target"
                        )
                        continue
                    if not sess.jsonl_path.exists():
                        failed += 1
                        failure_details.append(
                            f"{sess.short_id}: source file missing"
                        )
                        continue
                    # Copy using sessionId line replacement, same pattern as hard fork.
                    old_marker = f'"sessionId":"{sess.id}"'
                    new_marker = f'"sessionId":"{new_uuid}"'
                    src_text = sess.jsonl_path.read_text(encoding="utf-8")
                    new_path.write_text(
                        src_text.replace(old_marker, new_marker),
                        encoding="utf-8",
                    )
                    # Replace copy cwd with dest for the same reason as move.
                    _rewrite_all_cwd_fields(
                        new_path,
                        old_cwd=sess.cwd or "",
                        new_cwd=dest,
                    )
                    _append_copy_marker(
                        new_path,
                        original_id=sess.id,
                        new_id=new_uuid,
                        dest_cwd=dest,
                    )
                    # Determine parent_id: mapped value when preserving tree, else original session.
                    if preserve_tree:
                        orig_parent = _parent_for(sess.id)
                        if orig_parent and orig_parent in id_map:
                            mapped_parent = id_map[orig_parent]
                        else:
                            # Original parent is outside the copy set or root; use original as parent.
                            mapped_parent = sess.id
                    else:
                        mapped_parent = sess.id
                    copy_name = f"[Copy] {sess.custom_name or sess.auto_summary or sess.short_id}"[:120]
                    registry_set(
                        new_uuid,
                        parent_id=mapped_parent,
                        fork_type="hard",
                        name=copy_name,
                    )
                    copied += 1
                except OSError as exc:
                    failed += 1
                    failure_details.append(f"{sess.short_id}: {exc}")
            if failed:
                detail_msg = "\n".join(failure_details[:5])
                if len(failure_details) > 5:
                    detail_msg += f"\n… and {len(failure_details) - 5} more"
                self.notify(
                    f"Copied: {copied} / Failed: {failed}\n{detail_msg}",
                    severity="warning",
                    timeout=12,
                )
            else:
                self.notify(f"✓ Copied {copied} session(s) (target: {dest})")
            self._multi_selected_ids.clear()
            self.reload_sessions()
            self._update_multi_action_visibility()

        if extra > 0:
            self.push_screen(
                TreeOptionConfirmScreen(
                    "\n".join(msg_lines),
                    confirm_label="복사",
                    confirm_variant="primary",
                    title="📋 복사 확인",
                    preserve_tree_label="트리 구조 유지 (자식 포함 + parent 재매핑)",
                    preserve_tree_default=True,
                ),
                on_confirm,
            )
        else:
            def _on_simple(ok: bool) -> None:
                if ok:
                    on_confirm({"preserve_tree": False})
            self.push_screen(
                ConfirmScreen(
                    "\n".join(msg_lines),
                    confirm_label="복사",
                    confirm_variant="primary",
                    title="📋 복사 확인",
                ),
                _on_simple,
            )

    def action_multi_summarize(self) -> None:
        """Summarize multi-selection with one batch call, including progress UI.

        - User chooses Claude or Codex CLI.
        - Knight Rider scanner animation plus right-to-left stream text.
        - Parse numbered response and save each summary into the session registry.
        """
        if not self._multi_selected_ids:
            return
        has_claude = bool(shutil.which("claude"))
        has_codex = bool(shutil.which("codex"))
        if not (has_claude or has_codex):
            self.notify("요약에 사용할 claude/codex CLI를 PATH에서 찾지 못했습니다.", severity="error")
            return
        sel_ids = list(self._multi_selected_ids)
        sessions_to_summarize = [s for s in self.sessions if s.id in sel_ids]
        if not sessions_to_summarize:
            return

        def _start(provider: Optional[str]) -> None:
            if provider not in {"claude", "codex"}:
                return
            self._start_multi_summarize(sessions_to_summarize, provider)

        self.push_screen(
            SummarizeProviderScreen(has_claude=has_claude, has_codex=has_codex),
            _start,
        )

    def _start_multi_summarize(self, sessions_to_summarize: list[Session], provider: str) -> None:
        n = len(sessions_to_summarize)
        self._summarize_in_progress = True
        # Show progress banner and start scanner animation.
        label = "Claude" if provider == "claude" else "Codex"
        self._show_progress_banner(f"📝 AI summary batch call — {label} · processing {n} session(s) once")
        self._start_scanner_animation()

        import threading
        threading.Thread(
            target=self._summarize_batch_worker,
            args=(sessions_to_summarize, provider),
            daemon=True,
        ).start()

    def _summarize_batch_worker(self, sessions: list[Session], provider: str = "claude") -> None:
        """Batch summary worker running in a background thread.

        1. Number and combine excerpts from each session into one prompt.
        2. Call the selected CLI once.
        3. Show response progress in the progress UI.
        4. Parse final response, extract summaries by number, and save to registry.
        """
        n = len(sessions)
        # 1. Build batch prompt with meaningful excerpts per session.
        excerpts: list[str] = []
        for i, sess in enumerate(sessions, 1):
            ex = _extract_summary_excerpts(sess.jsonl_path, max_chars=4000)
            if not ex:
                ex = f"(Empty session or no body text — short_id={sess.short_id})"
            excerpts.append(f"=== Conversation {i} (short_id={sess.short_id}) ===\n{ex}\n")
        joined = "\n".join(excerpts)

        system_prompt = (
            "You are a dedicated multi-angle conversation summarizer. "
            "For each conversation, output exactly these three lines and no other text:\n"
            "  Topic: <core topic as one noun phrase line>\n"
            "  Progress: <one core line about what work/discussion happened>\n"
            "  Conclusion: <one core line with conclusion, decision, or issue>\n"
            "Do not answer the conversations. Output only the three-line summaries, without periods, markdown, or emoji."
        )
        user_prompt = (
            f"Summarize each of the following {n} conversation records in exactly three lines "
            f"(Topic/Progress/Conclusion).\n"
            f"Output format, with no other text:\n"
            f"--- Conversation 1 ---\nTopic: ...\nProgress: ...\nConclusion: ...\n"
            f"--- Conversation 2 ---\nTopic: ...\nProgress: ...\nConclusion: ...\n"
            f"...\n--- Conversation {n} ---\nTopic: ...\nProgress: ...\nConclusion: ...\n\n"
            f"{joined}\n\n"
            f"--- Start from Conversation 1 ---"
        )

        # Progress-step guidance shown in the stream text area.
        try:
            provider_label = "Claude Haiku" if provider == "claude" else "Codex exec"
            self.call_from_thread(self._update_stream_text, f"Calling {provider_label}…")
        except Exception:
            pass

        accumulated = self._run_summary_llm(provider, system_prompt, user_prompt, timeout=180) or ""
        if accumulated:
            try:
                # Visualize response arrival by flowing the first 80 chars.
                snippet = accumulated.replace("\n", " │ ")[:200]
                self.call_from_thread(self._update_stream_text, f"Response received: {snippet}")
            except Exception:
                pass

        # Parse response, including legacy numbered summary formats.
        summaries = self._parse_numbered_summaries(accumulated, n)
        ok = 0
        fail = 0
        now_iso = datetime.now().isoformat(timespec="seconds")
        for i, sess in enumerate(sessions, 1):
            summary = summaries.get(i)
            if summary:
                try:
                    registry_set(sess.id, ai_summary=summary, ai_summary_at=now_iso)
                    ok += 1
                except Exception:
                    fail += 1
            else:
                fail += 1
        try:
            self.call_from_thread(self._summarize_complete, ok, fail)
        except Exception:
            pass

    @staticmethod
    def _run_summary_llm(provider: str, system_prompt: str, user_prompt: str, *, timeout: int) -> Optional[str]:
        env = os.environ.copy()
        env.pop("VIRTUAL_ENV", None)
        env.pop("UV_PROJECT_ENVIRONMENT", None)
        env.pop("PYTHONHOME", None)
        if provider == "claude":
            has_api_key = bool(env.get("ANTHROPIC_API_KEY"))
            if has_api_key:
                args = [
                    "claude", "--bare", "-p", user_prompt, "--model", "haiku",
                    "--append-system-prompt", system_prompt,
                ]
                cwd = None
            else:
                args = [
                    "claude", "-p", user_prompt, "--model", "haiku",
                    "--no-session-persistence",
                    "--disable-slash-commands",
                    "--exclude-dynamic-system-prompt-sections",
                    "--append-system-prompt", system_prompt,
                ]
                cwd = "/tmp"
            try:
                result = subprocess.run(
                    args, capture_output=True, text=True, timeout=timeout,
                    env=env, cwd=cwd,
                )
                if result.returncode == 0:
                    return result.stdout
            except Exception:
                return None
            return None

        if provider == "codex":
            if not shutil.which("codex"):
                return None
            prompt = (
                f"{system_prompt}\n\n"
                "Perform the user request below. Do not read files or execute commands. "
                "Summarize only the provided text.\n\n"
                f"{user_prompt}"
            )
            env["CODEX_NO_SLIM_LOOP"] = "1"
            output_path = None
            try:
                with NamedTemporaryFile("w+", encoding="utf-8", delete=False) as tmp:
                    output_path = tmp.name
                args = [
                    "codex", "exec",
                    "--ephemeral",
                    "--skip-git-repo-check",
                    "--sandbox", "read-only",
                    "-C", "/tmp",
                    "-o", output_path,
                    "-",
                ]
                result = subprocess.run(
                    args,
                    input=prompt,
                    capture_output=True,
                    text=True,
                    timeout=timeout,
                    env=env,
                    cwd="/tmp",
                )
                if output_path:
                    try:
                        text = Path(output_path).read_text(encoding="utf-8", errors="ignore")
                    except OSError:
                        text = ""
                    if text.strip():
                        return text
                if result.returncode == 0:
                    return result.stdout
            except Exception:
                return None
            finally:
                if output_path:
                    try:
                        Path(output_path).unlink()
                    except OSError:
                        pass
            return None

        return None

    @staticmethod
    def _extract_stream_text_chunk(obj: dict) -> str:
        """Extract text chunks from stream-json events.

        Possible shapes:
          {"type":"stream_event","event":{"type":"content_block_delta","delta":{"type":"text_delta","text":"..."}}}
          {"type":"assistant","message":{"content":[{"type":"text","text":"..."}]}}
        """
        # content_block_delta
        evt = obj.get("event") or obj
        if isinstance(evt, dict):
            d = evt.get("delta")
            if isinstance(d, dict) and d.get("type") == "text_delta":
                t = d.get("text")
                if isinstance(t, str):
                    return t
        # assistant final block
        msg = obj.get("message")
        if isinstance(msg, dict):
            content = msg.get("content")
            if isinstance(content, list):
                parts = []
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "text":
                        t = block.get("text")
                        if isinstance(t, str):
                            parts.append(t)
                if parts:
                    return "".join(parts)
        return ""

    @staticmethod
    def _parse_numbered_summaries(text: str, n: int) -> dict[int, str]:
        """Parse rich three-line summaries into one multi-line string per conversation N.

        Example input:
          --- Conversation 1 ---
          Topic: gccfork TUI multi-select implementation
          Progress: checkbox clicks integrated with batch move/copy/delete
          Conclusion: system metadata markers preserve resume compatibility
          --- Conversation 2 ---
          ...
        Returns: {1: "Topic: ...\\nProgress: ...\\nConclusion: ...", 2: ...}
        """
        result: dict[int, str] = {}
        if not text:
            return result
        # Header detection: support both "--- Conversation N ---" and legacy variants.
        header_pattern = re.compile(
            r"^\s*(?:---\s*)?(?:\ub300\ud654|Conversation|conv\.?)\s*(\d+)(?:\s*---)?\s*$",
            re.IGNORECASE,
        )
        # Body lines support Topic/Progress/Conclusion plus legacy Korean labels.
        body_pattern = re.compile(
            r"^\s*(\uc8fc\uc81c|\uc9c4\ud589|\uacb0\ub860|Topic|Progress|Conclusion)\s*[:：]\s*(.+)$",
            re.IGNORECASE,
        )
        # Support legacy single-line "1. summary" format for compatibility.
        legacy_pattern = re.compile(r"^\s*(\d+)[.)\s]+(.+)$")

        current_idx: Optional[int] = None
        current_lines: list[str] = []

        def _flush() -> None:
            if current_idx is None:
                return
            text_joined = "\n".join(current_lines).strip()
            if text_joined and len(text_joined) >= 5:
                # Clean quotes and markdown.
                cleaned = text_joined.strip("`\"'“”‘’")
                if 1 <= current_idx <= n:
                    result[current_idx] = cleaned[:600]

        for raw_line in text.splitlines():
            line = raw_line.rstrip()
            if not line.strip():
                continue
            m = header_pattern.match(line)
            if m:
                _flush()
                try:
                    current_idx = int(m.group(1))
                    current_lines = []
                except ValueError:
                    current_idx = None
                continue
            # Body lines: topic/progress/conclusion.
            mb = body_pattern.match(line)
            if mb and current_idx is not None:
                current_lines.append(f"{mb.group(1)}: {mb.group(2).strip()}")
                continue
            # Legacy one-line format without header: "N. summary".
            ml = legacy_pattern.match(line)
            if ml and current_idx is None:
                _flush()
                try:
                    idx = int(ml.group(1))
                    if 1 <= idx <= n:
                        result[idx] = ml.group(2).strip()[:600]
                except ValueError:
                    pass
                continue
        _flush()
        return result

    def _show_progress_banner(self, message: str) -> None:
        """Show the progress banner and update its message."""
        try:
            banner = self.query_one("#progress-banner")
            banner.styles.display = "block"
            self.query_one("#progress-message", Static).update(message)
            self.query_one("#progress-stream", Static).update("")
        except Exception:
            pass

    def _hide_progress_banner(self) -> None:
        try:
            self.query_one("#progress-banner").styles.display = "none"
        except Exception:
            pass

    def _start_scanner_animation(self) -> None:
        """Knight Rider style scanner moving left and right repeatedly."""
        self._scanner_pos = 0
        self._scanner_dir = 1
        try:
            self._scanner_timer = self.set_interval(0.06, self._tick_scanner)
        except Exception:
            self._scanner_timer = None

    def _stop_scanner_animation(self) -> None:
        if hasattr(self, "_scanner_timer") and self._scanner_timer:
            try:
                self._scanner_timer.stop()
            except Exception:
                pass
            self._scanner_timer = None

    def _tick_scanner(self) -> None:
        """Called every 60 ms to update scanner position."""
        try:
            scanner = self.query_one("#progress-scanner", Static)
        except Exception:
            return
        width = 40
        chars = [" "] * width
        # Body.
        if 0 <= self._scanner_pos < width:
            chars[self._scanner_pos] = "█"
        # Trail with three-cell fade.
        for d in range(1, 4):
            trail = self._scanner_pos - self._scanner_dir * d
            if 0 <= trail < width:
                chars[trail] = "▓▒░"[d - 1]
        bar = "".join(chars)
        scanner.update(f"  ◀ {bar} ▶")
        # Position update and direction reversal.
        self._scanner_pos += self._scanner_dir
        if self._scanner_pos >= width - 1:
            self._scanner_dir = -1
        elif self._scanner_pos <= 0:
            self._scanner_dir = 1

    def _update_stream_text(self, accumulated: str) -> None:
        """Right-to-left streaming text showing only the last 80 chars."""
        try:
            stream = self.query_one("#progress-stream", Static)
        except Exception:
            return
        # Flatten newlines and tabs to spaces.
        flat = accumulated.replace("\n", " │ ").replace("\t", "  ")
        visible = flat[-80:]
        stream.update(visible)

    def _summarize_complete(self, ok: int, fail: int) -> None:
        """Background batch finished; clean up UI state."""
        self._summarize_in_progress = False
        self._stop_scanner_animation()
        self._hide_progress_banner()
        if fail:
            self.notify(
                f"📝 Batch summary — success {ok} / failed {fail}",
                severity="warning",
                timeout=8,
            )
        else:
            self.notify(f"✓ Created {ok} AI summary batch item(s)", timeout=6)
        self._multi_selected_ids.clear()
        self.reload_sessions()
        self._update_multi_action_visibility()

    def action_multi_delete(self) -> None:
        """Move multi-selected sessions to trash, selected items only; descendants are preserved.

        If any selected item has the important marker (★), show a three-way modal:
          - exclude important items
          - delete all including important items
          - cancel
        """
        if not self._multi_selected_ids:
            return
        sel_ids = set(self._multi_selected_ids)
        all_to_del = [s for s in self.sessions if s.id in sel_ids]
        if self._refuse_if_active_sessions(all_to_del):
            return
        important_in_sel = [s for s in all_to_del if s.important]

        if important_in_sel:
            # Three-way modal: exclude / include / cancel.
            important_titles = [
                f"{s.short_id}  {_single_line(s.title, default='(untitled)')[:50]}"
                for s in important_in_sel
            ]

            def _on_choice(choice: Optional[str]) -> None:
                if choice == "exclude":
                    safe_ids = {s.id for s in all_to_del if not s.important}
                    self._multi_selected_ids = safe_ids
                    self._proceed_multi_delete()
                elif choice == "include":
                    self._proceed_multi_delete()
                # Cancel: do nothing.

            self.push_screen(
                MultiDeleteImportantScreen(
                    total=len(all_to_del),
                    important_count=len(important_in_sel),
                    important_titles=important_titles,
                ),
                _on_choice,
            )
            return

        self._proceed_multi_delete()

    def _proceed_multi_delete(self) -> None:
        """Original action_multi_delete body: orphan warning plus trash move."""
        if not self._multi_selected_ids:
            return
        sel_ids = set(self._multi_selected_ids)
        all_to_del = [s for s in self.sessions if s.id in sel_ids]
        if self._refuse_if_active_sessions(all_to_del):
            return
        # Warn separately when deleting only parents that have children.
        descendants_left_orphan: list[Session] = []
        for s in self.sessions:
            if s.id in sel_ids:
                continue
            p = _parent_for(s.id)
            if p in sel_ids:
                descendants_left_orphan.append(s)

        msg_lines = [
            f"🗑 Move {len(all_to_del)} selected session(s) to trash.",
            "",
        ]
        if descendants_left_orphan:
            msg_lines.append(
                f"⚠ {len(descendants_left_orphan)} child session(s) will **not be deleted** "
                f"and will become orphaned in the tree."
            )
            msg_lines.append("")
            msg_lines.append("Children that will become orphaned:")
            for child in descendants_left_orphan[:8]:
                ctitle = _single_line(child.title, default="(untitled)")[:50]
                msg_lines.append(f"   └ {child.short_id}  {ctitle}")
            if len(descendants_left_orphan) > 8:
                msg_lines.append(f"   …and {len(descendants_left_orphan) - 8} more")
            msg_lines.append("")
        msg_lines.append("You can restore them from trash later.")

        def on_confirm(ok: bool) -> None:
            if not ok:
                return
            if self._refuse_if_active_sessions(all_to_del):
                return
            moved = 0
            failed = 0
            for sess in all_to_del:
                try:
                    if move_session_to_trash(sess.id, sess.jsonl_path):
                        moved += 1
                    else:
                        failed += 1
                except Exception:
                    failed += 1
            if failed:
                self.notify(
                    f"Moved to trash: {moved} / Failed: {failed}",
                    severity="warning",
                )
            else:
                self.notify(f"✓ Moved {moved} session(s) to trash")
            self._multi_selected_ids.clear()
            self.reload_sessions()
            self._update_multi_action_visibility()

        self.push_screen(
            ConfirmScreen(
                "\n".join(msg_lines),
                confirm_label="휴지통으로 이동",
                confirm_variant="error",
                title="🗑 Confirm multi-delete",
            ),
            on_confirm,
        )

    def _active_pids_for_session_id(self, session_id: str) -> list[int]:
        pids: list[int] = []
        try:
            pids.extend(find_claude_pids_for_session_id(session_id))
        except Exception:
            pass
        try:
            pids.extend(_codex_active_sid_pid_map().get(session_id, []))
        except Exception:
            pass
        seen: set[int] = set()
        out: list[int] = []
        for pid in pids:
            if pid in seen:
                continue
            seen.add(pid)
            out.append(pid)
        return out

    def _is_active_session(self, session: Session) -> bool:
        if self.current_session_id and session.id == self.current_session_id:
            return True
        return bool(self._active_pids_for_session_id(session.id))

    def _refuse_if_active_sessions(self, sessions: list[Session]) -> bool:
        active = [s for s in sessions if self._is_active_session(s)]
        if not active:
            return False
        labels = ", ".join(_display_session_id(s) for s in active[:5])
        if len(active) > 5:
            labels += f" and {len(active) - 5} more"
        self.notify(
            f"Cannot delete active sessions: {labels}. Close the related Claude/Codex windows first.",
            severity="warning",
            timeout=8,
        )
        return True

    def handle_list_mark_click(self, row: int) -> None:
        """Toggle important for a row when left-click lands in the mark column (▶★).

        Persist in the registry; True stores the key, False removes it. After toggling,
        refresh_list updates the ★ marker immediately.
        """
        body_row = row - self.LIST_HEADER_ROWS
        if body_row < 0 or body_row >= len(self.list_sessions):
            return
        scroll_pos = self._capture_list_scroll()
        session = self.list_sessions[body_row]
        new_state = not session.important
        session.important = new_state
        try:
            registry_set(session.id, important=(True if new_state else None))
        except Exception:
            pass
        # Cached in-memory Session object is already synchronized through shared reference.
        # Block the upcoming mouse_up selection clear in finish_list_pointer_interaction.
        self._suppress_pointer_clear = True
        self.selected_session_id = session.id
        self._move_list_cursor_to_body_row(body_row)
        self.refresh_list()
        self._restore_list_scroll(scroll_pos)
        # Notify so the user can clearly see the toggle result.
        try:
            self.notify(
                f"{'Marked important' if new_state else 'Cleared important'}: {session.title[:40]}",
                timeout=2,
            )
        except Exception:
            pass

    def handle_list_checkbox_click(self, row: int) -> None:
        """Toggle a row when left-click lands in the checkbox column.

        Called after SelectableTextArea super()._on_mouse_down updates
        cursor_location; convert row to a list_sessions index.
        """
        body_row = row - self.LIST_HEADER_ROWS
        if body_row < 0 or body_row >= len(self.list_sessions):
            return
        scroll_pos = self._capture_list_scroll()
        clicked = self.list_sessions[body_row]
        if clicked.id in self._multi_selected_ids:
            self._multi_selected_ids.discard(clicked.id)
        else:
            self._multi_selected_ids.add(clicked.id)
        self._multi_anchor_row = body_row
        self.selected_session_id = clicked.id
        self._move_list_cursor_to_body_row(body_row)
        self.update_preview()
        # Block the upcoming mouse_up clear in finish_list_pointer_interaction.
        self._suppress_pointer_clear = True
        # Reformat list so checkbox text toggles between [ ] and [x].
        self.refresh_list()
        self._restore_list_scroll(scroll_pos)
        self._update_title_bar()
        self._update_multi_action_visibility()

    def _toggle_multi_select_at_cursor(self) -> None:
        """Space key: toggle the session under the cursor in the multi-select set."""
        session = self.selected_session()
        if not session:
            return
        if session.id in self._multi_selected_ids:
            self._multi_selected_ids.discard(session.id)
        else:
            self._multi_selected_ids.add(session.id)
        self._multi_anchor_row = self._cursor_row_for_session(session.id)
        self.refresh_list()  # Refresh [ ] <-> [x] text.
        self._update_title_bar()
        self._update_multi_action_visibility()

    def _extend_multi_select(self, direction: int) -> None:
        """Shift+Up/Down: extend range from anchor to one row above/below current row.

        If no anchor exists, start by using the current row as anchor.
        """
        try:
            list_area = self.query_one("#session-list", TextArea)
        except Exception:
            return
        cur = list_area.cursor_location[0] - self.LIST_HEADER_ROWS
        if cur < 0 or cur >= len(self.list_sessions):
            return
        if self._multi_anchor_row is None:
            self._multi_anchor_row = cur
        new_cur = cur + direction
        if new_cur < 0 or new_cur >= len(self.list_sessions):
            return
        # Move cursor.
        list_area.move_cursor((new_cur + self.LIST_HEADER_ROWS, 0))
        # Select every row from anchor to the new cursor.
        lo = min(self._multi_anchor_row, new_cur)
        hi = max(self._multi_anchor_row, new_cur)
        for i in range(lo, hi + 1):
            if 0 <= i < len(self.list_sessions):
                self._multi_selected_ids.add(self.list_sessions[i].id)
        self.selected_session_id = self.list_sessions[new_cur].id
        self.update_preview()
        self.refresh_list()  # Refresh [ ] / [x] text.
        self._update_title_bar()
        self._update_multi_action_visibility()

    def _select_all_visible(self) -> None:
        """Ctrl+a: select all current list_sessions."""
        for s in self.list_sessions:
            self._multi_selected_ids.add(s.id)
        self.refresh_list()  # Refresh [ ] -> [x] text.
        self._update_title_bar()
        self._update_multi_action_visibility()

    def action_select_all_visible(self) -> None:
        """Binding action: Ctrl+a anywhere selects all visible sessions."""
        self._select_all_visible()

    def handle_list_modifier_click(self, row: int, ctrl: bool, shift: bool) -> None:
        """Handle Ctrl/Shift + left-click multi-select.

        row: TextArea cursor_location[0], including headers, converted to list index.
        ctrl: toggle clicked session, removing it if already present.
        shift: add range from anchor to clicked row.
        """
        body_row = row - self.LIST_HEADER_ROWS
        if body_row < 0 or body_row >= len(self.list_sessions):
            return
        scroll_pos = self._capture_list_scroll()
        clicked = self.list_sessions[body_row]
        if shift and self._multi_anchor_row is not None:
            lo = min(self._multi_anchor_row, body_row)
            hi = max(self._multi_anchor_row, body_row)
            for i in range(lo, hi + 1):
                if 0 <= i < len(self.list_sessions):
                    self._multi_selected_ids.add(self.list_sessions[i].id)
        elif ctrl:
            if clicked.id in self._multi_selected_ids:
                self._multi_selected_ids.discard(clicked.id)
            else:
                self._multi_selected_ids.add(clicked.id)
            self._multi_anchor_row = body_row
        # Update single selected_session_id too so preview follows the clicked item.
        self.selected_session_id = clicked.id
        self._move_list_cursor_to_body_row(body_row)
        self.update_preview()
        self._suppress_pointer_clear = True  # Block mouse_up clear.
        self._refresh_list_selection_highlight()
        self._restore_list_scroll(scroll_pos)
        self._update_title_bar()

    def _copy_menu(self) -> CopyMenuOverlay:
        try:
            return self.screen.query_one("#copy-menu", CopyMenuOverlay)
        except Exception:
            return self.query_one("#copy-menu", CopyMenuOverlay)

    def _hide_copy_menu(self) -> None:
        menu = self._copy_menu()
        menu.display = False
        self._menu_text = ""

    def _copy_menu_contains(self, widget) -> bool:
        if widget is None:
            return False
        try:
            menu = self._copy_menu()
        except Exception:
            return False
        if widget is menu:
            return True
        return menu in getattr(widget, "ancestors", [])

    def open_copy_context_menu(self, widget_id: Optional[str], text: str, screen_x: int, screen_y: int) -> None:
        self.remember_active_copy_widget(widget_id)
        menu_text = text
        if not menu_text and widget_id and self._pending_context_widget_id == widget_id:
            menu_text = self._pending_context_text
        self._pending_context_widget_id = None
        self._pending_context_text = ""
        self._menu_text = menu_text

        menu = self._copy_menu()
        copy_item = menu.query_one("#copy-menu-copy", CopyMenuItem)
        copy_item.set_state("⎘ 복사" if menu_text else "⎘ Cannot copy", enabled=bool(menu_text))
        menu.absolute_offset = Offset(max(0, screen_x), max(0, screen_y))
        menu.display = True

    def handle_copy_menu_action(self, action: str) -> None:
        if action == "cancel":
            self._hide_copy_menu()
            return
        if action != "copy":
            return

        menu_text = self._menu_text
        self._hide_copy_menu()
        if not menu_text:
            self.notify("선택된 텍스트가 없습니다.", severity="warning")
            return

        methods = self._copy_via_system_clipboard(menu_text)
        method_label = ", ".join(methods) if methods else "none"
        self.notify(f"Copied: {len(menu_text)} chars ({method_label})")

    def _primary_copy_widget(self) -> Optional[object]:
        if isinstance(self.focused, (TextArea, Input)):
            return self.focused
        if self._active_copy_widget_id:
            try:
                return self.query_one(f"#{self._active_copy_widget_id}", TextArea)
            except Exception:
                return None
        return None

    def _copy_via_system_clipboard(self, text: str) -> list[str]:
        methods: list[str] = []

        self.copy_to_clipboard(text)
        methods.append("osc52")

        for command, args in (
            ("wl-copy", ["wl-copy"]),
            ("xclip", ["xclip", "-selection", "clipboard"]),
            ("xsel", ["xsel", "--clipboard", "--input"]),
            ("pbcopy", ["pbcopy"]),
        ):
            binary = shutil.which(command)
            if not binary:
                continue
            try:
                subprocess.run(
                    [binary, *args[1:]],
                    input=text,
                    text=True,
                    check=True,
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                methods.append(command)
                return methods
            except Exception:
                continue

        if self._start_tk_clipboard_owner(text):
            methods.append("tk-owner")

        return methods

    def _stop_existing_clipboard_owner(self) -> None:
        try:
            raw = CLIPBOARD_OWNER_PID_PATH.read_text(encoding="utf-8").strip()
        except FileNotFoundError:
            return
        except Exception:
            raw = ""

        if raw:
            try:
                os.kill(int(raw), signal.SIGTERM)
            except Exception:
                pass

        try:
            CLIPBOARD_OWNER_PID_PATH.unlink()
        except FileNotFoundError:
            pass
        except Exception:
            pass

    def _start_tk_clipboard_owner(self, text: str) -> bool:
        if not os.environ.get("DISPLAY"):
            return False

        self._stop_existing_clipboard_owner()

        try:
            proc = subprocess.Popen(
                [sys.executable, "-c", TK_CLIPBOARD_OWNER_CODE],
                stdin=subprocess.PIPE,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                text=True,
                start_new_session=True,
            )
        except Exception:
            return False

        try:
            assert proc.stdin is not None
            proc.stdin.write(text)
            proc.stdin.close()
        except Exception:
            try:
                proc.terminate()
            except Exception:
                pass
            return False

        time.sleep(0.12)
        if proc.poll() is not None:
            return False

        try:
            CLIPBOARD_OWNER_PID_PATH.parent.mkdir(parents=True, exist_ok=True)
            CLIPBOARD_OWNER_PID_PATH.write_text(str(proc.pid), encoding="utf-8")
        except Exception:
            pass
        return True

    def on_text_area_selection_changed(self, event: TextArea.SelectionChanged) -> None:
        if self._programmatic_update:
            return
        self.remember_active_copy_widget(event.text_area.id)
        if event.text_area.id != "session-list":
            return
        if self._list_pointer_interacting:
            return
        if event.text_area.selected_text:
            return
        session = self.selected_session()
        if session:
            self.selected_session_id = session.id
            self.update_preview()

    def action_copy_selection(self) -> None:
        self._hide_copy_menu()
        widget = self._primary_copy_widget()
        if widget is not None:
            text = getattr(widget, "selected_text", "")
            if text:
                methods = self._copy_via_system_clipboard(text)
                method_label = ", ".join(methods) if methods else "none"
                self.notify(f"Copied: {len(text)} chars ({method_label})")
                return
        self.notify("선택된 텍스트가 없습니다.", severity="warning")

    def on_input_changed(self, event: Input.Changed) -> None:
        if event.input.id == "filter-input":
            self.filter_text = event.value
            # Deep mode: no incremental apply; Enter triggers scan.
            # Normal mode: apply filter immediately.
            if not self._deep_mode:
                self.refresh_list()

    # Search-related methods (toggle_deep_search / _enter_deep_mode / _exit_deep_mode /
    # _start_deep_search / _finish_deep_search / on_input_submitted) live in
    # `gccfork_search.py` as `DeepSearchMixin`, mixed into this App class.

    def _is_filter_tool(self, widget: object) -> bool:
        return isinstance(widget, FilterTool) and widget.id in {"btn-view-mode", "btn-settings", "btn-refresh"}

    def on_mouse_down(self, event: events.MouseDown) -> None:
        if not self._copy_menu().display:
            return
        if self._copy_menu_contains(event.widget):
            return
        self._hide_copy_menu()

    def on_key(self, event) -> None:
        focused = self.focused
        key = event.key

        if self._copy_menu().display and key == "escape":
            self._hide_copy_menu()
            event.stop()
            return

        # Esc clears multi-select before quitting the app.
        if key == "escape" and self._multi_selected_ids:
            self._multi_selected_ids.clear()
            self.refresh_list()  # Refresh [x] -> [ ] text.
            self._update_title_bar()
            self._update_multi_action_visibility()
            event.stop()
            return

        # Multi-select keyboard handling only when session-list has focus.
        focused_id = focused.id if focused else None
        if focused_id == "session-list":
            # Space toggles the current cursor row.
            if key == "space":
                self._toggle_multi_select_at_cursor()
                event.stop()
                return
            # Shift+Up / Shift+Down extends range from anchor.
            if key == "shift+up":
                self._extend_multi_select(-1)
                event.stop()
                return
            if key == "shift+down":
                self._extend_multi_select(1)
                event.stop()
                return
            # Ctrl+a selects all visible sessions.
            if key in ("ctrl+a",):
                self._select_all_visible()
                event.stop()
                return

        if key == "down" and isinstance(focused, Input):
            self._focus_list()
            event.stop()
            return

        if key == "down" and self._is_filter_tool(focused):
            self._focus_list()
            event.stop()
            return

        if key == "up" and isinstance(focused, Button) and focused.id not in {"btn-view-mode", "btn-settings", "btn-refresh"}:
            self._focus_list()
            event.stop()
            return

        if not isinstance(focused, TextArea):
            return

        if focused.id == "scope-info" and key == "down":
            self.query_one("#filter-input", Input).focus()
            event.stop()
            return

        if focused.id != "session-list":
            return

        if key == "enter":
            self.query_one("#btn-fork", Button).focus()
            event.stop()
            return

        cursor_row = self._list_cursor_row()
        if key == "up" and cursor_row == 0:
            self.query_one("#filter-input", Input).focus()
            event.stop()
            return

        if key == "down" and self.list_sessions and cursor_row >= len(self.list_sessions) - 1:
            buttons = self._action_bar_buttons()
            if buttons:
                buttons[0].focus()
                event.stop()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        bid = event.button.id
        if bid == "btn-new-root":
            self.action_new_root()
        elif bid == "btn-fork":
            self.action_fork()
        elif bid == "btn-hard-fork":
            self.action_hard_fork()
        elif bid == "btn-slim":
            self.action_slim_fork()
        elif bid == "btn-unfold":
            self.action_unfold()
        elif bid == "btn-resume":
            self.action_resume()
        elif bid == "btn-rename":
            self.action_rename()
        elif bid == "btn-delete":
            # btn-delete was removed from the bottom action bar, but keep this for keybinding fallback.
            self.action_delete()
        elif bid == "btn-trash":
            self.action_trash()
        elif bid == "btn-multi-move":
            self.action_multi_move()
        elif bid == "btn-multi-copy":
            self.action_multi_copy()
        elif bid == "btn-multi-summarize":
            self.action_multi_summarize()
        elif bid == "btn-multi-delete":
            self.action_multi_delete()
        elif bid == "btn-multi-archive":
            # Model B true merge: button works only when opt 5 trigger_mode is button/both.
            # In keybinding-only mode, the button is hidden by _update_multi_action_visibility.
            self.action_merge_selected()
        elif bid == "btn-multi-unmerge":
            # Split: shown for single selection. Dispatch:
            #   - is_merged=true (model B N) -> unmerge_new_session
            #   - only 📦N marker (legacy model A) -> unmerge_parent
            sel = list(self._multi_selected_ids)
            if len(sel) == 1:
                from gccfork_sessions import registry_get as _rg
                if _rg(sel[0]).get("is_merged"):
                    self.action_unmerge_selected_v2()
                else:
                    self.action_unmerge_selected()
            else:
                self.action_unmerge_selected()
        elif bid == "btn-multi-clear":
            self._multi_selected_ids.clear()
            self.refresh_list()
            self._update_title_bar()
            self._update_multi_action_visibility()
        elif bid == "btn-scope":
            self.action_toggle_scope()
        elif bid == "btn-view-mode":
            self.action_toggle_view_mode()
        elif bid == "btn-settings":
            self.action_show_settings()
        elif bid == "btn-config-files":
            self.action_show_config_files()
        elif bid == "btn-refresh":
            self.action_refresh()
        elif bid == "btn-quit":
            self.exit()

    def on_filter_tool_activated(self, event: FilterTool.Activated) -> None:
        bid = event.tool.id
        if bid == "btn-view-mode":
            self.action_toggle_view_mode()
        elif bid == "btn-settings":
            self.action_show_settings()
        elif bid == "btn-refresh":
            self.action_refresh()
        elif bid == "btn-config-files":
            self.action_show_config_files()

    def action_show_settings(self) -> None:
        # Settings: help is shown as a section inside the settings modal.
        self.push_screen(SettingsScreen())

    def action_refresh(self) -> None:
        before = len(self.sessions)
        self.reload_sessions()
        after = len(self.sessions)
        delta = after - before
        if delta > 0:
            self.notify(f"Refreshed: {after} sessions (+{delta})")
        elif delta < 0:
            self.notify(f"Refreshed: {after} sessions ({delta})")
        else:
            self.notify(f"Refreshed: {after} sessions (no change)")

    def action_toggle_view_mode(self) -> None:
        # Keep one stable "View" label to avoid width changes when toggled.
        # The actual mode remains internal state (tree/flat).
        self.view_mode = "flat" if self.view_mode == "tree" else "tree"
        self.refresh_list()

    def _action_bar_buttons(self) -> list[Button]:
        return list(self.query("#action-bar Button").results(Button))

    def _focused_action_button_index(self) -> Optional[int]:
        focused = self.focused
        if not isinstance(focused, Button):
            return None
        buttons = self._action_bar_buttons()
        for index, button in enumerate(buttons):
            if button is focused:
                return index
        return None

    def action_focus_next_button(self) -> None:
        index = self._focused_action_button_index()
        if index is None:
            return
        buttons = self._action_bar_buttons()
        buttons[(index + 1) % len(buttons)].focus()

    def action_focus_prev_button(self) -> None:
        index = self._focused_action_button_index()
        if index is None:
            return
        buttons = self._action_bar_buttons()
        buttons[(index - 1) % len(buttons)].focus()

    def action_toggle_scope(self) -> None:
        self.scope_all = not self.scope_all
        self._update_title_bar()
        self.reload_sessions()

    def _default_soft_fork_name(self, parent: Session) -> str:
        """For soft fork (claude --fork-session), new_uuid is not known yet.

        The name stores `????` as the new_short placeholder; the FS watcher replaces it
        when registration happens.
        """
        ptitle = _clean_parent_title(parent.custom_name or parent.auto_summary or "")
        suffix = f"????[<= {parent.id[:4]}]"
        return (f"{ptitle} {suffix}" if ptitle else suffix).strip()[:120]

    def _default_hard_fork_name(self, parent: Session, new_uuid: str) -> str:
        ptitle = _clean_parent_title(parent.custom_name or parent.auto_summary or "")
        if parent.source == "codex":
            suffix = f"{_codex_sid_label(new_uuid)}[<= {_codex_sid_label(parent.id)}]"
        else:
            suffix = f"{new_uuid[:4]}[<= {parent.id[:4]}]"
        return (f"{ptitle} {suffix}" if ptitle else suffix).strip()[:120]

    def _launch_claude_new_terminal(
        self,
        action: str,
        session: Session,
        pending_name: Optional[str] = None,
        spawn_mode: Optional[str] = None,
        target_terminal: Optional[str] = None,
    ) -> None:
        """Spawn `claude` in a new terminal tab/window while gccfork stays open.

        spawn_mode: "window" (default) or "tab"; None uses pref or "window".
        target_terminal: terminal explicitly requested by the user through the
            "send to another environment" toggle; None auto-detects with _detect_terminal().

        When routing to VS Code with two or more bridge instances, show the conflict
        warning modal first and proceed only after confirmation.
        """
        if spawn_mode is None:
            spawn_mode = pref_get("spawn_mode", "window") or "window"

        effective_target = target_terminal or _detect_terminal()
        if effective_target == "vscode":
            # Prefer self-hosting: if the current gccfork TUI is inside a VS Code window,
            # spawn there. Even if cwd does not match, claude --resume uses the JSONL cwd,
            # so startup cwd is not important. The natural result is a new terminal in
            # the window the user is watching.
            # 2026-05-06: earlier cwd-first routing could send sessions to another window
            # with the same folder, confusing users.
            # Multiple VS Code instances always show a picker; focused is the default.
            # A single live instance is automatic because there is nothing meaningful to choose.
            session_cwd = session.cwd
            matches = _find_vscode_for_cwd(session_cwd) if session_cwd else []
            all_insts = _bridge_instances()

            if len(all_insts) >= 2:
                # With multiple VS Code instances, always show all candidates.
                # cwd matching is used only for sorting, not filtering.
                pick_list = all_insts
                def _on_pick_strict(picked_sid: Optional[str]) -> None:
                    if not picked_sid:
                        return
                    self._do_launch_spawn_with_pin(
                        picked_sid, action, session, pending_name, spawn_mode, target_terminal,
                    )
                self.push_screen(BridgeTargetPickerScreen(pick_list, session_cwd=session_cwd), _on_pick_strict)
                return

            # One VS Code instance: focused/self-host/cwd are all one target, so route automatically.
            focused_sid = _focused_vscode_session_id() or _self_hosting_vscode_session_id()
            if focused_sid:
                self._do_launch_spawn_with_pin(
                    focused_sid,
                    action, session, pending_name, spawn_mode, target_terminal,
                )
                return

            if len(matches) == 1:
                # One live VS Code instance plus cwd match: clear single target, auto spawn.
                self._do_launch_spawn_with_pin(
                    matches[0].get("sessionId"),
                    action, session, pending_name, spawn_mode, target_terminal,
                )
                return

            if len(matches) > 1:
                # Multiple matches: let the user choose in the picker.
                def _on_pick_multi(picked_sid: Optional[str]) -> None:
                    if not picked_sid:
                        return
                    self._do_launch_spawn_with_pin(
                        picked_sid, action, session, pending_name, spawn_mode, target_terminal,
                    )
                self.push_screen(BridgeTargetPickerScreen(matches, session_cwd=session_cwd), _on_pick_multi)
                return

            # No matches.
            if session_cwd:
                # No window has the session workspace open; ask before opening a new window.
                def _on_open_confirm(decision: Optional[bool]) -> None:
                    if not decision:
                        return
                    self.notify(f"📂 Opening VS Code window… ({session_cwd})", timeout=15)

                    def _bg() -> None:
                        new_sid = _open_vscode_for_cwd(session_cwd)
                        if new_sid:
                            self.call_from_thread(
                                self._do_launch_spawn_with_pin,
                                new_sid, action, session, pending_name, spawn_mode, target_terminal,
                            )
                        else:
                            self.call_from_thread(
                                self.notify,
                                "Failed to open VS Code window: `code` CLI is not in PATH or bridge did not respond",
                                severity="error",
                            )

                    threading.Thread(target=_bg, daemon=True).start()

                self.push_screen(OpenWorkspaceConfirmScreen(session_cwd), _on_open_confirm)
                return

            # Exceptional case with no session_cwd: fallback picker over live instances.
            insts = _bridge_instances()
            self_sid = _self_hosting_vscode_session_id()
            if len(insts) > 1 and not self_sid:
                def _on_pick_fallback(picked_sid: Optional[str]) -> None:
                    if not picked_sid:
                        return
                    self._do_launch_spawn_with_pin(
                        picked_sid, action, session, pending_name, spawn_mode, target_terminal,
                    )
                self.push_screen(BridgeTargetPickerScreen(insts, session_cwd=session_cwd), _on_pick_fallback)
                return

        self._do_launch_spawn(
            action, session, pending_name, spawn_mode, target_terminal,
        )

    def _do_launch_spawn_with_pin(
        self,
        pinned_sid: Optional[str],
        action: str,
        session: Session,
        pending_name: Optional[str],
        spawn_mode: str,
        target_terminal: Optional[str],
    ) -> None:
        """Spawn after setting `_pinned_vscode_target_sid` for exact routing to one explicit SID."""
        global _pinned_vscode_target_sid
        _pinned_vscode_target_sid = pinned_sid
        try:
            self._do_launch_spawn(
                action, session, pending_name, spawn_mode, target_terminal,
            )
        finally:
            _pinned_vscode_target_sid = None

    def _do_launch_spawn(
        self,
        action: str,
        session: Session,
        pending_name: Optional[str],
        spawn_mode: str,
        target_terminal: Optional[str],
    ) -> None:
        """Actual spawn, called after warning modal approval or when no warning is needed."""
        ok, used = run_claude_command(
            action, session,
            pending_fork_name=pending_name,
            spawn_mode=spawn_mode,
            target_terminal=target_terminal,
        )
        mode_label = "🪟 new window" if spawn_mode == "window" else "📑 new tab"
        if ok:
            # Known SID (resume) is immediately registered in spawn tracking.
            # Soft fork/new do not have a child SID yet; _auto_reload_tick registers
            # newly_added & live within a few seconds.
            if action == "resume" and session.id:
                self._spawned_sids.add(session.id)
                self._spawned_at[session.id] = time.time()
                # Sync live state and refresh immediately without waiting for next marker tick.
                try:
                    self._sync_live_session_markers()
                    self.refresh_list()
                except Exception:
                    pass
            if used == "vscode-bridge":
                self.notify(f"✓ Created VS Code terminal tab (bridge extension, {session.short_id})")
            else:
                self.notify(f"✓ Started claude session in {used} ({mode_label}, {session.short_id})")
        else:
            if used == "vscode":
                self.notify(
                    "VS Code bridge extension is not installed or is inactive.\n"
                    "Run `code --install-extension gccfork-bridge-0.1.0.vsix` and restart VS Code.\n"
                    "Or install an external terminal such as gnome-terminal and retry.",
                    severity="error",
                    timeout=12,
                )
            else:
                self.notify(
                    f"New terminal spawn failed ({used}). External terminal binary is missing or not in PATH.",
                    severity="error",
                )

    def _launch_custom_session_terminal(
        self,
        *,
        cmd: list[str],
        session: Session,
        tab_title: str,
        spawn_mode: str,
        target_terminal: Optional[str],
        exit_label: str,
        success_message: str,
        color_session_id: Optional[str] = None,
        extra_env: Optional[dict[str, str]] = None,
    ) -> None:
        """Spawn an arbitrary CLI command into the exact target terminal.

        Normal Claude resume routes through `_launch_claude_new_terminal()` with VS Code
        picker/pin handling. Codex resume and cross-conversion use the same routing so
        they do not land in the wrong VS Code window when multiple windows are open.
        """
        if spawn_mode is None:
            spawn_mode = pref_get("spawn_mode", "window") or "window"
        effective_target = target_terminal or _detect_terminal()
        session_cwd = session.cwd

        def _spawn_now(terminal_name: str, pinned_sid: Optional[str] = None) -> None:
            global _pinned_vscode_target_sid
            old_pin = _pinned_vscode_target_sid
            if pinned_sid:
                _pinned_vscode_target_sid = pinned_sid
            try:
                cwd = session_cwd if session_cwd and Path(session_cwd).exists() else os.getcwd()
                env = _sanitize_env_for_claude()
                if extra_env:
                    env.update({k: v for k, v in extra_env.items() if v is not None})
                color_tag = _vscode_terminal_color_for_session(color_session_id or session.id)
                ok, used = _spawn_claude_in_new_terminal(
                    terminal_name,
                    cmd,
                    cwd,
                    env,
                    tab_title,
                    spawn_mode,
                    color_tag=color_tag,
                    exit_label=exit_label,
                )
            finally:
                _pinned_vscode_target_sid = old_pin
            if ok:
                self.notify(success_message)
            elif used == "vscode":
                self.notify(
                    "VS Code bridge extension is not installed or is inactive.\n"
                    "Run `code --install-extension gccfork-bridge-0.1.0.vsix` and restart VS Code.",
                    severity="error",
                    timeout=12,
                )
            else:
                self.notify(f"New terminal spawn failed ({used})", severity="error", timeout=12)

        if effective_target != "vscode":
            _spawn_now(effective_target)
            return

        matches = _find_vscode_for_cwd(session_cwd) if session_cwd else []
        all_insts = _bridge_instances()

        if len(all_insts) >= 2:
            # With multiple VS Code instances, always show all candidates.
            # cwd matching is used only for sorting, not filtering.
            pick_list = all_insts

            def _on_pick_strict(picked_sid: Optional[str]) -> None:
                if picked_sid:
                    _spawn_now("vscode", pinned_sid=picked_sid)

            self.push_screen(BridgeTargetPickerScreen(pick_list, session_cwd=session_cwd), _on_pick_strict)
            return

        focused_sid = _focused_vscode_session_id() or _self_hosting_vscode_session_id()
        if focused_sid:
            _spawn_now("vscode", pinned_sid=focused_sid)
            return

        if len(matches) == 1:
            _spawn_now("vscode", pinned_sid=matches[0].get("sessionId"))
            return

        if len(matches) > 1:
            def _on_pick_multi(picked_sid: Optional[str]) -> None:
                if picked_sid:
                    _spawn_now("vscode", pinned_sid=picked_sid)

            self.push_screen(BridgeTargetPickerScreen(matches, session_cwd=session_cwd), _on_pick_multi)
            return

        if session_cwd:
            def _on_open_confirm(decision: Optional[bool]) -> None:
                if not decision:
                    return
                self.notify(f"📂 Opening VS Code window… ({session_cwd})", timeout=15)

                def _bg() -> None:
                    new_sid = _open_vscode_for_cwd(session_cwd)
                    if new_sid:
                        self.call_from_thread(_spawn_now, "vscode", new_sid)
                    else:
                        self.call_from_thread(
                            self.notify,
                            "Failed to open VS Code window: `code` CLI is not in PATH or bridge did not respond",
                            severity="error",
                        )

                threading.Thread(target=_bg, daemon=True).start()

            self.push_screen(OpenWorkspaceConfirmScreen(session_cwd), _on_open_confirm)
            return

        _spawn_now("vscode")

    def _create_codex_session_from_claude(
        self,
        session: Session,
        import_options: Optional[dict] = None,
    ) -> Optional[dict]:
        """Create a new verified Codex-derived session from Claude JSONL."""
        script = Path(__file__).resolve().with_name("gccfork_codex_import.py")
        if script.exists():
            cmd = [sys.executable, str(script)]
        else:
            cmd = ["gccfork-codex-import"]
        cmd += ["--claude-jsonl", str(session.jsonl_path), "--json"]
        opts = import_options or {}
        if opts.get("recent_semantic"):
            cmd += ["--recent-semantic", str(int(opts["recent_semantic"]))]
        if opts.get("keep_raw_turns") is not None:
            cmd += ["--keep-raw-turns", str(int(opts["keep_raw_turns"]))]
        if opts.get("compact_excerpt_chars"):
            cmd += ["--compact-excerpt-chars", str(int(opts["compact_excerpt_chars"]))]
        if opts.get("include_local_commands"):
            cmd.append("--include-local-commands")
        try:
            proc = subprocess.run(
                cmd,
                cwd=session.cwd if session.cwd and Path(session.cwd).exists() else os.getcwd(),
                env=_sanitize_env_for_claude(),
                text=True,
                capture_output=True,
                timeout=180,
            )
        except Exception as exc:
            self.notify(f"Codex conversion failed: {type(exc).__name__}: {exc}", severity="error", timeout=12)
            return None
        if proc.returncode != 0:
            detail = (proc.stderr or proc.stdout or "").strip()
            self.notify(f"Codex conversion failed (exit {proc.returncode}): {detail[:500]}", severity="error", timeout=14)
            return None
        try:
            return json.loads(proc.stdout.strip().splitlines()[-1])
        except Exception as exc:
            self.notify(f"Failed to parse Codex conversion result: {exc}", severity="error", timeout=12)
            return None

    def _launch_codex_from_claude_session(
        self,
        session: Session,
        tab_name: Optional[str],
        spawn_mode: str,
        target_terminal: Optional[str],
        import_options: Optional[dict] = None,
    ) -> None:
        """Convert the selected Claude session to a Codex-derived session and open it."""
        self.notify(f"Creating Codex session… ({session.short_id})", timeout=10)
        result = self._create_codex_session_from_claude(session, import_options=import_options)
        if not result:
            return
        codex_sid = str(result.get("sid") or "")
        if not codex_sid:
            self.notify("Codex conversion result has no sid.", severity="error", timeout=10)
            return
        title_base = (tab_name or session.custom_name or session.auto_summary or session.short_id or "Codex").strip()
        convert_name = f"Open in Codex {_codex_sid_label(codex_sid)}[<= {session.id[:4]}] {title_base}"[:160]
        try:
            registry_set(
                codex_sid,
                parent_id=session.id,
                fork_type="convert",
                name=convert_name,
                source_cli="codex",
                source_session_id=session.id,
                source_jsonl=str(session.jsonl_path),
            )
        except Exception:
            pass
        cmd = ["codex", "resume", codex_sid]
        tab_title = _tab_title_for_values(
            session_id=codex_sid,
            title=convert_name,
            source="codex",
            parent_id=session.id,
            fork_type="convert",
        )
        mode_label = "🪟 new window" if spawn_mode == "window" else "📑 new tab"
        self._launch_custom_session_terminal(
            cmd=cmd,
            session=session,
            tab_title=tab_title,
            spawn_mode=spawn_mode,
            target_terminal=target_terminal,
            exit_label="codex session",
            success_message=f"✓ Opened in Codex ({mode_label}, {_codex_sid_label(codex_sid)} <= {session.short_id})",
            color_session_id=session.id,
            extra_env={
                "GCCFORK_CODEX_TITLE_BASE": convert_name,
            },
        )
        self.reload_sessions()

    def _create_claude_session_from_codex(self, session: Session) -> Optional[dict]:
        """Create a new verified Claude-derived session from Codex JSONL."""
        script = Path(__file__).resolve().with_name("gccfork_claude_import.py")
        if script.exists():
            cmd = [sys.executable, str(script)]
        else:
            cmd = ["gccfork-claude-import"]
        cmd += ["--codex-jsonl", str(session.jsonl_path), "--json"]
        try:
            proc = subprocess.run(
                cmd,
                cwd=session.cwd if session.cwd and Path(session.cwd).exists() else os.getcwd(),
                env=_sanitize_env_for_claude(),
                text=True,
                capture_output=True,
                timeout=180,
            )
        except Exception as exc:
            self.notify(f"Claude conversion failed: {type(exc).__name__}: {exc}", severity="error", timeout=12)
            return None
        if proc.returncode != 0:
            detail = (proc.stderr or proc.stdout or "").strip()
            self.notify(f"Claude conversion failed (exit {proc.returncode}): {detail[:500]}", severity="error", timeout=14)
            return None
        try:
            return json.loads(proc.stdout.strip().splitlines()[-1])
        except Exception as exc:
            self.notify(f"Failed to parse Claude conversion result: {exc}", severity="error", timeout=12)
            return None

    def _launch_claude_from_codex_session(
        self,
        session: Session,
        tab_name: Optional[str],
        spawn_mode: str,
        target_terminal: Optional[str],
    ) -> None:
        """Convert the selected Codex session to a Claude-derived session and open it."""
        self.notify(f"Creating Claude session… ({session.short_id})", timeout=10)
        result = self._create_claude_session_from_codex(session)
        if not result:
            return
        claude_sid = str(result.get("sid") or "")
        if not claude_sid:
            self.notify("Claude conversion result has no sid.", severity="error", timeout=10)
            return
        title_base = (tab_name or session.custom_name or session.auto_summary or session.short_id or "Claude").strip()
        convert_name = f"Open in Claude {claude_sid[:4]}[<= {_codex_sid_label(session.id)}] {title_base}"[:160]
        try:
            registry_set(
                claude_sid,
                parent_id=session.id,
                fork_type="convert",
                name=convert_name,
                source_cli="claude-code",
                source_session_id=session.id,
                source_jsonl=str(session.jsonl_path),
            )
        except Exception:
            pass
        tab_title = _tab_title_for_values(
            session_id=claude_sid,
            title=convert_name,
            source="claude",
            parent_id=session.id,
            fork_type="convert",
        )
        cmd = ["claude", "--resume", claude_sid]
        _add_claude_name_if_supported(cmd, tab_title)
        mode_label = "🪟 new window" if spawn_mode == "window" else "📑 new tab"
        self._launch_custom_session_terminal(
            cmd=cmd,
            session=session,
            tab_title=tab_title,
            spawn_mode=spawn_mode,
            target_terminal=target_terminal,
            exit_label="claude session",
            success_message=f"✓ Opened in Claude ({mode_label}, {claude_sid[:8]} <= {session.short_id})",
            color_session_id=claude_sid,
        )
        self.reload_sessions()

    def _launch_existing_codex_session(
        self,
        session: Session,
        tab_name: Optional[str],
        spawn_mode: str,
        target_terminal: Optional[str],
        replay_transcript: bool = False,
    ) -> None:
        """Open an existing Codex JSONL session with `codex resume`."""
        cmd = ["codex", "resume", session.id]
        if session.jsonl_path and session.jsonl_path.exists():
            import shlex
            helper = Path(__file__).resolve().with_name("gccfork_codex_replay.py")
            replay_cmd = " ".join(
                shlex.quote(part)
                for part in ("GCCFORK_REPLAY_BRAND=GccSlim", "python3", str(helper), str(session.jsonl_path))
            )
            resume_cmd = " ".join(shlex.quote(part) for part in cmd)
            cmd = ["bash", "-lc", f"{replay_cmd}; exec {resume_cmd}"]
        title_base = (tab_name or session.custom_name or session.auto_summary or session.short_id).strip()
        tab_title = _tab_title_for_values(
            session_id=session.id,
            title=title_base,
            source="codex",
            parent_id=session.parent_id,
            fork_type=session.fork_type,
        )
        mode_label = "🪟 new window" if spawn_mode == "window" else "📑 new tab"
        self._launch_custom_session_terminal(
            cmd=cmd,
            session=session,
            tab_title=tab_title,
            spawn_mode=spawn_mode,
            target_terminal=target_terminal,
            exit_label="codex session",
            success_message=f"✓ Resumed Codex session ({mode_label}, {session.short_id})",
            color_session_id=session.id,
            extra_env={
                "GCCFORK_CODEX_TITLE_BASE": title_base,
            },
        )
        self._spawned_sids.add(session.id)
        self._spawned_at[session.id] = time.time()

    def _launch_codex_new_root(
        self,
        name: str,
        cwd: str,
        spawn_mode: str = "window",
        target_terminal: Optional[str] = None,
    ) -> None:
        """Spawn a new Codex root session in a new terminal.

        Codex has no Claude-like `--name` session-name argument, so the user-entered
        name is used only for terminal title/notification. Codex creates the real SID
        and rollout file on first run; the next reload/scan picks it up in GccSlim.
        """
        dummy = Session(
            id="codex-new-root",
            jsonl_path=Path(cwd) / ".codex-new-root",
            mtime=datetime.now(),
            turn_count=0,
            size_bytes=0,
            cwd=normalize_cwd(cwd),
            source="codex",
            custom_name=name,
        )
        mode_label = "🪟 new window" if spawn_mode == "window" else "📑 new tab"
        self._launch_custom_session_terminal(
            cmd=["codex"],
            session=dummy,
            tab_title=f"🤖 {name}"[:80],
            spawn_mode=spawn_mode,
            target_terminal=target_terminal,
            exit_label="codex session",
            success_message=f"✓ Started new Codex session ({mode_label})",
            color_session_id=None,
            extra_env={
                "GCCFORK_CODEX_TITLE_BASE": name,
            },
        )

    def action_fork(self) -> None:
        """Soft fork: show ForkNameScreen, then run claude in a new terminal.

        Because claude has not created the actual JSONL yet, the FS watcher registers
        the name later. The user-specified name is kept in `_pending_soft_forks`.
        """
        session = self.selected_session()
        if not session:
            return
        if session.source == "codex":
            self.notify("Codex sessions currently support only resume/rename.", severity="warning", timeout=6)
            return
        default_name = self._default_soft_fork_name(session)
        current_terminal = _detect_terminal()
        other_env = _other_environment(current_terminal)

        def on_done(result: Optional[dict]) -> None:
            if result is None:
                return  # Cancel.
            name = result.get("name") or default_name
            spawn_mode = result.get("spawn_mode", "window")
            target_terminal = result.get("target_terminal")
            self._pending_soft_forks[session.id] = {
                "parent_id": session.id,
                "name": name or None,
                "created_at": time.time(),
            }
            self._launch_claude_new_terminal(
                "fork", session, pending_name=name or None,
                spawn_mode=spawn_mode, target_terminal=target_terminal,
            )

        self.push_screen(
            ForkNameScreen(
                default_name,
                title="🔱 Soft fork — child session name",
                other_env=other_env,
                current_terminal=current_terminal,
            ),
            on_done,
        )

    def action_hard_fork(self) -> None:
        """Hard fork: gccfork clones JSONL directly, then resumes it in a new terminal."""
        session = self.selected_session()
        if not session:
            return

        new_uuid = str(uuid_lib.uuid4())
        default_name = self._default_hard_fork_name(session, new_uuid)
        current_terminal = _detect_terminal()
        other_env = _other_environment(current_terminal)

        def on_done(result: Optional[dict]) -> None:
            if result is None:
                return
            name = result.get("name") or default_name
            spawn_mode = result.get("spawn_mode", "window")
            target_terminal = result.get("target_terminal")
            try:
                if session.source == "codex":
                    cloned = hard_fork_codex_session_with(session, new_uuid, name)
                else:
                    cloned = hard_fork_session_with(session, new_uuid, name)
            except Exception as exc:
                self.notify(f"Hard fork failed: {exc}", severity="error")
                return
            self.notify(f"✓ Hard fork complete: {cloned.short_id} (parent: {session.short_id})")
            self.reload_sessions()
            if cloned.source == "codex":
                self._launch_existing_codex_session(
                    cloned, None, spawn_mode=spawn_mode, target_terminal=target_terminal,
                    replay_transcript=True,
                )
            else:
                self._launch_claude_new_terminal(
                    "resume", cloned, spawn_mode=spawn_mode, target_terminal=target_terminal,
                )

        self.push_screen(
            ForkNameScreen(
                default_name,
                title="🪓 Hard fork — child session name",
                other_env=other_env,
                current_terminal=current_terminal,
            ),
            on_done,
        )

    def _find_latest_brain_session(self) -> Optional["Session"]:
        """Locate the most recently-modified brain agent session.

        Brain sessions are tagged with `agent_kind: "brain"` in the registry.
        Returns the Session with the latest jsonl mtime, or None when no
        brain session has been created yet.
        """
        candidates: list = []
        for s in self.sessions:
            try:
                meta = registry_get(s.id) or {}
            except Exception:
                meta = {}
            if meta.get("agent_kind") == "brain":
                candidates.append(s)
        if not candidates:
            return None

        def _mtime(sess) -> float:
            try:
                return sess.jsonl_path.stat().st_mtime
            except Exception:
                return 0.0

        return max(candidates, key=_mtime)

    def _spawn_brain_agent(self, resume_sid: Optional[str] = None) -> None:
        """Spawn a brain-agent claude session in a new terminal.

        The session is fully independent of every other claude process
        (new PID, new sid, new jsonl). When `resume_sid` is None a fresh
        UUID is pre-minted via `--session-id` so the brain marker can be
        registered before claude writes the first jsonl line.

        System prompt path resolution (in order):
          1. $GCCFORK_BRAIN_PROMPT_PATH
          2. ~/.local/share/gccslim/brain-system-prompt.md  (install default)

        Working directory resolution (in order):
          1. $GCCFORK_REPO_DIR
          2. ~/JOB_FOLD/<local GccSlim workspace>  (developer default)
          3. $HOME  (final fallback for portability)
        """
        import uuid as _uuid

        prompt_path = os.environ.get(
            "GCCFORK_BRAIN_PROMPT_PATH",
            os.path.expanduser("~/.local/share/gccslim/brain-system-prompt.md"),
        )
        if not Path(prompt_path).is_file():
            self.notify(
                f"❌ brain-system-prompt.md is missing: {prompt_path}",
                severity="error",
                timeout=8,
            )
            return

        repo_dir = os.environ.get(
            "GCCFORK_REPO_DIR",
            os.path.expanduser("~/JOB_FOLD/\uc720\uc6a9\ud55c\uae30\ub2a5\ucd94\uac00\ubd84/GccSlim"),
        )
        if not Path(repo_dir).is_dir():
            repo_dir = os.path.expanduser("~")

        display_name = "🧠 GccSlim brain agent"
        cmd: list[str] = [
            "claude",
            "--dangerously-skip-permissions",
            "--model", "sonnet",
            "--add-dir", repo_dir,
        ]
        _add_claude_name_if_supported(cmd, display_name)

        if resume_sid:
            cmd += ["--resume", resume_sid]
        else:
            # Pre-mint the session id so we can register the brain marker
            # before the spawned claude writes any jsonl line.
            new_sid = str(_uuid.uuid4())
            cmd += [
                "--session-id", new_sid,
                "--append-system-prompt-file", prompt_path,
            ]
            try:
                registry_set(
                    new_sid,
                    name=display_name,
                    agent_kind="brain",
                )
            except Exception:
                # Registry write failure is non-fatal — the spawn can still
                # proceed; it just won't be tagged as a brain session and
                # won't be surfaced for 'resume' next time.
                pass

        terminal = _detect_terminal()
        env = _sanitize_env_for_claude()

        ok, used = _spawn_claude_in_new_terminal(
            terminal=terminal,
            cmd=cmd,
            cwd=repo_dir,
            env=env,
            tab_title=display_name,
            spawn_mode="window",
        )
        if ok:
            kind_label = "resume" if resume_sid else "new session"
            self.notify(
                f"🧠 Brain agent {kind_label} started ({used})",
                severity="information",
                timeout=4,
            )
        else:
            self.notify(
                f"❌ Brain agent spawn failed ({used})",
                severity="error",
                timeout=6,
            )

    def _spawn_slim_brain_agent(self, source_sid: str, system_prompt: str, user_prompt: str) -> None:
        """Spawn a dedicated brain agent for the Slim modal analysis.

        Unlike the title-bar brain entry, this passes both a dedicated
        system prompt and the current Slim modal state as the first user
        prompt, so the agent can answer the exact analysis question
        immediately.
        """
        import uuid as _uuid

        repo_dir = os.environ.get(
            "GCCFORK_REPO_DIR",
            os.path.expanduser("~/JOB_FOLD/\uc720\uc6a9\ud55c\uae30\ub2a5\ucd94\uac00\ubd84/GccSlim"),
        )
        if not Path(repo_dir).is_dir():
            repo_dir = os.path.expanduser("~")

        display_name = f"🧠 Slim analysis [{source_sid[:4]}]"
        new_sid = str(_uuid.uuid4())
        cmd: list[str] = [
            "claude",
            "--dangerously-skip-permissions",
            "--model", "sonnet",
            "--add-dir", repo_dir,
            "--session-id", new_sid,
            "--append-system-prompt", system_prompt,
        ]
        _add_claude_name_if_supported(cmd, display_name)
        cmd.append(user_prompt)

        try:
            registry_set(
                new_sid,
                name=display_name,
                agent_kind="brain",
                parent_id=source_sid,
            )
        except Exception:
            pass

        terminal = _detect_terminal()
        env = _sanitize_env_for_claude()
        ok, used = _spawn_claude_in_new_terminal(
            terminal=terminal,
            cmd=cmd,
            cwd=repo_dir,
            env=env,
            tab_title=display_name,
            spawn_mode="window",
        )
        if ok:
            self.notify(
                f"🧠 Slim analysis brain started ({used})",
                severity="information",
                timeout=4,
            )
        else:
            self.notify(
                f"❌ Slim analysis brain spawn failed ({used})",
                severity="error",
                timeout=6,
            )

