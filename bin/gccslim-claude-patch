#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
case "$(uname -s):$(uname -m)" in
  Linux:x86_64) target="$DIR/linux-x86_64/gccslim-claude-patch" ;;
  Darwin:arm64|Darwin:arm64e) target="$DIR/macos-arm64/gccslim-claude-patch" ;;
  *) echo "Unsupported platform: $(uname -s) $(uname -m)" >&2; exit 2 ;;
esac
exec "$target" "$@"
